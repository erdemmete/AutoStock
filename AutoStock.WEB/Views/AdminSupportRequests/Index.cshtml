@model AutoStock.WEB.Models.SupportRequests.AdminSupportRequestIndexViewModel
@using AutoStock.Repositories.Enums
@using AutoStock.WEB.Models.Common
@using AutoStock.WEB.Models.SupportRequests

@{
    ViewData["Title"] = "Destek Talepleri";

    var requests = Model.Requests.Items ?? new List<SupportRequestListItemViewModel>();
    var query = Model.Query;

    var pageNumber = Model.Requests.PageNumber > 0 ? Model.Requests.PageNumber : query.PageNumber;
    var pageSize = Model.Requests.PageSize > 0 ? Model.Requests.PageSize : query.PageSize;
    var totalCount = Model.Requests.TotalCount;

    var paginationModel = new PaginationViewModel
    {
        Controller = "AdminSupportRequests",
        Action = "Index",
        PageNumber = pageNumber,
        PageSize = pageSize,
        TotalCount = totalCount,
        RouteValues = new Dictionary<string, string?>
        {
            ["search"] = query.Search,
            ["status"] = query.Status.HasValue ? ((int)query.Status.Value).ToString() : null,
            ["requestType"] = query.RequestType.HasValue ? ((int)query.RequestType.Value).ToString() : null,
            ["workshopId"] = query.WorkshopId?.ToString()
        }
    };
}

<div class="support-list-page">
    <div class="support-list-header">
        <div class="support-title-area">
            <div class="support-icon">
                <span>?</span>
            </div>

            <div>
                <h1>Destek Talepleri</h1>
                <p>Servislerden gelen sorun bildirimlerini ve kullanıcı ekleme taleplerini buradan yönetebilirsiniz.</p>
            </div>
        </div>

        @await Html.PartialAsync("_PageActions", new PageActionViewModel
        {
            BackController = "Admin",
            BackAction = "Dashboard",
            HomeController = "Admin",
            HomeAction = "Dashboard"
        })
    </div>

    <form class="support-filter-card"
          method="get"
          asp-controller="AdminSupportRequests"
          asp-action="Index">

        <div class="support-search-box">
            <span class="search-icon">⌕</span>
            <input name="Search"
                   value="@query.Search"
                   type="text"
                   placeholder="Konu, açıklama, servis veya kullanıcı ara..." />
        </div>

        <input name="WorkshopId"
               value="@query.WorkshopId"
               type="number"
               min="1"
               class="support-filter-input"
               placeholder="Servis Id" />

        <select name="Status" class="support-filter-select">
            <option value="">Tüm Durumlar</option>

            @if (query.Status == SupportRequestStatus.Open)
            {
                <option value="@((int)SupportRequestStatus.Open)" selected>Açık</option>
            }
            else
            {
                <option value="@((int)SupportRequestStatus.Open)">Açık</option>
            }

            @if (query.Status == SupportRequestStatus.InProgress)
            {
                <option value="@((int)SupportRequestStatus.InProgress)" selected>İşlemde</option>
            }
            else
            {
                <option value="@((int)SupportRequestStatus.InProgress)">İşlemde</option>
            }

            @if (query.Status == SupportRequestStatus.Answered)
            {
                <option value="@((int)SupportRequestStatus.Answered)" selected>Yanıtlandı</option>
            }
            else
            {
                <option value="@((int)SupportRequestStatus.Answered)">Yanıtlandı</option>
            }

            @if (query.Status == SupportRequestStatus.Closed)
            {
                <option value="@((int)SupportRequestStatus.Closed)" selected>Kapandı</option>
            }
            else
            {
                <option value="@((int)SupportRequestStatus.Closed)">Kapandı</option>
            }

            @if (query.Status == SupportRequestStatus.Cancelled)
            {
                <option value="@((int)SupportRequestStatus.Cancelled)" selected>İptal Edildi</option>
            }
            else
            {
                <option value="@((int)SupportRequestStatus.Cancelled)">İptal Edildi</option>
            }
        </select>

        <select name="RequestType" class="support-filter-select">
            <option value="">Tüm Talepler</option>

            @if (query.RequestType == SupportRequestType.Issue)
            {
                <option value="@((int)SupportRequestType.Issue)" selected>Sorun Bildirimi</option>
            }
            else
            {
                <option value="@((int)SupportRequestType.Issue)">Sorun Bildirimi</option>
            }

            @if (query.RequestType == SupportRequestType.UserCreateRequest)
            {
                <option value="@((int)SupportRequestType.UserCreateRequest)" selected>Kullanıcı Ekleme</option>
            }
            else
            {
                <option value="@((int)SupportRequestType.UserCreateRequest)">Kullanıcı Ekleme</option>
            }
        </select>

        <input type="hidden" name="PageNumber" value="1" />

        <select name="PageSize" class="support-filter-select">
            <option value="10" selected="@(pageSize == 10 ? "selected" : null)">10 kayıt</option>
            <option value="25" selected="@(pageSize == 25 ? "selected" : null)">25 kayıt</option>
            <option value="50" selected="@(pageSize == 50 ? "selected" : null)">50 kayıt</option>
        </select>

        <button type="submit"
                class="support-filter-button"
                title="Ara">
            ⌕
        </button>

        <a asp-controller="AdminSupportRequests"
           asp-action="Index"
           class="support-clear-button"
           title="Filtreleri temizle">
            ×
        </a>
    </form>

    @await Html.PartialAsync("_Pagination", paginationModel)

    <div class="support-table-card">
        <div class="table-responsive">
            <table class="support-table">
                <thead>
                    <tr>
                        <th>Servis</th>
                        <th>Konu</th>
                        <th>Tip</th>
                        <th>Durum</th>
                        <th>Öncelik</th>
                        <th>Oluşturan</th>
                        <th>Tarih</th>
                        <th class="text-right">İşlem</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!requests.Any())
                    {
                        <tr>
                            <td colspan="8" class="empty-cell">
                                Henüz destek talebi bulunamadı.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in requests)
                        {
                            <tr class="support-row">
                                <td>
                                    <div class="support-name">
                                        @(string.IsNullOrWhiteSpace(item.WorkshopName) ? $"Servis #{item.WorkshopId}" : item.WorkshopName)
                                    </div>
                                </td>

                                <td>
                                    <div class="support-subject">@item.Subject</div>

                                    @if (item.RespondedAt.HasValue)
                                    {
                                        <div class="small-success">Cevaplandı</div>
                                    }
                                </td>

                                <td>
                                    <span class="type-pill">@item.RequestTypeText</span>
                                </td>

                                <td>
                                    <span class="status-pill">@item.StatusText</span>
                                </td>

                                <td>
                                    <strong>@item.PriorityText</strong>
                                </td>

                                <td>@item.CreatedByUserName</td>

                                <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>

                                <td class="text-right">
                                    <a asp-controller="AdminSupportRequests"
                                       asp-action="Detail"
                                       asp-route-id="@item.Id"
                                       class="detail-btn">
                                        Detay
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .support-list-page {
        padding-top: 28px;
        padding-bottom: 32px;
    }

    .support-list-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 32px;
    }

    .support-title-area {
        display: flex;
        align-items: flex-start;
        gap: 14px;
    }

    .support-icon {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        background: #eef2ff;
        color: #4f46e5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        font-weight: 800;
    }

    .support-list-header h1 {
        margin: 0;
        font-size: 28px;
        font-weight: 800;
        color: #0f172a;
    }

    .support-list-header p {
        margin: 8px 0 0;
        color: #64748b;
        font-size: 14px;
    }

    .support-filter-card {
        display: grid;
        grid-template-columns: minmax(320px, 1fr) 120px 160px 170px 130px 48px 48px;
        gap: 12px;
        background: #fff;
        border: 1px solid #dbe3ef;
        border-radius: 16px;
        padding: 16px;
        margin-bottom: 18px;
        box-shadow: 0 8px 22px rgba(15, 23, 42, .06);
    }

    .support-search-box {
        position: relative;
    }

    .search-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        font-size: 22px;
    }

    .support-search-box input,
    .support-filter-select,
    .support-filter-input {
        width: 100%;
        height: 48px;
        border: 1px solid #cfd8e6;
        border-radius: 13px;
        background: #fff;
        color: #0f172a;
        font-size: 14px;
        outline: none;
    }

    .support-search-box input {
        padding: 0 16px 0 48px;
    }

    .support-filter-select,
    .support-filter-input {
        padding: 0 14px;
    }

        .support-search-box input:focus,
        .support-filter-select:focus,
        .support-filter-input:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 3px rgba(79, 70, 229, .12);
        }

    .support-filter-button,
    .support-clear-button {
        width: 48px;
        height: 48px;
        border: 1px solid #cfd8e6;
        border-radius: 13px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        text-decoration: none;
        cursor: pointer;
        transition: .18s ease;
    }

    .support-filter-button {
        background: #f8fafc;
        color: #475569;
        font-size: 20px;
    }

        .support-filter-button:hover {
            background: #eef2ff;
            border-color: #c7d2fe;
            color: #4f46e5;
        }

    .support-clear-button {
        background: #fff;
        color: #64748b;
        font-size: 22px;
    }

        .support-clear-button:hover {
            background: #fff1f2;
            border-color: #fecdd3;
            color: #e11d48;
        }

    .support-list-page > .pagination-bar {
        margin-bottom: 18px;
        border: 1px solid #dbe3ef;
        border-radius: 16px;
        box-shadow: 0 8px 22px rgba(15, 23, 42, .04);
    }

    .support-table-card {
        background: #fff;
        border: 1px solid #dbe3ef;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 8px 22px rgba(15, 23, 42, .06);
    }

    .table-responsive {
        width: 100%;
        overflow-x: auto;
    }

    .support-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 1080px;
    }

        .support-table thead {
            background: #f8fafc;
        }

        .support-table th {
            padding: 17px 24px;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: .04em;
            color: #64748b;
            font-weight: 800;
            text-align: left;
            border-bottom: 1px solid #dbe3ef;
        }

        .support-table td {
            padding: 20px 24px;
            border-bottom: 1px solid #edf2f7;
            vertical-align: middle;
            color: #0f172a;
            font-size: 14px;
        }

        .support-table tr:last-child td {
            border-bottom: none;
        }

    .support-row:hover {
        background: #fafbff;
    }

    .support-name,
    .support-subject {
        font-weight: 800;
        color: #0f172a;
    }

    .small-success {
        margin-top: 4px;
        color: #16a34a;
        font-size: 12px;
        font-weight: 800;
    }

    .type-pill {
        display: inline-flex;
        align-items: center;
        padding: 5px 10px;
        border-radius: 8px;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        color: #475569;
        font-size: 12px;
        font-weight: 700;
    }

    .status-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 6px 10px;
        border-radius: 999px;
        background: #eef2ff;
        color: #3730a3;
        font-size: 12px;
        font-weight: 800;
    }

    .detail-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 74px;
        height: 40px;
        border: 1px solid #cfd8e6;
        border-radius: 10px;
        color: #334155;
        background: #fff;
        text-decoration: none;
        font-weight: 800;
        font-size: 13px;
        transition: .18s ease;
    }

        .detail-btn:hover {
            background: #f8fafc;
            color: #0f172a;
        }

    .text-right {
        text-align: right !important;
    }

    .empty-cell {
        padding: 38px !important;
        text-align: center;
        color: #64748b !important;
    }

    @@media (max-width: 1100px) {
        .support-filter-card {
            grid-template-columns: 1fr 1fr;
        }

        .support-search-box {
            grid-column: 1 / -1;
        }
    }

    @@media (max-width: 700px) {
        .support-list-header {
            align-items: flex-start;
            flex-direction: column;
        }

        .support-filter-card {
            grid-template-columns: 1fr;
        }

        .support-search-box {
            grid-column: auto;
        }

        .support-filter-button,
        .support-clear-button {
            width: 100%;
        }
    }
</style>