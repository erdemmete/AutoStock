@model AutoStock.WEB.Models.DashboardViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sente360 | @Model.WorkshopName</title>

    <style>
            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                min-height: 100vh;
                font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
                color: #0f172a;
                background: radial-gradient(circle at 10% 0%, rgba(79, 70, 229, .12), transparent 32rem), radial-gradient(circle at 90% 10%, rgba(37, 99, 235, .10), transparent 30rem), linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
            }

            .dashboard-page {
                width: min(1240px, calc(100% - 48px));
                margin: 0 auto;
                padding: 30px 0 54px;
            }

            .topbar {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 18px;
                margin-bottom: 24px;
            }

            .brand {
                display: flex;
                align-items: center;
                gap: 14px;
            }

            .logo {
                width: 50px;
                height: 50px;
                border-radius: 17px;
                display: grid;
                place-items: center;
                color: white;
                font-weight: 950;
                letter-spacing: -.6px;
                background: linear-gradient(135deg, #4f46e5, #2563eb);
                box-shadow: 0 18px 38px rgba(79, 70, 229, .22);
            }

            .brand strong {
                display: block;
                font-size: 22px;
                font-weight: 950;
                letter-spacing: -.7px;
            }

            .brand span {
                display: block;
                margin-top: 3px;
                color: #64748b;
                font-size: 13px;
                font-weight: 750;
            }

            .logout-button {
                min-height: 44px;
                padding: 11px 18px;
                border-radius: 13px;
                border: 1px solid #fecaca;
                background: #fee2e2;
                color: #991b1b;
                font-weight: 900;
                cursor: pointer;
                transition: .18s ease;
            }

                .logout-button:hover {
                    background: #fecaca;
                }

            .hero {
                position: relative;
                overflow: hidden;
                border-radius: 30px;
                padding: 34px;
                margin-bottom: 22px;
                color: white;
                background: radial-gradient(circle at 90% 0%, rgba(255, 255, 255, .20), transparent 18rem), linear-gradient(135deg, #111827, #1e293b 48%, #4f46e5);
                box-shadow: 0 30px 75px rgba(15, 23, 42, .28);
            }

            .hero-content {
                position: relative;
                z-index: 1;
                display: flex;
                align-items: flex-end;
                justify-content: space-between;
                gap: 24px;
            }

            .eyebrow {
                display: inline-flex;
                padding: 7px 12px;
                border-radius: 999px;
                margin-bottom: 14px;
                background: rgba(255,255,255,.10);
                border: 1px solid rgba(255,255,255,.12);
                color: #c7d2fe;
                font-size: 12px;
                font-weight: 950;
            }

            .hero h1 {
                margin: 0;
                font-size: 42px;
                line-height: 1.08;
                letter-spacing: -1.7px;
                font-weight: 950;
            }

            .welcome {
                margin: 12px 0 0;
                color: rgba(255,255,255,.74);
                font-size: 15px;
                font-weight: 750;
            }

                .welcome strong {
                    color: white;
                }

            .date-pill {
                min-width: 190px;
                padding: 18px;
                border-radius: 22px;
                background: rgba(255,255,255,.10);
                border: 1px solid rgba(255,255,255,.13);
                backdrop-filter: blur(16px);
                text-align: right;
            }

                .date-pill span {
                    display: block;
                    color: rgba(255,255,255,.62);
                    font-size: 12px;
                    font-weight: 850;
                    margin-bottom: 6px;
                }

                .date-pill strong {
                    display: block;
                    color: white;
                    font-size: 20px;
                    font-weight: 950;
                    letter-spacing: -.5px;
                }

            .quick-grid {
                display: grid;
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: 18px;
                margin-bottom: 18px;
            }

            .module-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
                gap: 18px;
            }

            .quick-card,
            .module-card {
                position: relative;
                overflow: hidden;
                text-decoration: none;
                color: #0f172a;
                transition: .18s ease;
            }

            .quick-card {
                min-height: 190px;
                border-radius: 28px;
                padding: 28px;
                color: white;
                background: linear-gradient(135deg, #4f46e5, #2563eb);
                box-shadow: 0 22px 55px rgba(79, 70, 229, .24);
            }

                .quick-card.dark {
                    background: linear-gradient(135deg, #0f172a, #334155);
                    box-shadow: 0 22px 55px rgba(15, 23, 42, .18);
                }

                .quick-card:hover,
                .module-card:hover {
                    transform: translateY(-4px);
                }

                .quick-card:hover {
                    color: white;
                    box-shadow: 0 30px 70px rgba(79, 70, 229, .30);
                }

                .quick-card.dark:hover {
                    box-shadow: 0 30px 70px rgba(15, 23, 42, .24);
                }

            .module-card {
                min-height: 178px;
                border-radius: 26px;
                padding: 24px;
                background: rgba(255,255,255,.88);
                border: 1px solid #dbe3ef;
                box-shadow: 0 10px 28px rgba(15, 23, 42, .06);
                backdrop-filter: blur(14px);
            }

                .module-card:hover {
                    color: #0f172a;
                    border-color: #c7d2fe;
                    box-shadow: 0 22px 48px rgba(15, 23, 42, .12);
                }

            .card-icon {
                width: 56px;
                height: 56px;
                border-radius: 19px;
                display: grid;
                place-items: center;
                font-size: 25px;
                margin-bottom: 22px;
            }

            .quick-card .card-icon {
                background: rgba(255,255,255,.15);
            }

            .module-card .card-icon {
                background: #eef2ff;
                color: #4f46e5;
            }

            .quick-card h2,
            .module-card h2 {
                margin: 0;
                font-weight: 950;
                letter-spacing: -.6px;
            }

            .quick-card h2 {
                font-size: 26px;
            }

            .module-card h2 {
                font-size: 21px;
            }

            .card-arrow {
                position: absolute;
                right: 24px;
                bottom: 22px;
                width: 42px;
                height: 42px;
                border-radius: 14px;
                display: grid;
                place-items: center;
                font-size: 20px;
                font-weight: 950;
            }

            .quick-card .card-arrow {
                background: rgba(255,255,255,.14);
                color: white;
            }

            .module-card .card-arrow {
                background: #f8fafc;
                color: #4f46e5;
                border: 1px solid #e2e8f0;
            }

            .section-label {
                margin: 28px 0 14px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 16px;
            }

                .section-label h2 {
                    margin: 0;
                    font-size: 19px;
                    font-weight: 950;
                    letter-spacing: -.5px;
                }

                .section-label span {
                    color: #64748b;
                    font-size: 13px;
                    font-weight: 750;
                }

            @@media (max-width: 1100px) {
                .module-grid {
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                }
            }

            @@media (max-width: 760px) {
                .dashboard-page {
                    width: min(100% - 28px, 1240px);
                    padding-top: 18px;
                }

                .topbar,
                .hero-content {
                    align-items: flex-start;
                    flex-direction: column;
                }

                .date-pill {
                    width: 100%;
                    text-align: left;
                }

                .hero {
                    padding: 26px;
                    border-radius: 26px;
                }

                    .hero h1 {
                        font-size: 32px;
                    }

                .quick-grid,
                .module-grid {
                    grid-template-columns: 1fr;
                }

                .logout-button {
                    width: 100%;
                }

                .topbar form {
                    width: 100%;
                }
            }
    </style>
</head>

<body>
    <main class="dashboard-page">
        <header class="topbar">
            <div class="brand">
                <div class="logo">S360</div>
                <div>
                    <strong>Sente360</strong>
                    <span>Servis yönetim paneli</span>
                </div>
            </div>

            <form asp-controller="Auth" asp-action="Logout" method="post">
                <button class="logout-button" type="submit">
                    Çıkış
                </button>
            </form>
        </header>

        <section class="hero">
            <div class="hero-content">
                <div>
                    <div class="eyebrow">SERVİS PANELİ</div>

                    <h1>@Model.WorkshopName</h1>

                    <p class="welcome">
                        Hoş geldin, <strong>@Model.FullName</strong>
                    </p>
                </div>

                <div class="date-pill">
                    <span>Bugün</span>
                    <strong>@DateTime.Now.ToString("dd.MM.yyyy")</strong>
                </div>
            </div>
        </section>

        <section class="quick-grid">
            <a class="quick-card"
               asp-controller="ServiceRecords"
               asp-action="Create">
                <div class="card-icon">📝</div>
                <h2>Yeni Servis Girişi</h2>
                <div class="card-arrow">→</div>
            </a>

            <a class="quick-card dark"
               href="/ServiceRecords">
                <div class="card-icon">🛠️</div>
                <h2>Servis Kayıtları</h2>
                <div class="card-arrow">→</div>
            </a>
        </section>

        <div class="section-label">
            <h2>Modüller</h2>
            <span>Sente360</span>
        </div>

        <section class="module-grid">
            <a class="module-card" href="/CurrentAccounts">
                <div class="card-icon">💰</div>
                <h2>Cari Yönetimi</h2>
                <div class="card-arrow">→</div>
            </a>

            <a class="module-card" asp-controller="Customers" asp-action="Index">
                <div class="card-icon">👥</div>
                <h2>Müşteriler</h2>
                <div class="card-arrow">→</div>
            </a>

            <a class="module-card" href="/StockItems">
                <div class="card-icon">📦</div>
                <h2>Stok Yönetimi</h2>
                <div class="card-arrow">→</div>
            </a>

            <a class="module-card" href="/Invoices">
                <div class="card-icon">🧾</div>
                <h2>Faturalar</h2>
                <div class="card-arrow">→</div>
            </a>

            <a class="module-card" asp-controller="SupportRequests" asp-action="Index">
                <div class="card-icon">💬</div>
                <h2>Destek Talepleri</h2>
                <div class="card-arrow">→</div>
            </a>
        </section>
    </main>
</body>
</html>