@model AutoStock.WEB.Models.DashboardViewModel

@{
    Layout = null;

    var isOwner = string.Equals(Model.Role, "Owner", StringComparison.OrdinalIgnoreCase);
    var isStaff = string.Equals(Model.Role, "Staff", StringComparison.OrdinalIgnoreCase);

    var firstName = string.IsNullOrWhiteSpace(Model.FullName)
        ? "Kullanıcı"
        : Model.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? Model.FullName;

    string FormatMoney(decimal value)
    {
        return value.ToString("N2") + " ₺";
    }

    string FormatActivityDate(DateTime date)
    {
        if (date == default)
            return "";

        var now = DateTime.UtcNow;
        var diff = now - date;

        if (diff.TotalMinutes < 1)
            return "az önce";

        if (diff.TotalMinutes < 60)
            return $"{Math.Max(1, (int)diff.TotalMinutes)} dk önce";

        if (diff.TotalHours < 24)
            return $"{Math.Max(1, (int)diff.TotalHours)} saat önce";

        return date.ToString("dd.MM.yyyy");
    }

    string GetActivityIcon(string type)
    {
        return type switch
        {
            "service" => "🔧",
            "invoice" => "🧾",
            "stock" => "📦",
            _ => "•"
        };
    }
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Sente360 | @Model.WorkshopName</title>

    <style>
            * {
                box-sizing: border-box;
            }

            :root {
                --bg: #f6f8fc;
                --panel: #ffffff;
                --text: #0f172a;
                --muted: #64748b;
                --border: #e2e8f0;
                --primary: #635bff;
                --primary-soft: #eef2ff;
                --green: #10b981;
                --green-soft: #ecfdf5;
                --orange: #f97316;
                --orange-soft: #fff7ed;
                --red: #ef4444;
                --red-soft: #fff1f2;
                --blue: #2563eb;
                --blue-soft: #eff6ff;
                --shadow: 0 16px 40px rgba(15, 23, 42, .07);
                --soft-shadow: 0 8px 24px rgba(15, 23, 42, .06);
            }

            body {
                margin: 0;
                min-height: 100vh;
                font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
                color: var(--text);
                background: var(--bg);
            }

            a {
                color: inherit;
            }

            .app-shell {
                display: grid;
                grid-template-columns: 270px 1fr;
                min-height: 100vh;
            }

            .sidebar {
                position: sticky;
                top: 0;
                height: 100vh;
                background: var(--panel);
                border-right: 1px solid var(--border);
                padding: 24px 17px;
                display: flex;
                flex-direction: column;
            }

            .brand {
                display: flex;
                align-items: center;
                gap: 13px;
                padding: 0 8px 24px;
                border-bottom: 1px solid #f1f5f9;
                margin-bottom: 22px;
            }

            .brand-logo {
                width: 42px;
                height: 42px;
                border-radius: 14px;
                display: grid;
                place-items: center;
                color: white;
                font-weight: 950;
                background: linear-gradient(135deg, #4f46e5, #22c55e);
                box-shadow: 0 14px 30px rgba(99, 91, 255, .25);
            }

            .brand-title {
                font-size: 20px;
                font-weight: 950;
                letter-spacing: -.5px;
            }

            .brand-subtitle {
                margin-top: 2px;
                color: var(--muted);
                font-size: 12px;
                font-weight: 750;
                max-width: 170px;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .nav {
                display: grid;
                gap: 7px;
            }

            .nav-link {
                display: flex;
                align-items: center;
                gap: 12px;
                min-height: 45px;
                padding: 12px 14px;
                border-radius: 14px;
                color: #475569;
                text-decoration: none;
                font-weight: 800;
                transition: .16s ease;
            }

                .nav-link:hover {
                    background: #f8fafc;
                    color: var(--primary);
                }

                .nav-link.active {
                    background: var(--primary-soft);
                    color: var(--primary);
                }

            .nav-icon {
                width: 24px;
                text-align: center;
                font-size: 18px;
            }

            .sidebar-footer {
                margin-top: auto;
                display: grid;
                gap: 8px;
                padding-top: 18px;
                border-top: 1px solid #f1f5f9;
            }

            .logout-form {
                margin: 0;
            }

            .logout-button {
                width: 100%;
                min-height: 45px;
                padding: 12px 14px;
                border-radius: 14px;
                border: none;
                background: transparent;
                color: #f43f5e;
                font-weight: 900;
                cursor: pointer;
                text-align: left;
                display: flex;
                align-items: center;
                gap: 12px;
            }

                .logout-button:hover {
                    background: var(--red-soft);
                }

            .main {
                padding: 32px 36px 42px;
            }

            .page-header {
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
                gap: 24px;
                margin-bottom: 26px;
            }

                .page-header h1 {
                    margin: 0;
                    font-size: 30px;
                    line-height: 1.15;
                    letter-spacing: -.9px;
                    font-weight: 950;
                }

                .page-header p {
                    margin: 8px 0 0;
                    color: var(--muted);
                    font-weight: 650;
                }

            .date-badge {
                padding: 12px 16px;
                border: 1px solid var(--border);
                background: var(--panel);
                border-radius: 16px;
                box-shadow: var(--soft-shadow);
                color: #334155;
                font-weight: 850;
                white-space: nowrap;
            }

            .stats-grid {
                display: grid;
                grid-template-columns: repeat(4, minmax(0, 1fr));
                gap: 16px;
                margin-bottom: 24px;
            }

            .stat-card {
                background: var(--panel);
                border: 1px solid var(--border);
                border-radius: 20px;
                padding: 22px;
                display: flex;
                align-items: center;
                gap: 16px;
                box-shadow: var(--soft-shadow);
            }

            .stat-icon {
                width: 52px;
                height: 52px;
                border-radius: 17px;
                display: grid;
                place-items: center;
                font-size: 23px;
                flex: 0 0 auto;
            }

                .stat-icon.blue {
                    background: var(--blue-soft);
                    color: var(--blue);
                }

                .stat-icon.purple {
                    background: var(--primary-soft);
                    color: var(--primary);
                }

                .stat-icon.green {
                    background: var(--green-soft);
                    color: var(--green);
                }

                .stat-icon.red {
                    background: var(--red-soft);
                    color: var(--red);
                }

            .stat-content span {
                display: block;
                color: var(--muted);
                font-weight: 800;
                font-size: 13px;
                margin-bottom: 5px;
            }

            .stat-value {
                display: flex;
                align-items: baseline;
                gap: 8px;
            }

                .stat-value strong {
                    font-size: 26px;
                    line-height: 1;
                    font-weight: 950;
                    letter-spacing: -.8px;
                }

                .stat-value small {
                    color: var(--green);
                    font-weight: 900;
                }

                    .stat-value small.danger {
                        color: var(--red);
                    }

            .content-grid {
                display: grid;
                grid-template-columns: minmax(0, 1fr) 400px;
                gap: 24px;
                align-items: start;
            }

            .panel {
                background: var(--panel);
                border: 1px solid var(--border);
                border-radius: 22px;
                padding: 24px;
                box-shadow: var(--soft-shadow);
            }

            .section-title {
                display: flex;
                align-items: center;
                gap: 9px;
                margin: 0 0 18px;
                font-size: 20px;
                font-weight: 950;
                letter-spacing: -.5px;
            }

            .quick-start-grid {
                display: grid;
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: 14px;
            }

            .quick-start-card {
                position: relative;
                display: flex;
                align-items: center;
                gap: 14px;
                min-height: 106px;
                padding: 18px;
                border-radius: 18px;
                border: 1px solid var(--border);
                background: #fff;
                text-decoration: none;
                transition: .16s ease;
                overflow: hidden;
            }

                .quick-start-card:hover {
                    transform: translateY(-2px);
                    border-color: #c7d2fe;
                    box-shadow: 0 18px 35px rgba(15, 23, 42, .09);
                }

            .quick-start-icon {
                width: 50px;
                height: 50px;
                border-radius: 16px;
                display: grid;
                place-items: center;
                font-size: 23px;
                flex: 0 0 auto;
                background: var(--primary-soft);
                color: var(--primary);
            }

            .quick-start-card.green .quick-start-icon {
                background: var(--green-soft);
                color: var(--green);
            }

            .quick-start-card.orange .quick-start-icon {
                background: var(--orange-soft);
                color: var(--orange);
            }

            .quick-start-card.blue .quick-start-icon {
                background: var(--blue-soft);
                color: var(--blue);
            }

            .quick-start-content strong {
                display: block;
                font-size: 15px;
                font-weight: 950;
                margin-bottom: 4px;
                color: #0f172a;
            }

            .quick-start-content span {
                display: block;
                color: var(--muted);
                font-size: 12px;
                line-height: 1.35;
                font-weight: 700;
            }

            .quick-start-arrow {
                margin-left: auto;
                color: #94a3b8;
                font-weight: 950;
                font-size: 22px;
            }

            .notice-box {
                margin-top: 16px;
                border: 1px solid #dbeafe;
                background: #eff6ff;
                color: #1e40af;
                border-radius: 16px;
                padding: 14px 16px;
                font-size: 13px;
                font-weight: 750;
                line-height: 1.45;
            }

            .side-column {
                display: grid;
                gap: 20px;
            }

            .activity-list {
                display: grid;
                gap: 2px;
            }

            .activity-item {
                display: grid;
                grid-template-columns: 42px 1fr auto;
                gap: 12px;
                align-items: start;
                padding: 12px 0;
                border-bottom: 1px solid #f1f5f9;
            }

                .activity-item:last-child {
                    border-bottom: none;
                }

            .activity-icon {
                width: 36px;
                height: 36px;
                border-radius: 999px;
                display: grid;
                place-items: center;
                background: var(--blue-soft);
                font-size: 16px;
            }

            .activity-title {
                margin: 0;
                font-size: 14px;
                line-height: 1.4;
                color: #334155;
                font-weight: 800;
            }

            .activity-description {
                margin-top: 3px;
                color: var(--muted);
                font-size: 12px;
                font-weight: 700;
            }

            .activity-time {
                color: #94a3b8;
                font-size: 12px;
                font-weight: 850;
                white-space: nowrap;
                padding-top: 2px;
            }

            .mini-summary {
                display: grid;
                gap: 12px;
            }

            .mini-summary-row {
                display: flex;
                justify-content: space-between;
                gap: 14px;
                padding-bottom: 12px;
                border-bottom: 1px solid #f1f5f9;
            }

                .mini-summary-row:last-child {
                    border-bottom: none;
                    padding-bottom: 0;
                }

                .mini-summary-row span {
                    color: var(--muted);
                    font-weight: 750;
                    font-size: 13px;
                }

                .mini-summary-row strong {
                    font-weight: 950;
                    text-align: right;
                }

            .empty-state {
                padding: 18px 0 4px;
                color: var(--muted);
                font-weight: 700;
                text-align: center;
            }

            .mobile-topbar {
                display: none;
                background: var(--panel);
                border-bottom: 1px solid var(--border);
                padding: 14px 16px;
                align-items: center;
                justify-content: space-between;
                gap: 12px;
            }

            .mobile-brand {
                display: flex;
                align-items: center;
                gap: 10px;
                font-weight: 950;
                font-size: 18px;
            }

            .mobile-menu-button {
                border: 1px solid var(--border);
                background: #fff;
                border-radius: 12px;
                padding: 10px 12px;
                font-weight: 950;
                cursor: pointer;
            }

            @@media (max-width: 1180px) {
                .stats-grid {
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                }

                .content-grid {
                    grid-template-columns: 1fr;
                }

                .side-column {
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                }
            }

            @@media (max-width: 860px) {
                .mobile-topbar {
                    display: flex;
                    position: sticky;
                    top: 0;
                    z-index: 20;
                }

                .app-shell {
                    display: block;
                }

                .sidebar {
                    position: fixed;
                    z-index: 30;
                    left: 0;
                    top: 0;
                    width: 280px;
                    transform: translateX(-100%);
                    transition: .2s ease;
                    box-shadow: var(--shadow);
                }

                body.sidebar-open .sidebar {
                    transform: translateX(0);
                }

                .main {
                    padding: 24px 18px 34px;
                }

                .page-header {
                    flex-direction: column;
                }

                .stats-grid,
                .quick-start-grid,
                .side-column {
                    grid-template-columns: 1fr;
                }

                .date-badge {
                    width: 100%;
                }
            }

            @@media (max-width: 520px) {
                .stat-card {
                    align-items: flex-start;
                    padding: 18px;
                }

                .activity-item {
                    grid-template-columns: 36px 1fr;
                }

                .activity-time {
                    grid-column: 2;
                    padding-top: 0;
                }
            }

            .quick-start-button {
                width: 100%;
                text-align: left;
                cursor: pointer;
                font: inherit;
                color: inherit;
            }
            .last-qr-card {
    position: relative;
    margin-top: 16px;
    padding: 18px 56px 18px 18px;
    border: 1px solid #bfdbfe;
    background:
        radial-gradient(circle at top left, rgba(99, 91, 255, .12), transparent 32%),
        linear-gradient(135deg, #eff6ff 0%, #ffffff 100%);
    border-radius: 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    box-shadow: 0 14px 34px rgba(15, 23, 42, .07);
}

.last-qr-card[hidden] {
    display: none !important;
}

.last-qr-content {
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 14px;
}

.last-qr-icon {
    width: 48px;
    height: 48px;
    border-radius: 16px;
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    background: #dbeafe;
    color: #1d4ed8;
    font-size: 22px;
    font-weight: 950;
}

.last-qr-info {
    min-width: 0;
}

.last-qr-info span {
    display: block;
    color: #1e40af;
    font-size: 12px;
    font-weight: 950;
    margin-bottom: 4px;
}

.last-qr-main {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
}

.last-qr-main strong {
    display: block;
    color: #0f172a;
    font-size: 22px;
    font-weight: 950;
    letter-spacing: .2px;
}

.last-qr-main small {
    display: block;
    color: #475569;
    font-size: 14px;
    font-weight: 850;
}

.last-qr-info em {
    display: inline-flex;
    margin-top: 7px;
    padding: 4px 9px;
    border-radius: 999px;
    background: #ecfdf5;
    color: #047857;
    font-size: 11px;
    font-style: normal;
    font-weight: 950;
}

.last-qr-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
}

.last-qr-action {
    min-height: 38px;
    padding: 0 13px;
    border-radius: 12px;
    border: 1px solid #bfdbfe;
    background: rgba(255, 255, 255, .88);
    color: #1e40af;
    text-decoration: none;
    font-size: 12px;
    font-weight: 950;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: .16s ease;
}

.last-qr-action:hover {
    background: #dbeafe;
    transform: translateY(-1px);
}

.last-qr-action.primary {
    background: #2563eb;
    border-color: #2563eb;
    color: #fff;
    box-shadow: 0 10px 22px rgba(37, 99, 235, .2);
}

.last-qr-action.primary:hover {
    background: #1d4ed8;
}

.last-qr-dismiss {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 32px;
    height: 32px;
    border-radius: 11px;
    border: 1px solid #dbeafe;
    background: rgba(255, 255, 255, .9);
    color: #64748b;
    font-size: 22px;
    line-height: 1;
    font-weight: 850;
    cursor: pointer;
    transition: .16s ease;
}

.last-qr-dismiss:hover {
    background: #fee2e2;
    border-color: #fecaca;
    color: #991b1b;
}

@@media (max-width: 900px) {
    .last-qr-card {
        align-items: flex-start;
        flex-direction: column;
        padding-right: 52px;
    }

    .last-qr-actions {
        width: 100%;
        justify-content: flex-start;
    }
}

@@media (max-width: 560px) {
    .last-qr-actions {
        display: grid;
        grid-template-columns: 1fr;
    }

    .last-qr-action {
        width: 100%;
    }
}
           
            @@media (max-width: 760px) {
                .last-qr-card {
                    align-items: flex-start;
                    flex-direction: column;
                }

                .last-qr-actions {
                    width: 100%;
                }

                    .last-qr-actions a,
                    .last-qr-actions button {
                        flex: 1;
                        justify-content: center;
                        display: inline-flex;
                        align-items: center;
                    }
            }


            .mobile-topbar-actions {
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .dashboard-header-actions {
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .dashboard-notification-slot {
                display: flex;
                align-items: center;
            }

            @@media (max-width: 860px) {
                .page-header .dashboard-notification-slot {
                    display: none !important;
                }

                .mobile-topbar .s360-notification-shell {
                    z-index: 25 !important;
                }

                body.sidebar-open .mobile-topbar .s360-notification-shell {
                    display: none !important;
                }
            }

            .dashboard-header-actions,
            .mobile-topbar-actions {
                position: relative;
                z-index: 50;
            }

            .mobile-topbar {
                z-index: 99990 !important;
                overflow: visible !important;
            }

            .mobile-topbar-actions {
                position: relative !important;
                z-index: 99999 !important;
            }

            .mobile-topbar .s360-notification-shell {
                position: relative !important;
                z-index: 100000 !important;
            }

            .mobile-topbar .s360-notification-panel {
                z-index: 100001 !important;
            }

            .date-badge,
            .page-header,
            .main,
            .app-shell {
                position: relative;
                z-index: 1;
            }

            @@media (max-width: 860px) {
                .mobile-topbar .s360-notification-panel {
                    position: fixed !important;
                    top: 64px !important;
                    left: 12px !important;
                    right: 12px !important;
                    width: auto !important;
                    z-index: 100001 !important;
                }
            }
    </style>
</head>

<body>
    <div class="mobile-topbar">
        <div class="mobile-brand">
            <div class="brand-logo">S</div>
            <span>Sente360</span>
        </div>

        <div class="mobile-topbar-actions">
            @await Component.InvokeAsync("NotificationBell")

            <button type="button" class="mobile-menu-button" id="mobileMenuButton">
                Menü
            </button>
        </div>
    </div>

    <div class="app-shell">
        <aside class="sidebar" id="sidebar">
            <div class="brand">
                <div class="brand-logo">S</div>
                <div>
                    <div class="brand-title">Sente360</div>
                    <div class="brand-subtitle">@Model.WorkshopName</div>
                </div>
            </div>

            <nav class="nav">
                <a class="nav-link active" href="/Dashboard">
                    <span class="nav-icon">▦</span>
                    <span>Ana Ekran</span>
                </a>

                <a class="nav-link" href="/ServiceRecords">
                    <span class="nav-icon">🔧</span>
                    <span>Servis Kayıtları</span>
                </a>

                @if (isOwner)
                {
                    <a class="nav-link" href="/Customers">
                        <span class="nav-icon">👥</span>
                        <span>Müşteriler</span>
                    </a>

                    <a class="nav-link" href="/CurrentAccounts">
                        <span class="nav-icon">💰</span>
                        <span>Cari</span>
                    </a>
                }

                <a class="nav-link" href="/StockItems">
                    <span class="nav-icon">📦</span>
                    <span>Stok</span>
                </a>

                <a class="nav-link" href="/Invoices">
                    <span class="nav-icon">🧾</span>
                    <span>Faturalar</span>
                </a>

                <a class="nav-link" href="/SupportRequests/Index">
                    <span class="nav-icon">💬</span>
                    <span>Destek</span>
                </a>
            </nav>

            <div class="sidebar-footer">
                <form class="logout-form" asp-controller="Auth" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()

                    <button class="logout-button" type="submit">
                        <span class="nav-icon">↪</span>
                        <span>Çıkış Yap</span>
                    </button>
                </form>
            </div>
        </aside>

        <main class="main">
            <header class="page-header">
                <div>
                    <h1>Hoş geldin, @firstName 👋</h1>
                    <p>
                        @if (isOwner)
                        {
                            <span>Servisinizin operasyon ve finans özetini buradan takip edebilirsiniz.</span>
                        }
                        else
                        {
                            <span>Servis operasyonlarını hızlıca başlatabilir ve açık işleri takip edebilirsiniz.</span>
                        }
                    </p>
                </div>

                <div class="dashboard-header-actions">
                    <div class="dashboard-notification-slot">
                        @await Component.InvokeAsync("NotificationBell")
                    </div>

                    <div class="date-badge">
                        @DateTime.Now.ToString("dd.MM.yyyy")
                    </div>
                </div>
            </header>

            <section class="stats-grid">
                <article class="stat-card">
                    <div class="stat-icon blue">🚗</div>
                    <div class="stat-content">
                        <span>Açık Servis Kayıtları</span>
                        <div class="stat-value">
                            <strong>@Model.ActiveServiceRecordCount</strong>
                        </div>
                    </div>
                </article>

                @if (isOwner)
                {
                    <article class="stat-card">
                        <div class="stat-icon purple">🧾</div>
                        <div class="stat-content">
                            <span>Bekleyen Fatura Taslakları</span>
                            <div class="stat-value">
                                <strong>@Model.DraftInvoiceCount</strong>
                            </div>
                        </div>
                    </article>

                    <article class="stat-card">
                        <div class="stat-icon green">₺</div>
                        <div class="stat-content">
                            <span>Tahsilat Bekleyen</span>
                            <div class="stat-value">
                                <strong>@FormatMoney(Model.PendingCollectionAmount)</strong>
                            </div>
                        </div>
                    </article>
                }
                else
                {
                    <article class="stat-card">
                        <div class="stat-icon purple">🔧</div>
                        <div class="stat-content">
                            <span>Bugün Açılan Kayıtlar</span>
                            <div class="stat-value">
                                <strong>@Model.TodayServiceRecordCount</strong>
                            </div>
                        </div>
                    </article>

                    <article class="stat-card">
                        <div class="stat-icon green">⏱</div>
                        <div class="stat-content">
                            <span>İşlemdeki Kayıtlar</span>
                            <div class="stat-value">
                                <strong>@Model.InProgressServiceRecordCount</strong>
                            </div>
                        </div>
                    </article>
                }

                <article class="stat-card">
                    <div class="stat-icon red">!</div>
                    <div class="stat-content">
                        <span>Kritik Stok Uyarısı</span>
                        <div class="stat-value">
                            <strong>@Model.CriticalStockItemCount</strong>
                            @if (Model.CriticalStockItemCount > 0)
                            {
                                <small class="danger">İncele</small>
                            }
                        </div>
                    </div>
                </article>
            </section>

            <section class="content-grid">
                <div class="panel">
                    <h2 class="section-title">⚡ Hızlı Başlat</h2>

                    <div class="quick-start-grid">
                        <a class="quick-start-card blue"
                           asp-controller="ServiceRecords"
                           asp-action="Create">
                            <div class="quick-start-icon">🔧</div>
                            <div class="quick-start-content">
                                <strong>Yeni Servis Kaydı</strong>
                                <span>Araç kabulünü ve müşteri şikayetini hızlıca gir.</span>
                            </div>
                            <div class="quick-start-arrow">›</div>
                        </a>
                        <div id="lastQrScanCard" class="last-qr-card" hidden>
                            <button type="button"
                                    id="lastQrDismissButton"
                                    class="last-qr-dismiss"
                                    aria-label="Son okutulan aracı gizle">
                                ×
                            </button>

                            <div class="last-qr-content">
                                <div class="last-qr-icon">
                                    ▣
                                </div>

                                <div class="last-qr-info">
                                    <span>Son okutulan araç</span>

                                    <div class="last-qr-main">
                                        <strong id="lastQrPlate">-</strong>
                                        <small id="lastQrCustomer">-</small>
                                    </div>

                                    <em id="lastQrOpenRecordInfo" hidden>
                                        Açık servis kaydı var
                                    </em>
                                </div>
                            </div>

                            <div class="last-qr-actions">
                                <a id="lastQrOpenRecordLink"
                                   class="last-qr-action primary"
                                   href="#"
                                   hidden>
                                    Açık Kayda Git
                                </a>

                                <a id="lastQrNewRecordLink"
                                   class="last-qr-action"
                                   href="#">
                                    Yeni Kayıt Aç
                                </a>

                                <a id="lastQrHistoryLink"
                                   class="last-qr-action"
                                   href="#"
                                   target="_blank"
                                   rel="noopener">
                                    Geçmişi Gör
                                </a>

                                <button type="button"
                                        class="last-qr-action"
                                        data-qr-modal-open>
                                    Tekrar Tara
                                </button>
                            </div>
                        </div>
                        <button type="button"
                                class="quick-start-card quick-start-button green"
                                data-qr-modal-open>
                            <div class="quick-start-icon">▣</div>
                            <div class="quick-start-content">
                                <strong>QR Tara</strong>
                                <span>Aracı okut, açık kayda ya da yeni servis akışına geç.</span>
                            </div>
                            <div class="quick-start-arrow">›</div>
                        </button>

                        <a class="quick-start-card orange"
                           href="/StockItems/Create">
                            <div class="quick-start-icon">📦</div>
                            <div class="quick-start-content">
                                <strong>Yeni Stok Kartı</strong>
                                <span>Yeni parça veya sarf malzemesi tanımla.</span>
                            </div>
                            <div class="quick-start-arrow">›</div>
                        </a>

                        <a class="quick-start-card"
                           href="/Invoices">
                            <div class="quick-start-icon">🧾</div>
                            <div class="quick-start-content">
                                <strong>Fatura Taslakları</strong>
                                <span>Bekleyen taslakları kontrol et ve işlemi tamamla.</span>
                            </div>
                            <div class="quick-start-arrow">›</div>
                        </a>
                    </div>

                    @if (isStaff)
                    {
                        <div class="notice-box">
                            Staff kullanıcılar servis, stok ve fatura operasyonlarını yapabilir.
                            Cari ve genel müşteri listesi sadece servis sahibi tarafından görüntülenir.
                        </div>
                    }
                </div>

                <aside class="side-column">
                    <section class="panel">
                        <h2 class="section-title">▤ Son Hareketler</h2>

                        @if (Model.RecentActivities.Any())
                        {
                            <div class="activity-list">
                                @foreach (var activity in Model.RecentActivities)
                                {
                                    <div class="activity-item">
                                        <div class="activity-icon">
                                            @GetActivityIcon(activity.Type)
                                        </div>

                                        <div>
                                            <p class="activity-title">@activity.Title</p>

                                            @if (!string.IsNullOrWhiteSpace(activity.Description))
                                            {
                                                <div class="activity-description">
                                                    @activity.Description
                                                </div>
                                            }
                                        </div>

                                        <div class="activity-time">
                                            @FormatActivityDate(activity.CreatedAt)
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="empty-state">
                                Henüz hareket bulunmuyor.
                            </div>
                        }
                    </section>

                    <section class="panel">
                        <h2 class="section-title">📌 Bugünün Özeti</h2>

                        <div class="mini-summary">
                            <div class="mini-summary-row">
                                <span>Bugün açılan kayıt</span>
                                <strong>@Model.TodayServiceRecordCount</strong>
                            </div>

                            <div class="mini-summary-row">
                                <span>İşlemdeki servis</span>
                                <strong>@Model.InProgressServiceRecordCount</strong>
                            </div>

                            <div class="mini-summary-row">
                                <span>Fatura taslağı</span>
                                <strong>@Model.DraftInvoiceCount</strong>
                            </div>

                            @if (isOwner)
                            {
                                <div class="mini-summary-row">
                                    <span>Tahsilat bekleyen</span>
                                    <strong>@FormatMoney(Model.PendingCollectionAmount)</strong>
                                </div>
                            }
                        </div>
                    </section>
                </aside>
            </section>
        </main>
    </div>
    <partial name="_QrScannerModal" />
    <script>
            const mobileMenuButton = document.getElementById("mobileMenuButton");
            const sidebar = document.getElementById("sidebar");

            if (mobileMenuButton && sidebar) {
                mobileMenuButton.addEventListener("click", function () {
                    document.body.classList.toggle("sidebar-open");
                });

                document.addEventListener("click", function (event) {
                    const clickedInsideSidebar = sidebar.contains(event.target);
                    const clickedMenuButton = mobileMenuButton.contains(event.target);

                    if (!clickedInsideSidebar && !clickedMenuButton) {
                        document.body.classList.remove("sidebar-open");
                    }
                });
            }
    </script>
</body>
</html>
