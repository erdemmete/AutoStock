<script>
    document.addEventListener("DOMContentLoaded", function () {
        const toggleButton = document.querySelector("[data-filter-toggle]");
        const filterPanel = document.querySelector("[data-filter-panel]");
        const statusInput = document.getElementById("InvoiceStatusFilter");
        const statusButtons = document.querySelectorAll("[data-status-value]");

        toggleButton?.addEventListener("click", function () {
            const isOpen = filterPanel?.classList.toggle("is-open");

            toggleButton.classList.toggle("is-open", !!isOpen);
            toggleButton.setAttribute("aria-expanded", isOpen ? "true" : "false");
        });

        statusButtons.forEach(button => {
            button.addEventListener("click", function () {
                if (!statusInput) {
                    return;
                }

                statusInput.value = this.dataset.statusValue ?? "";

                statusButtons.forEach(x => x.classList.remove("active"));
                this.classList.add("active");
            });
        });
    });
</script>