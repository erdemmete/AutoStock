@model AutoStock.WEB.Models.Invoices.InvoiceIndexViewModel
@using AutoStock.Repositories.Enums
@using AutoStock.WEB.Models.Common
@using AutoStock.WEB.Models.Invoices

@{
    ViewData["Title"] = "Faturalar";

    var invoices = Model.Invoices.Items ?? new List<InvoiceListItemViewModel>();

    var totalCount = Model.Invoices.TotalCount;
    var pageNumber = Model.Invoices.PageNumber > 0 ? Model.Invoices.PageNumber : Model.Query.PageNumber;
    var pageSize = Model.Invoices.PageSize > 0 ? Model.Invoices.PageSize : Model.Query.PageSize;

    var paginationModel = new PaginationViewModel
    {
        Controller = "Invoices",
        Action = "Index",
        PageNumber = pageNumber,
        PageSize = pageSize,
        TotalCount = totalCount,
        RouteValues = new Dictionary<string, string?>
        {
            ["search"] = Model.Query.Search,
            ["status"] = Model.Query.Status.HasValue ? ((int)Model.Query.Status.Value).ToString() : null
        }
    };

    string GetStatusText(int status)
    {
        return status switch
        {
            1 => "Taslak",
            2 => "Kesildi",
            3 => "İptal",
            _ => "Bilinmiyor"
        };
    }

    string GetTypeText(int type)
    {
        return type switch
        {
            1 => "Matbu",
            2 => "e-Arşiv",
            3 => "e-Fatura",
            _ => "Bilinmiyor"
        };
    }
}

<div class="invoice-list-page">

    <section class="invoice-header">
        <div>
            <span class="header-badge">🧾 Fatura Yönetimi</span>
            <h1>Faturalar</h1>
            <p>Oluşturulan taslak, kesilmiş ve iptal edilmiş faturaları yönetin.</p>
        </div>

        @await Html.PartialAsync("_PageActions", new PageActionViewModel
        {
            BackController = "Dashboard",
            BackAction = "Index",
            HomeController = "Dashboard",
            HomeAction = "Index"
        })
    </section>

    <section class="invoice-panel">

        <form method="get"
              asp-controller="Invoices"
              asp-action="Index"
              class="invoice-filter-card">

            <div class="invoice-search-box">
                <span class="search-icon">⌕</span>
                <input name="Search"
                       value="@Model.Query.Search"
                       type="text"
                       placeholder="Fatura no, müşteri, plaka veya kayıt no ara..." />
            </div>

            <select name="Status" class="invoice-filter-select">
                <option value="">Tüm Durumlar</option>

                <option value="@((int)InvoiceStatus.Draft)"
                        selected="@(Model.Query.Status == InvoiceStatus.Draft ? "selected" : null)">
                    Taslak
                </option>

                <option value="@((int)InvoiceStatus.Issued)"
                        selected="@(Model.Query.Status == InvoiceStatus.Issued ? "selected" : null)">
                    Kesildi
                </option>

                <option value="@((int)InvoiceStatus.Cancelled)"
                        selected="@(Model.Query.Status == InvoiceStatus.Cancelled ? "selected" : null)">
                    İptal
                </option>
            </select>

            <select name="PageSize" class="invoice-filter-select">
                <option value="10" selected="@(pageSize == 10 ? "selected" : null)">10 kayıt</option>
                <option value="25" selected="@(pageSize == 25 ? "selected" : null)">25 kayıt</option>
                <option value="50" selected="@(pageSize == 50 ? "selected" : null)">50 kayıt</option>
            </select>

            <input type="hidden" name="PageNumber" value="1" />

            <button type="submit"
                    class="invoice-filter-button"
                    title="Ara">
                ⌕
            </button>

            <a asp-controller="Invoices"
               asp-action="Index"
               class="invoice-clear-button"
               title="Filtreleri temizle">
                ×
            </a>
        </form>

        @await Html.PartialAsync("_Pagination", paginationModel)

        <div class="invoice-table-card">
            <div class="invoice-table">
                <div class="invoice-table-head">
                    <span>Fatura No</span>
                    <span>Müşteri</span>
                    <span>Plaka</span>
                    <span>Tip</span>
                    <span>Durum</span>
                    <span>Tarih</span>
                    <span>Tutar</span>
                    <span></span>
                </div>

                @if (!invoices.Any())
                {
                    <div class="empty-state">
                        Kayıt bulunamadı. Arama veya filtre kriterlerini değiştirerek tekrar deneyin.
                    </div>
                }
                else
                {
                    foreach (var invoice in invoices)
                    {
                        <div class="invoice-row">
                            <span>
                                <strong>@invoice.InvoiceNumber</strong>
                            </span>

                            <span>@invoice.CustomerTitle</span>

                            <span>@(invoice.Plate ?? "-")</span>

                            <span>@GetTypeText(invoice.Type)</span>

                            <span>
                                <b class="status-pill status-@invoice.Status">
                                    @GetStatusText(invoice.Status)
                                </b>
                            </span>

                            <span>@invoice.InvoiceDate.ToString("dd MMMM yyyy")</span>

                            <span>
                                <strong>@invoice.GrandTotal.ToString("N2") ₺</strong>
                            </span>

                            <span>
                                <a href="/Invoices/Detail/@invoice.Id" class="detail-btn">
                                    Detay
                                </a>
                            </span>
                        </div>
                    }
                }
            </div>

            @await Html.PartialAsync("_Pagination", paginationModel)
        </div>

    </section>

</div>

<style>
    .invoice-list-page {
        width: min(1540px, calc(100% - 48px));
        margin: 0 auto;
        padding: 26px 0 42px;
        color: #0f172a;
    }

    .invoice-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        margin-bottom: 28px;
    }

    .header-badge {
        display: inline-flex;
        margin-bottom: 10px;
        padding: 7px 13px;
        border-radius: 999px;
        background: #eef2ff;
        color: #4f46e5;
        font-size: 13px;
        font-weight: 900;
    }

    .invoice-header h1 {
        margin: 0;
        font-size: 32px;
        font-weight: 950;
        letter-spacing: -1px;
    }

    .invoice-header p {
        margin: 8px 0 0;
        color: #64748b;
        font-size: 15px;
        font-weight: 700;
    }

    .invoice-panel {
        background: #fff;
        border: 1px solid #dbe3ef;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 8px 22px rgba(15, 23, 42, .06);
    }

    .invoice-filter-card {
        display: grid;
        grid-template-columns: minmax(320px, 1fr) 170px 130px 48px 48px;
        gap: 12px;
        background: #fff;
        border-bottom: 1px solid #edf2f7;
        padding: 16px;
    }

    .invoice-search-box {
        position: relative;
    }

    .search-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        font-size: 22px;
    }

    .invoice-search-box input,
    .invoice-filter-select {
        width: 100%;
        height: 48px;
        border: 1px solid #cfd8e6;
        border-radius: 13px;
        background: #fff;
        color: #0f172a;
        font-size: 14px;
        outline: none;
    }

    .invoice-search-box input {
        padding: 0 16px 0 48px;
    }

    .invoice-filter-select {
        padding: 0 14px;
    }

        .invoice-search-box input:focus,
        .invoice-filter-select:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 3px rgba(79, 70, 229, .12);
        }

    .invoice-filter-button,
    .invoice-clear-button {
        width: 48px;
        height: 48px;
        border: 1px solid #cfd8e6;
        border-radius: 13px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        text-decoration: none;
        cursor: pointer;
        transition: .18s ease;
    }

    .invoice-filter-button {
        background: #f8fafc;
        color: #475569;
        font-size: 20px;
    }

        .invoice-filter-button:hover {
            background: #eef2ff;
            border-color: #c7d2fe;
            color: #4f46e5;
        }

    .invoice-clear-button {
        background: #fff;
        color: #64748b;
        font-size: 22px;
    }

        .invoice-clear-button:hover {
            background: #fff1f2;
            border-color: #fecdd3;
            color: #e11d48;
        }

    .invoice-table-card {
        background: #fff;
    }

    .invoice-table {
        overflow-x: auto;
    }

    .invoice-table-head,
    .invoice-row {
        display: grid;
        grid-template-columns: 190px minmax(220px, 1fr) 120px 100px 110px 160px 140px 90px;
        gap: 10px;
        align-items: center;
        min-width: 1130px;
    }

    .invoice-table-head {
        padding: 14px 18px;
        background: #f8fafc;
        color: #64748b;
        font-size: 12px;
        font-weight: 950;
        border-top: 1px solid #edf2f7;
        border-bottom: 1px solid #edf2f7;
    }

    .invoice-row {
        padding: 14px 18px;
        border-bottom: 1px solid #edf2f7;
        background: white;
        font-size: 13px;
    }

        .invoice-row:hover {
            background: #fafbff;
        }

        .invoice-row span {
            min-width: 0;
            word-break: break-word;
        }

    .status-pill {
        display: inline-flex;
        padding: 7px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 950;
    }

    .status-1 {
        background: #fef3c7;
        color: #b45309;
    }

    .status-2 {
        background: #dcfce7;
        color: #15803d;
    }

    .status-3 {
        background: #fee2e2;
        color: #b91c1c;
    }

    .detail-btn {
        min-height: 38px;
        padding: 0 14px;
        border-radius: 12px;
        background: #eff6ff;
        color: #1d4ed8;
        text-decoration: none;
        font-weight: 950;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .detail-btn:hover {
            background: #dbeafe;
            color: #1e40af;
        }

    .empty-state {
        padding: 32px;
        color: #64748b;
        text-align: center;
        font-size: 14px;
        font-weight: 850;
        border-top: 1px solid #edf2f7;
    }

    @@media (max-width: 1000px) {
        .invoice-header {
            align-items: flex-start;
            flex-direction: column;
        }

        .invoice-filter-card {
            grid-template-columns: 1fr;
        }

        .invoice-filter-button,
        .invoice-clear-button {
            width: 100%;
        }
    }

    @@media (max-width: 700px) {
        .invoice-list-page {
            width: 100%;
            padding: 12px;
        }

        .invoice-table-head {
            display: none;
        }

        .invoice-row {
            grid-template-columns: 1fr;
            min-width: 0;
            gap: 8px;
        }
    }
</style>