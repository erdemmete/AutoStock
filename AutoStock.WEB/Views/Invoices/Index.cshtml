@model AutoStock.WEB.Models.Invoices.InvoiceIndexViewModel
@using AutoStock.Repositories.Enums
@using AutoStock.WEB.Models.Invoices

@{
    ViewData["Title"] = "Faturalar";

    var invoices = Model.Invoices.Items ?? new List<InvoiceListItemViewModel>();

    var totalCount = Model.Invoices.TotalCount;
    var pageNumber = Model.Invoices.PageNumber > 0 ? Model.Invoices.PageNumber : Model.Query.PageNumber;
    var pageSize = Model.Invoices.PageSize > 0 ? Model.Invoices.PageSize : Model.Query.PageSize;

    var totalPages = pageSize > 0
        ? Math.Max(1, (int)Math.Ceiling(totalCount / (double)pageSize))
        : 1;

    var currentStatus = Model.Query.Status;

    var hasAdvancedFilter = false;

    string GetStatusText(int status)
    {
        return status switch
        {
            1 => "Taslak",
            2 => "Kesildi",
            3 => "İptal",
            _ => "Bilinmiyor"
        };
    }

    string GetStatusClass(int status)
    {
        return status switch
        {
            1 => "status-draft",
            2 => "status-issued",
            3 => "status-cancelled",
            _ => "status-unknown"
        };
    }

    string GetTypeText(int type)
    {
        return type switch
        {
            1 => "Matbu",
            2 => "e-Arşiv",
            3 => "e-Fatura",
            _ => "Bilinmiyor"
        };
    }
}

<div class="inv-page">
    <section class="inv-hero">
        <div class="inv-hero-left">
            <a asp-controller="Dashboard"
               asp-action="Index"
               class="inv-home-btn"
               title="Ana sayfa">
                ⌂
            </a>

            <div>
                <span class="inv-eyebrow">SENTE360</span>
                <h1>Faturalar</h1>
                <p>Taslak, kesilmiş ve iptal edilmiş faturaları tek ekrandan takip edin.</p>
            </div>
        </div>
        <div class="inv-hero-actions">
            <a asp-controller="Invoices"
               asp-action="Export"
               class="inv-export-btn">
                <span>⇩</span>
                <strong>Fatura Aktarımı</strong>
            </a>
        </div>

    </section>

    <section class="inv-filter-shell">
        <form method="get"
              asp-controller="Invoices"
              asp-action="Index"
              id="invoiceFilterForm">

            <input type="hidden" name="PageNumber" value="1" />
            <input type="hidden"
                   name="Status"
                   id="InvoiceStatusFilter"
                   value="@(currentStatus.HasValue ? ((int)currentStatus.Value).ToString() : "")" />

            <div class="inv-search-row">
                <div class="inv-search-box">
                    <span class="inv-search-icon">⌕</span>
                    <input name="Search"
                           value="@Model.Query.Search"
                           type="text"
                           placeholder="Fatura no, müşteri, plaka veya kayıt no ara..." />
                </div>

                <button type="submit" class="inv-search-submit">
                    Ara
                </button>

                <button type="button"
                        class="inv-filter-toggle @(hasAdvancedFilter ? "is-open" : "")"
                        data-filter-toggle
                        aria-expanded="@(hasAdvancedFilter ? "true" : "false")">
                    <span>☷</span>
                    <strong>Filtreler</strong>
                    <em>⌄</em>
                </button>
            </div>

            <div class="inv-advanced-filters @(hasAdvancedFilter ? "is-open" : "")" data-filter-panel>
                <div class="inv-filter-section">
                    <label>Fatura Durumu</label>

                    <div class="inv-status-chips">
                        <button type="button"
                                class="inv-status-chip @(!currentStatus.HasValue ? "active" : "")"
                                data-status-value="">
                            Tümü
                        </button>

                        <button type="button"
                                class="inv-status-chip @(currentStatus == InvoiceStatus.Draft ? "active" : "")"
                                data-status-value="@((int)InvoiceStatus.Draft)">
                            Taslak
                        </button>

                        <button type="button"
                                class="inv-status-chip @(currentStatus == InvoiceStatus.Issued ? "active" : "")"
                                data-status-value="@((int)InvoiceStatus.Issued)">
                            Kesildi
                        </button>

                        <button type="button"
                                class="inv-status-chip @(currentStatus == InvoiceStatus.Cancelled ? "active" : "")"
                                data-status-value="@((int)InvoiceStatus.Cancelled)">
                            İptal
                        </button>
                    </div>
                </div>

                <div class="inv-filter-section">
                    <label>Sayfa Boyutu</label>

                    <select name="PageSize">
                        <option value="10" selected="@(pageSize == 10 ? "selected" : null)">10 kayıt</option>
                        <option value="25" selected="@(pageSize == 25 ? "selected" : null)">25 kayıt</option>
                        <option value="50" selected="@(pageSize == 50 ? "selected" : null)">50 kayıt</option>
                    </select>
                </div>

                <div class="inv-filter-actions">
                    <button type="submit" class="inv-apply-btn">Filtrele</button>

                    <a asp-controller="Invoices"
                       asp-action="Index"
                       class="inv-clear-btn">
                        Temizle
                    </a>
                </div>
            </div>
        </form>
    </section>

    <section class="inv-list-shell">
        <div class="inv-list-toolbar">
            <div class="inv-list-summary">
                @if (totalCount > 0)
                {
                    <span>
                        <strong>@totalCount</strong> fatura —
                        <strong>Sayfa @pageNumber / @totalPages</strong>
                    </span>
                }
                else
                {
                    <span>Fatura bulunamadı.</span>
                }
            </div>

            @if (totalPages > 1)
            {
                <div class="inv-top-pager">
                    <a class="inv-top-nav @(pageNumber > 1 ? "" : "disabled")"
                       href="@(pageNumber > 1
                                                      ? Url.Action("Index", "Invoices", new
                                                      {
                                                          Search = Model.Query.Search,
                                                          Status = currentStatus.HasValue ? (int?)currentStatus.Value : null,
                                                          PageNumber = pageNumber - 1,
                                                          PageSize = pageSize
                                                      })
                                                      : "#")">
                        ‹
                    </a>

                    <div class="inv-top-page-list">
                        @for (var number = 1; number <= totalPages; number++)
                        {
                            if (number == 1 ||
                                number == totalPages ||
                                Math.Abs(number - pageNumber) <= 1)
                            {
                                <a class="inv-top-page @(number == pageNumber ? "active" : "")"
                                   href="@Url.Action("Index", "Invoices", new
                                   {
                                       Search = Model.Query.Search,
                                       Status = currentStatus.HasValue ? (int?)currentStatus.Value : null,
                                       PageNumber = number,
                                       PageSize = pageSize
                                   })">
                                    @number
                                </a>
                            }
                        }
                    </div>

                    <a class="inv-top-nav @(pageNumber < totalPages ? "" : "disabled")"
                       href="@(pageNumber<totalPages
                                                      ? Url.Action("Index", "Invoices", new
                                                      {
                                                          Search = Model.Query.Search,
                                                          Status = currentStatus.HasValue ? (int?)currentStatus.Value : null,
                                                          PageNumber = pageNumber + 1,
                                                          PageSize = pageSize
                                                      })
                              : "#")">
                        ›
                    </a>
                </div>
            }
        </div>

        <div class="inv-list">
            @if (!invoices.Any())
            {
                <div class="inv-empty">
                    <div class="inv-empty-icon">⌕</div>
                    <strong>Fatura bulunamadı</strong>
                    <span>Arama veya filtre kriterlerini değiştirerek tekrar deneyebilirsin.</span>
                </div>
            }
            else
            {
                foreach (var invoice in invoices)
                {
                    var statusText = GetStatusText(invoice.Status);
                    var statusClass = GetStatusClass(invoice.Status);
                    var typeText = GetTypeText(invoice.Type);

                    <article class="inv-card">
                        <a href="/Invoices/Detail/@invoice.Id" class="inv-main">
                            <div class="inv-icon-box">
                                <span>FAT</span>
                                <strong>@typeText</strong>
                            </div>

                            <div class="inv-title-block">
                                <strong>@invoice.InvoiceNumber</strong>
                                <span>@invoice.CustomerTitle</span>
                            </div>
                        </a>

                        <div class="inv-meta">
                            <div class="inv-line">
                                <span>Plaka</span>
                                <strong>@(invoice.Plate ?? "-")</strong>
                            </div>

                            <div class="inv-line">
                                <span>Tarih</span>
                                <strong>@invoice.InvoiceDate.ToString("dd MMMM yyyy")</strong>
                            </div>
                        </div>

                        <div class="inv-status-area">
                            <span class="inv-status @statusClass">@statusText</span>
                        </div>

                        <div class="inv-total">
                            <span>Tutar</span>
                            <strong>@invoice.GrandTotal.ToString("N2") ₺</strong>
                        </div>

                        <div class="inv-actions">
                            <a href="/Invoices/Detail/@invoice.Id" class="inv-detail-btn">
                                Detay
                            </a>
                        </div>
                    </article>
                }
            }
        </div>

        @if (totalPages > 1)
        {
            <div class="inv-pagination">
                <a class="inv-page-btn @(pageNumber > 1 ? "" : "disabled")"
                   href="@(pageNumber > 1
                                              ? Url.Action("Index", "Invoices", new
                                              {
                                                  Search = Model.Query.Search,
                                                  Status = currentStatus.HasValue ? (int?)currentStatus.Value : null,
                                                  PageNumber = pageNumber - 1,
                                                  PageSize = pageSize
                                              })
                                              : "#")">
                    Önceki
                </a>

                <div class="inv-page-numbers">
                    @for (var number = 1; number <= totalPages; number++)
                    {
                        if (number == 1 ||
                            number == totalPages ||
                            Math.Abs(number - pageNumber) <= 2)
                        {
                            <a class="inv-page-number @(number == pageNumber ? "active" : "")"
                               href="@Url.Action("Index", "Invoices", new
                               {
                                   Search = Model.Query.Search,
                                   Status = currentStatus.HasValue ? (int?)currentStatus.Value : null,
                                   PageNumber = number,
                                   PageSize = pageSize
                               })">
                                @number
                            </a>
                        }
                    }
                </div>

                <a class="inv-page-btn @(pageNumber < totalPages ? "" : "disabled")"
                   href="@(pageNumber<totalPages
                                              ? Url.Action("Index", "Invoices", new
                                              {
                                                  Search = Model.Query.Search,
                                                  Status = currentStatus.HasValue ? (int?)currentStatus.Value : null,
                                                  PageNumber = pageNumber + 1,
                                                  PageSize = pageSize
                                              })
                          : "#")">
                    Sonraki
                </a>
            </div>
        }
    </section>
</div>

<style>
    .inv-page {
        width: min(1280px, calc(100% - 56px));
        margin: 0 auto;
        padding: 30px 0 64px;
        color: #061936;
    }

    .inv-hero {
        margin-bottom: 22px;
        padding: 24px 28px;
        border-radius: 30px;
        background: radial-gradient(circle at 78% 40%, rgba(255,255,255,.16), transparent 30%), linear-gradient(135deg, #07111f 0%, #111827 48%, #4f46e5 100%);
        color: white;
        box-shadow: 0 26px 70px rgba(15, 23, 42, .20);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 22px;
        overflow: hidden;
    }

    .inv-hero-left {
        display: flex;
        align-items: center;
        gap: 18px;
        min-width: 0;
    }

    .inv-home-btn {
        width: 54px;
        height: 54px;
        flex: 0 0 54px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #2563eb, #16a34a);
        color: white;
        text-decoration: none;
        font-size: 24px;
        font-weight: 950;
        box-shadow: 0 18px 36px rgba(37, 99, 235, .25);
    }

    .inv-eyebrow {
        display: inline-flex;
        margin-bottom: 8px;
        padding: 6px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.18);
        color: rgba(255,255,255,.82);
        font-size: 12px;
        font-weight: 950;
        letter-spacing: .2px;
    }

    .inv-hero h1 {
        margin: 0;
        font-size: clamp(30px, 4vw, 42px);
        line-height: 1;
        letter-spacing: -1.6px;
    }

    .inv-hero p {
        margin: 10px 0 0;
        color: rgba(255,255,255,.72);
        font-size: 15px;
        line-height: 1.45;
    }

    .inv-filter-shell {
        margin-bottom: 22px;
        padding: 20px;
        border-radius: 26px;
        background: rgba(255,255,255,.96);
        border: 1px solid #dbe3ef;
        box-shadow: 0 18px 42px rgba(15, 23, 42, .07);
    }

    .inv-search-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto auto;
        gap: 10px;
        align-items: center;
    }

    .inv-search-box {
        position: relative;
        min-width: 0;
    }

    .inv-search-icon {
        position: absolute;
        left: 18px;
        top: 50%;
        transform: translateY(-50%);
        color: #8aa0bd;
        font-size: 24px;
        pointer-events: none;
    }

    .inv-search-box input {
        width: 100%;
        height: 56px;
        padding: 0 18px 0 52px;
        border-radius: 18px;
        border: 1px solid #d4deeb;
        background: #f8fafc;
        color: #0f172a;
        font-size: 16px;
        font-weight: 750;
        outline: none;
        box-sizing: border-box;
    }

        .inv-search-box input::placeholder {
            color: #8aa0bd;
            font-weight: 700;
        }

        .inv-search-box input:focus {
            background: white;
            border-color: #4f46e5;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, .10);
        }

    .inv-search-submit,
    .inv-filter-toggle {
        height: 56px;
        border-radius: 18px;
        border: 1px solid #c7d2fe;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        cursor: pointer;
        font-size: 15px;
        font-weight: 950;
        white-space: nowrap;
    }

    .inv-search-submit {
        padding: 0 22px;
        background: #4f46e5;
        color: white;
        border-color: #4f46e5;
        box-shadow: 0 12px 24px rgba(79, 70, 229, .20);
    }

    .inv-filter-toggle {
        padding: 0 18px;
        background: #f8fafc;
        color: #312e81;
    }

        .inv-filter-toggle span {
            font-size: 18px;
        }

        .inv-filter-toggle em {
            font-style: normal;
            transition: .18s ease;
        }

        .inv-filter-toggle.is-open em {
            transform: rotate(180deg);
        }

    .inv-advanced-filters {
        display: none;
        margin-top: 18px;
        padding-top: 18px;
        border-top: 1px solid #e2e8f0;
        grid-template-columns: minmax(0, 1.4fr) minmax(180px, .5fr) auto;
        gap: 14px;
        align-items: end;
    }

        .inv-advanced-filters.is-open {
            display: grid;
        }

    .inv-filter-section {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 9px;
    }

        .inv-filter-section label {
            color: #64748b;
            font-size: 12px;
            font-weight: 950;
            letter-spacing: .7px;
            text-transform: uppercase;
        }

        .inv-filter-section select {
            width: 100%;
            height: 46px;
            padding: 0 14px;
            border-radius: 15px;
            border: 1px solid #d4deeb;
            background: #f8fafc;
            color: #0f172a;
            font-size: 15px;
            font-weight: 800;
            outline: none;
            box-sizing: border-box;
        }

    .inv-status-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 9px;
    }

    .inv-status-chip {
        height: 36px;
        padding: 0 16px;
        border: none;
        border-radius: 999px;
        background: #f1f5f9;
        color: #334155;
        font-size: 13px;
        font-weight: 900;
        cursor: pointer;
    }

        .inv-status-chip.active {
            background: #0f172a;
            color: white;
        }

    .inv-filter-actions {
        display: flex;
        gap: 10px;
    }

    .inv-apply-btn,
    .inv-clear-btn {
        height: 46px;
        padding: 0 18px;
        border-radius: 15px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-size: 14px;
        font-weight: 950;
        white-space: nowrap;
    }

    .inv-apply-btn {
        border: none;
        background: #4f46e5;
        color: white;
        cursor: pointer;
    }

    .inv-clear-btn {
        border: 1px solid #d4deeb;
        background: #f8fafc;
        color: #4f46e5;
    }

    .inv-list-toolbar {
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
    }

    .inv-list-summary {
        color: #64748b;
        font-size: 14px;
        font-weight: 850;
    }

        .inv-list-summary strong {
            color: #334155;
        }

    .inv-top-pager {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px;
        border-radius: 999px;
        background: white;
        border: 1px solid #dbe3ef;
        box-shadow: 0 8px 22px rgba(15, 23, 42, .05);
    }

    .inv-top-page-list {
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    .inv-top-nav,
    .inv-top-page {
        width: 34px;
        height: 34px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: #475569;
        font-size: 14px;
        font-weight: 950;
        transition: .15s ease;
    }

    .inv-top-nav {
        font-size: 24px;
        line-height: 1;
        background: #f8fafc;
    }

    .inv-top-page.active {
        background: #4f46e5;
        color: white;
        box-shadow: 0 8px 18px rgba(79, 70, 229, .28);
    }

    .inv-top-nav.disabled {
        opacity: .35;
        pointer-events: none;
    }

    .inv-list {
        display: grid;
        gap: 14px;
    }

    .inv-card {
        min-height: 92px;
        padding: 20px 24px;
        border-radius: 24px;
        border: 1px solid #dbe3ef;
        background: white;
        color: #0f172a;
        display: grid;
        grid-template-columns: minmax(270px, 1.35fr) minmax(220px, 1fr) 120px 150px 90px;
        gap: 18px;
        align-items: center;
        box-shadow: 0 10px 26px rgba(15, 23, 42, .045);
        transition: .16s ease;
    }

        .inv-card:hover {
            transform: translateY(-2px);
            border-color: #c7d2fe;
            box-shadow: 0 18px 38px rgba(15, 23, 42, .08);
        }

    .inv-main {
        min-width: 0;
        display: flex;
        align-items: center;
        gap: 15px;
        color: inherit;
        text-decoration: none;
    }

    .inv-icon-box {
        width: 70px;
        height: 54px;
        flex: 0 0 70px;
        border-radius: 17px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        display: grid;
        align-content: center;
        justify-items: center;
        gap: 2px;
    }

        .inv-icon-box span {
            color: #8aa0bd;
            font-size: 10px;
            font-weight: 950;
            letter-spacing: .6px;
        }

        .inv-icon-box strong {
            color: #0f172a;
            font-size: 12px;
            font-weight: 950;
            text-align: center;
        }

    .inv-title-block {
        min-width: 0;
    }

        .inv-title-block strong {
            display: block;
            color: #0f172a;
            font-size: 17px;
            font-weight: 950;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .inv-title-block span {
            display: block;
            margin-top: 6px;
            color: #64748b;
            font-size: 14px;
            font-weight: 850;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

    .inv-meta {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .inv-line,
    .inv-total {
        min-width: 0;
        padding: 12px 14px;
        border-radius: 18px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
    }

        .inv-line span,
        .inv-total span {
            display: block;
            color: #8aa0bd;
            font-size: 12px;
            font-weight: 950;
            margin-bottom: 5px;
        }

        .inv-line strong,
        .inv-total strong {
            display: block;
            color: #0f172a;
            font-size: 14px;
            font-weight: 950;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

    .inv-status-area {
        display: flex;
        justify-content: flex-start;
    }

    .inv-status {
        min-width: 86px;
        height: 32px;
        padding: 0 12px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 950;
        white-space: nowrap;
    }

        .inv-status.status-draft {
            background: #fef3c7;
            color: #b45309;
        }

        .inv-status.status-issued {
            background: #dcfce7;
            color: #15803d;
        }

        .inv-status.status-cancelled {
            background: #fee2e2;
            color: #b91c1c;
        }

        .inv-status.status-unknown {
            background: #f1f5f9;
            color: #475569;
        }

    .inv-actions {
        display: flex;
        justify-content: flex-end;
    }

    .inv-detail-btn {
        height: 42px;
        padding: 0 15px;
        border-radius: 14px;
        border: 1px solid #d4deeb;
        background: #f8fafc;
        color: #18365d;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-size: 13px;
        font-weight: 950;
        white-space: nowrap;
    }

        .inv-detail-btn:hover {
            background: #eef2ff;
            color: #4f46e5;
            border-color: #c7d2fe;
        }

    .inv-empty {
        padding: 48px 20px;
        border-radius: 24px;
        background: white;
        border: 1px dashed #cbd5e1;
        color: #64748b;
        text-align: center;
        display: grid;
        justify-items: center;
        gap: 8px;
    }

    .inv-empty-icon {
        width: 58px;
        height: 58px;
        border-radius: 20px;
        display: grid;
        place-items: center;
        background: #eef2ff;
        color: #4f46e5;
        font-size: 28px;
        font-weight: 950;
    }

    .inv-empty strong {
        color: #0f172a;
        font-size: 18px;
        font-weight: 950;
    }

    .inv-pagination {
