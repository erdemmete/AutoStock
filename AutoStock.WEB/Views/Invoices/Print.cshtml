@model AutoStock.WEB.Models.Invoices.InvoiceDetailViewModel

@{
    Layout = null;

    string GetStatusText(int status)
    {
        return status switch
        {
            1 => "Taslak",
            2 => "Kesildi",
            3 => "İptal",
            _ => "Bilinmiyor"
        };
    }

    string GetItemTypeText(int type)
    {
        return type switch
        {
            1 => "İşçilik",
            2 => "Parça",
            3 => "Diğer",
            _ => "Diğer"
        };
    }

    string ValueOrDash(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value.Trim();
    }

    string JoinText(params string?[] values)
    {
        var parts = values
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => x!.Trim());

        return string.Join(" / ", parts);
    }

    string FormatMoney(decimal value)
    {
        return value.ToString("N2") + " TL";
    }

    string FormatPercent(decimal value)
    {
        return "%" + value.ToString("N2");
    }

    string FormatIban(string? iban)
    {
        if (string.IsNullOrWhiteSpace(iban))
            return "-";

        var clean = new string(iban.Where(char.IsLetterOrDigit).ToArray()).ToUpperInvariant();

        if (string.IsNullOrWhiteSpace(clean))
            return "-";

        var groups = Enumerable.Range(0, (clean.Length + 3) / 4)
            .Select(i => clean.Substring(i * 4, Math.Min(4, clean.Length - i * 4)));

        return string.Join(" ", groups);
    }

    var workshopTitle =
        !string.IsNullOrWhiteSpace(Model.WorkshopLegalTitle)
            ? Model.WorkshopLegalTitle
            : !string.IsNullOrWhiteSpace(Model.WorkshopDisplayName)
                ? Model.WorkshopDisplayName
                : "Servis İşletmesi";

    var workshopAddress = JoinText(
        Model.WorkshopAddressLine,
        Model.WorkshopDistrict,
        Model.WorkshopCity,
        Model.WorkshopPostalCode,
        Model.WorkshopCountry);

    var workshopContactLine = JoinText(
        string.IsNullOrWhiteSpace(Model.WorkshopPhoneNumber) ? null : $"Tel: {Model.WorkshopPhoneNumber}",
        string.IsNullOrWhiteSpace(Model.WorkshopFaxNumber) ? null : $"Fax: {Model.WorkshopFaxNumber}");

    var workshopDigitalLine = JoinText(
        string.IsNullOrWhiteSpace(Model.WorkshopWebsite) ? null : $"Web: {Model.WorkshopWebsite}",
        string.IsNullOrWhiteSpace(Model.WorkshopEmail) ? null : $"E-Posta: {Model.WorkshopEmail}");

    var workshopTaxLine = JoinText(
        string.IsNullOrWhiteSpace(Model.WorkshopTaxOffice) ? null : $"Vergi Dairesi: {Model.WorkshopTaxOffice}",
        string.IsNullOrWhiteSpace(Model.WorkshopTaxNumber) ? null : $"VKN/TCKN: {Model.WorkshopTaxNumber}");

    var workshopRegistryLine = JoinText(
        string.IsNullOrWhiteSpace(Model.WorkshopTradeRegistryNumber) ? null : $"Ticaret Sicil No: {Model.WorkshopTradeRegistryNumber}",
        string.IsNullOrWhiteSpace(Model.WorkshopMersisNumber) ? null : $"MERSİS No: {Model.WorkshopMersisNumber}");

    var vehicleText = JoinText(
        Model.Plate,
        Model.VehicleBrandName,
        Model.VehicleModelName,
        Model.VehicleModelYear?.ToString());

    var customerTaxLine = JoinText(
        string.IsNullOrWhiteSpace(Model.CustomerTckn) ? null : $"TCKN: {Model.CustomerTckn}",
        string.IsNullOrWhiteSpace(Model.CustomerTaxNumber) ? null : $"VKN: {Model.CustomerTaxNumber}",
        string.IsNullOrWhiteSpace(Model.CustomerTaxOffice) ? null : $"Vergi Dairesi: {Model.CustomerTaxOffice}");

    var noteText = !string.IsNullOrWhiteSpace(Model.Notes)
        ? Model.Notes.Trim()
        : "";

    var bankAccounts = Model.BankAccounts?
        .Where(x => x.ShowOnInvoices && !string.IsNullOrWhiteSpace(x.Iban))
        .OrderByDescending(x => x.IsDefault)
        .ThenBy(x => x.SortOrder)
        .ThenBy(x => x.BankName)
        .ToList() ?? new List<AutoStock.WEB.Models.Invoices.InvoiceBankAccountViewModel>();

    var itemCount = Model.Items?.Count ?? 0;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@Model.InvoiceNumber</title>

    <style>
        * {
            box-sizing: border-box;
        }

        :root {
            --ink: #111827;
            --muted: #475569;
            --line: #111827;
            --soft-line: #cbd5e1;
            --soft: #f8fafc;
            --soft-2: #f1f5f9;
        }

        html,
        body {
            margin: 0;
            padding: 0;
            background: #e5e7eb;
            color: var(--ink);
            font-family: Arial, Helvetica, sans-serif;
            font-size: 11px;
            font-weight: 600;
        }

        .print-toolbar {
            position: sticky;
            top: 0;
            z-index: 20;
            display: flex;
            justify-content: center;
            gap: 10px;
            padding: 12px;
            background: rgba(255, 255, 255, .96);
            border-bottom: 1px solid #d1d5db;
        }

        .toolbar-btn {
            height: 40px;
            padding: 0 18px;
            border: none;
            border-radius: 10px;
            background: #1d4ed8;
            color: white;
            font-size: 13px;
            font-weight: 900;
            cursor: pointer;
        }

        .toolbar-btn.secondary {
            background: #e5e7eb;
            color: #111827;
        }

        .page {
            width: 210mm;
            min-height: 297mm;
            margin: 14px auto;
            background: white;
            padding: 8mm;
            box-shadow: 0 18px 60px rgba(15, 23, 42, .16);
        }

        .document {
            min-height: calc(297mm - 16mm);
            display: flex;
            flex-direction: column;
            border: 1.4px solid var(--line);
            padding: 4mm;
            background: white;
        }

        .top-line {
            height: 2px;
            background: var(--line);
            margin-bottom: 3mm;
        }

        .header {
            display: grid;
            grid-template-columns: 1.12fr .88fr;
            gap: 6mm;
            align-items: start;
            padding-bottom: 3mm;
            border-bottom: 1.4px solid var(--line);
        }

        .issuer-title {
            margin: 0 0 2mm;
            font-size: 14px;
            line-height: 1.12;
            letter-spacing: .2px;
            font-weight: 950;
            text-transform: uppercase;
        }

        .issuer-lines {
            display: grid;
            gap: 1.1mm;
            color: #111827;
            font-size: 9.6px;
            line-height: 1.25;
            font-weight: 700;
        }

        .document-title {
            margin-bottom: 3mm;
            text-align: right;
        }

        .document-title h1 {
            margin: 0;
            font-size: 18px;
            line-height: 1.05;
            font-weight: 950;
            letter-spacing: -.2px;
            text-transform: uppercase;
        }

        .document-title p {
            margin: 1mm 0 0;
            color: var(--muted);
            font-size: 10px;
            font-weight: 800;
        }

        .meta-table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }

        .meta-table th,
        .meta-table td {
            border: 1px solid var(--line);
            padding: 2.1mm 2.4mm;
            font-size: 9.7px;
            line-height: 1.15;
            vertical-align: middle;
        }

        .meta-table th {
            width: 34mm;
            background: var(--soft-2);
            text-align: left;
            color: #334155;
            font-weight: 950;
        }

        .meta-table td {
            text-align: right;
            font-weight: 900;
            word-break: break-word;
        }

        .party-area {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6mm;
            padding: 3mm 0;
            border-bottom: 1.4px solid var(--line);
        }

        .section-caption {
            margin: 0 0 1.5mm;
            padding-bottom: 1.1mm;
            border-bottom: 1.3px solid var(--line);
            font-size: 10px;
            font-weight: 950;
            letter-spacing: .4px;
            text-transform: uppercase;
        }

        .customer-name {
            margin: 0 0 1mm;
            font-size: 11.2px;
            line-height: 1.2;
            font-weight: 950;
            text-transform: uppercase;
        }

        .customer-detail {
            margin: 0;
            color: #111827;
            font-size: 9.8px;
            line-height: 1.38;
            font-weight: 700;
        }

        .vehicle-grid {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }

        .vehicle-grid th,
        .vehicle-grid td {
            border: 1px solid var(--line);
            padding: 1.8mm 2.2mm;
            font-size: 9.6px;
            line-height: 1.15;
        }

        .vehicle-grid th {
            width: 24mm;
            text-align: left;
            background: var(--soft-2);
            color: #334155;
            font-weight: 950;
        }

        .vehicle-grid td {
            text-align: right;
            font-weight: 900;
            word-break: break-word;
        }

        .reference-line {
            padding: 2.5mm 0 1.2mm;
            color: #334155;
            font-size: 9.3px;
            line-height: 1.2;
            font-weight: 800;
        }

        .items-table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }

        .items-table th,
        .items-table td {
            border: 1px solid var(--line);
            vertical-align: top;
        }

        .items-table th {
            padding: 1.8mm 1.7mm;
            background: var(--soft-2);
            color: #111827;
            font-size: 9px;
            line-height: 1.1;
            font-weight: 950;
            text-align: center;
        }

        .items-table td {
            padding: 1.8mm 1.7mm;
            color: #111827;
            font-size: 9.2px;
            line-height: 1.22;
            font-weight: 750;
        }

        .col-no { width: 8mm; text-align: center; }
        .col-type { width: 15mm; text-align: center; }
        .col-desc { width: auto; }
        .col-qty { width: 17mm; text-align: right; }
        .col-price { width: 22mm; text-align: right; }
        .col-discount { width: 19mm; text-align: right; }
        .col-vat { width: 19mm; text-align: right; }
        .col-total { width: 26mm; text-align: right; }

        .item-desc {
            font-weight: 850;
            word-break: break-word;
        }

        .small-sub {
            display: block;
            margin-top: .7mm;
            color: #475569;
            font-size: 8.2px;
            font-weight: 700;
        }

        .after-table {
            display: grid;
            grid-template-columns: 1fr 56mm;
            gap: 6mm;
            margin-top: 3mm;
            align-items: start;
        }

        .note-box {
            min-height: 20mm;
            border: 1px solid var(--line);
            padding: 2.3mm;
            font-size: 9.2px;
            line-height: 1.35;
            font-weight: 700;
        }

        .note-box strong {
            display: block;
            margin-bottom: 1.2mm;
            font-size: 9.6px;
            font-weight: 950;
        }

        .totals-table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }

        .totals-table th,
        .totals-table td {
            border: 1px solid var(--line);
            padding: 1.9mm 2mm;
            font-size: 9.4px;
            line-height: 1.1;
        }

        .totals-table th {
            background: var(--soft-2);
            text-align: right;
            font-weight: 950;
        }

        .totals-table td {
            width: 25mm;
            text-align: right;
            font-weight: 950;
        }

        .totals-table .grand th,
        .totals-table .grand td {
            background: #f8fafc;
            font-size: 10.3px;
            font-weight: 950;
        }

        .payment-section {
            margin-top: 3mm;
            border: 1px solid var(--line);
            page-break-inside: avoid;
        }

        .payment-title {
            padding: 1.9mm 2.2mm;
            background: var(--soft-2);
            border-bottom: 1px solid var(--line);
            font-size: 9.8px;
            line-height: 1.1;
            font-weight: 950;
            letter-spacing: .3px;
            text-transform: uppercase;
        }

        

        

        .pay-bank { width: 31mm; }
        .pay-holder { width: 40mm; }
        .pay-iban { width: auto; }
        .pay-currency { width: 16mm; text-align: center; }
        .pay-note { width: 38mm; }

        .default-badge {
            display: inline-block;
            margin-left: 1mm;
            padding: .5mm 1.3mm;
            border: 1px solid #111827;
            border-radius: 999px;
            font-size: 7.2px;
            font-weight: 950;
            vertical-align: middle;
        }

        .bottom-push {
            flex: 1;
            min-height: 8mm;
        }

        .signature-area {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24mm;
            padding-top: 6mm;
            margin-top: auto;
        }

        .signature {
            text-align: center;
        }

        .signature-line {
            height: 1.3px;
            background: var(--line);
            margin-bottom: 2mm;
        }

        .signature span {
            color: #334155;
            font-size: 9.5px;
            font-weight: 900;
        }

        .legal-note {
            margin-top: 5mm;
            padding-top: 2.5mm;
            border-top: 1px solid var(--line);
            color: #334155;
            font-size: 8.8px;
            line-height: 1.35;
            font-weight: 700;
        }

        @@media print {
            html,
            body {
                background: white;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

            .print-toolbar {
                display: none;
            }

            .page {
                width: auto;
                min-height: auto;
                margin: 0;
                padding: 0;
                box-shadow: none;
            }

            .document {
                min-height: calc(297mm - 16mm);
                border: none;
                padding: 0;
            }

            .items-table {
                page-break-inside: auto;
            }

            .items-table tr {
                page-break-inside: avoid;
                page-break-after: auto;
            }

            .items-table thead {
                display: table-header-group;
            }

            .payment-section,
            .after-table,
            .signature-area,
            .legal-note {
                page-break-inside: avoid;
            }

            @@page {
                size: A4;
                margin: 8mm;
            }
        }

            .payment-note-box {
                margin-top: 3mm;
                border: 1px solid var(--line);
                padding: 2mm 2.4mm;
                page-break-inside: avoid;
            }

            .payment-note-title {
                margin-bottom: 1.2mm;
                color: #111827;
                font-size: 9.4px;
                line-height: 1.1;
                font-weight: 950;
            }

            .payment-note-lines {
                display: grid;
                gap: .8mm;
            }

            .payment-note-line {
                color: #111827;
                font-size: 8.8px;
                line-height: 1.25;
                font-weight: 700;
            }

                .payment-note-line strong {
                    font-weight: 950;
                }

                .payment-note-line b {
                    font-weight: 900;
                }

                .payment-note-line em {
                    margin-left: 1.5mm;
                    color: #475569;
                    font-style: normal;
                    font-weight: 900;
                }

                .payment-note-line small {
                    margin-left: 1.8mm;
                    color: #475569;
                    font-size: 8.2px;
                    font-weight: 700;
                }
    </style>
</head>

<body>
    <div class="print-toolbar">
        <button class="toolbar-btn" onclick="window.print()">Yazdır</button>
        <button class="toolbar-btn secondary" onclick="window.close()">Kapat</button>
    </div>

    <main class="page">
        <section class="document">
            <div class="top-line"></div>

            <header class="header">
                <section>
                    <h2 class="issuer-title">@workshopTitle</h2>

                    <div class="issuer-lines">
                        @if (!string.IsNullOrWhiteSpace(workshopAddress))
                        {
                            <div>@workshopAddress</div>
                        }

                        @if (!string.IsNullOrWhiteSpace(workshopContactLine))
                        {
                            <div>@workshopContactLine</div>
                        }

                        @if (!string.IsNullOrWhiteSpace(workshopDigitalLine))
                        {
                            <div>@workshopDigitalLine</div>
                        }

                        @if (!string.IsNullOrWhiteSpace(workshopTaxLine))
                        {
                            <div>@workshopTaxLine</div>
                        }

                        @if (!string.IsNullOrWhiteSpace(workshopRegistryLine))
                        {
                            <div>@workshopRegistryLine</div>
                        }
                    </div>
                </section>

                <section>
                    <div class="document-title">
                        <h1>Servis Hesap Özeti</h1>
                        <p>Matbu belge / ön muhasebe kaydı</p>
                    </div>

                    <table class="meta-table">
                        <tbody>
                            <tr><th>Belge No</th><td>@Model.InvoiceNumber</td></tr>
                            <tr><th>Tarih</th><td>@Model.InvoiceDate.ToString("dd.MM.yyyy HH:mm")</td></tr>
                            <tr><th>Durum</th><td>@GetStatusText(Model.Status)</td></tr>
                            <tr><th>Servis Kaydı</th><td>@(Model.ServiceRecordId?.ToString() ?? "-")</td></tr>
                            <tr><th>Plaka</th><td>@ValueOrDash(Model.Plate)</td></tr>
                            <tr><th>Şasi</th><td>@ValueOrDash(Model.ChassisNumber)</td></tr>
                            <tr><th>KM</th><td>@((Model.Mileage ?? 0).ToString("N0"))</td></tr>
                        </tbody>
                    </table>
                </section>
            </header>

            <section class="party-area">
                <section>
                    <h3 class="section-caption">Sayın</h3>
                    <h4 class="customer-name">@ValueOrDash(Model.CustomerTitle)</h4>

                    <p class="customer-detail">
                        @ValueOrDash(Model.CustomerAddress)

                        @if (!string.IsNullOrWhiteSpace(customerTaxLine))
                        {
                            <br />
                            @customerTaxLine
                        }
                    </p>
                </section>

                <section>
                    <h3 class="section-caption">Araç / Belge Bilgileri</h3>

                    <table class="vehicle-grid">
                        <tbody>
                            <tr>
                                <th>Plaka</th>
                                <td>@ValueOrDash(Model.Plate)</td>
                            </tr>
                            <tr>
                                <th>Şasi</th>
                                <td>@ValueOrDash(Model.ChassisNumber)</td>
                            </tr>
                            <tr>
                                <th>Marka / Model</th>
                                <td>@ValueOrDash(JoinText(Model.VehicleBrandName, Model.VehicleModelName))</td>
                            </tr>
                            <tr>
                                <th>Yıl / KM</th>
                                <td>@JoinText(Model.VehicleModelYear?.ToString(), (Model.Mileage ?? 0).ToString("N0"))</td>
                            </tr>
                        </tbody>
                    </table>
                </section>
            </section>

            <div class="reference-line">
                Belge referansı: @Model.InvoiceNumber
                @if (!string.IsNullOrWhiteSpace(vehicleText))
                {
                    <span> | Araç: @vehicleText</span>
                }
                <span> | Kalem sayısı: @itemCount</span>
            </div>

            <section>
                <table class="items-table">
                    <thead>
                        <tr>
                            <th class="col-no">Sıra</th>
                            <th class="col-type">Tür</th>
                            <th class="col-desc">Mal / Hizmet</th>
                            <th class="col-qty">Miktar</th>
                            <th class="col-price">Birim Fiyat</th>
                            <th class="col-discount">İsk.</th>
                            <th class="col-vat">KDV</th>
                            <th class="col-total">Tutar</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model.Items == null || !Model.Items.Any())
                        {
                            <tr>
                                <td colspan="8" style="text-align:center; padding: 6mm; font-weight:900;">
                                    Fatura kalemi bulunmuyor.
                                </td>
                            </tr>
                        }
                        else
                        {
                            var index = 1;

                            foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="col-no">@index</td>
                                    <td class="col-type">@GetItemTypeText(item.ItemType)</td>
                                    <td class="col-desc"><div class="item-desc">@item.Description</div></td>
                                    <td class="col-qty">@item.Quantity.ToString("N2")<span class="small-sub">@item.Unit</span></td>
                                    <td class="col-price">@FormatMoney(item.UnitPrice)</td>
                                    <td class="col-discount">
                                        @if (item.DiscountAmount > 0)
                                        {
                                            @FormatMoney(item.DiscountAmount)
                                            <span class="small-sub">@FormatPercent(item.DiscountRate)</span>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td class="col-vat">@FormatMoney(item.VatAmount)<span class="small-sub">@FormatPercent(item.VatRate)</span></td>
                                    <td class="col-total"><strong>@FormatMoney(item.LineTotal)</strong></td>
                                </tr>

                                index++;
                            }
                        }
                    </tbody>
                </table>
            </section>

            <section class="after-table">
                <div class="note-box">
                    <strong>Not:</strong>
                    @if (!string.IsNullOrWhiteSpace(noteText))
                    {
                        @noteText
                    }
                    else
                    {
                        <span>-</span>
                    }
                </div>

                <table class="totals-table">
                    <tbody>
                        <tr><th>Mal Hizmet Toplam Tutarı</th><td>@FormatMoney(Model.Subtotal)</td></tr>
                        <tr><th>Toplam İskonto</th><td>@FormatMoney(Model.DiscountTotal)</td></tr>
                        <tr><th>Hesaplanan KDV</th><td>@FormatMoney(Model.VatTotal)</td></tr>
                        <tr><th>Vergiler Dahil Toplam Tutar</th><td>@FormatMoney(Model.GrandTotal)</td></tr>
                        <tr class="grand"><th>Ödenecek Tutar</th><td>@FormatMoney(Model.GrandTotal)</td></tr>
                    </tbody>
                </table>
            </section>

            @if (Model.BankAccounts != null && Model.BankAccounts.Any())
            {
                <section class="payment-note-box">
                    <div class="payment-note-title">Ödeme Bilgileri</div>

                    <div class="payment-note-lines">
                        @foreach (var bankAccount in Model.BankAccounts
                                .OrderByDescending(x => x.IsDefault)
                                .ThenBy(x => x.SortOrder)
                                .ThenBy(x => x.BankName))
                        {
                            <div class="payment-note-line">
                                <strong>@bankAccount.BankName</strong>
                                <span>-</span>
                                <b>@bankAccount.Iban</b>

                                @if (!string.IsNullOrWhiteSpace(bankAccount.CurrencyCode))
                                {
                                    <em>@bankAccount.CurrencyCode</em>
                                }

                                @if (!string.IsNullOrWhiteSpace(bankAccount.AccountHolder))
                                {
                                    <small>Alıcı: @bankAccount.AccountHolder</small>
                                }

                                @if (!string.IsNullOrWhiteSpace(bankAccount.Description))
                                {
                                    <small>@bankAccount.Description</small>
                                }
                            </div>
                        }
                    </div>
                </section>
            }

            <div class="bottom-push"></div>

            <section class="signature-area">
                <div class="signature">
                    <div class="signature-line"></div>
                    <span>Yetkili İmza / Kaşe</span>
                </div>

                <div class="signature">
                    <div class="signature-line"></div>
                    <span>Müşteri İmza</span>
                </div>
            </section>

            <footer class="legal-note">
