@model AutoStock.WEB.Models.Invoices.InvoiceDetailViewModel

@{
    var recipientEmail = Model.CustomerEmail?.Trim();
    var workshopName = !string.IsNullOrWhiteSpace(Model.WorkshopDisplayName)
        ? Model.WorkshopDisplayName
        : !string.IsNullOrWhiteSpace(Model.WorkshopLegalTitle)
            ? Model.WorkshopLegalTitle
            : "Sente360 Servis";
    var secureDocumentUrl = Model.ServiceRecordId.HasValue && !string.IsNullOrWhiteSpace(Model.PublicServiceQrCode)
        ? $"{Context.Request.Scheme}://{Context.Request.Host}/public/service-pdf/{Uri.EscapeDataString(Model.PublicServiceQrCode)}/{Model.ServiceRecordId.Value}"
        : null;
}

<footer class="invoice-footer-actions">
    <div class="invoice-footer-left">
        @if (Model.ServiceRecordId.HasValue)
        {
            <a class="invoice-footer-link"
               asp-controller="ServiceRecords"
               asp-action="Detail"
               asp-route-id="@Model.ServiceRecordId">
                <span>←</span>
                Servis Kaydına Git
            </a>
        }
    </div>

    <div class="invoice-footer-right">
        @if (Model.Status != 3)
        {
            <button type="button"
                    class="invoice-email-btn"
                    data-invoice-email-draft
                    data-customer-name="@Model.CustomerTitle"
                    data-recipient-email="@recipientEmail"
                    data-workshop-name="@workshopName"
                    data-document-number="@Model.InvoiceNumber"
                    data-plate="@Model.Plate"
                    data-vehicle-id="@Model.VehicleId"
                    data-service-record-id="@Model.ServiceRecordId"
                    data-secure-url="@secureDocumentUrl">
                <span class="invoice-email-icon">✉</span>
                <span>E-posta Taslağı Aç</span>
            </button>
        }

        <a class="invoice-footer-list-btn"
           asp-controller="Invoices"
           asp-action="Index">
            Hesap Özeti Listesine Dön
        </a>
    </div>
</footer>
