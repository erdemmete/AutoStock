@model AutoStock.WEB.Models.Invoices.InvoiceDetailViewModel

<div class="invoice-modal-backdrop" id="invoiceModalBackdrop" hidden></div>

<div class="invoice-modal" id="customerModal" hidden>
    <div class="modal-card invoice-party-modal invoice-professional-modal invoice-scroll-modal">

        <div class="modal-header invoice-modal-titlebar">
            <div>
                <h3>Alıcı Bilgilerini Düzenle</h3>
                <p>Faturadaki alıcı bilgilerini güncelle. Gerekirse ana müşteri kartına da işle.</p>
            </div>

            <button type="button"
                    onclick="closeAllInvoiceModals()"
                    aria-label="Kapat">
                ×
            </button>
        </div>

        <div class="invoice-modal-scroll-body">

            <div class="invoice-edit-type-grid customer-type-switch-modal">
                <button type="button"
                        class="invoice-edit-type-card"
                        data-customer-type="individual"
                        onclick="setInvoiceCustomerType('individual')">
                    <span class="invoice-edit-type-check">✓</span>
                    <span class="invoice-edit-type-icon">♙</span>
                    <strong>Bireysel</strong>
                    <small>TC kimlik bilgili kişi</small>
                </button>

                <button type="button"
                        class="invoice-edit-type-card sole"
                        data-customer-type="sole"
                        onclick="setInvoiceCustomerType('sole')">
                    <span class="invoice-edit-type-check">✓</span>
                    <span class="invoice-edit-type-icon">▣</span>
                    <strong>Şahıs Firması</strong>
                    <small>VKN / vergi dairesi</small>
                </button>

                <button type="button"
                        class="invoice-edit-type-card"
                        data-customer-type="corporate"
                        onclick="setInvoiceCustomerType('corporate')">
                    <span class="invoice-edit-type-check">✓</span>
                    <span class="invoice-edit-type-icon">▤</span>
                    <strong>Kurumsal</strong>
                    <small>Firma resmi ünvanı</small>
                </button>
            </div>

            <div class="invoice-edit-section-title">
                <span>▧</span>
                <h4>Kimlik ve Firma Bilgileri</h4>
            </div>

            <div class="modal-grid invoice-edit-grid">

                <label class="full">
                    <span id="customerTitleInputLabel">Ad Soyad / Ünvan</span>
                    <input type="text"
                           id="customerTitleInput"
                           autocomplete="off" />
                </label>

                <label class="customer-individual-field invoice-half-field">
                    <span>TC Kimlik Numarası</span>
                    <input type="text"
                           id="customerTcknInput"
                           inputmode="numeric"
                           maxlength="11"
                           autocomplete="off" />
                </label>

                <label class="customer-tax-field invoice-half-field">
                    <span>Vergi Kimlik Numarası</span>
                    <input type="text"
                           id="customerTaxNumberInput"
                           inputmode="numeric"
                           maxlength="10"
                           autocomplete="off" />
                </label>

                <label class="customer-tax-field invoice-half-field">
                    <span>Vergi Dairesi İli</span>
                    <select id="customerTaxOfficeCityInput">
                        <option value="">İl seçiniz</option>
                    </select>
                </label>

                <label class="customer-tax-field invoice-half-field">
                    <span>Vergi Dairesi</span>
                    <select id="customerTaxOfficeInput">
                        <option value="">Önce il seçiniz</option>
                    </select>
                </label>

            </div>

            <div class="invoice-edit-section-title with-space">
                <span>☎</span>
                <h4>İletişim ve Adres Bilgileri</h4>
            </div>

            <div class="modal-grid invoice-edit-grid">

                <label>
                    <span>İl</span>
                    <select id="customerAddressCityInput">
                        <option value="">İl seçiniz</option>
                    </select>
                </label>

                <label>
                    <span>İlçe</span>
                    <select id="customerAddressDistrictInput">
                        <option value="">Önce il seçiniz</option>
                    </select>
                </label>

                <label class="full">
                    <span>Açık Adres</span>
                    <textarea id="customerAddressLineInput"
                              rows="4"
                              placeholder="Mahalle, sokak, bina ve kapı no detaylarını giriniz..."></textarea>
                </label>

            </div>

            <label class="invoice-sync-check-card">
                <input type="checkbox" id="updateCustomerCardInput" />

                <span class="invoice-sync-check-box">✓</span>

                <span>
                    <strong>Ana müşteri kartını da güncelle</strong>
                    <small>
                        İşaretlenirse bu bilgiler müşteri kartına da kaydedilir.
                        İşaretlenmezse sadece fatura üzerindeki alıcı bilgisi değişir.
                    </small>
                </span>
            </label>

        </div>

        <div class="modal-actions invoice-edit-actions invoice-sticky-actions">
            <button type="button"
                    class="modal-secondary-btn"
                    onclick="closeAllInvoiceModals()">
                Vazgeç
            </button>

            <button type="button"
                    class="modal-primary-btn"
                    onclick="saveCustomerModal()">
                Kaydet
            </button>
        </div>

    </div>
</div>

<div class="invoice-modal" id="vehicleModal" hidden>
    <div class="modal-card invoice-party-modal invoice-professional-modal invoice-scroll-modal vehicle-edit-modal">

        <div class="modal-header invoice-modal-titlebar">
            <div>
                <h3>Araç Bilgilerini Düzenle</h3>
                <p>Faturadaki araç bilgisini güncelle. Gerekirse ana araç kartına da işle.</p>
            </div>

            <button type="button"
                    onclick="closeAllInvoiceModals()"
                    aria-label="Kapat">
                ×
            </button>
        </div>

        <div class="invoice-modal-scroll-body">

            <div class="invoice-edit-section-title">
                <span>▣</span>
                <h4>Araç Bilgileri</h4>
            </div>

            <div class="modal-grid invoice-edit-grid">

                <label>
                    <span>Plaka</span>
                    <input type="text"
                           id="plateInput"
                           maxlength="12"
                           autocomplete="off" />
                </label>

                <label>
                    <span>Şasi No</span>
                    <input type="text"
                           id="chassisNumberInput"
                           maxlength="17"
                           autocomplete="off" />
                </label>

                <label>
                    <span>Marka</span>
                    <select id="vehicleBrandIdInput">
                        <option value="">Marka seçiniz</option>
                    </select>
                </label>

                <label>
                    <span>Model</span>
                    <select id="vehicleModelIdInput">
                        <option value="">Önce marka seçiniz</option>
                    </select>
                </label>

                <label>
                    <span>Model Yılı</span>
                    <input type="number"
                           id="vehicleModelYearInput"
                           min="1950"
                           max="2100"
                           step="1"
                           placeholder="Örn: 2020" />
                </label>

                <label>
                    <span>Kilometre</span>
                    <input type="number"
                           id="mileageInput"
                           min="0"
                           step="1" />
                </label>

            </div>

            <label class="invoice-sync-check-card">
                <input type="checkbox" id="updateVehicleCardInput" />

                <span class="invoice-sync-check-box">✓</span>

                <span>
                    <strong>Ana araç kartını da güncelle</strong>
                    <small>
                        İşaretlenirse plaka, marka, model, model yılı ve şasi bilgisi araç kartına da kaydedilir.
                        Kilometre fatura / servis bilgisi olarak kalır.
                    </small>
                </span>
            </label>

        </div>

        <div class="modal-actions invoice-edit-actions invoice-sticky-actions">
            <button type="button"
                    class="modal-secondary-btn"
                    onclick="closeAllInvoiceModals()">
                Vazgeç
            </button>

            <button type="button"
                    class="modal-primary-btn"
                    onclick="saveVehicleModal()">
                Kaydet
            </button>
        </div>

    </div>
</div>

<div class="invoice-modal" id="itemModal" hidden>
    <div class="modal-card invoice-item-edit-modal">

        <div class="modal-header invoice-modal-titlebar">
            <div>
                <h3 id="itemModalTitle">Fatura Kalemi</h3>
                <p>Fatura kalemini düzenle veya yeni kalem ekle.</p>
            </div>

            <button type="button"
                    onclick="closeAllInvoiceModals()"
                    aria-label="Kapat">
                ×
            </button>
        </div>

        <input type="hidden" id="itemEditIndex" value="-1" />

        <div class="modal-grid invoice-edit-grid">

            <label>
                <span>Tür</span>
                <select id="itemTypeInput">
                    <option value="1">İşçilik</option>
                    <option value="2">Parça</option>
                    <option value="3">Diğer</option>
                </select>
            </label>

            <label class="full">
                <span id="itemDescriptionLabel">Açıklama</span>

                <div class="invoice-stock-search-box">
                    <input type="text"
                           id="itemDescriptionInput"
                           autocomplete="off" />

                    <input type="hidden" id="itemStockItemIdInput" />

                    <div class="invoice-stock-search-results"
                         id="itemStockSearchResults"></div>
                </div>

                <small class="modal-help" id="itemStockHelp" hidden>
                    Parça seçiliyse stok kartı arayabilir veya serbest açıklama girebilirsiniz.
                </small>
            </label>

            @if (Model.ServiceRecordId.HasValue)
            {
                <label class="full" id="itemServiceRequestField" hidden>
                    <span>Servis Şikayeti / Talep</span>

                    <select id="itemServiceRequestItemIdInput">
                        <option value="">Seçiniz</option>

                        @foreach (var requestItem in Model.ServiceRequestItems)
                        {
                            <option value="@requestItem.Id">
                                @requestItem.Title
                            </option>
                        }
                    </select>

                    <small class="modal-help">
                        Parça ve işçilik kalemleri servis kaydına işlem olarak eklenecek,
                        SKF’de görünecek ve faturaya otomatik yansıyacak.
                    </small>
                </label>
            }

            <label>
                <span>Miktar</span>
                <input type="number"
                       id="itemQuantityInput"
                       min="0"
                       step="0.01" />
            </label>

            <label>
                <span>Birim</span>
                <input type="text"
                       id="itemUnitInput" />
            </label>

            <label>
                <span>Birim Fiyat</span>
                <input type="number"
                       id="itemUnitPriceInput"
                       min="0"
                       step="0.01" />
            </label>

            <label>
                <span>İskonto %</span>
                <input type="number"
                       id="itemDiscountRateInput"
                       min="0"
                       step="0.01" />
            </label>

            <label>
                <span>KDV %</span>
                <input type="number"
                       id="itemVatRateInput"
                       min="0"
                       step="0.01" />
            </label>

        </div>

        <div class="modal-actions between">
            <button type="button"
                    class="modal-danger-btn"
                    id="deleteItemBtn"
                    onclick="deleteCurrentItem()"
                    hidden>
                Kalemi Sil
            </button>

            <div>
                <button type="button"
                        class="modal-secondary-btn"
                        onclick="closeAllInvoiceModals()">
                    Vazgeç
                </button>

                <button type="button"
                        class="modal-primary-btn"
                        onclick="saveItemModal()">
                    Kaydet
                </button>
            </div>
        </div>

    </div>
</div>

<div class="invoice-modal" id="targetTotalModal" hidden>
    <div class="modal-card invoice-target-modal-v2">

        <button type="button"
                class="invoice-target-close"
                onclick="closeAllInvoiceModals()"
                aria-label="Kapat">
            ×
        </button>

        <div class="invoice-target-hero">
            <div class="invoice-target-icon">↘</div>

            <div>
                <h3>Hedef Tutara Uyarla</h3>
                <p>Genel toplamı hedef tutara indirmek için fatura kalemlerine otomatik iskonto uygular.</p>
            </div>
        </div>

        <div class="invoice-target-alert">
            <strong>Servis kaydı değişmez.</strong>
            <span>Sadece bu faturadaki iskonto oranları güncellenir.</span>
        </div>

        <div class="invoice-target-stats">
            <div class="invoice-target-stat">
                <span>İskontosuz Toplam</span>
                <strong id="targetUndiscountedTotalText">0,00 ₺</strong>
            </div>

            <div class="invoice-target-stat">
                <span>Mevcut Toplam</span>
                <strong id="targetCurrentTotalText">0,00 ₺</strong>
            </div>

            <div class="invoice-target-stat discount">
                <span>Uygulanacak İskonto</span>
                <strong id="targetDiscountRateText">-</strong>
            </div>
        </div>

        <label class="invoice-target-input-card">
            <span>Hedef Genel Toplam</span>

            <div class="invoice-target-input-wrap">
                <input id="targetTotalInput"
                       type="number"
                       step="0.01"
                       min="0"
                       placeholder="Örn: 12000"
                       autocomplete="off" />

                <b>₺</b>
            </div>
        </label>

        <div class="invoice-target-result" id="targetTotalHelp">
            Hedef tutarı girince uygulanacak iskonto oranı burada gösterilir.
        </div>

        <div class="invoice-target-actions">
            <button type="button"
                    class="invoice-target-cancel"
                    onclick="closeAllInvoiceModals()">
                Vazgeç
            </button>

            <button type="button"
                    class="invoice-target-apply"
                    onclick="applyTargetTotalToInvoice()">
                Uygula ve Kaydet
            </button>
        </div>

    </div>
</div>