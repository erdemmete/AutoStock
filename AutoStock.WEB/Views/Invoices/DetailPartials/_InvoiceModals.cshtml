@model AutoStock.WEB.Models.Invoices.InvoiceDetailViewModel

<div class="invoice-modal-backdrop" id="invoiceModalBackdrop" hidden></div>

<div class="invoice-modal" id="customerModal" hidden>
    <div class="modal-card invoice-party-modal">

        <div class="modal-header">
            <div>
                <h3>Alıcı Bilgilerini Düzenle</h3>
                <p>Bu değişiklik fatura üzerindeki alıcı bilgilerini günceller.</p>
            </div>

            <button type="button" onclick="closeAllInvoiceModals()">×</button>
        </div>

        <div class="customer-type-switch-modal">
            <button type="button"
                    data-customer-type="individual"
                    onclick="setInvoiceCustomerType('individual')">
                Bireysel
            </button>

            <button type="button"
                    data-customer-type="sole"
                    onclick="setInvoiceCustomerType('sole')">
                Şahıs
            </button>

            <button type="button"
                    data-customer-type="corporate"
                    onclick="setInvoiceCustomerType('corporate')">
                Kurumsal
            </button>
        </div>

        <div class="modal-grid">

            <label class="full">
                <span id="customerTitleInputLabel">Ad Soyad / Ünvan</span>
                <input type="text"
                       id="customerTitleInput"
                       autocomplete="off" />
            </label>

            <label class="customer-individual-field">
                <span>TC Kimlik No</span>
                <input type="text"
                       id="customerTcknInput"
                       inputmode="numeric"
                       maxlength="11"
                       autocomplete="off" />
            </label>

            <label class="customer-tax-field">
                <span>Vergi Dairesi</span>
                <input type="text"
                       id="customerTaxOfficeInput"
                       autocomplete="off" />
            </label>

            <label class="customer-tax-field">
                <span>Vergi No</span>
                <input type="text"
                       id="customerTaxNumberInput"
                       inputmode="numeric"
                       maxlength="10"
                       autocomplete="off" />
            </label>

            <label class="full">
                <span>Adres</span>
                <textarea id="customerAddressInput"
                          rows="3"></textarea>
            </label>

        </div>

        <div class="modal-info-strip">
            Ana müşteri kartı şu an güncellenmez. Bu bilgiler faturanın üzerindeki alıcı bilgisi olarak kaydedilir.
        </div>

        <div class="modal-actions">
            <button type="button"
                    class="modal-secondary-btn"
                    onclick="closeAllInvoiceModals()">
                Vazgeç
            </button>

            <button type="button"
                    class="modal-primary-btn"
                    onclick="saveCustomerModal()">
                Kaydet
            </button>
        </div>

    </div>
</div>

<div class="invoice-modal" id="vehicleModal" hidden>
    <div class="modal-card invoice-party-modal">

        <div class="modal-header">
            <div>
                <h3>Araç Bilgilerini Düzenle</h3>
                <p>Bu değişiklik fatura üzerindeki araç bilgisini günceller.</p>
            </div>

            <button type="button" onclick="closeAllInvoiceModals()">×</button>
        </div>

        <div class="modal-grid">

            <label>
                <span>Plaka</span>
                <input type="text"
                       id="plateInput"
                       maxlength="12"
                       autocomplete="off" />
            </label>

            <label>
                <span>Şasi No</span>
                <input type="text"
                       id="chassisNumberInput"
                       maxlength="17"
                       autocomplete="off" />
            </label>

            <label>
                <span>Kilometre</span>
                <input type="number"
                       id="mileageInput"
                       min="0"
                       step="1" />
            </label>

        </div>

        <div class="modal-info-strip">
            Ana araç kartı şu an güncellenmez. Bu bilgiler faturanın üzerindeki araç bilgisi olarak kaydedilir.
        </div>

        <div class="modal-actions">
            <button type="button"
                    class="modal-secondary-btn"
                    onclick="closeAllInvoiceModals()">
                Vazgeç
            </button>

            <button type="button"
                    class="modal-primary-btn"
                    onclick="saveVehicleModal()">
                Kaydet
            </button>
        </div>

    </div>
</div>

<div class="invoice-modal" id="itemModal" hidden>
    <div class="modal-card">
        <div class="modal-header">
            <h3 id="itemModalTitle">Fatura Kalemi</h3>
            <button type="button" onclick="closeAllInvoiceModals()">×</button>
        </div>

        <input type="hidden" id="itemEditIndex" value="-1" />

        <div class="modal-grid">

            <label>
                <span>Tür</span>
                <select id="itemTypeInput">
                    <option value="1">İşçilik</option>
                    <option value="2">Parça</option>
                    <option value="3">Diğer</option>
                </select>
            </label>

            <label class="full">
                <span id="itemDescriptionLabel">Açıklama</span>

                <div class="invoice-stock-search-box">
                    <input type="text"
                           id="itemDescriptionInput"
                           autocomplete="off" />

                    <input type="hidden" id="itemStockItemIdInput" />

                    <div class="invoice-stock-search-results" id="itemStockSearchResults"></div>
                </div>

                <small class="modal-help" id="itemStockHelp" hidden>
                    Parça seçiliyse stok kartı arayabilir veya serbest açıklama girebilirsiniz.
                </small>
            </label>

            @if (Model.ServiceRecordId.HasValue)
            {
                <label class="full" id="itemServiceRequestField" hidden>
                    <span>Servis Şikayeti / Talep</span>

                    <select id="itemServiceRequestItemIdInput">
                        <option value="">Seçiniz</option>

                        @foreach (var requestItem in Model.ServiceRequestItems)
                        {
                            <option value="@requestItem.Id">
                                @requestItem.Title
                            </option>
                        }
                    </select>

                    <small class="modal-help">
                        Parça ve işçilik kalemleri servis kaydına işlem olarak eklenecek, SKF’de görünecek ve faturaya otomatik yansıyacak.
                    </small>
                </label>
            }

            <label>
                <span>Miktar</span>
                <input type="number" id="itemQuantityInput" min="0" step="0.01" />
            </label>

            <label>
                <span>Birim</span>
                <input type="text" id="itemUnitInput" />
            </label>

            <label>
                <span>Birim Fiyat</span>
                <input type="number" id="itemUnitPriceInput" min="0" step="0.01" />
            </label>

            <label>
                <span>İskonto %</span>
                <input type="number" id="itemDiscountRateInput" min="0" step="0.01" />
            </label>

            <label>
                <span>KDV %</span>
                <input type="number" id="itemVatRateInput" min="0" step="0.01" />
            </label>

        </div>

        <div class="modal-actions between">
            <button type="button"
                    class="modal-danger-btn"
                    id="deleteItemBtn"
                    onclick="deleteCurrentItem()"
                    hidden>
                Kalemi Sil
            </button>

            <div>
                <button type="button"
                        class="modal-secondary-btn"
                        onclick="closeAllInvoiceModals()">
                    Vazgeç
                </button>

                <button type="button"
                        class="modal-primary-btn"
                        onclick="saveItemModal()">
                    Kaydet
                </button>
            </div>
        </div>
    </div>
</div>
