@model AutoStock.WEB.Models.Invoices.InvoiceDetailViewModel
@using AutoStock.WEB.Models.Shared

<section class="info-section">

    <article class="info-box editable-box"
             data-editable="@(Model.Status == 1 ? "true" : "false")"
             onclick="openCustomerModal()">

        <div class="box-header">
            <div class="box-title">♙ ALICI BİLGİLERİ</div>

            @if (Model.Status == 1)
            {
                <button type="button"
                        class="edit-pill"
                        onclick="event.stopPropagation(); openCustomerModal();">
                    Düzenle
                </button>
            }
        </div>

        <h3 id="customerTitleView">@Model.CustomerTitle</h3>

        <div class="info-lines">
            <p id="customerTcknLine">
                <span>#</span>
                TC:
                <strong id="customerTcknView">@(Model.CustomerTckn ?? "-")</strong>
            </p>

            <p id="customerTaxNumberLine">
                <span>#</span>
                Vergi No:
                <strong id="customerTaxNumberView">@(Model.CustomerTaxNumber ?? "-")</strong>
            </p>

            <p id="customerTaxOfficeLine">
                <span>◎</span>
                Vergi Dairesi:
                <strong id="customerTaxOfficeView">@(Model.CustomerTaxOffice ?? "-")</strong>
            </p>

            <p>
                <span>@@</span>
                E-posta:
                <strong id="customerEmailView">@(Model.CustomerEmail ?? "-")</strong>
            </p>

            <p class="invoice-phone-line">
                <span>☎</span>
                Telefon:
                <strong id="customerPhoneView">@(string.IsNullOrWhiteSpace(Model.CustomerPhone) ? "-" : Model.CustomerPhone)</strong>
            </p>

            @if (!string.IsNullOrWhiteSpace(Model.CustomerPhone))
            {
                <div class="invoice-contact-actions-row">
                    @await Html.PartialAsync("_ContactActions", new ContactActionsViewModel
                    {
                        PhoneNumber = Model.CustomerPhone,
                        CustomerName = Model.CustomerTitle,
                        Plate = Model.Plate,
                        ServiceStatus = Model.Status == 2 ? "Completed" : Model.Status.ToString(),
                        Variant = "compact"
                    })
                </div>
            }

            <p>
                <span>⌖</span>
                <strong id="customerAddressView">@(Model.CustomerAddress ?? "-")</strong>
            </p>
        </div>

    </article>

    <article class="info-box editable-box"
             data-editable="@(Model.Status == 1 ? "true" : "false")"
             onclick="openVehicleModal()">

        <div class="box-header">
            <div class="box-title">▣ ARAÇ BİLGİLERİ</div>

            @if (Model.Status == 1)
            {
                <button type="button"
                        class="edit-pill"
                        onclick="event.stopPropagation(); openVehicleModal();">
                    Düzenle
                </button>
            }
        </div>

        <h3 id="plateView">@(Model.Plate ?? "-")</h3>

        <div class="vehicle-subtitle-line" id="vehicleBrandModelView">
            @{
                var vehicleName = string.Join(" ", new[]
                {
                    Model.VehicleBrandName,
                    Model.VehicleModelName,
                    Model.VehicleModelYear?.ToString()
                }.Where(x => !string.IsNullOrWhiteSpace(x)));
            }
            @(string.IsNullOrWhiteSpace(vehicleName) ? "Marka / model belirtilmemiş" : vehicleName)
        </div>

        <div class="vehicle-grid vehicle-grid-extended">
            <div>
                <label>Marka</label>
                <strong id="vehicleBrandNameView">@(Model.VehicleBrandName ?? "-")</strong>
            </div>

            <div>
                <label>Model</label>
                <strong id="vehicleModelNameView">@(Model.VehicleModelName ?? "-")</strong>
            </div>

            <div>
                <label>Model Yılı</label>
                <strong id="vehicleModelYearView">@(Model.VehicleModelYear?.ToString() ?? "-")</strong>
            </div>

            <div>
                <label>Kilometre</label>
                <strong id="mileageView">@((Model.Mileage ?? 0).ToString("N0")) km</strong>
            </div>

            <div class="full">
                <label>Şasi Numarası</label>
                <strong id="chassisNumberView">@(Model.ChassisNumber ?? "-")</strong>
            </div>
        </div>

    </article>

</section>
