<script>
    document.addEventListener("DOMContentLoaded", function () {
        const drawer = document.getElementById("invoiceActionDrawer");
        const drawerOpen = document.querySelector("[data-invoice-action-drawer-open]");
        const drawerCloseButtons = document.querySelectorAll("[data-invoice-action-drawer-close]");

        function openDrawer() {
            if (drawer) drawer.hidden = false;
        }

        function closeDrawer() {
            if (drawer) drawer.hidden = true;
        }

        drawerOpen?.addEventListener("click", openDrawer);
        drawerCloseButtons.forEach(btn => btn.addEventListener("click", closeDrawer));
        drawer?.addEventListener("click", function (event) {
            if (event.target === drawer) closeDrawer();
        });

        document.addEventListener("keydown", function (event) {
            if (event.key === "Escape") {
                closeDrawer();
                const accountingModal = document.querySelector("[data-accounting-modal]");
                if (accountingModal) accountingModal.hidden = true;
                const paymentModal = document.getElementById("invoiceCurrentPaymentModal");
                if (paymentModal) paymentModal.hidden = true;
            }
        });
    });
</script>

@if (isIssued && canReceivePayment)
{
    <script>
        (function () {
            const modal = document.getElementById("invoiceCurrentPaymentModal");
            const form = document.getElementById("invoiceCurrentPaymentForm");
            const amountInput = document.getElementById("invoiceCurrentPaymentAmount");
            const dateInput = document.getElementById("invoiceCurrentPaymentDate");
            const methodInput = document.getElementById("invoiceCurrentPaymentMethod");
            const descriptionInput = document.getElementById("invoiceCurrentPaymentDescription");
            const errorBox = document.getElementById("invoiceCurrentPaymentError");

            if (!modal || !form) return;

            function openModal(button) {
                amountInput.value = button?.dataset?.amount || "";
                window.SenteMoney?.formatInput(amountInput);
                dateInput.value = "";
                methodInput.value = "Nakit";
                descriptionInput.value = button?.dataset?.description || "";
                errorBox.hidden = true;
                errorBox.textContent = "";
                modal.hidden = false;
                setTimeout(function () { amountInput.focus(); }, 50);
            }

            function closeModal() {
                modal.hidden = true;
            }

            document.querySelectorAll("[data-invoice-payment-open]").forEach(function (button) {
                button.addEventListener("click", function () { openModal(button); });
            });

            document.querySelectorAll("[data-invoice-payment-close]").forEach(function (button) {
                button.addEventListener("click", closeModal);
            });

            modal.addEventListener("click", function (event) {
                if (event.target === modal) closeModal();
            });

            form.addEventListener("submit", async function (event) {
                event.preventDefault();

                const amount = window.SenteMoney
                    ? SenteMoney.parse(amountInput.value)
                    : Number(amountInput.value);

                if (!amount || amount <= 0) {
                    errorBox.textContent = "Geçerli bir tahsilat tutarı giriniz.";
                    errorBox.hidden = false;
                    return;
                }

                try {
                    const response = await fetch("/CurrentAccounts/CreatePayment", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            customerId: @Model.CustomerId,
                            invoiceId: @Model.Id,
                            amount: amount,
                            paymentDate: dateInput.value || null,
                            paymentMethod: methodInput.value || null,
                            description: descriptionInput.value || null
                        })
                    });

                    const result = await response.json().catch(function () { return null; });

                    if (!response.ok || !result || result.isFailure || result.isSuccess === false) {
                        const message = result?.errorMessage
                            || (Array.isArray(result?.errorMessages) ? result.errorMessages.join("\n") : null)
                            || "Tahsilat kaydedilemedi.";

                        errorBox.textContent = message;
                        errorBox.hidden = false;
                        return;
                    }

                    window.location.reload();
                } catch {
                    errorBox.textContent = "Tahsilat kaydedilirken beklenmeyen bir hata oluştu.";
                    errorBox.hidden = false;
                }
            });
        })();
    </script>
}

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const card = document.querySelector("[data-accounting-card]");
        if (!card) return;

        const invoiceId = parseInt(card.dataset.invoiceId || "0", 10);
        const statusBoxes = Array.from(document.querySelectorAll("[data-accounting-status]"));
        const modal = document.querySelector("[data-accounting-modal]");
        const openBtns = document.querySelectorAll("[data-accounting-open]");
        const closeBtns = document.querySelectorAll("[data-accounting-close]");
        const sendBtn = document.querySelector("[data-accounting-send]");
        const recipientList = document.querySelector("[data-accounting-recipient-list]");
        const errorBox = document.querySelector("[data-accounting-error]");
        const successBox = document.querySelector("[data-accounting-success]");

        const showError = message => {
            if (!errorBox) return;
            errorBox.textContent = message || "İşlem başarısız.";
            errorBox.hidden = false;
            if (successBox) successBox.hidden = true;
        };

        const showSuccess = message => {
            if (!successBox) return;
            successBox.textContent = message || "İşlem başarılı.";
            successBox.hidden = false;
            if (errorBox) errorBox.hidden = true;
        };

        const readError = async response => {
            try {
                const json = await response.json();
                return json?.errorMessage || json?.ErrorMessage || (json?.errorMessages || json?.ErrorMessages || [])[0] || "İşlem başarısız.";
            } catch {
                return "İşlem başarısız.";
            }
        };

        const setStatusHtml = html => {
            statusBoxes.forEach(box => box.innerHTML = html);
        };

        const loadStatus = async () => {
            if (!invoiceId) return;

            try {
                const response = await fetch(`/AccountingInvoiceRequests/Invoice/${invoiceId}/Status`);
                if (!response.ok) throw new Error(await readError(response));
                const data = await response.json();
                renderStatus(data);
            } catch (err) {
                setStatusHtml(`<strong>Fatura bilgisi alınamadı</strong><span>${err.message || "Tekrar deneyiniz."}</span>`);
            }
        };

        const renderStatus = data => {
            const doc = data?.latestOfficialInvoice || data?.LatestOfficialInvoice;
            const statusText = data?.statusText || data?.StatusText || "Fatura bekleniyor";
            const lastSentAt = data?.lastSentAt || data?.LastSentAt;
            const lastSentToEmail = data?.lastSentToEmail || data?.LastSentToEmail;

            let subText = "Muhasebeciden fatura PDF’i bekleniyor.";
            let action = "";
            let compact = `<span>Fatura</span><strong>${statusText}</strong>`;

            if (doc) {
                const number = doc.officialInvoiceNumber || doc.OfficialInvoiceNumber || "-";
                const docId = doc.id || doc.Id;
                subText = `Fatura yüklendi: ${number}`;
                action = `<a class="invoice-action-download" href="/AccountingInvoiceRequests/OfficialDocument/${docId}/Download">PDF İndir</a>`;
                compact = `<span>Fatura</span><strong>Yüklendi</strong><small>${number}</small>`;
            } else if (lastSentAt) {
                subText = `Son gönderim: ${new Date(lastSentAt).toLocaleString("tr-TR")} / ${lastSentToEmail || "-"}`;
                compact = `<span>Fatura</span><strong>Bekleniyor</strong><small>Muhasebeciye gönderildi</small>`;
            }

            statusBoxes.forEach(box => {
                if (box.classList.contains("invoice-action-chip")) {
                    box.classList.toggle("uploaded", !!doc);
                    box.innerHTML = compact;
                    return;
                }

                box.classList.toggle("uploaded", !!doc);
                box.innerHTML = `
                    <strong>${statusText}</strong>
                    <span>${subText}</span>
                    ${action ? `<div style="margin-top:10px;">${action}</div>` : ""}`;
            });
        };

        const loadRecipients = async () => {
            if (!recipientList) return;
            recipientList.innerHTML = `<span class="inv-accounting-muted">Adresler yükleniyor...</span>`;

            try {
                const response = await fetch("/AccountingInvoiceRequests/Recipients");
                if (!response.ok) throw new Error(await readError(response));
                const recipients = await response.json();

                if (!recipients || recipients.length === 0) {
                    recipientList.innerHTML = `<span class="inv-accounting-muted">Kayıtlı muhasebe adresi yok. Yeni e-posta alanından ekleyebilirsiniz.</span>`;
                    return;
                }

                recipientList.innerHTML = recipients.map(x => `
                    <label class="inv-accounting-recipient">
                        <input type="checkbox" value="${x.email || x.Email}" ${x.isDefault || x.IsDefault ? "checked" : ""} />
                        <span>
                            <strong>${x.displayName || x.DisplayName}</strong>
                            <span>${x.email || x.Email}</span>
                        </span>
                    </label>`).join("");
            } catch (err) {
                recipientList.innerHTML = `<span class="inv-accounting-muted">Adresler alınamadı: ${err.message || "Hata"}</span>`;
            }
        };

        openBtns.forEach(btn => {
            btn.addEventListener("click", function () {
                if (!modal || btn.disabled) return;
                modal.hidden = false;
                if (errorBox) errorBox.hidden = true;
                if (successBox) successBox.hidden = true;
                loadRecipients();
            });
        });

        closeBtns.forEach(btn => btn.addEventListener("click", () => {
            if (modal) modal.hidden = true;
        }));

        modal?.addEventListener("click", function (event) {
            if (event.target === modal) modal.hidden = true;
        });

        sendBtn?.addEventListener("click", async function () {
            const selectedEmails = Array.from(document.querySelectorAll("[data-accounting-recipient-list] input[type='checkbox']:checked"))
                .map(x => x.value)
                .filter(Boolean);

            const newEmail = document.querySelector("[data-accounting-new-email]")?.value || "";
            const newName = document.querySelector("[data-accounting-new-name]")?.value || "";
            const saveNew = document.querySelector("[data-accounting-save-new]")?.checked || false;
            const message = document.querySelector("[data-accounting-message]")?.value || "";

            if (selectedEmails.length === 0 && !newEmail.trim()) {
                showError("En az bir muhasebeci e-posta adresi seçiniz veya yeni adres yazınız.");
                return;
            }

            sendBtn.disabled = true;
            sendBtn.textContent = "Gönderiliyor...";

            try {
                const response = await fetch("/AccountingInvoiceRequests/Send", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        invoiceId,
                        recipientEmails: selectedEmails,
                        newRecipientEmail: newEmail,
                        newRecipientDisplayName: newName,
                        saveNewRecipient: saveNew,
                        message
                    })
                });

                if (!response.ok) throw new Error(await readError(response));

                showSuccess("Fatura hazırlık talebi muhasebeciye gönderildi.");
                await loadStatus();

                setTimeout(() => {
                    if (modal) modal.hidden = true;
                }, 900);
            } catch (err) {
                showError(err.message || "Gönderim başarısız.");
            } finally {
                sendBtn.disabled = false;
                sendBtn.textContent = "Gönder";
            }
        });

        loadStatus();
    });
</script>
