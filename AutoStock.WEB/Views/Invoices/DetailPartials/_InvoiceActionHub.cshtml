@model AutoStock.WEB.Models.Invoices.InvoiceDetailViewModel
@using System.Globalization

@{
    var isDraft = Model.Status == 1;
    var isIssued = Model.Status == 2;
    var isCancelled = Model.Status == 3;
    var canReceivePayment = true; // API tarafında Owner kontrolü var. Razor User.IsInRole Session token yapısında güvenilir değil.

    var paidTotal = Model.InvoicePaidTotal < 0 ? 0 : Model.InvoicePaidTotal;
    var remainingAmount = Model.InvoiceRemainingAmount < 0 ? 0 : Model.InvoiceRemainingAmount;

    string Money(decimal value) => SenteMoney.Format(value);

    string BalanceText(decimal balance)
    {
        if (balance > 0) return "Servisin alacağı";
        if (balance < 0) return "Müşteri alacaklı";
        return "Bakiye kapalı";
    }

    string BalanceClass(decimal balance)
    {
        if (balance > 0) return "positive";
        if (balance < 0) return "negative";
        return "zero";
    }

    var paymentDescription = $"{Model.InvoiceNumber} kalan tahsilatı";
}

<section class="invoice-action-hub" data-accounting-card data-invoice-id="@Model.Id" data-invoice-status="@Model.Status">
    <div class="invoice-action-hub-main">
        <div class="invoice-action-hub-title">
            <span>Hızlı İşlemler</span>
            <h3>Belge akışı ve tahsilat</h3>
        </div>

        <div class="invoice-action-hub-summary" aria-label="Hesap özeti kısa özet">
            <article class="invoice-action-chip">
                <span>Kalan</span>
                <strong>@Money(remainingAmount)</strong>
            </article>

            <article class="invoice-action-chip @BalanceClass(Model.CustomerBalance)">
                <span>Hesap</span>
                <strong>@Money(Model.CustomerBalance)</strong>
                <small>@BalanceText(Model.CustomerBalance)</small>
            </article>

            <article class="invoice-action-chip accounting" data-accounting-status>
                <span>Fatura</span>
                <strong>Kontrol ediliyor</strong>
            </article>
        </div>

        <div class="invoice-action-hub-buttons">
            @if (Model.Status != 3)
            {
                <form asp-controller="Invoices"
                      asp-action="SendEmail"
                      asp-route-id="@Model.Id"
                      method="post"
                      class="invoice-action-email-form"
                      data-sente-confirm
                      data-sente-confirm-title="Hesap özetini e-posta ile gönder"
                      data-sente-confirm-message="Hesap özetini e-posta olarak göndermek istiyor musun?"
                      data-sente-confirm-text="Gönder"
                      data-sente-confirm-cancel-text="Vazgeç">
                    @Html.AntiForgeryToken()

                    <button type="submit" class="invoice-action-primary">
                        <span>✉</span>
                        E-posta Gönder
                    </button>
                </form>
            }

            <button type="button" class="invoice-action-secondary" data-invoice-action-drawer-open>
                İşlemler
            </button>
        </div>
    </div>
</section>

<div class="invoice-action-drawer-backdrop" id="invoiceActionDrawer" hidden>
    <div class="invoice-action-drawer" role="dialog" aria-modal="true" aria-labelledby="invoiceActionDrawerTitle">
        <div class="invoice-action-drawer-head">
            <div>
                <span>Belge İşlemleri</span>
                <h3 id="invoiceActionDrawerTitle">Hesap Özeti Yönetimi</h3>
                <p>@Model.CustomerTitle / @Model.InvoiceNumber</p>
            </div>

            <button type="button" class="invoice-action-drawer-close" data-invoice-action-drawer-close aria-label="Kapat">
                ×
            </button>
        </div>

        <div class="invoice-action-drawer-body">
            <section class="invoice-action-group">
                <div class="invoice-action-group-head">
                    <span>Hesap Özeti / Tahsilat</span>
                    <strong>Ödeme ve ekstre</strong>
                </div>

                <div class="invoice-action-grid">
                    <a class="invoice-action-tile"
                       asp-controller="CurrentAccounts"
                       asp-action="Customer"
                       asp-route-customerId="@Model.CustomerId">
                        <span>₺</span>
                        <strong>Hesap Özeti</strong>
                        <small>@BalanceText(Model.CustomerBalance): @Money(Model.CustomerBalance)</small>
                    </a>

                    @if (isIssued && remainingAmount > 0 && canReceivePayment)
                    {
                        <button type="button"
                                class="invoice-action-tile button"
                                data-invoice-payment-open
                                data-amount=""
                                data-description="@Model.InvoiceNumber kısmi tahsilatı">
                            <span>＋</span>
                            <strong>Kısmi Tahsilat</strong>
                            <small>Manuel tutar gir</small>
                        </button>

                        <button type="button"
                                class="invoice-action-tile button green"
                                data-invoice-payment-open
                                data-amount="@remainingAmount.ToString(CultureInfo.InvariantCulture)"
                                data-description="@paymentDescription">
                            <span>✓</span>
                            <strong>Tamamını Tahsil Et</strong>
                            <small>@Money(remainingAmount)</small>
                        </button>
                    }
                    else if (isIssued && remainingAmount <= 0)
                    {
                        <div class="invoice-action-info success">
                            Bu hesap özetinde kalan tahsilat bulunmuyor.
                        </div>
                    }
                    else if (isCancelled)
                    {
                        <div class="invoice-action-info muted">
                            İptal edilen belgede tahsilat alınmaz.
                        </div>
                    }
                    else
                    {
                        <div class="invoice-action-info muted">
                            Tahsilat için hesap özeti onaylanmış olmalıdır.
                        </div>
                    }
                </div>
            </section>

            <section class="invoice-action-group">
                <div class="invoice-action-group-head">
                    <span>Muhasebe</span>
                    <strong>Fatura hazırlık akışı</strong>
                </div>

                <div class="invoice-action-accounting-row">
                    <div class="invoice-action-accounting-status" data-accounting-status>
                        <strong>Fatura bekleniyor</strong>
                        <span>Lütfen bekleyin.</span>
                    </div>

                    <button type="button"
                            class="invoice-action-accounting-send"
                            data-accounting-open
                            @(isIssued ? null : "disabled")>
                        Muhasebeciye Gönder
                    </button>
                </div>
            </section>
        </div>
    </div>
</div>

@if (isIssued && canReceivePayment)
{
    <div class="invoice-current-modal-backdrop" id="invoiceCurrentPaymentModal" hidden>
        <div class="invoice-current-modal" role="dialog" aria-modal="true" aria-labelledby="invoiceCurrentPaymentTitle">
            <div class="invoice-current-modal-head">
                <div>
                    <span>Tahsilat</span>
                    <h3 id="invoiceCurrentPaymentTitle">Tahsilat Ekle</h3>
                    <p>@Model.CustomerTitle / @Model.InvoiceNumber</p>
                </div>

                <button type="button"
                        class="invoice-current-modal-close"
                        data-invoice-payment-close
                        aria-label="Kapat">
                    ×
                </button>
            </div>

            <form id="invoiceCurrentPaymentForm">
                <div class="invoice-current-form-grid">
                    <label>
                        <span>Tutar</span>
                        <input type="text"
                               min="0.01"
                               max="@remainingAmount.ToString(CultureInfo.InvariantCulture)"
                               step="0.01"
                               id="invoiceCurrentPaymentAmount"
                               inputmode="decimal"
                               data-sente-money-input
                               required />
                    </label>

                    <label>
                        <span>Tarih</span>
                        <input type="datetime-local" id="invoiceCurrentPaymentDate" />
                    </label>

                    <label>
                        <span>Ödeme Yöntemi</span>
                        <select id="invoiceCurrentPaymentMethod">
                            <option value="Nakit">Nakit</option>
                            <option value="Kredi Kartı">Kredi Kartı</option>
                            <option value="Havale/EFT">Havale/EFT</option>
                            <option value="Diğer">Diğer</option>
                        </select>
                    </label>

                    <label class="full">
                        <span>Açıklama</span>
                        <textarea id="invoiceCurrentPaymentDescription"
                                  rows="3"
                                  maxlength="500"></textarea>
                    </label>
                </div>

                <div class="invoice-current-error" id="invoiceCurrentPaymentError" hidden></div>

                <div class="invoice-current-modal-actions">
                    <button type="button"
                            class="invoice-current-btn soft"
                            data-invoice-payment-close>
                        Vazgeç
                    </button>

                    <button type="submit" class="invoice-current-btn primary">
                        Tahsilat Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
}

<div class="inv-accounting-modal-backdrop" data-accounting-modal hidden>
    <div class="inv-accounting-modal">
        <div class="inv-accounting-modal-head">
            <div>
                <span class="inv-accounting-kicker">FATURA HAZIRLIK</span>
                <h3>Muhasebeciye Gönder</h3>
            </div>
            <button type="button" class="inv-accounting-close" data-accounting-close>×</button>
        </div>

        <div class="inv-accounting-modal-body">
            <div class="inv-accounting-error" data-accounting-error hidden></div>
            <div class="inv-accounting-success" data-accounting-success hidden></div>

            <div class="inv-accounting-section">
                <label>Kayıtlı muhasebe adresleri</label>
                <div class="inv-accounting-recipient-list" data-accounting-recipient-list>
                    <span class="inv-accounting-muted">Adresler yükleniyor...</span>
                </div>
            </div>

            <div class="inv-accounting-section two-col">
                <div>
                    <label>Yeni e-posta</label>
                    <input type="email" data-accounting-new-email placeholder="muhasebe@firma.com" />
                </div>
                <div>
                    <label>Kayıt adı</label>
                    <input type="text" data-accounting-new-name placeholder="Muhasebe" />
                </div>
            </div>

            <label class="inv-accounting-checkline">
                <input type="checkbox" data-accounting-save-new />
                <span>Yeni adresi kayıtlı muhasebe adreslerine ekle</span>
            </label>

            <div class="inv-accounting-section">
                <label>Mesaj</label>
                <textarea data-accounting-message placeholder="Muhasebeciye iletilecek kısa not..."></textarea>
            </div>
        </div>

        <div class="inv-accounting-modal-actions">
            <button type="button" class="inv-accounting-cancel" data-accounting-close>Vazgeç</button>
            <button type="button" class="inv-accounting-confirm" data-accounting-send>Gönder</button>
        </div>
    </div>
</div>

<style>
    .invoice-action-hub {
        margin-top: 20px;
        border-radius: 24px;
        border: 1px solid #dbe3ef;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        box-shadow: 0 14px 34px rgba(15, 23, 42, .06);
        overflow: hidden;
    }

    .invoice-action-hub-main {
        padding: 18px;
        display: grid;
        grid-template-columns: minmax(190px, .65fr) minmax(0, 1.35fr) auto;
        gap: 14px;
        align-items: center;
    }

    .invoice-action-hub-title span,
    .invoice-action-group-head span,
    .inv-accounting-kicker {
        display: inline-flex;
        color: #4f46e5;
        font-size: 11px;
        font-weight: 950;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .invoice-action-hub-title h3 {
        margin: 5px 0 0;
        color: #0f172a;
        font-size: 20px;
        font-weight: 950;
        letter-spacing: -.45px;
    }

    .invoice-action-hub-summary {
        min-width: 0;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
    }

    .invoice-action-chip {
        min-width: 0;
        padding: 12px 13px;
        border-radius: 17px;
        background: #ffffff;
        border: 1px solid #e2e8f0;
    }

    .invoice-action-chip.positive { background: #f0fdf4; border-color: #bbf7d0; }
    .invoice-action-chip.negative { background: #fff1f2; border-color: #fecdd3; }
    .invoice-action-chip.accounting.uploaded { background: #eef2ff; border-color: #c7d2fe; }

    .invoice-action-chip span {
        display: block;
        margin-bottom: 4px;
        color: #64748b;
        font-size: 11px;
        font-weight: 950;
    }

    .invoice-action-chip strong {
        display: block;
        color: #0f172a;
        font-size: 15px;
        font-weight: 950;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .invoice-action-chip small {
        display: block;
        margin-top: 3px;
        color: #64748b;
        font-size: 11px;
        font-weight: 800;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .invoice-action-hub-buttons {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 9px;
    }

    .invoice-action-email-form { margin: 0; }

    .invoice-action-primary,
    .invoice-action-secondary,
    .invoice-action-accounting-send,
    .invoice-current-btn {
        min-height: 44px;
        padding: 0 16px;
        border-radius: 15px;
        border: none;
        font-size: 13px;
        font-weight: 950;
        cursor: pointer;
        white-space: nowrap;
    }

    .invoice-action-primary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        background: linear-gradient(135deg, #4f46e5, #2563eb);
        color: #ffffff;
        box-shadow: 0 14px 28px rgba(79, 70, 229, .20);
    }

    .invoice-action-primary span {
        width: 26px;
        height: 26px;
        border-radius: 999px;
        display: grid;
        place-items: center;
        background: rgba(255,255,255,.18);
    }

    .invoice-action-secondary {
        background: #ffffff;
        color: #0f172a;
        border: 1px solid #d8e2ef;
    }

    .invoice-action-drawer-backdrop,
    .invoice-current-modal-backdrop,
    .inv-accounting-modal-backdrop {
        position: fixed;
        inset: 0;
        z-index: 9999;
        padding: 18px;
        background: rgba(15, 23, 42, .58);
        backdrop-filter: blur(5px);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .invoice-action-drawer {
        width: min(840px, 100%);
        max-height: calc(100vh - 36px);
        overflow: auto;
        border-radius: 28px;
        background: #ffffff;
        box-shadow: 0 32px 90px rgba(15, 23, 42, .35);
    }

    .invoice-action-drawer-head,
    .invoice-current-modal-head,
    .inv-accounting-modal-head {
        padding: 22px;
        display: flex;
        justify-content: space-between;
        gap: 14px;
        border-bottom: 1px solid #e5edf7;
    }

    .invoice-action-drawer-head span,
    .invoice-current-modal-head span {
        color: #4f46e5;
        font-size: 12px;
        font-weight: 950;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .invoice-action-drawer-head h3,
    .invoice-current-modal-head h3,
    .inv-accounting-modal h3 {
        margin: 5px 0;
        color: #0f172a;
        font-size: 23px;
        font-weight: 950;
        letter-spacing: -.5px;
    }

    .invoice-action-drawer-head p,
    .invoice-current-modal-head p {
        margin: 0;
        color: #64748b;
        font-size: 14px;
        font-weight: 800;
    }

    .invoice-action-drawer-close,
    .invoice-current-modal-close,
    .inv-accounting-close {
        width: 40px;
        height: 40px;
        flex: 0 0 40px;
        border-radius: 14px;
        border: 1px solid #d8e2ef;
        background: #f8fafc;
        color: #0f172a;
        font-size: 26px;
        line-height: 1;
        cursor: pointer;
    }

    .invoice-action-drawer-body {
        padding: 18px 22px 22px;
        display: grid;
        gap: 16px;
    }

    .invoice-action-group {
        padding: 16px;
        border-radius: 22px;
        border: 1px solid #e2e8f0;
        background: #ffffff;
    }

    .invoice-action-group-head {
        margin-bottom: 12px;
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
    }

    .invoice-action-group-head strong {
        color: #0f172a;
        font-size: 15px;
        font-weight: 950;
    }

    .invoice-action-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
    }

    .invoice-action-tile {
        min-width: 0;
        min-height: 92px;
        padding: 14px;
        border-radius: 18px;
        border: 1px solid #dbe3ef;
        background: #f8fafc;
        color: #0f172a;
        text-decoration: none;
        text-align: left;
        display: grid;
        align-content: start;
        gap: 5px;
        font: inherit;
        cursor: pointer;
    }

    .invoice-action-tile span {
        width: 30px;
        height: 30px;
        border-radius: 12px;
        display: grid;
        place-items: center;
        background: #eef2ff;
        color: #4f46e5;
        font-weight: 950;
    }

    .invoice-action-tile strong {
        color: #0f172a;
        font-size: 14px;
        font-weight: 950;
    }

    .invoice-action-tile small {
        color: #64748b;
        font-size: 12px;
        font-weight: 800;
        line-height: 1.35;
    }

    .invoice-action-tile.green span {
        background: #dcfce7;
        color: #047857;
    }

    .invoice-action-info {
        grid-column: 1 / -1;
        padding: 13px 14px;
        border-radius: 16px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        color: #64748b;
        font-size: 13px;
        font-weight: 850;
    }

    .invoice-action-info.success {
        background: #f0fdf4;
        border-color: #bbf7d0;
        color: #166534;
    }

    .invoice-action-accounting-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 12px;
        align-items: center;
    }

    .invoice-action-accounting-status {
        min-width: 0;
        padding: 14px;
        border-radius: 18px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
    }

    .invoice-action-accounting-status strong {
        display: block;
        color: #0f172a;
        font-size: 14px;
        font-weight: 950;
    }

    .invoice-action-accounting-status span {
        display: block;
        margin-top: 4px;
        color: #64748b;
        font-size: 12px;
        font-weight: 800;
    }

    .invoice-action-accounting-status.uploaded {
        background: #eef2ff;
        border-color: #c7d2fe;
    }

    .invoice-action-accounting-send {
        background: #4f46e5;
        color: white;
    }

    .invoice-action-accounting-send:disabled {
        opacity: .45;
        cursor: not-allowed;
    }

    .invoice-action-download {
        height: 36px;
        padding: 0 13px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #0f172a;
        color: white;
        text-decoration: none;
        font-size: 12px;
        font-weight: 950;
        white-space: nowrap;
    }

    .invoice-current-modal,
    .inv-accounting-modal {
        width: min(620px, 100%);
        max-height: calc(100vh - 36px);
        overflow: auto;
        border-radius: 26px;
        background: #ffffff;
        box-shadow: 0 32px 90px rgba(15, 23, 42, .35);
    }

    .invoice-current-form-grid,
    .inv-accounting-modal-body {
        padding: 22px;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .invoice-current-form-grid label,
    .inv-accounting-section label,
    .inv-accounting-section > label {
        display: grid;
        gap: 7px;
        color: #334155;
        font-size: 13px;
        font-weight: 950;
    }

    .invoice-current-form-grid label.full,
    .inv-accounting-section,
    .inv-accounting-checkline,
    .inv-accounting-error,
    .inv-accounting-success {
        grid-column: 1 / -1;
    }

    .invoice-current-form-grid input,
    .invoice-current-form-grid select,
    .invoice-current-form-grid textarea,
    .inv-accounting-section input,
    .inv-accounting-section textarea {
        width: 100%;
        border: 1px solid #d8e2ef;
        border-radius: 16px;
        background: #f8fafc;
        color: #0f172a;
        font: inherit;
        font-weight: 750;
        outline: none;
        box-sizing: border-box;
    }

    .invoice-current-form-grid input,
    .invoice-current-form-grid select,
    .inv-accounting-section input {
        height: 50px;
        padding: 0 13px;
    }

    .invoice-current-form-grid textarea,
    .inv-accounting-section textarea {
        min-height: 90px;
        padding: 12px 13px;
        resize: vertical;
    }

    .invoice-current-error,
    .inv-accounting-error,
    .inv-accounting-success {
        margin: 0;
        padding: 12px 14px;
        border-radius: 15px;
        font-size: 13px;
        font-weight: 850;
    }

    .invoice-current-error,
    .inv-accounting-error { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; }
    .inv-accounting-success { background: #dcfce7; border: 1px solid #bbf7d0; color: #166534; }

    .invoice-current-modal-actions,
    .inv-accounting-modal-actions {
        padding: 18px 22px 22px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        border-top: 1px solid #e5edf7;
    }

    .invoice-current-btn.primary,
    .inv-accounting-confirm {
        background: #059669;
        color: #ffffff;
    }

    .invoice-current-btn.soft,
    .inv-accounting-cancel {
        background: #ffffff;
        color: #0f172a;
        border: 1px solid #d8e2ef;
    }

    .inv-accounting-section.two-col {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    .inv-accounting-recipient-list {
        display: grid;
        gap: 9px;
    }

    .inv-accounting-recipient {
        padding: 12px;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 10px;
        align-items: center;
    }

    .inv-accounting-recipient strong {
        display: block;
        color: #0f172a;
        font-size: 13px;
        font-weight: 950;
    }

    .inv-accounting-recipient span span,
    .inv-accounting-muted {
        color: #64748b;
        font-size: 12px;
        font-weight: 800;
    }

    .inv-accounting-checkline {
        display: flex;
        align-items: center;
        gap: 9px;
        color: #334155;
        font-size: 13px;
        font-weight: 850;
