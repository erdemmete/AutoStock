@model AutoStock.WEB.Models.Invoices.InvoiceDetailViewModel

<section class="invoice-head">
    <div>
        <h2>@Model.InvoiceNumber</h2>

        <div class="meta-line">
            <span>▣ @Model.InvoiceDate.ToString("dd MMMM yyyy")</span>

            @if (Model.ServiceRecordId.HasValue)
            {
                <span>🔧 Servis Kaydı: #@Model.ServiceRecordId</span>
            }

            @{
                var documentVehicleName = string.Join(" ", new[]
                {
                    Model.VehicleBrandName,
                    Model.VehicleModelName,
                    Model.VehicleModelYear?.ToString()
                }.Where(x => !string.IsNullOrWhiteSpace(x)));
            }

            @if (!string.IsNullOrWhiteSpace(documentVehicleName))
            {
                <span id="invoiceHeadVehicleName">🚘 @documentVehicleName</span>
            }
        </div>
    </div>

    <div class="plate-box">
        <span>TR</span>
        <strong>@(Model.Plate ?? "-")</strong>
    </div>
</section>
