@model AutoStock.WEB.Models.Invoices.InvoiceDetailViewModel

<style>
    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        background: #f4f7fb;
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: #0f172a;
    }

    .invoice-page {
        width: min(1180px, calc(100% - 40px));
        margin: 0 auto;
        padding: 30px 0 56px;
    }

    .top-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 18px;
        margin-bottom: 26px;
    }

    .title-row {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .title-row h1 {
            margin: 0;
            font-size: 24px;
            letter-spacing: -.6px;
        }

    .top-header p {
        margin: 6px 0 0;
        color: #64748b;
        font-size: 14px;
        font-weight: 650;
    }

    .status-badge {
        display: inline-flex;
        padding: 7px 10px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 900;
        border: 1px solid transparent;
    }

    .status-1 {
        color: #c2410c;
        background: #fff7ed;
        border-color: #fed7aa;
    }

    .status-2 {
        color: #15803d;
        background: #dcfce7;
        border-color: #bbf7d0;
    }

    .status-3 {
        color: #b91c1c;
        background: #fee2e2;
        border-color: #fecaca;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .action-btn {
        min-height: 42px;
        padding: 0 16px;
        border-radius: 11px;
        border: 1px solid #dbe3ef;
        background: white;
        color: #334155;
        font-weight: 900;
        text-decoration: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 6px 16px rgba(15, 23, 42, .08);
    }

        .action-btn.primary {
            background: #4f46e5;
            color: white;
            border-color: #4f46e5;
        }

        .action-btn.success {
            background: #16a34a;
            color: white;
            border-color: #16a34a;
        }

        .action-btn.danger {
            color: #dc2626;
            border-color: #fecaca;
            background: white;
        }

    .invoice-card {
        background: white;
        border: 1px solid #dfe7f1;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 16px 36px rgba(15, 23, 42, .06);
    }

    .invoice-head {
        min-height: 118px;
        padding: 32px 36px;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 18px;
        border-bottom: 1px solid #eef2f7;
    }

        .invoice-head h2 {
            margin: 0;
            font-size: 26px;
            letter-spacing: -.6px;
        }

    .meta-line {
        margin-top: 8px;
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
        color: #64748b;
        font-size: 14px;
        font-weight: 650;
    }

    .plate-box {
        min-width: 170px;
        min-height: 44px;
        border: 1px solid #dbe3ef;
        border-radius: 10px;
        display: grid;
        grid-template-columns: 40px 1fr;
        overflow: hidden;
        box-shadow: 0 6px 14px rgba(15, 23, 42, .06);
    }

        .plate-box span {
            display: grid;
            place-items: center;
            background: #2563eb;
            color: white;
            font-size: 11px;
            font-weight: 950;
        }

        .plate-box strong {
            display: grid;
            place-items: center;
            font-size: 20px;
            letter-spacing: 1.5px;
        }

    .info-section {
        padding: 34px 36px 22px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }

    .info-box {
        min-height: 160px;
        border: 1px solid #e5ebf3;
        border-radius: 16px;
        padding: 22px;
        background: #fff;
    }

    .box-title {
        color: #64748b;
        font-size: 12px;
        font-weight: 950;
        letter-spacing: .6px;
        text-transform: uppercase;
        margin-bottom: 18px;
    }

    .info-box h3 {
        margin: 0 0 14px;
        font-size: 20px;
        font-weight: 900;
    }

    .info-lines {
        display: grid;
        gap: 10px;
    }

        .info-lines p {
            margin: 0;
            color: #64748b;
            font-size: 14px;
            line-height: 1.55;
            font-weight: 650;
        }

        .info-lines span {
            display: inline-block;
            width: 22px;
            color: #94a3b8;
        }

    .vehicle-grid {
        margin-top: 18px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 22px;
    }

        .vehicle-grid label {
            display: block;
            color: #64748b;
            font-size: 12px;
            font-weight: 850;
            margin-bottom: 4px;
        }

        .vehicle-grid strong {
            font-size: 14px;
            font-weight: 900;
            word-break: break-word;
        }

    .items-section {
        padding: 8px 36px 28px;
    }

        .items-section h4,
        .notes-box h4 {
            margin: 0 0 14px;
            color: #64748b;
            font-size: 13px;
            font-weight: 950;
            letter-spacing: .6px;
            text-transform: uppercase;
        }

    .invoice-table {
        border: 1px solid #dfe7f1;
        border-radius: 14px;
        overflow-x: auto;
    }

    .table-head,
    .table-row {
        display: grid;
        grid-template-columns: 110px minmax(260px, 1fr) 90px 130px 110px 90px 130px;
        align-items: center;
        min-width: 900px;
    }

    .table-head {
        background: #f8fafc;
        color: #64748b;
        font-size: 12px;
        font-weight: 950;
        text-transform: uppercase;
    }

        .table-head span,
        .table-row span {
            padding: 15px 18px;
        }

    .table-row {
        border-top: 1px solid #edf2f7;
        font-size: 14px;
    }

    .description {
        color: #0f172a;
        font-weight: 900;
    }

    .item-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 70px;
        padding: 6px 10px;
        border-radius: 9px;
        font-size: 12px;
        font-weight: 900;
    }

    .type-1 {
        background: #f3e8ff;
        color: #9333ea;
        border: 1px solid #e9d5ff;
    }

    .type-2 {
        background: #eff6ff;
        color: #2563eb;
        border: 1px solid #bfdbfe;
    }

    .type-3 {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
    }

    .discount {
        color: #ef4444;
    }

    .line-total {
        color: #0f172a;
        font-weight: 950;
        text-align: right;
    }

    .bottom-section {
        padding: 20px 36px 38px;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 420px;
        gap: 36px;
        align-items: start;
    }

    .notes-box > div {
        min-height: 112px;
        padding: 18px;
        border-radius: 14px;
        background: #f8fafc;
        border: 1px solid #edf2f7;
        color: #475569;
        font-size: 14px;
        line-height: 1.65;
        font-weight: 650;
    }

    .total-box {
        padding: 22px 26px;
        border-radius: 18px;
        border: 1px solid #edf2f7;
        background: #fff;
        display: grid;
        gap: 18px;
    }

        .total-box div {
            display: flex;
            justify-content: space-between;
            gap: 18px;
            color: #475569;
            font-size: 15px;
        }

        .total-box strong {
            color: #0f172a;
            font-weight: 900;
        }

        .total-box .red,
        .total-box .red strong {
            color: #ef4444;
        }

        .total-box .grand {
            padding-top: 18px;
            border-top: 1px solid #e2e8f0;
            align-items: center;
            color: #0f172a;
            font-size: 17px;
            font-weight: 900;
        }

            .total-box .grand strong {
                color: #4f46e5;
                font-size: 28px;
                letter-spacing: -.8px;
            }

    .footer-actions {
        padding: 20px 36px;
        border-top: 1px solid #eef2f7;
        display: flex;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .footer-link {
        color: #2563eb;
        text-decoration: none;
        font-weight: 900;
    }

    @@media (max-width: 1000px) {
        .top-header,
        .invoice-head,
        .footer-actions {
            flex-direction: column;
        }

        .header-actions {
            justify-content: flex-start;
        }

        .info-section,
        .bottom-section {
            grid-template-columns: 1fr;
        }

        .plate-box {
            width: 180px;
        }
    }

    @@media (max-width: 700px) {
        .invoice-page {
            width: 100%;
            padding: 14px;
        }

        .invoice-head,
        .info-section,
        .items-section,
        .bottom-section,
        .footer-actions {
            padding-left: 18px;
            padding-right: 18px;
        }

        .title-row {
            align-items: flex-start;
            flex-direction: column;
        }

        .header-actions {
            width: 100%;
        }

        .action-btn {
            width: 100%;
        }

        .vehicle-grid {
            grid-template-columns: 1fr;
        }
    }

    .box-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 18px;
    }

        .box-header .box-title {
            margin-bottom: 0;
        }

    .editable-box {
        width: 100%;
        text-align: left;
        cursor: pointer;
        transition: .18s ease;
    }

        .editable-box:hover {
            border-color: #c7d2fe;
            box-shadow: 0 18px 36px rgba(79, 70, 229, .08);
            transform: translateY(-1px);
        }

        .editable-box:disabled {
            cursor: default;
        }

            .editable-box:disabled:hover {
                transform: none;
                border-color: #e5ebf3;
                box-shadow: none;
            }

    .edit-pill {
        min-height: 28px;
        padding: 0 10px;
        border-radius: 999px;
        background: #eef2ff;
        color: #4f46e5;
        display: inline-flex;
        align-items: center;
        font-size: 12px;
        font-weight: 950;
    }

    .items-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        margin-bottom: 14px;
    }

        .items-title-row h4 {
            margin: 0;
        }

    .small-outline-btn {
        min-height: 36px;
        padding: 0 13px;
        border-radius: 11px;
        border: 1px solid #c7d2fe;
        background: white;
        color: #4f46e5;
        font-size: 13px;
        font-weight: 950;
        cursor: pointer;
    }

    .table-head.has-actions,
    .table-row.has-actions {
        grid-template-columns: 110px minmax(260px, 1fr) 90px 130px 110px 90px 130px 80px;
    }

    .table-row.editable-row {
        cursor: pointer;
        transition: .18s ease;
    }

        .table-row.editable-row:hover {
            background: #fbfdff;
        }

    .row-edit-btn {
        min-height: 32px;
        border: 1px solid #dbe3ef;
        border-radius: 10px;
        background: white;
        color: #334155;
        font-size: 12px;
        font-weight: 950;
        cursor: pointer;
    }

        .row-edit-btn:hover {
            color: #4f46e5;
            border-color: #c7d2fe;
        }

    .invoice-modal-backdrop {
        position: fixed;
        inset: 0;
        z-index: 990;
        background: rgba(15, 23, 42, .42);
        backdrop-filter: blur(4px);
    }

    .invoice-modal {
        position: fixed;
        inset: 0;
        z-index: 1000;
        padding: 22px;
        display: grid;
        place-items: center;
    }

        .invoice-modal[hidden],
        .invoice-modal-backdrop[hidden] {
            display: none !important;
        }

    .modal-card {
        width: min(720px, 100%);
        max-height: calc(100vh - 44px);
        overflow-y: auto;
        padding: 22px;
        border-radius: 22px;
        background: white;
        box-shadow: 0 30px 90px rgba(15, 23, 42, .30);
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        margin-bottom: 18px;
    }

        .modal-header h3 {
            margin: 0;
            color: #0f172a;
            font-size: 20px;
            font-weight: 950;
            letter-spacing: -.35px;
        }

        .modal-header button {
            width: 38px;
            height: 38px;
            border: 1px solid #dbe3ef;
            border-radius: 13px;
            background: white;
            color: #64748b;
            font-size: 22px;
            font-weight: 900;
            cursor: pointer;
        }

    .modal-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 13px;
    }

        .modal-grid label {
            display: grid;
            gap: 6px;
        }

            .modal-grid label.full {
                grid-column: 1 / -1;
            }

        .modal-grid span {
            color: #64748b;
            font-size: 12px;
            font-weight: 900;
        }

        .modal-grid input,
        .modal-grid textarea,
        .modal-grid select {
            width: 100%;
            min-height: 44px;
            border: 1px solid #dbe3ef;
            border-radius: 13px;
            background: white;
            color: #0f172a;
            padding: 0 13px;
            font: inherit;
            font-size: 14px;
            font-weight: 750;
            outline: none;
        }

        .modal-grid textarea {
            padding-top: 10px;
            resize: vertical;
        }

            .modal-grid input:focus,
            .modal-grid textarea:focus,
            .modal-grid select:focus {
                border-color: #4f46e5;
                box-shadow: 0 0 0 4px rgba(79, 70, 229, .10);
            }

            .modal-grid input.is-invalid,
            .modal-grid textarea.is-invalid,
            .modal-grid select.is-invalid {
                border-color: #fb7185;
                background: #fff7f8;
                box-shadow: 0 0 0 4px rgba(244, 63, 94, .10);
            }

    .invoice-field-error {
        color: #be123c;
        font-size: 12px;
        font-weight: 850;
        line-height: 1.35;
    }

    .invoice-modal-message {
        margin-bottom: 14px;
        padding: 12px 14px;
        border-radius: 16px;
        font-size: 13px;
        font-weight: 850;
        line-height: 1.45;
    }

    .invoice-modal-message.error {
        border: 1px solid #fecdd3;
        background: #fff1f2;
        color: #9f1239;
    }

    .invoice-modal-message.info {
        border: 1px solid #bfdbfe;
        background: #eff6ff;
        color: #1e3a8a;
    }

    .modal-actions {
        margin-top: 18px;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

        .modal-actions.between {
            justify-content: space-between;
            align-items: center;
        }

    .modal-primary-btn,
    .modal-secondary-btn,
    .modal-danger-btn {
        min-height: 42px;
        padding: 0 16px;
        border-radius: 13px;
        font-size: 14px;
        font-weight: 950;
        cursor: pointer;
    }

    .modal-primary-btn {
        border: none;
        background: #4f46e5;
        color: white;
    }

    .modal-secondary-btn {
        border: 1px solid #dbe3ef;
        background: white;
        color: #334155;
    }

    .modal-danger-btn {
        border: 1px solid #fecaca;
        background: #fff1f2;
        color: #dc2626;
    }

    @@media (max-width: 700px) {
        .modal-grid {
            grid-template-columns: 1fr;
        }

        .table-head.has-actions,
        .table-row.has-actions {
            grid-template-columns: 1fr;
            min-width: 0;
        }
    }

    .invoice-stock-search-box {
        position: relative;
    }

    .invoice-stock-search-results {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        right: 0;
        z-index: 1050;
        display: none;
        border: 1px solid #dbe3ef;
        border-radius: 14px;
        background: white;
        box-shadow: 0 18px 42px rgba(15, 23, 42, .18);
        overflow: hidden;
    }

        .invoice-stock-search-results.active {
            display: block;
        }

    .invoice-stock-search-item {
        padding: 12px 13px;
        display: flex;
        justify-content: space-between;
        gap: 14px;
        align-items: center;
        border-bottom: 1px solid #eef2f7;
        cursor: pointer;
        transition: .18s ease;
    }

        .invoice-stock-search-item:last-child {
            border-bottom: none;
        }

        .invoice-stock-search-item:hover {
            background: #f8fafc;
        }

        .invoice-stock-search-item strong {
            display: block;
            color: #0f172a;
            font-size: 13px;
            font-weight: 900;
        }

        .invoice-stock-search-item small {
            display: block;
            margin-top: 3px;
            color: #64748b;
            font-size: 11px;
            font-weight: 700;
        }

        .invoice-stock-search-item span {
            color: #16a34a;
            font-size: 12px;
            font-weight: 950;
            white-space: nowrap;
        }

    .modal-help {
        display: block;
        margin-top: 6px;
        color: #64748b;
        font-size: 12px;
        line-height: 1.45;
        font-weight: 750;
    }

    .editable-box {
        position: relative;
    }

        .editable-box[data-editable="true"] {
            transition: .18s ease;
        }

            .editable-box[data-editable="true"]:hover {
                border-color: #c7d2fe;
                box-shadow: 0 18px 36px rgba(79, 70, 229, .08);
                transform: translateY(-1px);
            }

    .edit-pill {
        border: none;
        min-height: 30px;
        padding: 0 12px;
        border-radius: 999px;
        background: #eef2ff;
        color: #4f46e5;
        display: inline-flex;
        align-items: center;
        font-size: 12px;
        font-weight: 950;
        cursor: pointer;
    }

        .edit-pill:hover {
            background: #e0e7ff;
        }

    .invoice-party-modal {
        width: min(760px, 100%);
    }

    .modal-header > div p {
        margin: 5px 0 0;
        color: #64748b;
        font-size: 13px;
        line-height: 1.45;
        font-weight: 700;
    }

    .customer-type-switch-modal {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
        padding: 6px;
        margin-bottom: 18px;
        border-radius: 999px;
        background: #f1f5f9;
    }

        .customer-type-switch-modal button {
            min-height: 40px;
            border: none;
            border-radius: 999px;
            background: transparent;
            color: #64748b;
            font-size: 13px;
            font-weight: 950;
            cursor: pointer;
            transition: .18s ease;
        }

            .customer-type-switch-modal button.active {
                background: #4f46e5;
                color: white;
                box-shadow: 0 10px 22px rgba(79, 70, 229, .18);
            }

    .modal-info-strip {
        margin-top: 14px;
        padding: 12px 14px;
        border-radius: 14px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        color: #64748b;
        font-size: 12px;
        line-height: 1.45;
        font-weight: 750;
    }

    .customer-tax-field[hidden],
    .customer-individual-field[hidden],
    #customerTcknLine[hidden],
    #customerTaxNumberLine[hidden],
    #customerTaxOfficeLine[hidden] {
        display: none !important;
    }

    @@media (max-width: 700px) {
        .customer-type-switch-modal {
            grid-template-columns: 1fr;
            border-radius: 18px;
        }
    }


    /* Invoice detail mobile refinements: keep desktop paper/invoice look, but render line items as readable mobile rows. */
    @@media (max-width: 700px) {
        body {
            background: #eaf1fb;
        }

        .invoice-page {
            width: min(100% - 18px, 680px);
            padding: 10px 0 34px;
        }

        .top-header {
            padding: 0 4px;
        }

        .invoice-card {
            border-radius: 16px;
            box-shadow: 0 14px 32px rgba(15, 23, 42, .08);
        }

        .invoice-head {
            gap: 16px;
        }

        .invoice-head h2 {
            font-size: 24px;
            word-break: break-word;
        }

        .meta-line {
            gap: 8px;
            flex-direction: column;
        }

        .plate-box {
            width: min(100%, 220px);
            min-width: 0;
        }

        .info-box {
            padding: 18px;
        }

        .box-header {
            align-items: flex-start;
        }

        .items-title-row {
            align-items: flex-start;
            flex-direction: column;
        }

        .small-outline-btn {
            width: 100%;
            min-height: 42px;
        }

        .invoice-table {
            border: none;
            border-radius: 0;
            overflow: visible;
        }

        .table-head {
            display: none !important;
        }

        .table-row,
        .table-row.has-actions {
            min-width: 0;
            grid-template-columns: 1fr;
            gap: 10px;
            padding: 16px 0;
            border-top: 1px solid #edf2f7;
            font-size: 14px;
        }

        .table-row:first-child {
            border-top: none;
        }

        .table-row > span {
            padding: 0;
            min-width: 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 14px;
            color: #0f172a;
        }

        .table-row > span::before {
            content: attr(data-label);
            flex: 0 0 auto;
            color: #64748b;
            font-size: 12px;
            font-weight: 950;
            letter-spacing: .25px;
            text-transform: uppercase;
        }

        .table-row > span.description {
            display: block;
            padding: 12px 14px;
            border-radius: 14px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
