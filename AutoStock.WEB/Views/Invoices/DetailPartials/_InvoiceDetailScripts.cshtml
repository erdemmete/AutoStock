            document.querySelectorAll(".customer-type-switch-modal button").forEach(button => {
                button.classList.toggle(
                    "active",
                    button.dataset.customerType === type
                );
            });

            const isIndividual = type === "individual";
            const isTaxCustomer = type === "sole" || type === "corporate";

            document.querySelectorAll(".customer-individual-field").forEach(field => {
                field.hidden = !isIndividual;
            });

            document.querySelectorAll(".customer-tax-field").forEach(field => {
                field.hidden = !isTaxCustomer;
            });

            const titleLabel = document.getElementById("customerTitleInputLabel");

            if (titleLabel) {
                titleLabel.textContent = isIndividual
                    ? "Ad Soyad"
                    : type === "sole"
                        ? "Şahıs / Fatura Ünvanı"
                        : "Firma Ünvanı";
            }
