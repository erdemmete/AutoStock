@model AutoStock.WEB.Models.Invoices.InvoiceDetailViewModel

<script>
    const invoiceStatus = @Model.Status;
    const invoiceId = @Model.Id;

    const invoiceState = {
        id: @Model.Id,
        customerId: @Model.CustomerId,
        serviceRecordId: @(Model.ServiceRecordId.HasValue ? Model.ServiceRecordId.Value.ToString() : "null"),

        customerTitle: @Json.Serialize(Model.CustomerTitle),
        customerTaxOffice: @Json.Serialize(Model.CustomerTaxOffice),
        customerTaxNumber: @Json.Serialize(Model.CustomerTaxNumber),
        customerTckn: @Json.Serialize(Model.CustomerTckn),
        customerEmail: @Json.Serialize(Model.CustomerEmail),

        customerAddress: @Json.Serialize(Model.CustomerAddress),
        customerAddressLine: @Json.Serialize(Model.CustomerAddressLine),
        customerAddressCity: @Json.Serialize(Model.CustomerAddressCity),
        customerAddressDistrict: @Json.Serialize(Model.CustomerAddressDistrict),

        plate: @Json.Serialize(Model.Plate),
        chassisNumber: @Json.Serialize(Model.ChassisNumber),

        vehicleBrandId: @(Model.VehicleBrandId.HasValue ? Model.VehicleBrandId.Value.ToString() : "null"),
        vehicleModelId: @(Model.VehicleModelId.HasValue ? Model.VehicleModelId.Value.ToString() : "null"),
        vehicleBrandName: @Json.Serialize(Model.VehicleBrandName),
        vehicleModelName: @Json.Serialize(Model.VehicleModelName),
        vehicleModelYear: @(Model.VehicleModelYear.HasValue ? Model.VehicleModelYear.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null"),

        mileage: @(Model.Mileage.HasValue ? Model.Mileage.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null"),

        notes: @Json.Serialize(Model.Notes),

        items: [
            @foreach (var item in Model.Items)
            {
                    <text>{
                            id: @item.Id,
                            itemType: @item.ItemType,
                            description: @Json.Serialize(item.Description),
                            quantity: @item.Quantity.ToString(System.Globalization.CultureInfo.InvariantCulture),
                            unit: @Json.Serialize(item.Unit),
                            unitPrice: @item.UnitPrice.ToString(System.Globalization.CultureInfo.InvariantCulture),
                            discountRate: @item.DiscountRate.ToString(System.Globalization.CultureInfo.InvariantCulture),
                            vatRate: @item.VatRate.ToString(System.Globalization.CultureInfo.InvariantCulture),
                            stockItemId: @(item.StockItemId.HasValue ? item.StockItemId.Value.ToString() : "null")
                        },</text>
                }
            ],

            updateCustomerCard: false,
            updateVehicleCard: false
        };

        let invoiceCustomerType = getInitialInvoiceCustomerType();

        let invoiceTurkeyLocations = [];
        let invoiceTaxOffices = [];
        let invoiceVehicleBrands = [];
        let invoiceStatusActionInProgress = false;

        function toNumber(value) {
            return window.SenteMoney
                ? SenteMoney.parse(value)
                : Number(String(value || "").replace(",", ".")) || 0;
        }

        function formatMoney(value) {
            return window.SenteMoney
                ? SenteMoney.format(value)
                : toNumber(value).toLocaleString("tr-TR") + " ₺";
        }

        function formatQuantity(value) {
            return toNumber(value).toLocaleString("tr-TR", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });
        }

        function escapeHtml(value) {
            if (value === null || value === undefined) return "";

            return String(value)
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function normalizeTr(text) {
            return (text || "")
                .toLocaleLowerCase("tr-TR")
                .trim();
        }

        function toTitleCase(text) {
            return (text || "")
                .toLocaleLowerCase("tr-TR")
                .replace(/(^|\s)\S/g, x => x.toLocaleUpperCase("tr-TR"));
        }

        function getSelectText(selectId) {
            const select = document.getElementById(selectId);

            if (!select || !select.value) return "";

            return select.options[select.selectedIndex]?.text?.trim() || "";
        }

        function onlyDigits(value, maxLength) {
            return String(value || "")
                .replace(/\D/g, "")
                .slice(0, maxLength);
        }

        function normalizeText(value, maxLength = 80) {
            return String(value || "")
                .trim()
                .slice(0, maxLength);
        }

        function isValidOptionalEmail(value) {
            const email = String(value || "").trim();

            if (!email) return true;

            return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email);
        }

        function normalizePlate(value) {
            return String(value || "")
                .toLocaleUpperCase("tr-TR")
                .replace(/[^A-Z0-9]/g, "")
                .slice(0, 12);
        }

        function normalizeChassis(value) {
            return String(value || "")
                .toLocaleUpperCase("tr-TR")
                .replace(/[^A-Z0-9]/g, "")
                .slice(0, 17);
        }

        function showInvoiceToast(message, type = "error") {
            if (typeof window.showToast === "function") {
                window.showToast(message, type);
            }
        }

        function getVisibleInvoiceModal() {
            return Array.from(document.querySelectorAll(".invoice-modal"))
                .find(modal => !modal.hidden);
        }

        function setInvoiceModalMessage(id, message, type = "error") {
            const box = document.getElementById(id);
            if (!box) return;

            box.textContent = message || "";
            box.classList.toggle("error", type === "error");
            box.classList.toggle("info", type === "info");
            box.hidden = !message;
        }

        function clearInvoiceModalMessages(modal) {
            const scope = typeof modal === "string"
                ? document.getElementById(modal)
                : modal;

            const root = scope || document;

            root.querySelectorAll(".invoice-modal-message").forEach(box => {
                box.textContent = "";
                box.hidden = true;
            });
        }

        function clearInvoiceFieldError(input) {
            if (!input) return;

            input.classList.remove("is-invalid");
            input.removeAttribute("aria-invalid");

            const label = input.closest("label");
            label?.querySelectorAll(".invoice-field-error").forEach(error => error.remove());
        }

        function clearInvoiceFieldErrors(modal) {
            const scope = typeof modal === "string"
                ? document.getElementById(modal)
                : modal;

            const root = scope || document;
            const selector = scope ? ".is-invalid" : ".invoice-modal .is-invalid";

            root.querySelectorAll(selector).forEach(input => {
                clearInvoiceFieldError(input);
            });
        }

        function clearInvoiceFeedback(modal) {
            clearInvoiceModalMessages(modal);
            clearInvoiceFieldErrors(modal);
        }

        function setInvoiceFieldError(input, message, modalErrorId) {
            if (!input) {
                if (modalErrorId) {
                    setInvoiceModalMessage(modalErrorId, message);
                }
                return;
            }

            clearInvoiceFieldError(input);

            input.classList.add("is-invalid");
            input.setAttribute("aria-invalid", "true");

            const label = input.closest("label");
            if (label) {
                const error = document.createElement("small");
                error.className = "invoice-field-error";
                error.textContent = message;
                label.appendChild(error);
            }

            if (modalErrorId) {
                setInvoiceModalMessage(modalErrorId, message);
            }

            input.focus();
        }

        function showInvoiceOperationError(message) {
            const visibleModal = getVisibleInvoiceModal();

            if (visibleModal?.id === "customerModal") {
                setInvoiceModalMessage("invoiceCustomerModalError", message);
                return;
            }

            if (visibleModal?.id === "vehicleModal") {
                setInvoiceModalMessage("invoiceVehicleModalError", message);
                return;
            }

            if (visibleModal?.id === "itemModal") {
                setInvoiceModalMessage("invoiceItemModalError", message);
                return;
            }

            showInvoiceToast(message, "error");
        }

        function setTextById(id, value, fallback = "-") {
            const element = document.getElementById(id);

            if (!element) return;

            element.textContent =
                value !== null &&
                value !== undefined &&
                String(value).trim()
                    ? value
                    : fallback;
        }

        function setHiddenById(id, hidden) {
            const element = document.getElementById(id);

            if (!element) return;

            element.hidden = hidden;
        }

        function getJsonField(item, lowerName, upperName) {
            if (!item) return null;

            return item[lowerName] ?? item[upperName] ?? null;
        }

        function getCityName(city) {
            return getJsonField(city, "name", "Name");
        }

        function getDistricts(city) {
            return getJsonField(city, "districts", "Districts") || [];
        }

        function getTaxOfficeCity(item) {
            return getJsonField(item, "city", "City");
        }

        function getTaxOfficeDistrict(item) {
            return getJsonField(item, "district", "District");
        }

        function getTaxOfficeName(item) {
            return getJsonField(item, "name", "Name");
        }

        function getVehicleBrandId(item) {
            return getJsonField(item, "id", "Id");
        }

        function getVehicleBrandName(item) {
            return getJsonField(item, "name", "Name");
        }

        function getVehicleModelId(item) {
            return getJsonField(item, "id", "Id");
        }

        function getVehicleModelName(item) {
            return getJsonField(item, "name", "Name");
        }

        function buildCustomerInvoiceAddress(line, city, district) {
            const addressLine = normalizeText(line, 500);

            const locationPart = [district, city]
                .filter(x => x && String(x).trim())
                .join(" / ");

            return [addressLine, locationPart]
                .filter(x => x && String(x).trim())
                .join(" ");
        }

        function inferAddressPartsFromLegacyAddress() {
            if (invoiceState.customerAddressLine || invoiceState.customerAddressCity || invoiceState.customerAddressDistrict) {
                return;
            }

            const address = invoiceState.customerAddress || "";

            if (!address.trim()) return;

            const slashParts = address
                .split("/")
                .map(x => x.trim())
                .filter(Boolean);

            if (slashParts.length >= 2) {
                const possibleCity = slashParts[slashParts.length - 1];
                const beforeCity = slashParts.slice(0, slashParts.length - 1).join(" / ");

                const knownCity = invoiceTurkeyLocations.find(x =>
                    normalizeTr(getCityName(x)) === normalizeTr(possibleCity)
                );

                if (knownCity) {
                    invoiceState.customerAddressCity = getCityName(knownCity);

                    const districtList = getDistricts(knownCity);

                    const districtMatch = districtList.find(x => {
                        const districtName = getCityName(x);
                        return beforeCity && normalizeTr(beforeCity).includes(normalizeTr(districtName));
                    });

                    if (districtMatch) {
                        invoiceState.customerAddressDistrict = getCityName(districtMatch);

                        const districtName = getCityName(districtMatch);
                        invoiceState.customerAddressLine = beforeCity
                            .replace(new RegExp(districtName, "i"), "")
                            .trim();
                    } else {
                        invoiceState.customerAddressLine = beforeCity;
                    }

                    return;
                }
            }

            invoiceState.customerAddressLine = address;
        }

        function getInitialInvoiceCustomerType() {
            const hasTaxInfo =
                Boolean(invoiceState.customerTaxOffice) ||
                Boolean(invoiceState.customerTaxNumber);

            const hasTckn = Boolean(invoiceState.customerTckn);

            if (hasTaxInfo) return "sole";
            if (hasTckn) return "individual";

            return "individual";
        }

        async function loadInvoiceReferenceData() {
            try {
                const [locationsResponse, taxOfficesResponse, vehicleBrandsResponse] = await Promise.all([
                    fetch("/data/turkey-locations.json", { credentials: "same-origin" }),
                    fetch("/data/tax-offices.json", { credentials: "same-origin" }),
                    fetch("/Invoices/VehicleBrands", { credentials: "same-origin" })
                ]);

                if (locationsResponse.ok) {
                    invoiceTurkeyLocations = await locationsResponse.json();
                }

                if (taxOfficesResponse.ok) {
                    invoiceTaxOffices = await taxOfficesResponse.json();
                }

                if (vehicleBrandsResponse.ok) {
                    invoiceVehicleBrands = await vehicleBrandsResponse.json();
                }

                inferAddressPartsFromLegacyAddress();

                fillInvoiceCitySelect("customerAddressCityInput");
                fillInvoiceCitySelect("customerTaxOfficeCityInput");
                fillInvoiceVehicleBrandSelect();
            }
            catch {
                console.warn("Fatura referans verileri yüklenemedi.");
            }
        }

        function fillInvoiceCitySelect(selectId) {
            const select = document.getElementById(selectId);

            if (!select) return;

            const currentValue = select.value;

            select.innerHTML = `<option value="">İl seçiniz</option>`;

            invoiceTurkeyLocations
                .slice()
                .sort((a, b) => String(getCityName(a)).localeCompare(String(getCityName(b)), "tr"))
                .forEach(city => {
                    const cityName = getCityName(city);

                    if (!cityName) return;

                    select.innerHTML += `
                        <option value="${escapeHtml(cityName)}">
                            ${escapeHtml(toTitleCase(cityName))}
                        </option>`;
                });

            if (currentValue) {
                select.value = currentValue;
            }
        }

        function fillInvoiceDistrictSelect(citySelectId, districtSelectId, selectedDistrict = null) {
            const city = document.getElementById(citySelectId)?.value;
            const districtSelect = document.getElementById(districtSelectId);

            if (!districtSelect) return;

            const currentValue = selectedDistrict || districtSelect.value;

            districtSelect.innerHTML = `<option value="">İlçe seçiniz</option>`;

            const location = invoiceTurkeyLocations.find(x =>
                normalizeTr(getCityName(x)) === normalizeTr(city)
            );

            if (!location) return;

            getDistricts(location)
                .slice()
                .sort((a, b) => String(getCityName(a)).localeCompare(String(getCityName(b)), "tr"))
                .forEach(district => {
                    const districtName = getCityName(district);

                    if (!districtName) return;

                    districtSelect.innerHTML += `
                        <option value="${escapeHtml(districtName)}">
                            ${escapeHtml(toTitleCase(districtName))}
                        </option>`;
                });

            if (currentValue) {
                districtSelect.value = currentValue;
            }
        }

        function fillInvoiceTaxOfficeSelect(citySelectId, taxOfficeSelectId, selectedTaxOffice = null) {
            const city = document.getElementById(citySelectId)?.value;
            const taxOfficeSelect = document.getElementById(taxOfficeSelectId);

            if (!taxOfficeSelect) return;

            const currentValue = selectedTaxOffice || taxOfficeSelect.value;

            taxOfficeSelect.innerHTML = city
                ? `<option value="">Vergi dairesi seçiniz</option>`
                : `<option value="">Önce il seçiniz</option>`;

            if (!city) return;

            invoiceTaxOffices
                .filter(x => normalizeTr(getTaxOfficeCity(x)) === normalizeTr(city))
                .sort((a, b) => {
                    const districtCompare = String(getTaxOfficeDistrict(a) || "")
                        .localeCompare(String(getTaxOfficeDistrict(b) || ""), "tr");

                    if (districtCompare !== 0) return districtCompare;

                    return String(getTaxOfficeName(a) || "")
                        .localeCompare(String(getTaxOfficeName(b) || ""), "tr");
                })
                .forEach(item => {
                    const name = getTaxOfficeName(item);
                    const district = getTaxOfficeDistrict(item);
                    const itemCity = getTaxOfficeCity(item);

                    if (!name) return;

                    taxOfficeSelect.innerHTML += `
                        <option value="${escapeHtml(name)}">
                            ${escapeHtml(name)}${district ? ` - ${escapeHtml(district)}` : ""}${itemCity ? ` / ${escapeHtml(itemCity)}` : ""}
                        </option>`;
                });

            if (currentValue) {
                taxOfficeSelect.value = currentValue;
            }
        }

        function findTaxOfficeByName(name) {
            if (!name) return null;

            return invoiceTaxOffices.find(x =>
                normalizeTr(getTaxOfficeName(x)) === normalizeTr(name)
            ) || null;
        }

        function fillInvoiceVehicleBrandSelect() {
            const select = document.getElementById("vehicleBrandIdInput");

            if (!select) return;

            const currentValue = select.value;

            select.innerHTML = `<option value="">Marka seçiniz</option>`;

            invoiceVehicleBrands.forEach(brand => {
                const id = getVehicleBrandId(brand);
                const name = getVehicleBrandName(brand);

                if (!id || !name) return;

                select.innerHTML += `
                    <option value="${id}">
                        ${escapeHtml(name)}
                    </option>`;
            });

            if (currentValue) {
                select.value = currentValue;
            }
        }

        function findBrandIdByName(name) {
            if (!name) return null;

            const brand = invoiceVehicleBrands.find(x =>
                normalizeTr(getVehicleBrandName(x)) === normalizeTr(name)
            );

            return brand ? Number(getVehicleBrandId(brand)) : null;
        }

        async function loadInvoiceVehicleModels(brandId, selectedModelId = null, selectedModelName = null) {
            const modelSelect = document.getElementById("vehicleModelIdInput");

            if (!modelSelect) return;

            modelSelect.innerHTML = `<option value="">Model yükleniyor...</option>`;

            if (!brandId) {
                modelSelect.innerHTML = `<option value="">Önce marka seçiniz</option>`;
                return;
            }

            try {
                const response = await fetch(`/Invoices/VehicleModels?brandId=${brandId}`, {
                    credentials: "same-origin"
                });

                if (!response.ok) {
                    modelSelect.innerHTML = `<option value="">Model alınamadı</option>`;
                    return;
                }

                const models = await response.json();

                modelSelect.innerHTML = `<option value="">Model seçiniz</option>`;

                models.forEach(model => {
                    const id = getVehicleModelId(model);
                    const name = getVehicleModelName(model);

                    if (!id || !name) return;

                    modelSelect.innerHTML += `
                        <option value="${id}">
                            ${escapeHtml(name)}
                        </option>`;
                });

                if (selectedModelId) {
                    modelSelect.value = selectedModelId;
                } else if (selectedModelName) {
                    const match = models.find(x =>
                        normalizeTr(getVehicleModelName(x)) === normalizeTr(selectedModelName)
                    );

                    if (match) {
                        modelSelect.value = getVehicleModelId(match);
                    }
                }
            }
            catch {
                modelSelect.innerHTML = `<option value="">Model alınamadı</option>`;
            }
        }

        function getItemTypeText(type) {
            type = Number(type);

            if (type === 1) return "İşçilik";
            if (type === 2) return "Parça";
            return "Diğer";
        }

        function isServiceLinkedInvoice() {
            return invoiceState.serviceRecordId !== null &&
                   invoiceState.serviceRecordId !== undefined &&
                   Number(invoiceState.serviceRecordId) > 0;
        }

        function isOperationalInvoiceItemType(type) {
            type = Number(type);

            return type === 1 || type === 2;
        }

        function mapInvoiceItemTypeToOperationType(itemType) {
            itemType = Number(itemType);

            if (itemType === 2) return 1;
            if (itemType === 1) return 2;

            return 2;
        }

        function calculateLine(item) {
            const gross = toNumber(item.quantity) * toNumber(item.unitPrice);
            const discountAmount = gross * toNumber(item.discountRate) / 100;
            const taxableAmount = gross - discountAmount;
            const vatAmount = taxableAmount * toNumber(item.vatRate) / 100;
            const lineTotal = taxableAmount + vatAmount;

            return {
                gross,
                discountAmount,
                vatAmount,
                lineTotal
            };
        }

        function calculateTotals() {
            let subtotal = 0;
            let discountTotal = 0;
            let vatTotal = 0;
            let grandTotal = 0;

            invoiceState.items.forEach(item => {
                const line = calculateLine(item);

                subtotal += line.gross;
                discountTotal += line.discountAmount;
                vatTotal += line.vatAmount;
                grandTotal += line.lineTotal;
            });

            return {
                subtotal,
                discountTotal,
                vatTotal,
                grandTotal
            };
        }

                function calculateUndiscountedGrandTotal() {
            let total = 0;

            invoiceState.items.forEach(item => {
                const quantity = toNumber(item.quantity);
                const unitPrice = toNumber(item.unitPrice);
                const vatRate = toNumber(item.vatRate);

                const gross = quantity * unitPrice;
                const vat = gross * vatRate / 100;

                total += gross + vat;
            });

            return total;
        }

        function calculateTargetDiscountRate(targetTotal, undiscountedGrandTotal) {
            if (undiscountedGrandTotal <= 0) {
                return null;
            }

            if (targetTotal <= 0) {
                return null;
            }

            if (targetTotal >= undiscountedGrandTotal) {
                return null;
            }

            const discountRate = (1 - (targetTotal / undiscountedGrandTotal)) * 100;

            return Math.min(
                100,
                Math.max(0, Number(discountRate.toFixed(6)))
            );
        }

        function updateTargetTotalPreview() {
            const input = document.getElementById("targetTotalInput");
            const discountText = document.getElementById("targetDiscountRateText");
            const help = document.getElementById("targetTotalHelp");

            if (!input || !discountText || !help) return;

            const targetTotal = toNumber(input.value);
            const undiscountedGrandTotal = calculateUndiscountedGrandTotal();
            const discountRate = calculateTargetDiscountRate(
                targetTotal,
                undiscountedGrandTotal
            );

            if (!targetTotal) {
                discountText.textContent = "-";
                help.textContent = "Bu işlem servis kaydındaki işlem tutarlarını değiştirmez. Sadece fatura kalemlerine iskonto uygular.";
                return;
            }

            if (discountRate === null) {
                discountText.textContent = "-";
                help.textContent = "Hedef tutar, iskontosuz genel toplamdan düşük olmalıdır.";
                return;
            }

            discountText.textContent = `%${discountRate.toLocaleString("tr-TR", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            })}`;

            help.textContent =
                `Bu işlem tüm fatura kalemlerine yaklaşık %${discountRate.toLocaleString("tr-TR", {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                })} iskonto uygular.`;
        }

        function openTargetTotalModal() {
            if (invoiceStatus !== 1) return;

            const totals = calculateTotals();
            const undiscountedGrandTotal = calculateUndiscountedGrandTotal();

            const undiscountedText = document.getElementById("targetUndiscountedTotalText");
            const currentText = document.getElementById("targetCurrentTotalText");
            const discountText = document.getElementById("targetDiscountRateText");
            const input = document.getElementById("targetTotalInput");
            const help = document.getElementById("targetTotalHelp");

            if (undiscountedText) {
                undiscountedText.textContent = formatMoney(undiscountedGrandTotal);
            }

            if (currentText) {
                currentText.textContent = formatMoney(totals.grandTotal);
            }

            if (discountText) {
                discountText.textContent = "-";
            }

            if (input) {
                input.value = "";
            }

            if (help) {
                help.textContent = "Bu işlem servis kaydındaki işlem tutarlarını değiştirmez. Sadece fatura kalemlerine iskonto uygular.";
            }

            openBackdrop();
            showInvoiceElement("targetTotalModal");

            setTimeout(() => {
                input?.focus();
            }, 50);
        }

        async function applyTargetTotalToInvoice() {
            const input = document.getElementById("targetTotalInput");

            if (!input) return;

            const targetTotal = toNumber(input.value);
            const undiscountedGrandTotal = calculateUndiscountedGrandTotal();

            if (targetTotal <= 0) {
                alert("Geçerli bir hedef tutar girin.");
                input.focus();
                return;
            }

            if (undiscountedGrandTotal <= 0) {
                alert("Fatura toplamı hesaplanamadı.");
                return;
            }

            if (targetTotal >= undiscountedGrandTotal) {
                alert("Hedef tutar, iskontosuz genel toplamdan düşük olmalıdır.");
                input.focus();
                return;
            }

            const discountRate = calculateTargetDiscountRate(
                targetTotal,
                undiscountedGrandTotal
            );

            if (discountRate === null) {
                alert("İskonto oranı hesaplanamadı.");
                return;
            }

            const confirmed = await SenteConfirm.show({
                title: "Toplu iskonto uygula",
                message: `Fatura kalemlerine yaklaşık %${discountRate.toLocaleString("tr-TR", {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                })} iskonto uygulanacak.\n\nDevam etmek istiyor musun?`,
                confirmText: "Uygula",
                cancelText: "Vazgeç"
            });

            if (!confirmed) return;

            invoiceState.items = invoiceState.items.map(item => ({
                ...item,
                discountRate: discountRate
            }));

            await persistInvoice();

            renderItems();
            closeAllInvoiceModals();
        }

        function renderItems() {
            const body = document.getElementById("invoiceItemsBody");

            if (!body) return;

            body.innerHTML = "";

            invoiceState.items.forEach((item, index) => {
                const line = calculateLine(item);

                const discountText = line.discountAmount > 0
                    ? "-" + formatMoney(line.discountAmount)
                    : "-";

                const row = document.createElement("div");

                row.className = invoiceStatus === 1
                    ? "table-row has-actions editable-row"
                    : "table-row";

                row.innerHTML = `
                    <span data-label="Tür">
                        <b class="item-badge type-${Number(item.itemType)}">
                            ${getItemTypeText(item.itemType)}
                        </b>
                    </span>

                    <span class="description" data-label="Açıklama">${escapeHtml(item.description || "-")}</span>
                    <span data-label="Miktar">${formatQuantity(item.quantity)}</span>
                    <span data-label="Birim Fiyat">${formatMoney(item.unitPrice)}</span>
                    <span class="discount" data-label="İskonto">${discountText}</span>
                    <span data-label="KDV">%${toNumber(item.vatRate).toLocaleString("tr-TR", { maximumFractionDigits: 2 })}</span>
                    <span class="line-total" data-label="Tutar">${formatMoney(line.lineTotal)}</span>

                    ${invoiceStatus === 1
                        ? `<span class="row-actions-cell"><button type="button" class="row-edit-btn">Düzenle</button></span>`
                        : ""}
                `;

                if (invoiceStatus === 1) {
                    row.addEventListener("click", () => openItemModal(index));
                }

                body.appendChild(row);
            });

            const tableHead = document.querySelector(".table-head");

            if (tableHead && invoiceStatus === 1) {
                tableHead.classList.add("has-actions");
            }

            renderTotals();
        }

        function renderTotals() {
            const totals = calculateTotals();
            const totalBox = document.querySelector(".total-box");

            if (!totalBox) return;

            const rows = totalBox.querySelectorAll("strong");

            if (rows.length >= 4) {
                rows[0].textContent = formatMoney(totals.subtotal);
                rows[1].textContent = "-" + formatMoney(totals.discountTotal);
                rows[2].textContent = formatMoney(totals.vatTotal);
                rows[3].textContent = formatMoney(totals.grandTotal);
            }
        }

        function showInvoiceElement(id) {
            const element = document.getElementById(id);

            if (!element) return;

            element.hidden = false;
            element.removeAttribute("hidden");
        }

        function hideInvoiceElement(element) {
            if (!element) return;

            element.hidden = true;
            element.setAttribute("hidden", "hidden");
        }

        function openBackdrop() {
            showInvoiceElement("invoiceModalBackdrop");
        }

        function closeAllInvoiceModals() {
            document.querySelectorAll(".invoice-modal").forEach(modal => {
                hideInvoiceElement(modal);
            });

            hideInvoiceElement(document.getElementById("invoiceModalBackdrop"));

