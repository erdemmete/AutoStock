        function updateItemModalMode() {
            const itemType = Number(document.getElementById("itemTypeInput")?.value || 3);
            const isOperational = isOperationalInvoiceItemType(itemType);
            const isServiceLinked = isServiceLinkedInvoice();

            const requestField = document.getElementById("itemServiceRequestField");
            const stockHelp = document.getElementById("itemStockHelp");
            const descriptionLabel = document.getElementById("itemDescriptionLabel");
            const stockInput = document.getElementById("itemStockItemIdInput");
            const results = document.getElementById("itemStockSearchResults");

            if (requestField) {
                requestField.hidden = !(isServiceLinked && isOperational);
            }

            if (stockHelp) {
                stockHelp.hidden = itemType !== 2;
            }

            if (descriptionLabel) {
                descriptionLabel.textContent = itemType === 2
                    ? "Parça / Stok Kartı"
                    : "Açıklama";
            }

            if (itemType !== 2) {
                if (stockInput) {
                    stockInput.value = "";
                }

                if (results) {
                    results.innerHTML = "";
                    results.classList.remove("active");
                }
            }
        }

        function closeStockSearchResults() {
            const results = document.getElementById("itemStockSearchResults");

            if (!results) return;

            results.innerHTML = "";
            results.classList.remove("active");
        }

        function bindInvoiceItemModalEvents() {
            const typeInput = document.getElementById("itemTypeInput");

            if (typeInput && typeInput.dataset.bound !== "true") {
                typeInput.dataset.bound = "true";

                typeInput.addEventListener("change", function () {
                    document.getElementById("itemStockItemIdInput").value = "";
                    closeStockSearchResults();
                    updateItemModalMode();
                });
            }

            bindInvoiceStockSearch();
        }

        function bindInvoiceStockSearch() {
            const input = document.getElementById("itemDescriptionInput");
            const stockInput = document.getElementById("itemStockItemIdInput");
            const results = document.getElementById("itemStockSearchResults");
            const priceInput = document.getElementById("itemUnitPriceInput");

            if (!input || !stockInput || !results || input.dataset.stockSearchBound === "true") {
                return;
            }

            input.dataset.stockSearchBound = "true";

            let timer = null;

            input.addEventListener("input", function () {
                clearTimeout(timer);
                stockInput.value = "";

                const query = input.value.trim();
                const itemType = Number(document.getElementById("itemTypeInput")?.value || 3);

                if (itemType !== 2 || query.length < 2) {
                    closeStockSearchResults();
                    return;
                }

                timer = setTimeout(async function () {
                    try {
                        const response = await fetch(
                            `/ServiceRecords/SearchStockItems?q=${encodeURIComponent(query)}`,
                            {
                                credentials: "same-origin"
                            }
                        );

                        if (!response.ok) {
                            closeStockSearchResults();
                            return;
                        }

                        const payload = await response.json();

                        const items = Array.isArray(payload)
                            ? payload
                            : (payload.data || payload.Data || []);

                        results.innerHTML = "";

                        if (!items.length) {
                            results.innerHTML = `
                                <div class="invoice-stock-search-item">
                                    <div>
                                        <strong>Sonuç bulunamadı</strong>
                                        <small>Bu parçayı serbest açıklama olarak ekleyebilirsiniz.</small>
                                    </div>
                                </div>
                            `;

                            results.classList.add("active");
                            return;
                        }

                        items.forEach(item => {
                            const id = item.id ?? item.Id;
                            const name =
                                item.name ??
                                item.Name ??
                                item.description ??
                                item.Description ??
                                "";

                            const code =
                                item.code ??
                                item.Code ??
                                item.itemCode ??
                                item.ItemCode ??
                                item.stockCode ??
                                item.StockCode ??
                                "";

                            const quantity =
                                item.quantity ??
                                item.Quantity ??
                                item.currentQuantity ??
                                item.CurrentQuantity ??
                                item.stockQuantity ??
                                item.StockQuantity ??
                                0;

                            const salePrice =
                                item.salePrice ??
                                item.SalePrice ??
                                item.sellingPrice ??
                                item.SellingPrice ??
                                item.unitPrice ??
                                item.UnitPrice ??
                                null;

                            const element = document.createElement("div");
                            element.className = "invoice-stock-search-item";

                            element.innerHTML = `
                                <div>
                                    <strong>${escapeHtml(name)}</strong>
                                    <small>
                                        ${code ? `Kod: ${escapeHtml(code)} • ` : ""}
                                        Stok: ${toNumber(quantity).toLocaleString("tr-TR")}
                                    </small>
                                </div>

                                <span>${salePrice !== null ? formatMoney(salePrice) : ""}</span>
                            `;

                            element.addEventListener("click", function () {
                                input.value = name;
                                stockInput.value = id;

                                if (salePrice !== null && priceInput) {
                                    priceInput.value = toNumber(salePrice);
                                    window.SenteMoney?.formatInput(priceInput);
                                }

                                closeStockSearchResults();
                                input.focus();
                            });

                            results.appendChild(element);
                        });

                        results.classList.add("active");
                    }
                    catch {
                        closeStockSearchResults();
                    }
                }, 250);
            });

            input.addEventListener("keydown", function (event) {
                if (event.key === "Escape") {
                    closeStockSearchResults();
                }
            });
        }

        async function saveItemModal() {
            const index = Number(document.getElementById("itemEditIndex").value);

            const item = {
                id: index >= 0 ? invoiceState.items[index].id : 0,
                itemType: Number(document.getElementById("itemTypeInput").value),
                description: document.getElementById("itemDescriptionInput").value.trim(),
                quantity: toNumber(document.getElementById("itemQuantityInput").value),
                unit: document.getElementById("itemUnitInput").value.trim() || "Adet",
                unitPrice: toNumber(document.getElementById("itemUnitPriceInput").value),
                discountRate: toNumber(document.getElementById("itemDiscountRateInput").value),
                vatRate: toNumber(document.getElementById("itemVatRateInput").value),
                stockItemId: document.getElementById("itemStockItemIdInput").value
                    ? Number(document.getElementById("itemStockItemIdInput").value)
                    : null
            };

            if (!item.description) {
                setInvoiceFieldError(
                    document.getElementById("itemDescriptionInput"),
                    "Kalem açıklaması zorunludur.",
                    "invoiceItemModalError"
                );
                return;
            }

            if (item.quantity <= 0) {
                setInvoiceFieldError(
                    document.getElementById("itemQuantityInput"),
                    "Miktar 0'dan büyük olmalıdır.",
                    "invoiceItemModalError"
                );
                return;
            }

            const isServiceLinked = isServiceLinkedInvoice();
            const isOperational = isOperationalInvoiceItemType(item.itemType);

            if (isServiceLinked && isOperational) {
                if (index >= 0) {
                    setInvoiceModalMessage(
                        "invoiceItemModalInfo",
                        "Servis kaydından gelen parça/işçilik kalemleri servis kaydı üzerinden düzenlenmelidir.",
                        "info"
                    );

                    return;
                }

                await addServiceOperationFromInvoiceItem(item);
                return;
            }

            if (index >= 0) {
                invoiceState.items[index] = item;
            } else {
                invoiceState.items.push(item);
            }

            await persistInvoice();
            renderItems();
            closeAllInvoiceModals();
        }

        async function addServiceOperationFromInvoiceItem(item) {
            const serviceRequestInput = document.getElementById("itemServiceRequestItemIdInput");
            const serviceRequestItemId = Number(serviceRequestInput?.value || 0);

            if (serviceRequestItemId <= 0) {
                setInvoiceFieldError(
                    serviceRequestInput,
                    "Bu parça/işçilik için servis şikayeti veya talep seçmelisiniz.",
                    "invoiceItemModalError"
                );
                return;
            }

            if (item.itemType === 2 && !item.stockItemId) {
                const confirmed = await SenteConfirm.show({
                    title: "Stok kartı seçilmedi",
                    message: "Bu parça servis kaydına eklenecek ancak stoktan düşmeyecek.\n\nDevam etmek istiyor musunuz?",
                    confirmText: "Devam Et",
                    cancelText: "Vazgeç"
                });

                if (!confirmed) {
                    return;
                }
            }

            const formData = new FormData();

            formData.append("ServiceRecordId", invoiceState.serviceRecordId);
            formData.append("ServiceRequestItemId", serviceRequestItemId);
            formData.append("Type", mapInvoiceItemTypeToOperationType(item.itemType));
            formData.append("Description", item.description);
            formData.append("Quantity", item.quantity);
            formData.append("UnitPrice", item.unitPrice);
            formData.append("Note", "Fatura ekranından eklendi.");

            if (item.stockItemId) {
                formData.append("StockItemId", item.stockItemId);
            }

            const response = await fetch("/ServiceRecords/AddOperation", {
                method: "POST",
                body: formData,
                credentials: "same-origin"
            });

            const text = await response.text();

            let result = null;

            try {
                result = JSON.parse(text);
            } catch {
                result = null;
            }

            if (!response.ok || result?.isSuccess === false) {
                const message =
                    result?.errorMessage ||
                    result?.errorMessages?.[0] ||
                    "Servis işlemine kalem eklenirken hata oluştu.";

                setInvoiceModalMessage("invoiceItemModalError", message);
                return;
            }

            closeAllInvoiceModals();
            window.location.reload();
        }

        async function deleteCurrentItem() {
            const index = Number(document.getElementById("itemEditIndex").value);

            if (index < 0) return;

            if (invoiceState.items.length <= 1) {
                alert("En az bir fatura kalemi kalmalıdır.");
                return;
            }

            const item = invoiceState.items[index];

            if (isServiceLinkedInvoice() && isOperationalInvoiceItemType(item.itemType)) {
                alert(
                    "Servis kaydından gelen parça/işçilik kalemleri servis operasyonudur.\n\n" +
                    "Silme işlemi servis kaydı üzerinden yapılmalıdır."
                );

                return;
            }

            const confirmed = await SenteConfirm.show({
                title: "Fatura kalemini sil",
                message: "Bu fatura kalemini silmek istediğinize emin misiniz?",
                confirmText: "Sil",
                cancelText: "Vazgeç",
                danger: true
            });

            if (!confirmed) return;

            invoiceState.items.splice(index, 1);

            await persistInvoice();
            renderItems();
            closeAllInvoiceModals();
        }

        function buildUpdatePayload() {
            return {
                id: invoiceState.id,
                invoiceId: invoiceState.id,
                customerId: invoiceState.customerId,
                serviceRecordId: invoiceState.serviceRecordId,

                customerTitle: invoiceState.customerTitle,
                customerTaxOffice: invoiceState.customerTaxOffice || null,
                customerTaxNumber: invoiceState.customerTaxNumber || null,
                customerTckn: invoiceState.customerTckn || null,
                customerEmail: invoiceState.customerEmail || null,

                customerAddress: invoiceState.customerAddress || null,
                customerAddressLine: invoiceState.customerAddressLine || null,
                customerAddressCity: invoiceState.customerAddressCity || null,
                customerAddressDistrict: invoiceState.customerAddressDistrict || null,
                customerType: invoiceCustomerType,

                plate: invoiceState.plate || null,
                chassisNumber: invoiceState.chassisNumber || null,

                vehicleBrandId: invoiceState.vehicleBrandId || null,
                vehicleModelId: invoiceState.vehicleModelId || null,
                vehicleBrandName: invoiceState.vehicleBrandName || null,
                vehicleModelName: invoiceState.vehicleModelName || null,
                vehicleModelYear: invoiceState.vehicleModelYear,

                mileage: invoiceState.mileage,

                updateCustomerCard: Boolean(invoiceState.updateCustomerCard),
                updateVehicleCard: Boolean(invoiceState.updateVehicleCard),

                notes: invoiceState.notes || null,

                items: invoiceState.items.map(item => ({
                    id: item.id,
                    itemType: Number(item.itemType),
                    description: item.description,
                    quantity: toNumber(item.quantity),
                    unit: item.unit || "Adet",
                    unitPrice: toNumber(item.unitPrice),
                    discountRate: toNumber(item.discountRate),
                    vatRate: toNumber(item.vatRate),
                    stockItemId: item.stockItemId
                }))
            };
        }

        async function persistInvoice() {
            const response = await fetch(`/Invoices/Edit/${invoiceState.id}`, {
                method: "PUT",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(buildUpdatePayload())
            });

            const text = await response.text();

            let result = null;

            try {
                result = JSON.parse(text);
            } catch {
                result = null;
            }

            if (!response.ok || result?.isSuccess === false) {
                const message =
                    result?.errorMessage ||
                    result?.errorMessages?.[0] ||
                    "Hesap özeti güncellenirken hata oluştu.";

                showInvoiceOperationError(message);
                throw new Error(message);
            }

            return result;
        }

        async function issueInvoice(invoiceId) {
            if (invoiceStatusActionInProgress) return;

            const confirmed = await SenteConfirm.show({
                title: "Hesap özetini onayla",
                message: "Bu hesap özetini onaylamak istediğinize emin misiniz?\n\nOnaylanan hesap özetleri artık taslak olarak düzenlenemez.",
                confirmText: "Onayla",
                cancelText: "Vazgeç"
            });

            if (!confirmed) return;

            invoiceStatusActionInProgress = true;

            try {
                const response = await fetch(`/Invoices/Issue/${invoiceId}`, {
                    method: "POST"
                });

                const text = await response.text();

                let result = null;

                try {
                    result = JSON.parse(text);
                } catch {
                    result = null;
                }

                if (!response.ok || !result?.isSuccess) {
                    alert(result?.errorMessage || "Hesap özeti onaylanırken hata oluştu.");
                    return;
                }

                window.location.reload();
            }
            catch {
                alert("Beklenmeyen bir hata oluştu.");
            } finally {
                invoiceStatusActionInProgress = false;
            }
        }

        async function cancelInvoice(invoiceId) {
            if (invoiceStatusActionInProgress) return;

            const confirmed = await SenteConfirm.show({
                title: "Hesap özetini iptal et",
                message: "Bu hesap özetini iptal etmek istediğinize emin misiniz?",
                confirmText: "İptal Et",
                cancelText: "Vazgeç",
                danger: true
            });

            if (!confirmed) return;

            invoiceStatusActionInProgress = true;

            try {
                const response = await fetch(`/Invoices/Cancel/${invoiceId}`, {
                    method: "POST"
                });

                if (!response.ok) {
                    alert("Hesap özeti iptal edilemedi.");
                    return;
                }

                location.reload();
            }
            catch {
                alert("Beklenmeyen bir hata oluştu.");
            } finally {
                invoiceStatusActionInProgress = false;
            }
        }

        function bindInvoicePartyModalInputGuards() {
            const tcknInput = document.getElementById("customerTcknInput");
            const taxNumberInput = document.getElementById("customerTaxNumberInput");
            const plateInput = document.getElementById("plateInput");
            const chassisInput = document.getElementById("chassisNumberInput");
            const modelYearInput = document.getElementById("vehicleModelYearInput");
            const mileageInput = document.getElementById("mileageInput");

            tcknInput?.addEventListener("input", function () {
                this.value = onlyDigits(this.value, 11);
            });

            taxNumberInput?.addEventListener("input", function () {
                this.value = onlyDigits(this.value, 10);
            });

            plateInput?.addEventListener("input", function () {
                this.value = normalizePlate(this.value);
            });

            chassisInput?.addEventListener("input", function () {
                this.value = normalizeChassis(this.value);
            });

            modelYearInput?.addEventListener("input", function () {
                this.value = onlyDigits(this.value, 4);
            });

            mileageInput?.addEventListener("input", function () {
                this.value = onlyDigits(this.value, 9);
            });

            document.querySelectorAll(".invoice-modal input, .invoice-modal textarea, .invoice-modal select")
                .forEach(input => {
                    if (input.dataset.invoiceValidationBound === "true") {
                        return;
                    }

                    input.dataset.invoiceValidationBound = "true";

                    const clearFeedback = function () {
                        clearInvoiceFieldError(input);

                        const modal = input.closest(".invoice-modal");
                        if (modal && !modal.querySelector(".is-invalid")) {
                            clearInvoiceModalMessages(modal);
                        }
                    };

                    input.addEventListener("input", clearFeedback);
                    input.addEventListener("change", clearFeedback);
                });
        }

        function bindInvoiceReferenceEvents() {
            document.getElementById("customerAddressCityInput")?.addEventListener("change", function () {
                fillInvoiceDistrictSelect(
                    "customerAddressCityInput",
                    "customerAddressDistrictInput"
                );
            });

            document.getElementById("customerTaxOfficeCityInput")?.addEventListener("change", function () {
                fillInvoiceTaxOfficeSelect(
                    "customerTaxOfficeCityInput",
                    "customerTaxOfficeInput"
                );
            });

            document.getElementById("vehicleBrandIdInput")?.addEventListener("change", async function () {
                invoiceState.vehicleBrandId = this.value ? Number(this.value) : null;
                invoiceState.vehicleModelId = null;

                await loadInvoiceVehicleModels(this.value);
            });
        }

        window.openCustomerModal = openCustomerModal;
        window.openVehicleModal = openVehicleModal;
        window.openItemModal = openItemModal;
        window.closeAllInvoiceModals = closeAllInvoiceModals;

        window.saveCustomerModal = saveCustomerModal;
        window.saveVehicleModal = saveVehicleModal;
        window.saveItemModal = saveItemModal;
        window.deleteCurrentItem = deleteCurrentItem;
                window.openTargetTotalModal = openTargetTotalModal;
        window.applyTargetTotalToInvoice = applyTargetTotalToInvoice;

        window.issueInvoice = issueInvoice;
        window.cancelInvoice = cancelInvoice;
        window.setInvoiceCustomerType = setInvoiceCustomerType;

        document.addEventListener("DOMContentLoaded", async function () {
            await loadInvoiceReferenceData();

            renderItems();
            refreshCustomerCard();
            refreshVehicleCard();

            bindInvoiceItemModalEvents();
            bindInvoicePartyModalInputGuards();
            bindInvoiceReferenceEvents();

            const backdrop = document.getElementById("invoiceModalBackdrop");

            if (backdrop) {
                backdrop.addEventListener("click", closeAllInvoiceModals);
            }

            document.addEventListener("keydown", function (event) {
                if (event.key === "Escape") {
                    closeAllInvoiceModals();
                }
            });

                document.getElementById("targetTotalInput")?.addEventListener("input", updateTargetTotalPreview);
            document.addEventListener("click", function (event) {
                const itemModal = document.getElementById("itemModal");
                const results = document.getElementById("itemStockSearchResults");

                if (!itemModal || !results) return;

                if (!itemModal.contains(event.target)) {
                    closeStockSearchResults();
                }
            });
        });
    </script>
