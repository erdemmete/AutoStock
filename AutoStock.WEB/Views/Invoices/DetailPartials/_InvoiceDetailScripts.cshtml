            invoiceState.vehicleBrandId = vehicleBrandId;
            invoiceState.vehicleModelId = vehicleModelId;
            invoiceState.vehicleBrandName = vehicleBrandName || null;
            invoiceState.vehicleModelName = vehicleModelName || null;
            invoiceState.vehicleModelYear = vehicleModelYear;
            invoiceState.mileage = mileage;

