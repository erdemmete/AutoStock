        async function saveCustomerModal() {
            const titleInput = document.getElementById("customerTitleInput");
            const tcknInput = document.getElementById("customerTcknInput");
            const taxOfficeInput = document.getElementById("customerTaxOfficeInput");
            const taxNumberInput = document.getElementById("customerTaxNumberInput");
            const emailInput = document.getElementById("customerEmailInput");
            const addressLineInput = document.getElementById("customerAddressLineInput");
            const addressCityInput = document.getElementById("customerAddressCityInput");
            const addressDistrictInput = document.getElementById("customerAddressDistrictInput");

            const title = normalizeText(titleInput.value, 150);
            const tckn = onlyDigits(tcknInput.value, 11);
            const taxNumber = onlyDigits(taxNumberInput.value, 10);
            const email = normalizeText(emailInput.value, 150);
            const taxOffice = taxOfficeInput.value;
            const addressLine = normalizeText(addressLineInput.value, 500);
            const addressCity = addressCityInput.value;
            const addressDistrict = addressDistrictInput.value;

            const address = buildCustomerInvoiceAddress(
                addressLine,
                addressCity,
                addressDistrict
            );

            if (!title) {
                setInvoiceFieldError(
                    titleInput,
                    "Alıcı adı / ünvan zorunludur.",
                    "invoiceCustomerModalError"
                );
                return;
            }

            if (invoiceCustomerType === "individual" && tckn && tckn.length !== 11) {
                setInvoiceFieldError(
                    tcknInput,
                    "TC kimlik numarası 11 haneli olmalıdır.",
                    "invoiceCustomerModalError"
                );
                return;
            }

            if (invoiceCustomerType !== "individual" && taxNumber && taxNumber.length !== 10) {
                setInvoiceFieldError(
                    taxNumberInput,
                    "Vergi numarası 10 haneli olmalıdır.",
                    "invoiceCustomerModalError"
                );
                return;
            }

            if (!isValidOptionalEmail(email)) {
                setInvoiceFieldError(
                    emailInput,
                    "Geçerli bir e-posta adresi giriniz.",
                    "invoiceCustomerModalError"
                );
                return;
            }

            invoiceState.customerTitle = title;
            invoiceState.customerEmail = email || null;
            invoiceState.customerAddressLine = addressLine || null;
            invoiceState.customerAddressCity = addressCity || null;
            invoiceState.customerAddressDistrict = addressDistrict || null;
            invoiceState.customerAddress = address || null;

            if (invoiceCustomerType === "individual") {
                invoiceState.customerTckn = tckn || null;
                invoiceState.customerTaxOffice = null;
                invoiceState.customerTaxNumber = null;
            } else {
                invoiceState.customerTckn = null;
                invoiceState.customerTaxOffice = taxOffice || null;
                invoiceState.customerTaxNumber = taxNumber || null;
            }

            invoiceState.updateCustomerCard = Boolean(
                document.getElementById("updateCustomerCardInput")?.checked
            );

            try {
                await persistInvoice();
                invoiceState.updateCustomerCard = false;
                refreshCustomerCard();
                closeAllInvoiceModals();
            } catch {
                invoiceState.updateCustomerCard = false;
            }
