@model AutoStock.WEB.Models.Invoices.InvoiceDetailViewModel
@using Microsoft.AspNetCore.Http

@{
    var isOwner = string.Equals(Context.Session.GetString("UserRole"), "Owner", StringComparison.OrdinalIgnoreCase);

    string GetStatusText(int status) => status switch
    {
        1 => "Taslak",
        2 => "Hazırlandı",
        3 => "İptal",
        _ => "Bilinmiyor"
    };

    var title = Model.Status switch
    {
        1 => "Hesap Özeti Taslağı",
        2 => "Hazırlanmış Servis Hesap Özeti",
        3 => "İptal Edilmiş Hesap Özeti",
        _ => "Servis Hesap Özeti Detayı"
    };
}

<header class="top-header">
    <div>
        <div class="title-row">
            <h1>@title</h1>
            <span class="status-badge status-@Model.Status">@GetStatusText(Model.Status)</span>
        </div>

        <p>
            <span>▧</span>
            @Model.InvoiceNumber numaralı servis hesap özeti
        </p>
    </div>

    <div class="header-actions">
        <a asp-controller="Dashboard"
           asp-action="Index"
           class="invoice-home-link"
           title="Ana Sayfa"
           aria-label="Ana Sayfa">
            <span>⌂</span>
            <strong>Ana Sayfa</strong>
        </a>

        @if (Model.Status == 2)
        {
            <a href="/Invoices/Print/@Model.Id" target="_blank" class="action-btn light">
                🖨 Yazdır
            </a>

            @if (isOwner)
            {
                <button type="button" class="action-btn danger" onclick="cancelInvoice(@Model.Id)">
                    × İptal Et
                </button>
            }
        }

        @if (Model.Status == 1)
        {
            <button type="button" class="action-btn primary" onclick="openCustomerModal()">
                ✎ Bilgileri Düzenle
            </button>

            <button type="button" class="action-btn success" onclick="issueInvoice(@Model.Id)">
                Hesap Özetini Onayla
            </button>
        }
    </div>
</header>
