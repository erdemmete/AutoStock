@model AutoStock.WEB.Models.Invoices.InvoiceDetailViewModel

@{
    ViewData["Title"] = "Hesap Özeti Detayı";
    var canForceEditLock = string.Equals(Context.Session.GetString("UserRole"), "Owner", StringComparison.Ordinal);
}

<link rel="stylesheet" href="~/css/entity-edit-lock.css" asp-append-version="true" />

<div class="invoice-page"
     data-entity-edit-lock
     data-entity-type="Invoice"
     data-entity-id="@Model.Id"
     data-can-force-release="@canForceEditLock.ToString().ToLowerInvariant()">

    @await Html.PartialAsync("~/Views/Invoices/DetailPartials/_InvoiceTopHeader.cshtml", Model)

    <main class="invoice-card">

        @await Html.PartialAsync("~/Views/Invoices/DetailPartials/_InvoiceDocumentHeader.cshtml", Model)

        @await Html.PartialAsync("~/Views/Invoices/DetailPartials/_InvoicePartyInfo.cshtml", Model)

        @await Html.PartialAsync("~/Views/Invoices/DetailPartials/_InvoiceItems.cshtml", Model)

        @await Html.PartialAsync("~/Views/Invoices/DetailPartials/_InvoiceTotals.cshtml", Model)

        @await Html.PartialAsync("~/Views/Invoices/DetailPartials/_InvoiceActionHub.cshtml", Model)

        @if (Model.Status == 1)
        {
            @await Html.PartialAsync("~/Views/Invoices/DetailPartials/_InvoiceModals.cshtml", Model)
        }

    </main>

</div>

@await Html.PartialAsync("~/Views/Invoices/DetailPartials/_InvoiceDetailStyles.cshtml", Model)

<script src="~/js/entity-edit-lock.js" asp-append-version="true"></script>

@await Html.PartialAsync("~/Views/Invoices/DetailPartials/_InvoiceDetailScripts.cshtml", Model)
