@model AutoStock.WEB.Models.Customers.CustomerDetailViewModel
@using AutoStock.Repositories.Enums
@using AutoStock.WEB.Models.Shared

@{
    ViewData["Title"] = "Müşteri Detayı";

    var displayName = !string.IsNullOrWhiteSpace(Model.DisplayName)
        ? Model.DisplayName
        : !string.IsNullOrWhiteSpace(Model.FullName)
            ? Model.FullName
            : !string.IsNullOrWhiteSpace(Model.CompanyName)
                ? Model.CompanyName
                : $"Müşteri #{Model.Id}";

    var recentServiceRecords = Model.RecentServiceRecords
        .OrderByDescending(x => x.CreatedAt)
        .ThenByDescending(x => x.Id)
        .ToList();

    var visibleGeneralServices = recentServiceRecords.Take(3).ToList();
    var addressText = JoinText(", ", Model.Address, Model.AddressDistrict, Model.AddressCity);
    var hasAddress = !string.IsNullOrWhiteSpace(addressText);
}

<div class="customer-detail-shell">
    <section class="customer-topbar">
        <div class="customer-identity">
            <a class="customer-back" asp-controller="Customers" asp-action="Index" aria-label="Müşteri listesine dön">←</a>

            <div class="customer-title">
                <h1>
                    <span>@displayName</span>
                    @if (!Model.IsActive)
                    {
                        <span class="customer-passive-badge">Pasif</span>
                    }
                </h1>

                <div class="customer-phone-line">@FormatPhone(Model.PhoneNumber)</div>

                <div class="customer-contact-row">
                    @await Html.PartialAsync("_ContactActions", new ContactActionsViewModel
                    {
                        PhoneNumber = Model.PhoneNumber,
                        CustomerName = displayName,
                        Variant = "compact",
                        EditUrl = Url.Action("Edit", "Customers", new { id = Model.Id })
                    })
                </div>
            </div>
        </div>

        <div class="customer-actions">
            <a class="customer-action primary" href="/ServiceRecords/Create?customerId=@Model.Id">Yeni Servis Kaydı</a>
            <a class="customer-action soft" asp-controller="Customers" asp-action="Edit" asp-route-id="@Model.Id">Düzenle</a>

            <div class="customer-more">
                <button type="button"
                        class="customer-more-btn"
                        data-customer-more-toggle
                        aria-haspopup="true"
                        aria-expanded="false"
                        aria-label="Diğer işlemler">
                    …
                </button>

                <div class="customer-more-menu" data-customer-more-menu hidden>
                    @if (Model.IsActive)
                    {
                        <form asp-controller="Customers"
                              asp-action="SetPassive"
                              asp-route-id="@Model.Id"
                              method="post"
                              onsubmit="return confirm('Bu müşteriyi pasife almak istediğinize emin misiniz?');">
                            <button type="submit">Müşteriyi Pasife Al</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="customer-section-switcher" aria-label="Müşteri detay bölümleri">
        <div class="customer-tabs" role="tablist">
            <button type="button" class="active" data-customer-tab="general">Genel</button>
            <button type="button" data-customer-tab="service-history">Servis Geçmişi</button>
            <button type="button" data-customer-tab="finance">Finans</button>
            <button type="button" data-customer-tab="details">Bilgiler</button>
        </div>

        <select class="customer-tab-select" data-customer-tab-select aria-label="Bölüm seç">
            <option value="general">Genel</option>
            <option value="service-history">Servis Geçmişi</option>
            <option value="finance">Finans</option>
            <option value="details">Bilgiler</option>
        </select>
    </section>

    <section class="customer-panel active" data-customer-panel="general">
        <div class="customer-mini-stats">
            <article>
                <span>Araç</span>
                <strong>@Model.VehicleCount</strong>
                <small>kayıtlı araç</small>
            </article>

            <article>
                <span>Servis Kaydı</span>
                <strong>@Model.ServiceRecordCount</strong>
                <small>@(Model.LastServiceDate.HasValue ? $"Son: {Model.LastServiceDate.Value:dd.MM.yyyy}" : "Henüz servis yok")</small>
            </article>
        </div>

        <div class="customer-two-col">
            <section class="customer-card">
                <div class="customer-card-head">
                    <div>
                        <span>Araçlar</span>
                        <h2>Kayıtlı Araçlar</h2>
                    </div>
                </div>

                @if (!Model.Vehicles.Any())
                {
                    <div class="customer-empty">
                        <strong>Kayıtlı araç yok</strong>
                        <span>İlk servis kaydında araç bilgisi oluşacaktır.</span>
                    </div>
                }
                else
                {
                    <div class="customer-vehicle-grid">
                        @foreach (var vehicle in Model.Vehicles)
                        {
                            var vehicleName = BuildVehicleName(vehicle.BrandName, vehicle.ModelName, vehicle.ModelYear);

                            <article class="customer-vehicle-card">
                                <div class="plate-box">
                                    <span>TR</span>
                                    <strong>@vehicle.Plate</strong>
                                </div>

                                <div>
                                    <strong>@(string.IsNullOrWhiteSpace(vehicleName) ? "Araç bilgisi belirtilmemiş" : vehicleName)</strong>
                                    <small>
                                        @(vehicle.Mileage.HasValue ? $"{vehicle.Mileage.Value:N0} km" : "Kilometre yok")
                                        @if (!string.IsNullOrWhiteSpace(vehicle.ChassisNumber))
                                        {
                                            <text> · Şasi: @vehicle.ChassisNumber</text>
                                        }
                                    </small>
                                </div>

                                <div class="customer-vehicle-foot">
                                    <span>@vehicle.ServiceRecordCount servis</span>
                                    <span>@(vehicle.LastServiceDate.HasValue ? vehicle.LastServiceDate.Value.ToString("dd.MM.yyyy") : "Servis yok")</span>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>

            <section class="customer-card">
                <div class="customer-card-head">
                    <div>
                        <span>Son kayıtlar</span>
                        <h2>Son Servis Kayıtları</h2>
                    </div>

                    @if (recentServiceRecords.Count > visibleGeneralServices.Count)
                    {
                        <button type="button" class="customer-section-link" data-customer-tab-link="service-history">Tümünü Gör</button>
                    }
                </div>

                @if (!visibleGeneralServices.Any())
                {
                    <div class="customer-empty compact">
                        <strong>Servis kaydı yok</strong>
                        <span>Bu müşteri için henüz servis işlemi açılmamış.</span>
                    </div>
                }
                else
                {
                    <div class="customer-service-list compact">
                        @foreach (var record in visibleGeneralServices)
                        {
                            @RenderServiceRecord(record, showAmount: false)
                        }
                    </div>
                }
            </section>
        </div>
    </section>

    <section class="customer-panel" data-customer-panel="service-history">
        <section class="customer-card">
            <div class="customer-card-head">
                <div>
                    <span>Servis geçmişi</span>
                    <h2>Servis Kayıtları</h2>
                </div>
            </div>

            @if (!recentServiceRecords.Any())
            {
                <div class="customer-empty">
                    <strong>Servis kaydı yok</strong>
                    <span>Bu müşteri için henüz servis işlemi açılmamış.</span>
                </div>
            }
            else
            {
                <div class="customer-service-list">
                    @foreach (var record in recentServiceRecords)
                    {
                        @RenderServiceRecord(record, showAmount: true)
                    }
                </div>
            }
        </section>
    </section>

    <section class="customer-panel" data-customer-panel="finance">
        <div class="customer-finance-grid">
            <article class="customer-finance-card balance @(Model.Balance > 0 ? "debt" : Model.Balance < 0 ? "credit" : "zero")">
                <span>Hesap Bakiyesi</span>
                <strong>@Money(Model.Balance)</strong>
                <small>@GetBalanceDescription(Model.Balance)</small>
            </article>

            <article class="customer-finance-card">
                <span>Servis Hesap Özeti</span>
                <strong>@Model.InvoiceCount</strong>
                <small>oluşturulan belge</small>
            </article>
        </div>

        <div class="customer-two-col finance">
            <section class="customer-card">
                <div class="customer-card-head">
                    <div>
                        <span>Belgeler</span>
                        <h2>Servis Hesap Özetleri ve Faturalar</h2>
                    </div>
                </div>

                @if (!Model.RecentInvoices.Any())
                {
                    <div class="customer-empty compact">
                        <strong>Belge yok</strong>
                        <span>Bu müşteri adına henüz servis hesap özeti oluşturulmamış.</span>
                    </div>
                }
                else
                {
                    <div class="customer-document-list">
                        @foreach (var invoice in Model.RecentInvoices)
                        {
                            var serviceSummaryUrl = Url.Action("Detail", "Invoices", new { invoiceId = invoice.Id }) ?? $"/Invoices/Detail/{invoice.Id}";
                            var serviceSummaryPrintUrl = Url.Action("Print", "Invoices", new { invoiceId = invoice.Id }) ?? $"/Invoices/Print/{invoice.Id}";
                            var officialInvoiceUrl = invoice.OfficialInvoice is not null
                                ? $"{Context.Request.Scheme}://{Context.Request.Host}{Url.Action("PublicInvoiceFile", "AccountingInvoiceRequests", new { shareToken = invoice.OfficialInvoice.ShareToken })}"
                                : null;
                            var officialInvoiceWhatsappText = officialInvoiceUrl is not null
                                ? Uri.EscapeDataString($"{invoice.InvoiceNumber} numaralı servis hesabına ait fatura: {officialInvoiceUrl}")
                                : null;

                            <article class="customer-document-card">
                                <div class="customer-document-main">
                                    <div>
                                        <span>Belge No</span>
                                        <strong>@invoice.InvoiceNumber</strong>
                                    </div>

                                    <div>
                                        <span>Plaka</span>
                                        <strong>@(string.IsNullOrWhiteSpace(invoice.Plate) ? "-" : invoice.Plate)</strong>
                                    </div>

                                    <div>
                                        <span>Tarih</span>
                                        <strong>@invoice.InvoiceDate.ToString("dd.MM.yyyy")</strong>
                                    </div>

                                    <div>
                                        <span>Tutar</span>
                                        <strong>@Money(invoice.GrandTotal)</strong>
                                    </div>
                                </div>

                                <div class="customer-document-actions">
                                    <div>
                                        <strong>Servis Hesap Özeti</strong>
                                        <span class="customer-document-badge @InvoiceStatusClass(invoice.StatusText)">@GetInvoiceStatusText(invoice.StatusText)</span>
                                    </div>

                                    <div class="customer-document-buttons">
                                        <a href="@serviceSummaryUrl">Görüntüle</a>
                                        <a href="@serviceSummaryPrintUrl" target="_blank" rel="noopener">PDF</a>
                                    </div>
                                </div>

                                <div class="customer-document-actions official">
                                    @if (invoice.OfficialInvoice is null)
                                    {
                                        <div>
                                            <strong>Fatura</strong>
                                            <span class="customer-document-muted">Fatura bekleniyor</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div>
                                            <strong>Fatura</strong>
                                            <span class="customer-document-badge success">Fatura yüklendi</span>
                                            <small>@invoice.OfficialInvoice.OfficialInvoiceNumber · @invoice.OfficialInvoice.OfficialInvoiceDate.ToString("dd.MM.yyyy")</small>
                                        </div>

                                        <div class="customer-document-buttons">
                                            <a href="@officialInvoiceUrl" target="_blank" rel="noopener">Görüntüle</a>
                                            <a href="@Url.Action("DownloadOfficialDocument", "AccountingInvoiceRequests", new { documentId = invoice.OfficialInvoice.Id })">İndir</a>
                                            <a href="https://wa.me/?text=@officialInvoiceWhatsappText" target="_blank" rel="noopener">Paylaş</a>
                                        </div>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>

            <section class="customer-card">
                <div class="customer-card-head">
                    <div>
                        <span>Hesap</span>
                        <h2>Son Hesap Hareketleri</h2>
                    </div>
                </div>

                @if (!Model.RecentCurrentAccountMovements.Any())
                {
                    <div class="customer-empty compact">
                        <strong>Hareket yok</strong>
                        <span>Bu müşteri için henüz hesap hareketi oluşmamış.</span>
                    </div>
                }
                else
                {
                    <div class="customer-mini-list">
                        @foreach (var movement in Model.RecentCurrentAccountMovements)
                        {
                            <div class="customer-mini-row">
                                <div>
                                    <strong>@GetMovementTypeText(movement.TypeText)</strong>
                                    <span>@movement.TransactionDate.ToString("dd.MM.yyyy") · @(movement.DocumentNumber ?? movement.Description)</span>
                                </div>

                                <div>
                                    <strong class="@(movement.BalanceEffect >= 0 ? "money-debit" : "money-credit")">@Money(movement.BalanceEffect)</strong>
                                </div>
                            </div>
                        }
                    </div>
                }
            </section>
        </div>
    </section>

    <section class="customer-panel" data-customer-panel="details">
        <div class="customer-details-grid">
            <section class="customer-card">
                <div class="customer-card-head">
                    <div>
                        <span>Kimlik / Firma</span>
                        <h2>Temel Bilgiler</h2>
                    </div>
                </div>

                <dl class="customer-info-list">
                    <div><dt>Tip</dt><dd>@GetCustomerTypeText(Model.Type)</dd></div>
                    @RenderInfo("Ad / Ünvan", Model.FullName)
                    @RenderInfo("Tabela / Firma", Model.CompanyName)
                    @RenderInfo("Yetkili Kişi", Model.AuthorizedPersonName)
                    <div><dt>Kayıt Tarihi</dt><dd>@Model.CreatedAt.ToString("dd.MM.yyyy")</dd></div>
                </dl>
            </section>

            <section class="customer-card">
                <div class="customer-card-head">
                    <div>
                        <span>İletişim</span>
                        <h2>Telefon ve E-posta</h2>
                    </div>
                </div>

                <dl class="customer-info-list">
                    <div><dt>Telefon</dt><dd>@FormatPhone(Model.PhoneNumber)</dd></div>
                    @if (!string.IsNullOrWhiteSpace(Model.Email))
                    {
                        <div><dt>E-posta</dt><dd><a href="mailto:@Model.Email">@Model.Email</a></dd></div>
                    }
                    else
                    {
                        <div><dt>E-posta</dt><dd>Belirtilmemiş</dd></div>
                    }
                </dl>
            </section>

            <section class="customer-card">
                <div class="customer-card-head">
                    <div>
                        <span>Adres</span>
                        <h2>Adres Bilgileri</h2>
                    </div>
                    @if (hasAddress)
                    {
                        <a class="customer-section-link" href="https://www.google.com/maps/search/?api=1&query=@Uri.EscapeDataString(addressText)" target="_blank" rel="noopener">Haritada Aç</a>
                    }
                </div>

                <dl class="customer-info-list">
                    @RenderInfo("İl", Model.AddressCity)
                    @RenderInfo("İlçe", Model.AddressDistrict)
                    @RenderInfo("Açık Adres", Model.Address)
                    @if (!hasAddress)
                    {
                        <div><dt>Adres</dt><dd>Belirtilmemiş</dd></div>
                    }
                </dl>
            </section>

            <section class="customer-card">
                <div class="customer-card-head">
                    <div>
                        <span>Vergi</span>
                        <h2>Vergi Bilgileri</h2>
                    </div>
                </div>

                <dl class="customer-info-list">
                    @RenderInfo("TC Kimlik No", Model.NationalIdentityNumber)
                    @RenderInfo("Vergi No", Model.TaxNumber)
                    @RenderInfo("Vergi Dairesi", Model.TaxOffice)
                    @if (string.IsNullOrWhiteSpace(Model.NationalIdentityNumber)
                        && string.IsNullOrWhiteSpace(Model.TaxNumber)
                        && string.IsNullOrWhiteSpace(Model.TaxOffice))
                    {
                        <div><dt>Vergi bilgileri</dt><dd>Belirtilmemiş</dd></div>
                    }
                </dl>
            </section>
        </div>
    </section>
</div>

<style>
    .customer-detail-shell {
        width: min(1360px, calc(100% - 48px));
        margin: 0 auto;
        padding: 24px 0 64px;
        color: #0f172a;
    }

    .customer-topbar {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 18px;
        padding: 18px;
        border: 1px solid #dbe6f4;
        border-radius: 26px;
        background: linear-gradient(135deg, #ffffff 0%, #f6f9ff 100%);
        box-shadow: 0 18px 48px rgba(15, 23, 42, .075);
    }

    .customer-identity {
        min-width: 0;
        display: flex;
        align-items: flex-start;
        gap: 14px;
    }

    .customer-back {
        width: 44px;
        height: 44px;
        flex: 0 0 44px;
        border-radius: 15px;
        display: grid;
        place-items: center;
        text-decoration: none;
        font-weight: 950;
    }

    .customer-back {
        background: #ffffff;
        border: 1px solid #d8e2ef;
        color: #64748b;
        font-size: 22px;
    }

    .customer-title {
        min-width: 0;
    }

    .customer-title h1 {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        margin: 1px 0 5px;
        font-size: clamp(25px, 3.2vw, 38px);
        line-height: 1.02;
        font-weight: 950;
        letter-spacing: -.04em;
    }

    .customer-title h1 span:first-child {
        min-width: 0;
        overflow-wrap: anywhere;
    }

    .customer-phone-line {
        color: #475569;
        font-size: 15px;
        font-weight: 850;
        line-height: 1.35;
    }

    .customer-passive-badge {
        min-height: 24px;
        padding: 0 9px;
        border-radius: 999px;
        border: 1px solid #fecdd3;
        background: #fff1f2;
        color: #be123c;
        display: inline-flex;
        align-items: center;
        font-size: 12px;
        font-weight: 950;
        letter-spacing: 0;
    }

    .customer-contact-row {
        display: flex;
        align-items: center;
        gap: 7px;
        flex-wrap: wrap;
    }

    .customer-contact-row {
        margin-top: 8px;
    }

    .customer-actions {
        display: flex;
        align-items: center;
        gap: 9px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .customer-action,
    .customer-more-btn {
        min-height: 42px;
        border-radius: 15px;
        border: 1px solid #d8e2ef;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: #0f172a;
        background: #ffffff;
        font-size: 13px;
        font-weight: 950;
        cursor: pointer;
    }

    .customer-action {
        padding: 0 15px;
    }

    .customer-action.primary {
        background: #2563eb;
        border-color: #2563eb;
        color: #ffffff;
        box-shadow: 0 14px 28px rgba(37, 99, 235, .20);
    }

    .customer-action.soft {
        background: #f8fafc;
    }

    .customer-more {
        position: relative;
    }

    .customer-more-btn {
        width: 44px;
        font-size: 24px;
        line-height: 1;
    }

    .customer-more-menu {
        position: absolute;
        right: 0;
        top: calc(100% + 8px);
        z-index: 20;
        min-width: 220px;
        padding: 7px;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        background: #ffffff;
        box-shadow: 0 22px 48px rgba(15, 23, 42, .16);
    }

    .customer-more-menu button {
        width: 100%;
        min-height: 42px;
        border: none;
        border-radius: 12px;
        background: #fff1f2;
        color: #be123c;
        font-weight: 950;
        cursor: pointer;
        text-align: left;
        padding: 0 12px;
    }

    .customer-section-switcher {
        margin: 18px 0;
        padding: 8px;
        border: 1px solid #dbe6f4;
        border-radius: 20px;
        background: #ffffff;
        box-shadow: 0 10px 28px rgba(15, 23, 42, .045);
    }

    .customer-tabs {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 7px;
    }

    .customer-tabs button {
        min-height: 42px;
        border: none;
        border-radius: 14px;
        background: transparent;
        color: #64748b;
        font-weight: 950;
        cursor: pointer;
    }

    .customer-tabs button.active {
        background: #eef2ff;
        color: #2563eb;
    }

    .customer-tab-select {
        display: none;
        width: 100%;
        height: 46px;
        border: 1px solid #d8e2ef;
        border-radius: 15px;
        background: #f8fafc;
        color: #0f172a;
        padding: 0 13px;
        font-weight: 950;
    }

    .customer-panel {
        display: none;
    }

    .customer-panel.active {
        display: block;
    }

    .customer-mini-stats,
    .customer-finance-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
        margin-bottom: 14px;
    }

    .customer-mini-stats article,
    .customer-finance-card {
        padding: 18px;
        border-radius: 22px;
        border: 1px solid #dbe6f4;
        background: #ffffff;
        box-shadow: 0 12px 32px rgba(15, 23, 42, .055);
    }

    .customer-mini-stats span,
    .customer-finance-card span {
        display: block;
        color: #64748b;
        font-size: 12px;
        font-weight: 950;
    }

    .customer-mini-stats strong,
    .customer-finance-card strong {
        display: block;
        margin: 8px 0 4px;
        color: #0f172a;
        font-size: 26px;
        line-height: 1;
        font-weight: 950;
    }

    .customer-mini-stats small,
    .customer-finance-card small {
        color: #64748b;
        font-size: 12px;
        font-weight: 850;
    }

    .customer-finance-card.balance.debt {
        background: linear-gradient(135deg, #ffffff 0%, #fff7ed 100%);
        border-color: #fed7aa;
    }

    .customer-finance-card.balance.credit {
        background: linear-gradient(135deg, #ffffff 0%, #ecfdf5 100%);
        border-color: #bbf7d0;
    }

    .customer-two-col,
    .customer-details-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.15fr) minmax(0, .85fr);
        gap: 14px;
        align-items: start;
    }

    .customer-two-col.finance,
    .customer-details-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .customer-card {
        min-width: 0;
        padding: 18px;
        border-radius: 24px;
        border: 1px solid #dbe6f4;
        background: #ffffff;
        box-shadow: 0 12px 32px rgba(15, 23, 42, .055);
    }

    .customer-card-head {
        margin-bottom: 14px;
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: flex-start;
    }

    .customer-card-head span {
        color: #64748b;
        font-size: 12px;
        font-weight: 950;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .customer-card-head h2 {
        margin: 3px 0 0;
        color: #0f172a;
        font-size: 21px;
        font-weight: 950;
        letter-spacing: -.03em;
    }

    .customer-section-link {
        border: none;
        border-radius: 999px;
        padding: 9px 12px;
        background: #eef2ff;
        color: #2563eb;
        text-decoration: none;
        font-size: 12px;
        font-weight: 950;
        cursor: pointer;
        white-space: nowrap;
    }

    .customer-vehicle-grid,
    .customer-service-list,
    .customer-mini-list {
        display: grid;
        gap: 10px;
    }

