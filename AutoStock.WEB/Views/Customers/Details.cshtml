<script>
    document.addEventListener("DOMContentLoaded", function () {
        const tabs = Array.from(document.querySelectorAll("[data-customer-tab]"));
        const panels = Array.from(document.querySelectorAll("[data-customer-panel]"));
        const select = document.querySelector("[data-customer-tab-select]");
        const sectionLinks = document.querySelectorAll("[data-customer-tab-link]");
        const moreToggle = document.querySelector("[data-customer-more-toggle]");
        const moreMenu = document.querySelector("[data-customer-more-menu]");
        const validTabs = ["general", "service-history", "finance", "details"];

        function showTab(tabName, updateHash) {
            const target = validTabs.includes(tabName) ? tabName : "general";

            tabs.forEach(tab => {
                tab.classList.toggle("active", tab.dataset.customerTab === target);
            });

            panels.forEach(panel => {
                panel.classList.toggle("active", panel.dataset.customerPanel === target);
            });

            if (select) {
                select.value = target;
            }

            if (updateHash) {
                history.replaceState(null, "", "#" + target);
            }
        }

        tabs.forEach(tab => {
            tab.addEventListener("click", function () {
                showTab(tab.dataset.customerTab || "general", true);
            });
        });

        select?.addEventListener("change", function () {
            showTab(select.value, true);
        });

        sectionLinks.forEach(link => {
            link.addEventListener("click", function () {
                showTab(link.dataset.customerTabLink || "general", true);
            });
        });

        moreToggle?.addEventListener("click", function (event) {
            event.stopPropagation();
            const isHidden = moreMenu?.hasAttribute("hidden");

            if (!moreMenu) {
                return;
            }

            moreMenu.toggleAttribute("hidden", !isHidden);
            moreToggle.setAttribute("aria-expanded", isHidden ? "true" : "false");
        });

        document.addEventListener("click", function (event) {
            if (!moreMenu || moreMenu.hasAttribute("hidden")) {
                return;
            }

            if (!event.target.closest(".customer-more")) {
                moreMenu.setAttribute("hidden", "");
                moreToggle?.setAttribute("aria-expanded", "false");
            }
        });

        document.addEventListener("keydown", function (event) {
            if (event.key === "Escape" && moreMenu && !moreMenu.hasAttribute("hidden")) {
                moreMenu.setAttribute("hidden", "");
                moreToggle?.setAttribute("aria-expanded", "false");
                moreToggle?.focus();
            }
        });

        const initialHash = (window.location.hash || "").replace("#", "");
        showTab(initialHash, false);
    });
</script>

@functions {
    private static string ValueOrDash(string? value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? "Belirtilmemiş"
            : value;
    }

    private static string GetInitial(string value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? "M"
            : value.Trim()[0].ToString().ToUpperInvariant();
    }

    private static string Money(decimal value) => AutoStock.WEB.Helpers.SenteMoney.Format(value);

    private static string FormatPhone(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "Telefon yok";

        var digits = new string(value.Where(char.IsDigit).ToArray());

        if (digits.Length == 10)
            return $"0{digits[..3]} {digits.Substring(3, 3)} {digits.Substring(6, 2)} {digits.Substring(8, 2)}";

        if (digits.Length == 11 && digits.StartsWith("0"))
            return $"{digits[..4]} {digits.Substring(4, 3)} {digits.Substring(7, 2)} {digits.Substring(9, 2)}";

        return value;
    }

    private static string JoinText(string separator, params string?[] values)
    {
        return string.Join(separator, values.Where(x => !string.IsNullOrWhiteSpace(x)).Select(x => x!.Trim()));
    }

    private static string GetBalanceDescription(decimal balance)
    {
        if (balance > 0)
            return "tahsil edilecek";

        if (balance < 0)
            return "müşteri alacaklı";

        return "bakiye yok";
    }

    private static string GetCustomerTypeText(CustomerType type)
    {
        return type switch
        {
            CustomerType.Individual => "Bireysel",
            CustomerType.SoleProprietorship => "Şahıs Firması",
            CustomerType.Corporate => "Kurumsal",
            _ => type.ToString()
        };
    }

    private static string BuildVehicleName(string? brand, string? model, int? year)
    {
        var parts = new List<string>();

        if (!string.IsNullOrWhiteSpace(brand)) parts.Add(brand);
        if (!string.IsNullOrWhiteSpace(model)) parts.Add(model);
        if (year.HasValue) parts.Add(year.Value.ToString());

        return string.Join(" ", parts);
    }

    private static string StatusClass(string status)
    {
        return status switch
        {
            "Open" => "open",
            "InProgress" => "progress",
            "Completed" => "completed",
            "Cancelled" => "cancelled",
            _ => "open"
        };
    }

    private static string InvoiceStatusClass(string status)
    {
        return status switch
        {
            "Draft" => "draft",
            "Issued" => "issued",
            "Cancelled" => "cancelled",
            _ => "draft"
        };
    }

    private static string GetServiceStatusText(string status)
    {
        return status switch
        {
            "Open" => "Açık",
            "InProgress" => "İşlemde",
            "Completed" => "Tamamlandı",
            "Cancelled" => "İptal",
            _ => status
        };
    }

    private static string GetInvoiceStatusText(string status)
    {
        return status switch
        {
            "Draft" => "Taslak",
            "Issued" => "Hazırlandı",
            "Cancelled" => "İptal",
            _ => status
        };
    }

    private static string GetMovementTypeText(string type)
    {
        return type switch
        {
            "InvoiceDebit" => "Servis Hesap Özeti",
            "InvoiceIssued" => "Servis Hesap Özeti",
            "Payment" => "Tahsilat",
            "Refund" => "İade",
            "Adjustment" => "Düzeltme",
            "Cancel" => "İptal",
            "InvoiceCancellation" => "Belge İptali",
            _ => type
        };
    }

    private static Microsoft.AspNetCore.Html.IHtmlContent RenderInfo(string label, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return new Microsoft.AspNetCore.Html.HtmlString(string.Empty);
        }

        var html = $"<div><dt>{System.Net.WebUtility.HtmlEncode(label)}</dt><dd>{System.Net.WebUtility.HtmlEncode(value)}</dd></div>";

        return new Microsoft.AspNetCore.Html.HtmlString(html);
    }

    private static Microsoft.AspNetCore.Html.IHtmlContent RenderServiceRecord(
        AutoStock.WEB.Models.Customers.CustomerServiceRecordSummaryViewModel record,
        bool showAmount)
    {
        var vehicleName = BuildVehicleName(record.VehicleBrandName, record.VehicleModelName, null);
        var statusClass = StatusClass(record.StatusText);
        var complaint = string.IsNullOrWhiteSpace(record.ComplaintTitle) ? "Servis kaydı" : record.ComplaintTitle;
        var amount = showAmount ? $"<strong>{System.Net.WebUtility.HtmlEncode(Money(record.TotalAmount))}</strong>" : string.Empty;

        var html = $"""
            <a class="customer-service-row" href="/ServiceRecords/Detail/{record.Id}">
                <div>
                    <strong>{System.Net.WebUtility.HtmlEncode(record.RecordNumber)}</strong>
                    <span>{System.Net.WebUtility.HtmlEncode(record.VehiclePlate)} · {System.Net.WebUtility.HtmlEncode(string.IsNullOrWhiteSpace(vehicleName) ? "Araç bilgisi yok" : vehicleName)}</span>
                    <small>{System.Net.WebUtility.HtmlEncode(complaint)}</small>
                </div>
                <div class="customer-service-side">
                    <span class="customer-status {statusClass}">{System.Net.WebUtility.HtmlEncode(GetServiceStatusText(record.StatusText))}</span>
                    {amount}
                    <small>{record.CreatedAt:dd.MM.yyyy}</small>
                </div>
            </a>
            """;

        return new Microsoft.AspNetCore.Html.HtmlString(html);
    }
}
