<script>
    document.addEventListener("DOMContentLoaded", function () {
        const toggleButton = document.querySelector("[data-filter-toggle]");
        const filterPanel = document.querySelector("[data-filter-panel]");
        const typeInput = document.getElementById("CustomerTypeFilter");
        const typeButtons = document.querySelectorAll("[data-type-value]");

        toggleButton?.addEventListener("click", function () {
            const isOpen = filterPanel?.classList.toggle("is-open");

            toggleButton.classList.toggle("is-open", !!isOpen);
            toggleButton.setAttribute("aria-expanded", isOpen ? "true" : "false");
        });

        typeButtons.forEach(button => {
            button.addEventListener("click", function () {
                if (!typeInput) {
                    return;
                }

                typeInput.value = this.dataset.typeValue ?? "";

                typeButtons.forEach(x => x.classList.remove("active"));
                this.classList.add("active");
            });
        });
    });
</script>
