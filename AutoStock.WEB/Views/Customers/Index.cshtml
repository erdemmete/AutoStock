@model AutoStock.WEB.Models.Customers.CustomerIndexViewModel
@using AutoStock.Repositories.Enums
@using AutoStock.WEB.Models.Common
@using AutoStock.WEB.Models.Customers

@{
    ViewData["Title"] = "Müşteriler";

    var items = Model.Customers.Items ?? new List<CustomerListItemViewModel>();

    var totalCustomerCount = Model.Customers.TotalCount;
    var currentPageCount = items.Count;

    var pageNumber = Model.Customers.PageNumber > 0 ? Model.Customers.PageNumber : Model.Query.PageNumber;
    var pageSize = Model.Customers.PageSize > 0 ? Model.Customers.PageSize : Model.Query.PageSize;

    var paginationModel = new PaginationViewModel
    {
        Controller = "Customers",
        Action = "Index",
        PageNumber = pageNumber,
        PageSize = pageSize,
        TotalCount = totalCustomerCount,
        RouteValues = new Dictionary<string, string?>
        {
            ["search"] = Model.Query.Search,
            ["type"] = Model.Query.Type.HasValue ? ((int)Model.Query.Type.Value).ToString() : null
        }
    };

    string GetTypeText(string? typeText)
    {
        return typeText switch
        {
            "Corporate" => "Kurumsal",
            "SoleProprietorship" => "Şahıs Firması",
            "Individual" => "Bireysel",
            _ => "Bireysel"
        };
    }
}

<div class="customer-page">

    <div class="page-badge">👥 Müşteri Yönetimi</div>

    <div class="customer-header">
        <div>
            <h1>Müşteriler</h1>
            <p>
                Tüm bireysel, şahıs ve kurumsal müşterilerinizi yönetin,
                servis geçmişlerini inceleyin ve yeni kayıtlar oluşturun.
            </p>
        </div>

        @await Html.PartialAsync("_PageActions", new PageActionViewModel
        {
            BackController = "Dashboard",
            BackAction = "Index",
            HomeController = "Dashboard",
            HomeAction = "Index",
            PrimaryText = "+ Yeni Müşteri Ekle",
            PrimaryController = "Customers",
            PrimaryAction = "Create"
        })
    </div>

    <div class="customer-table-card">

        <form method="get" asp-controller="Customers" asp-action="Index" class="table-toolbar">

            <div class="search-box">
                <span>⌕</span>
                <input name="Search"
                       value="@Model.Query.Search"
                       type="text"
                       placeholder="İsim, firma, telefon, e-posta, TCKN veya VKN ile ara..." />
            </div>

            <select name="Type" class="filter-select">
                <option value="">Tüm müşteri türleri</option>

                <option value="@((int)CustomerType.Individual)"
                        selected="@(Model.Query.Type == CustomerType.Individual ? "selected" : null)">
                    Bireysel
                </option>

                <option value="@((int)CustomerType.SoleProprietorship)"
                        selected="@(Model.Query.Type == CustomerType.SoleProprietorship ? "selected" : null)">
                    Şahıs
                </option>

                <option value="@((int)CustomerType.Corporate)"
                        selected="@(Model.Query.Type == CustomerType.Corporate ? "selected" : null)">
                    Kurumsal
                </option>
            </select>

            <select name="PageSize" class="filter-select">
                <option value="10" selected="@(pageSize == 10 ? "selected" : null)">10 kayıt</option>
                <option value="25" selected="@(pageSize == 25 ? "selected" : null)">25 kayıt</option>
                <option value="50" selected="@(pageSize == 50 ? "selected" : null)">50 kayıt</option>
            </select>

            <input type="hidden" name="PageNumber" value="1" />

            <button type="submit" class="filter-btn">
                Filtrele
            </button>

            <a asp-controller="Customers"
               asp-action="Index"
               class="clear-btn">
                Temizle
            </a>

        </form>

        @await Html.PartialAsync("_Pagination", paginationModel)

        <table class="customer-table">
            <thead>
                <tr>
                    <th>Müşteri Profili</th>
                    <th>İletişim</th>
                    <th>Tür</th>
                    <th class="text-end">Cari Bakiye</th>
                    <th class="text-end">İşlem</th>
                </tr>
            </thead>

            <tbody>
                @if (!items.Any())
                {
                    <tr>
                        <td colspan="5">
                            <div class="empty-state">
                                Kayıt bulunamadı. Arama veya filtre kriterlerini değiştirerek tekrar deneyin.
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in items)
                    {
                        var initials = string.IsNullOrWhiteSpace(item.DisplayName)
                            ? "?"
                            : item.DisplayName.Substring(0, 1).ToUpper();

                        var balanceClass = item.Balance >= 0 ? "positive" : "negative";

                        <tr class="customer-row">
                            <td>
                                <div class="profile-cell">
                                    <div class="avatar">@initials</div>

                                    <div>
                                        <strong>
                                            @item.DisplayName
                                            <span class="active-dot"></span>
                                        </strong>
                                        <small>Müşteri No: @item.Id</small>
                                    </div>
                                </div>
                            </td>

                            <td>
                                <div class="contact-cell">
                                    <div>☎ @(item.PhoneNumber ?? "-")</div>
                                    <small>✉ @(item.Email ?? "-")</small>
                                </div>
                            </td>

                            <td>
                                <span class="type-badge">
                                    @GetTypeText(item.TypeText)
                                </span>
                            </td>

                            <td class="text-end">
                                <strong class="@balanceClass">
                                    @item.Balance.ToString("N2") TL
                                </strong>
                            </td>

                            <td class="text-end">
                                <div class="action-group">
                                    <a class="action-btn"
                                       href="/CurrentAccounts/Customer/@item.Id">
                                        Cari
                                    </a>

                                    <a asp-controller="Customers"
                                       asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="action-btn">
                                        Detay
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        @await Html.PartialAsync("_Pagination", paginationModel)

    </div>

</div>

<style>
    .customer-page {
        max-width: 1320px;
        margin: 0 auto;
        padding: 32px 24px;
        color: #061936;
    }

    .page-badge {
        display: inline-flex;
        align-items: center;
        background: #eef2ff;
        color: #4f35e8;
        padding: 8px 14px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 14px;
        margin-bottom: 16px;
    }

    .customer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 36px;
        gap: 24px;
    }

        .customer-header h1 {
            font-size: 34px;
            font-weight: 900;
            margin: 0 0 10px;
        }

        .customer-header p {
            max-width: 620px;
            color: #667896;
            font-size: 17px;
            line-height: 1.5;
            margin: 0;
        }

    .customer-table-card {
        background: #fff;
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid #e4ebf5;
        box-shadow: 0 14px 40px rgba(15, 23, 42, .07);
    }

    .table-toolbar {
        padding: 22px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        border-bottom: 1px solid #edf2f7;
        flex-wrap: wrap;
    }

    .search-box {
        width: 430px;
        height: 48px;
        border: 1px solid #d4deec;
        border-radius: 13px;
        display: flex;
        align-items: center;
        padding: 0 16px;
        gap: 10px;
    }

        .search-box input {
            border: none;
            outline: none;
            width: 100%;
            font-size: 15px;
        }

    .filter-select {
        height: 48px;
        border: 1px solid #d4deec;
        border-radius: 13px;
        padding: 0 14px;
        font-weight: 700;
        color: #18365d;
        background: #fff;
        outline: none;
    }

    .filter-btn,
    .clear-btn,
    .action-btn {
        border: 1px solid #cbd8ea;
        background: #fff;
        color: #18365d;
        border-radius: 10px;
        padding: 10px 16px;
        font-weight: 800;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .filter-btn {
        height: 48px;
        cursor: pointer;
    }

    .clear-btn {
        height: 48px;
    }

    .customer-table {
        width: 100%;
        border-collapse: collapse;
    }

        .customer-table thead {
            background: #f7faff;
        }

        .customer-table th {
            text-align: left;
            padding: 18px 24px;
            color: #667896;
            font-size: 13px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: .04em;
        }

        .customer-table td {
            padding: 22px 24px;
            border-top: 1px solid #edf2f7;
            vertical-align: middle;
        }

    .profile-cell {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .avatar {
        width: 52px;
        height: 52px;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        color: #17365d;
    }

    .profile-cell strong {
        display: block;
        font-size: 16px;
        margin-bottom: 6px;
    }

    .profile-cell small,
    .contact-cell small {
        color: #667896;
    }

    .active-dot {
        display: inline-block;
        width: 7px;
        height: 7px;
        background: #10b981;
        border-radius: 50%;
        margin-left: 6px;
    }

    .contact-cell div {
        margin-bottom: 6px;
    }

    .type-badge {
        background: #eef2ff;
        color: #4f35e8;
        padding: 7px 13px;
        border-radius: 999px;
        font-weight: 900;
        font-size: 13px;
    }

    .positive {
        color: #009966;
    }

    .negative {
        color: #e60046;
    }

    .text-end {
        text-align: right !important;
    }

    .action-group {
        display: inline-flex;
        justify-content: flex-end;
        gap: 8px;
    }

    .empty-state {
        padding: 28px;
        text-align: center;
        color: #667896;
        font-weight: 800;
    }

    @@media (max-width: 900px) {
        .customer-header,
        .table-toolbar {
            flex-direction: column;
            align-items: flex-start;
        }

        .search-box {
            width: 100%;
        }

        .customer-table-card {
            overflow-x: auto;
        }

        .customer-table {
            min-width: 980px;
        }
    }
</style>