@model AutoStock.WEB.Models.Customers.CustomerIndexViewModel
@using AutoStock.Repositories.Enums
@using AutoStock.WEB.Models.Customers

@{
    ViewData["Title"] = "Müşteriler";

    var items = Model.Customers.Items ?? new List<CustomerListItemViewModel>();

    var totalCustomerCount = Model.Customers.TotalCount;
    var pageNumber = Model.Customers.PageNumber > 0 ? Model.Customers.PageNumber : Model.Query.PageNumber;
    var pageSize = Model.Customers.PageSize > 0 ? Model.Customers.PageSize : Model.Query.PageSize;
    var totalPages = Model.Customers.TotalPages;

    var currentType = Model.Query.Type;

    var hasAdvancedFilter =
        currentType.HasValue ||
        pageSize != 10;

    string GetTypeText(string? typeText)
    {
        return typeText switch
        {
            "Corporate" => "Kurumsal",
            "SoleProprietorship" => "Şahıs",
            "Individual" => "Bireysel",
            "Kurumsal" => "Kurumsal",
            "Şahıs" => "Şahıs",
            "Şahıs Firması" => "Şahıs",
            "Bireysel" => "Bireysel",
            _ => "Bireysel"
        };
    }

    string GetTypeClass(string? typeText)
    {
        return GetTypeText(typeText) switch
        {
            "Kurumsal" => "type-corporate",
            "Şahıs" => "type-sole",
            _ => "type-individual"
        };
    }

    string GetInitials(string? displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName))
            return "?";

        var words = displayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (words.Length == 1)
            return words[0].Substring(0, 1).ToUpper();

        return $"{words[0][0]}{words[^1][0]}".ToUpper();
    }
}

<div class="cus-page">
    <section class="cus-hero">
        <div class="cus-hero-left">
            <a asp-controller="Dashboard"
               asp-action="Index"
               class="cus-home-btn"
               title="Ana sayfa">
                ⌂
            </a>

            <div>
                <span class="cus-eyebrow">SENTE360</span>
                <h1>Müşteriler</h1>
                <p>Müşteri bilgilerini, iletişim detaylarını ve hesap durumlarını hızlıca yönetin.</p>
            </div>
        </div>

        <a asp-controller="Customers"
           asp-action="Create"
           class="cus-create-btn">
            <span>+</span>
            <strong>Yeni Müşteri</strong>
        </a>
    </section>

    <section class="cus-filter-shell">
        <form method="get" asp-controller="Customers" asp-action="Index" id="customerFilterForm">
            <input type="hidden" name="PageNumber" value="1" />
            <input type="hidden" name="Type" id="CustomerTypeFilter" value="@(currentType.HasValue ? ((int)currentType.Value).ToString() : "")" />

            <div class="cus-search-row">
                <div class="cus-search-box">
                    <span class="cus-search-icon">⌕</span>
                    <input name="Search"
                           value="@Model.Query.Search"
                           type="text"
                           placeholder="İsim, firma, telefon veya e-posta ara..." />
                </div>

                <button type="submit" class="cus-search-submit">
                    Ara
                </button>

                <button type="button"
                        class="cus-filter-toggle @(hasAdvancedFilter ? "is-open" : "")"
                        data-filter-toggle
                        aria-expanded="@(hasAdvancedFilter ? "true" : "false")">
                    <span>☷</span>
                    <strong>Filtreler</strong>
                    <em>⌄</em>
                </button>
            </div>

            <div class="cus-advanced-filters @(hasAdvancedFilter ? "is-open" : "")" data-filter-panel>
                <div class="cus-filter-section">
                    <label>Müşteri Türü</label>

                    <div class="cus-type-chips">
                        <button type="button"
                                class="cus-type-chip @(!currentType.HasValue ? "active" : "")"
                                data-type-value="">
                            Tümü
                        </button>

                        <button type="button"
                                class="cus-type-chip @(currentType == CustomerType.Individual ? "active" : "")"
                                data-type-value="@((int)CustomerType.Individual)">
                            Bireysel
                        </button>

                        <button type="button"
                                class="cus-type-chip @(currentType == CustomerType.SoleProprietorship ? "active" : "")"
                                data-type-value="@((int)CustomerType.SoleProprietorship)">
                            Şahıs
                        </button>

                        <button type="button"
                                class="cus-type-chip @(currentType == CustomerType.Corporate ? "active" : "")"
                                data-type-value="@((int)CustomerType.Corporate)">
                            Kurumsal
                        </button>
                    </div>
                </div>

                <div class="cus-filter-section">
                    <label>Sayfa Boyutu</label>
                    <select name="PageSize">
                        <option value="10" selected="@(pageSize == 10 ? "selected" : null)">10 kayıt</option>
                        <option value="25" selected="@(pageSize == 25 ? "selected" : null)">25 kayıt</option>
                        <option value="50" selected="@(pageSize == 50 ? "selected" : null)">50 kayıt</option>
                    </select>
                </div>

                <div class="cus-filter-actions">
                    <button type="submit" class="cus-apply-btn">Filtrele</button>
                    <a asp-controller="Customers"
                       asp-action="Index"
                       class="cus-clear-btn">
                        Temizle
                    </a>
                </div>
            </div>
        </form>
    </section>

    <section class="cus-list-shell">
        <div class="cus-list-toolbar">
            <div class="cus-list-summary">
                @if (totalCustomerCount > 0)
                {
                    <span>
                        <strong>@totalCustomerCount</strong> müşteri —
                        <strong>Sayfa @pageNumber / @totalPages</strong>
                    </span>
                }
                else
                {
                    <span>Müşteri bulunamadı.</span>
                }
            </div>

            @if (totalPages > 1)
            {
                <div class="cus-top-pager">
                    <a class="cus-top-nav @(pageNumber > 1 ? "" : "disabled")"
                       href="@(pageNumber > 1
                                                      ? Url.Action("Index", "Customers", new
                                                      {
                                                          Search = Model.Query.Search,
                                                          Type = currentType.HasValue ? (int?)currentType.Value : null,
                                                          PageNumber = pageNumber - 1,
                                                          PageSize = pageSize
                                                      })
                                                      : "#")">
                        ‹
                    </a>

                    <div class="cus-top-page-list">
                        @for (var number = 1; number <= totalPages; number++)
                        {
                            if (number == 1 ||
                                number == totalPages ||
                                Math.Abs(number - pageNumber) <= 1)
                            {
                                <a class="cus-top-page @(number == pageNumber ? "active" : "")"
                                   href="@Url.Action("Index", "Customers", new
                                   {
                                       Search = Model.Query.Search,
                                       Type = currentType.HasValue ? (int?)currentType.Value : null,
                                       PageNumber = number,
                                       PageSize = pageSize
                                   })">
                                    @number
                                </a>
                            }
                        }
                    </div>

                    <a class="cus-top-nav @(pageNumber < totalPages ? "" : "disabled")"
                       href="@(pageNumber<totalPages
                                                      ? Url.Action("Index", "Customers", new
                                                      {
                                                          Search = Model.Query.Search,
                                                          Type = currentType.HasValue ? (int?)currentType.Value : null,
                                                          PageNumber = pageNumber + 1,
                                                          PageSize = pageSize
                                                      })
                              : "#")">
                        ›
                    </a>
                </div>
            }
        </div>

        <div class="cus-list">
            @if (!items.Any())
            {
                <div class="cus-empty">
                    <div class="cus-empty-icon">⌕</div>
                    <strong>Müşteri bulunamadı</strong>
                    <span>Arama veya filtre kriterlerini değiştirerek tekrar deneyebilirsin.</span>
                </div>
            }
            else
            {
                foreach (var item in items)
                {
                    var typeText = GetTypeText(item.TypeText);
                    var typeClass = GetTypeClass(item.TypeText);
                    var initials = GetInitials(item.DisplayName);
                    var balanceClass = item.Balance >= 0 ? "is-positive" : "is-negative";

                    <article class="cus-card">
                        <a asp-controller="Customers"
                           asp-action="Details"
                           asp-route-id="@item.Id"
                           class="cus-card-main">
                            <div class="cus-avatar">@initials</div>

                            <div class="cus-profile">
                                <div class="cus-name-row">
                                    <strong>@item.DisplayName</strong>
                                    <span class="cus-live-dot"></span>
                                </div>

                                <span class="cus-no">Müşteri No: @item.Id</span>
                            </div>
                        </a>

                        <div class="cus-contact">
                            <div class="cus-line">
                                <span>☎</span>
                                <strong>@(string.IsNullOrWhiteSpace(item.PhoneNumber) ? "-" : item.PhoneNumber)</strong>
                            </div>

                            <div class="cus-line">
                                <span>✉</span>
                                <strong>@(string.IsNullOrWhiteSpace(item.Email) ? "-" : item.Email)</strong>
                            </div>
                        </div>

                        <div class="cus-type-area">
                            <span class="cus-type-badge @typeClass">@typeText</span>
                        </div>

                        <div class="cus-balance">
                            <span>Hesap Bakiyesi</span>
                            <strong class="@balanceClass">@SenteMoney.Format(item.Balance)</strong>
                        </div>

                        <div class="cus-actions">
                            <a class="cus-action-btn"
                               href="/CurrentAccounts/Customer/@item.Id">
                                Hesap
                            </a>

                            <a asp-controller="Customers"
                               asp-action="Details"
                               asp-route-id="@item.Id"
                               class="cus-action-btn primary">
                                Detay
                            </a>
                        </div>
                    </article>
                }
            }
        </div>

        @if (totalPages > 1)
        {
            <div class="cus-pagination">
                <a class="cus-page-btn @(pageNumber > 1 ? "" : "disabled")"
                   href="@(pageNumber > 1
                                              ? Url.Action("Index", "Customers", new
                                              {
                                                  Search = Model.Query.Search,
                                                  Type = currentType.HasValue ? (int?)currentType.Value : null,
                                                  PageNumber = pageNumber - 1,
                                                  PageSize = pageSize
                                              })
                                              : "#")">
                    Önceki
                </a>

                <div class="cus-page-numbers">
                    @for (var number = 1; number <= totalPages; number++)
                    {
                        if (number == 1 ||
                            number == totalPages ||
                            Math.Abs(number - pageNumber) <= 2)
                        {
                            <a class="cus-page-number @(number == pageNumber ? "active" : "")"
                               href="@Url.Action("Index", "Customers", new
                               {
                                   Search = Model.Query.Search,
                                   Type = currentType.HasValue ? (int?)currentType.Value : null,
                                   PageNumber = number,
                                   PageSize = pageSize
                               })">
                                @number
                            </a>
                        }
                    }
                </div>

                <a class="cus-page-btn @(pageNumber < totalPages ? "" : "disabled")"
                   href="@(pageNumber<totalPages
                                              ? Url.Action("Index", "Customers", new
                                              {
                                                  Search = Model.Query.Search,
                                                  Type = currentType.HasValue ? (int?)currentType.Value : null,
                                                  PageNumber = pageNumber + 1,
                                                  PageSize = pageSize
                                              })
                          : "#")">
                    Sonraki
                </a>
            </div>
        }
    </section>
</div>

<style>
    .cus-page {
        width: min(1280px, calc(100% - 56px));
        margin: 0 auto;
        padding: 30px 0 64px;
        color: #061936;
    }

    .cus-hero {
        margin-bottom: 22px;
        padding: 24px 28px;
        border-radius: 30px;
        background: radial-gradient(circle at 78% 40%, rgba(255,255,255,.16), transparent 30%), linear-gradient(135deg, #07111f 0%, #111827 48%, #4f46e5 100%);
        color: white;
        box-shadow: 0 26px 70px rgba(15, 23, 42, .20);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 22px;
        overflow: hidden;
    }

    .cus-hero-left {
        display: flex;
        align-items: center;
        gap: 18px;
        min-width: 0;
    }

    .cus-home-btn {
        width: 54px;
        height: 54px;
        flex: 0 0 54px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #2563eb, #16a34a);
        color: white;
        text-decoration: none;
        font-size: 24px;
        font-weight: 950;
        box-shadow: 0 18px 36px rgba(37, 99, 235, .25);
    }

    .cus-eyebrow {
        display: inline-flex;
        margin-bottom: 8px;
        padding: 6px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.18);
        color: rgba(255,255,255,.82);
        font-size: 12px;
        font-weight: 950;
        letter-spacing: .2px;
    }

    .cus-hero h1 {
        margin: 0;
        font-size: clamp(30px, 4vw, 42px);
        line-height: 1;
        letter-spacing: -1.6px;
    }

    .cus-hero p {
        margin: 10px 0 0;
        color: rgba(255,255,255,.72);
        font-size: 15px;
        line-height: 1.45;
    }

    .cus-create-btn {
        height: 56px;
        padding: 0 22px;
        border-radius: 18px;
        background: #4f46e5;
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
        font-size: 16px;
        box-shadow: 0 18px 34px rgba(79, 70, 229, .36);
        white-space: nowrap;
    }

        .cus-create-btn span {
            font-size: 28px;
            line-height: 1;
        }

        .cus-create-btn strong {
            font-weight: 950;
        }

    .cus-filter-shell {
        margin-bottom: 22px;
        padding: 20px;
        border-radius: 26px;
        background: rgba(255,255,255,.96);
        border: 1px solid #dbe3ef;
        box-shadow: 0 18px 42px rgba(15, 23, 42, .07);
    }

    .cus-search-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto auto;
        gap: 10px;
        align-items: center;
    }

    .cus-search-box {
        position: relative;
        min-width: 0;
    }

    .cus-search-icon {
        position: absolute;
        left: 18px;
        top: 50%;
        transform: translateY(-50%);
        color: #8aa0bd;
        font-size: 24px;
        pointer-events: none;
    }

    .cus-search-box input {
        width: 100%;
        height: 56px;
        padding: 0 18px 0 52px;
        border-radius: 18px;
        border: 1px solid #d4deeb;
        background: #f8fafc;
        color: #0f172a;
        font-size: 16px;
        font-weight: 750;
        outline: none;
        box-sizing: border-box;
    }

        .cus-search-box input::placeholder {
            color: #8aa0bd;
            font-weight: 700;
        }

        .cus-search-box input:focus {
            background: white;
            border-color: #4f46e5;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, .10);
        }

    .cus-search-submit,
    .cus-filter-toggle {
        height: 56px;
        border-radius: 18px;
        border: 1px solid #c7d2fe;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        cursor: pointer;
        font-size: 15px;
        font-weight: 950;
        white-space: nowrap;
    }

    .cus-search-submit {
        padding: 0 22px;
        background: #4f46e5;
        color: white;
        border-color: #4f46e5;
        box-shadow: 0 12px 24px rgba(79, 70, 229, .20);
    }

    .cus-filter-toggle {
        padding: 0 18px;
        background: #f8fafc;
        color: #312e81;
    }

        .cus-filter-toggle span {
            font-size: 18px;
        }

        .cus-filter-toggle em {
            font-style: normal;
            transition: .18s ease;
        }

        .cus-filter-toggle.is-open em {
            transform: rotate(180deg);
        }

    .cus-advanced-filters {
        display: none;
        margin-top: 18px;
        padding-top: 18px;
        border-top: 1px solid #e2e8f0;
        grid-template-columns: minmax(0, 1.4fr) minmax(180px, .5fr) auto;
        gap: 14px;
        align-items: end;
    }

        .cus-advanced-filters.is-open {
            display: grid;
        }

    .cus-filter-section {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 9px;
    }

        .cus-filter-section label {
            color: #64748b;
            font-size: 12px;
            font-weight: 950;
            letter-spacing: .7px;
            text-transform: uppercase;
        }

        .cus-filter-section select {
            width: 100%;
            height: 46px;
            padding: 0 14px;
            border-radius: 15px;
            border: 1px solid #d4deeb;
            background: #f8fafc;
            color: #0f172a;
            font-size: 15px;
            font-weight: 800;
            outline: none;
            box-sizing: border-box;
        }

    .cus-type-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 9px;
    }

    .cus-type-chip {
        height: 36px;
        padding: 0 16px;
        border: none;
        border-radius: 999px;
        background: #f1f5f9;
        color: #334155;
        font-size: 13px;
        font-weight: 900;
        cursor: pointer;
    }

        .cus-type-chip.active {
            background: #0f172a;
            color: white;
        }

    .cus-filter-actions {
        display: flex;
        gap: 10px;
    }

    .cus-apply-btn,
    .cus-clear-btn {
        height: 46px;
        padding: 0 18px;
        border-radius: 15px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-size: 14px;
        font-weight: 950;
        white-space: nowrap;
    }

    .cus-apply-btn {
        border: none;
        background: #4f46e5;
        color: white;
        cursor: pointer;
    }

    .cus-clear-btn {
        border: 1px solid #d4deeb;
        background: #f8fafc;
        color: #4f46e5;
    }

    .cus-list-toolbar {
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
    }

    .cus-list-summary {
        color: #64748b;
        font-size: 14px;
        font-weight: 850;
    }

        .cus-list-summary strong {
            color: #334155;
        }

    .cus-top-pager {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px;
        border-radius: 999px;
        background: white;
        border: 1px solid #dbe3ef;
        box-shadow: 0 8px 22px rgba(15, 23, 42, .05);
    }

    .cus-top-page-list {
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    .cus-top-nav,
    .cus-top-page {
        width: 34px;
        height: 34px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: #475569;
        font-size: 14px;
        font-weight: 950;
        transition: .15s ease;
    }

    .cus-top-nav {
        font-size: 24px;
        line-height: 1;
        background: #f8fafc;
    }

    .cus-top-page.active {
        background: #4f46e5;
        color: white;
        box-shadow: 0 8px 18px rgba(79, 70, 229, .28);
    }

    .cus-top-nav:not(.disabled):hover,
    .cus-top-page:not(.active):hover {
        background: #eef2ff;
        color: #4f46e5;
    }

    .cus-top-nav.disabled {
        opacity: .35;
        pointer-events: none;
    }

    .cus-list {
        display: grid;
        gap: 14px;
    }

    .cus-card {
        min-height: 92px;
        padding: 20px 24px;
        border-radius: 24px;
        border: 1px solid #dbe3ef;
        background: white;
        color: #0f172a;
        display: grid;
        grid-template-columns: minmax(260px, 1.45fr) minmax(260px, 1.25fr) 120px 150px 150px;
        gap: 20px;
        align-items: center;
        box-shadow: 0 10px 26px rgba(15, 23, 42, .045);
        transition: .16s ease;
    }

        .cus-card:hover {
            transform: translateY(-2px);
            border-color: #c7d2fe;
            box-shadow: 0 18px 38px rgba(15, 23, 42, .08);
        }

    .cus-card-main {
        min-width: 0;
        display: flex;
        align-items: center;
        gap: 15px;
        text-decoration: none;
        color: inherit;
    }

    .cus-avatar {
        width: 54px;
        height: 54px;
        flex: 0 0 54px;
        border-radius: 18px;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        color: #17365d;
        display: grid;
        place-items: center;
        font-size: 16px;
        font-weight: 950;
    }

    .cus-profile {
        min-width: 0;
    }

    .cus-name-row {
        display: flex;
        align-items: center;
        gap: 8px;
        min-width: 0;
    }

        .cus-name-row strong {
            color: #0f172a;
            font-size: 17px;
            font-weight: 950;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

    .cus-live-dot {
        width: 7px;
        height: 7px;
        flex: 0 0 7px;
        border-radius: 999px;
        background: #10b981;
    }

    .cus-no {
        display: block;
        margin-top: 6px;
        color: #8aa0bd;
        font-size: 13px;
        font-weight: 850;
    }

    .cus-contact {
        min-width: 0;
        display: grid;
        gap: 8px;
    }

    .cus-line {
        min-width: 0;
        display: flex;
        align-items: center;
        gap: 10px;
        color: #526782;
        font-size: 14px;
        font-weight: 800;
    }

        .cus-line span {
            width: 18px;
            flex: 0 0 18px;
            color: #8aa0bd;
            text-align: center;
        }

        .cus-line strong {
            min-width: 0;
            color: #526782;
            font-size: 14px;
            font-weight: 850;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

    .cus-type-area {
        display: flex;
        justify-content: flex-start;
    }

    .cus-type-badge {
        min-width: 86px;
        height: 32px;
        padding: 0 12px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 950;
        white-space: nowrap;
    }

        .cus-type-badge.type-individual {
            background: #eef2ff;
            color: #4f46e5;
        }

        .cus-type-badge.type-sole {
            background: #ecfeff;
            color: #0891b2;
        }

        .cus-type-badge.type-corporate {
            background: #fef3c7;
            color: #b45309;
        }

    .cus-balance span {
        display: block;
        margin-bottom: 5px;
        color: #8aa0bd;
        font-size: 12px;
        font-weight: 900;
