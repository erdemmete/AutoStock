@model AutoStock.Services.Dtos.Common.PagedResult<AutoStock.Services.Dtos.Notifications.NotificationListItemDto>
@using AutoStock.Services.Dtos.Notifications

@{
    ViewData["Title"] = "Bildirimler";

    var query = ViewBag.Query as NotificationListQueryDto ?? new NotificationListQueryDto();
    var items = Model.Items ?? new List<NotificationListItemDto>();
    var totalPages = Model.TotalPages <= 0 ? 1 : Model.TotalPages;
}

<div class="ntf-page">
    <section class="ntf-topbar">
        <a href="/Dashboard" class="ntf-back">← Ana Sayfa</a>

        <form method="post" action="/Notifications/ReadAll">
            <button type="submit" class="ntf-read-all">Tümünü okundu yap</button>
        </form>
    </section>

    <section class="ntf-hero">
        <span>SENTE360</span>
        <h1>Bildirimler</h1>
        <p>Destek yanıtları ve fatura bildirimleri.</p>
    </section>

    <section class="ntf-push-card">
        <div>
            <strong>Tarayıcı bildirimleri</strong>
            <span data-web-push-status>Kontrol ediliyor</span>
            <small data-web-push-hint>Anlık destek ve fatura bildirimleri için açabilirsiniz.</small>
        </div>
        <div>
            <button type="button" data-web-push-open>Bildirimleri Aç</button>
            <button type="button" class="secondary" data-web-push-close-device>Bu Cihazda Kapat</button>
        </div>
    </section>

    <section class="ntf-filter">
        <a class="@(query.IsRead == null ? "active" : "")" href="/Notifications">Tümü</a>
        <a class="@(query.IsRead == false ? "active" : "")" href="/Notifications?IsRead=false">Okunmamış</a>
        <a class="@(query.IsRead == true ? "active" : "")" href="/Notifications?IsRead=true">Okunmuş</a>
    </section>

    <section class="ntf-list">
        @if (!items.Any())
        {
            <div class="ntf-empty">
                <div class="ntf-empty-icon">🔔</div>
                <strong>Bildirim bulunamadı</strong>
                <span>Yeni destek talepleri, destek cevapları ve fatura yüklemeleri burada görünecek.</span>
            </div>
        }
        else
        {
            foreach (var item in items)
            {
                var actionUrl = string.IsNullOrWhiteSpace(item.ActionUrl)
                    ? "/Notifications"
                    : item.ActionUrl;

                <article class="ntf-card @(item.IsRead ? "is-read" : "is-unread")">
                    <div class="ntf-icon">🔔</div>

                    <div class="ntf-content">
                        <div class="ntf-topline">
                            <div>
                                <strong>@item.Title</strong>
                                <p>@item.Message</p>
                            </div>
                            <span>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>

                        <div class="ntf-actions">
                            <form method="post" action="/Notifications/@item.Id/Read">
                                <input type="hidden" name="returnUrl" value="@actionUrl" />
                                <button type="submit">Detaya Git</button>
                            </form>

                            @if (!item.IsRead)
                            {
                                <form method="post" action="/Notifications/@item.Id/Read">
                                    <input type="hidden" name="returnUrl" value="/Notifications" />
                                    <button type="submit" class="secondary">Okundu Yap</button>
                                </form>
                            }
                        </div>
                    </div>
                </article>
            }
        }
    </section>

    @if (totalPages > 1)
    {
        <section class="ntf-pager">
            @if (Model.HasPreviousPage)
            {
                <a href="/Notifications?PageNumber=@(Model.PageNumber - 1)&PageSize=@Model.PageSize&IsRead=@query.IsRead">Önceki</a>
            }

            <span>Sayfa @Model.PageNumber / @totalPages</span>

            @if (Model.HasNextPage)
            {
                <a href="/Notifications?PageNumber=@(Model.PageNumber + 1)&PageSize=@Model.PageSize&IsRead=@query.IsRead">Sonraki</a>
            }
        </section>
    }
</div>

<style>
    .ntf-page {
        width: min(1040px, calc(100% - 44px));
        margin: 0 auto;
        padding: 24px 0 64px;
        color: #0f172a;
    }

    .ntf-topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
    }

    .ntf-back,
    .ntf-read-all {
        min-height: 42px;
        padding: 0 15px;
        border-radius: 14px;
        border: 1px solid #dbe3ef;
        background: #ffffff;
        color: #334155;
        text-decoration: none;
        font-size: 13px;
        font-weight: 950;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: 0 10px 24px rgba(15,23,42,.05);
    }

    .ntf-read-all {
        color: #4f46e5;
    }

    .ntf-hero {
        padding: 30px 32px;
        border-radius: 30px;
        background: radial-gradient(circle at 80% 30%, rgba(255,255,255,.16), transparent 28%), linear-gradient(135deg, #07111f 0%, #111827 48%, #4f46e5 100%);
        color: white;
        box-shadow: 0 26px 70px rgba(15, 23, 42, .18);
    }

    .ntf-hero span {
        display: inline-flex;
        margin-bottom: 12px;
        padding: 6px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,.14);
        color: rgba(255,255,255,.84);
        font-size: 12px;
        font-weight: 950;
    }

    .ntf-hero h1 {
        margin: 0;
        font-size: clamp(32px, 4vw, 48px);
        line-height: 1;
        letter-spacing: -1.7px;
    }

    .ntf-hero p {
        margin: 12px 0 0;
        color: rgba(255,255,255,.74);
        font-size: 15px;
        font-weight: 750;
        line-height: 1.45;
    }

    .ntf-filter {
        margin: 18px 0;
        padding: 8px;
        border-radius: 999px;
        background: white;
        border: 1px solid #dbe3ef;
        display: inline-flex;
        gap: 6px;
        box-shadow: 0 12px 26px rgba(15, 23, 42, .05);
    }

    .ntf-push-card {
        margin: 18px 0 0;
        padding: 16px;
        border-radius: 22px;
        background: #ffffff;
        border: 1px solid #dbe3ef;
        box-shadow: 0 12px 28px rgba(15, 23, 42, .045);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        flex-wrap: wrap;
    }

        .ntf-push-card strong {
            display: block;
            color: #0f172a;
            font-size: 15px;
            font-weight: 950;
        }

        .ntf-push-card span {
            display: block;
            margin-top: 4px;
            color: #64748b;
            font-size: 13px;
            font-weight: 850;
        }

        .ntf-push-card small {
            display: block;
            margin-top: 6px;
            max-width: 520px;
            color: #64748b;
            font-size: 12px;
            font-weight: 750;
            line-height: 1.45;
        }

        .ntf-push-card div:last-child {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .ntf-push-card button {
            min-height: 40px;
            border: none;
            border-radius: 999px;
            padding: 0 14px;
            background: #2563eb;
            color: #ffffff;
            font-weight: 950;
            cursor: pointer;
        }

            .ntf-push-card button.secondary {
                background: #f8fafc;
                color: #475569;
                border: 1px solid #dbe3ef;
            }

    .ntf-filter a {
        min-height: 38px;
        padding: 0 16px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        color: #475569;
        text-decoration: none;
        font-size: 13px;
        font-weight: 950;
    }

    .ntf-filter a.active {
        background: #4f46e5;
        color: white;
    }

    .ntf-list {
        display: grid;
        gap: 12px;
    }

    .ntf-card {
        padding: 16px;
        border-radius: 22px;
        background: white;
        border: 1px solid #dbe3ef;
        display: grid;
        grid-template-columns: 48px minmax(0, 1fr);
        gap: 14px;
        box-shadow: 0 12px 28px rgba(15, 23, 42, .045);
    }

    .ntf-card.is-unread {
        border-color: #c7d2fe;
        background: linear-gradient(90deg, rgba(79, 70, 229, .08), #ffffff 45%);
    }

    .ntf-icon {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        background: #eef2ff;
        color: #4f46e5;
        display: grid;
        place-items: center;
        font-size: 20px;
    }

    .ntf-card.is-read .ntf-icon {
        background: #f1f5f9;
        color: #64748b;
    }

    .ntf-content {
        min-width: 0;
    }

    .ntf-topline {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-start;
    }

    .ntf-topline strong {
        display: block;
        color: #0f172a;
        font-size: 17px;
        font-weight: 950;
        margin-bottom: 6px;
    }

    .ntf-topline p {
        margin: 0;
        color: #475569;
        font-size: 14px;
        font-weight: 750;
        line-height: 1.45;
    }

    .ntf-topline span {
        color: #94a3b8;
        font-size: 13px;
        font-weight: 850;
        white-space: nowrap;
    }

    .ntf-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 14px;
    }

    .ntf-actions button {
        min-height: 38px;
        padding: 0 14px;
        border-radius: 13px;
        border: none;
        background: #4f46e5;
        color: white;
        font-size: 13px;
        font-weight: 950;
        cursor: pointer;
    }

    .ntf-actions button.secondary {
        background: #f1f5f9;
        color: #334155;
    }

    .ntf-empty {
        padding: 56px 20px;
        border-radius: 26px;
        background: white;
        border: 1px dashed #cbd5e1;
        text-align: center;
        display: grid;
        justify-items: center;
        gap: 10px;
    }

    .ntf-empty-icon {
        width: 54px;
        height: 54px;
        border-radius: 18px;
        background: #eef2ff;
        color: #4f46e5;
        display: grid;
        place-items: center;
        font-size: 24px;
    }

    .ntf-empty strong {
        color: #0f172a;
        font-size: 18px;
        font-weight: 950;
    }

    .ntf-empty span {
        color: #64748b;
        font-size: 14px;
        font-weight: 750;
    }

    .ntf-pager {
        margin-top: 18px;
        padding: 14px;
        border-radius: 18px;
        background: white;
        border: 1px solid #dbe3ef;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

    .ntf-pager a,
    .ntf-pager span {
        color: #334155;
        text-decoration: none;
        font-size: 14px;
        font-weight: 950;
    }

    @@media (max-width: 720px) {
        .ntf-page {
            width: min(100% - 22px, 1040px);
            padding-top: 16px;
        }

        .ntf-topbar {
            align-items: stretch;
            flex-direction: column;
        }

        .ntf-back,
        .ntf-read-all,
        .ntf-topbar form {
            width: 100%;
        }

        .ntf-hero {
            padding: 22px;
            border-radius: 26px;
        }

        .ntf-filter {
            width: 100%;
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            border-radius: 20px;
        }

        .ntf-filter a {
            justify-content: center;
        }

        .ntf-card {
            grid-template-columns: 42px minmax(0, 1fr);
            padding: 14px;
        }

        .ntf-icon {
            width: 42px;
            height: 42px;
            border-radius: 15px;
        }

        .ntf-topline {
            flex-direction: column;
            gap: 6px;
        }
    }
</style>
