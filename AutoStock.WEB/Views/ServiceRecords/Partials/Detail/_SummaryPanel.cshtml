@model AutoStock.WEB.Models.ServiceRecords.ServiceRecordDetailViewModel
@using Microsoft.AspNetCore.Http

@{
    var isOwner = string.Equals(Context.Session.GetString("UserRole"), "Owner", StringComparison.OrdinalIgnoreCase);

    string FormatMoney(decimal value) => SenteMoney.Format(value);

    var estimatedTotal = Model.RequestItems.Sum(x => x.EstimatedAmount ?? 0);
    var subTotal = Model.TotalAmount;
    var vatTotal = subTotal * 0.20m;
    var grandTotal = subTotal + vatTotal;
    var publicQrUrl = !string.IsNullOrWhiteSpace(Model.AssignedQrCode)
        ? $"{Context.Request.Scheme}://{Context.Request.Host}/qr/{Uri.EscapeDataString(Model.AssignedQrCode)}"
        : string.Empty;
    var whatsappText = !string.IsNullOrWhiteSpace(publicQrUrl)
        ? $"Merhaba, aracınızın Sente360 servis geçmişi bağlantısı: {publicQrUrl}"
        : string.Empty;
    var whatsappPhone = NormalizePhoneForWhatsApp(Model.CustomerPhone);
    var whatsappUrl = !string.IsNullOrWhiteSpace(whatsappPhone)
        ? $"https://wa.me/{whatsappPhone}?text={Uri.EscapeDataString(whatsappText)}"
        : $"https://wa.me/?text={Uri.EscapeDataString(whatsappText)}";
    var emailSubject = $"Sente360 araç servis geçmişi - {Model.VehiclePlate}";
    var emailBody = $"Merhaba,%0D%0A%0D%0AAracınızın Sente360 servis geçmişi bağlantısı:%0D%0A{Uri.EscapeDataString(publicQrUrl)}";
}

<aside class="srx-side-panel">

    <section class="srx-summary-card">

        <div class="srx-summary-card-header">
            <h2>Servis Özeti</h2>

            @if (isOwner && (Model.Status == 1 || Model.Status == 2))
            {
                <details class="srx-summary-menu" id="summaryActionMenu">
                    <summary aria-label="Servis özeti işlemleri">…</summary>

                    <div class="srx-summary-menu-panel">
                        <button type="button"
                                class="srx-summary-menu-danger status-btn"
                                data-status="4">
                            Servis Kaydını İptal Et
                        </button>
                    </div>
                </details>
            }
        </div>

        <div class="srx-estimate-box">
            <span>Tahmini Fiyat Verildi</span>
            <strong>@FormatMoney(estimatedTotal)</strong>
        </div>

        <div class="srx-summary-lines">

            <div>
                <span>Ara Toplam</span>
                <strong class="summary-total"
                        data-total="@subTotal">
                    @FormatMoney(subTotal)
                </strong>
            </div>

            <div>
                <span>KDV (%20)</span>
                <strong class="summary-vat"
                        data-vat="@vatTotal">
                    @FormatMoney(vatTotal)
                </strong>
            </div>

        </div>

        <div class="srx-grand-total">
            <span>Genel Toplam</span>
            <strong class="summary-grand-total"
                    data-grand-total="@grandTotal">
                @FormatMoney(grandTotal)
            </strong>
        </div>

        <div class="srx-summary-main-actions">
            @if (Model.ActiveInvoiceId.HasValue)
            {
                <a href="/Invoices/Detail/@Model.ActiveInvoiceId"
                   class="srx-primary-action">
                    <span class="srx-action-text-full">@(Model.ActiveInvoiceStatus == 1 ? "Taslak Faturaya Git" : "Faturaya Git")</span>
                    <span class="srx-action-text-short">Faturaya Geç</span>
                </a>
            }
            else
            {
                <button type="button"
                        class="srx-primary-action"
                        data-action="create-invoice-draft"
                        data-service-record-id="@Model.Id">
                    <span class="srx-action-text-full">Fatura Taslağına Geç</span>
                    <span class="srx-action-text-short">Faturaya Geç</span>
                </button>
            }

            @if (Model.Status == 1 || Model.Status == 2)
            {
                <button type="button"
                        class="srx-secondary-action success status-btn srx-complete-action"
                        data-status="3">
                    Servisi Tamamla
                </button>
            }
            else if (Model.Status == 3 || Model.Status == 4)
            {
                <button type="button"
                        class="srx-secondary-action status-btn srx-complete-action"
                        data-status="1">
                    Tekrar Aktif Yap
                </button>
            }
        </div>

        <div class="srx-quick-actions-grid">

            <button type="button"
                    class="srx-quick-action-card"
                    data-action="open-photo-modal">
                <span class="srx-quick-icon">IMG</span>
                <span class="srx-quick-copy">
                    <strong>Fotoğraflar</strong>
                    <small id="photoActionCount">@Model.Images.Count fotoğraf</small>
                </span>
            </button>

            <a href="/service-pdf/create/@Model.Id"
               target="_blank"
               class="srx-quick-action-card">
                <span class="srx-quick-icon">PDF</span>
                <span class="srx-quick-copy">
                    <strong>PDF Oluştur</strong>
                    <small>Servis belgesi</small>
                </span>
            </a>

            <div class="srx-qr-action-stack"
                 id="qrActionStack"
                 data-qr-bound="@Model.HasAssignedQrCode.ToString().ToLowerInvariant()"
                 data-public-url="@publicQrUrl">
                <button type="button"
                        class="srx-quick-action-card srx-qr-create-action @(Model.HasAssignedQrCode ? "is-hidden" : "")"
                        id="qrCreateButton"
                        data-action="create-vehicle-qr"
                        data-vehicle-id="@Model.VehicleId">
                    <span class="srx-quick-icon">QR</span>
                    <span class="srx-quick-copy">
                        <strong class="srx-quick-title">Araç QR'ı Oluştur</strong>
                        <small>Dijital servis geçmişi</small>
                    </span>
                </button>

                <div class="srx-quick-action-card srx-qr-ready-control @(Model.HasAssignedQrCode ? "" : "is-hidden")"
                     id="qrReadyControl">
                    <span class="srx-quick-icon success">QR</span>
                    <span class="srx-quick-copy">
                        <strong class="srx-qr-ready-title">QR Hazır</strong>
                        <small id="qrPublicLinkText">@(!string.IsNullOrWhiteSpace(publicQrUrl) ? "Araç servis geçmişi bağlantısı hazır" : "Bağlantı hazırlanıyor")</small>
                    </span>

                    <div class="srx-qr-share-actions">
                        <a class="srx-qr-share-btn"
                           id="qrWhatsappLink"
                           href="@whatsappUrl"
                           target="_blank"
                           rel="noopener">
                            WhatsApp
                        </a>

                        @if (!string.IsNullOrWhiteSpace(Model.CustomerEmail))
                        {
                            <a class="srx-qr-share-btn"
                               id="qrEmailLink"
                               href="mailto:@Model.CustomerEmail?subject=@Uri.EscapeDataString(emailSubject)&body=@emailBody">
                                E-posta
                            </a>
                        }
                        else
                        {
                            <span class="srx-qr-share-btn is-disabled"
                                  id="qrEmailLink"
                                  aria-disabled="true">
                                E-posta
                            </span>
                        }

                        <a class="srx-qr-share-btn"
                           id="qrDownloadLink"
                           href="/ServiceRecords/VehicleQr/@Model.VehicleId/Download">
                            İndir
                        </a>

                        <button type="button"
                                class="srx-qr-share-btn danger"
                                id="qrReplaceButton"
                                data-action="replace-vehicle-qr"
                                data-vehicle-id="@Model.VehicleId">
                            Değiştir
                        </button>
                    </div>
                </div>
            </div>

        </div>

    </section>

</aside>

@functions {
    private static string? NormalizePhoneForWhatsApp(string? phone)
    {
        if (string.IsNullOrWhiteSpace(phone))
            return null;

        var digits = new string(phone.Where(char.IsDigit).ToArray());

        if (string.IsNullOrWhiteSpace(digits))
            return null;

        if (digits.StartsWith("00"))
            digits = digits[2..];

        if (digits.StartsWith("0") && digits.Length == 11)
            digits = "90" + digits[1..];

        return digits;
    }
}
