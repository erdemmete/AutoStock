@model AutoStock.WEB.Models.ServiceRecords.ServiceRecordDetailViewModel

@{
    string FormatMoney(decimal value) => SenteMoney.Format(value);

    var estimatedTotal = Model.RequestItems.Sum(x => x.EstimatedAmount ?? 0);
    var subTotal = Model.TotalAmount;
    var vatTotal = subTotal * 0.20m;
    var grandTotal = subTotal + vatTotal;
}

<aside class="srx-side-panel">

    <section class="srx-summary-card">

        <div class="srx-summary-card-header">
            <h2>Servis Özeti</h2>

            @if (Model.Status == 1 || Model.Status == 2)
            {
                <details class="srx-summary-menu" id="summaryActionMenu">
                    <summary aria-label="Servis özeti işlemleri">…</summary>

                    <div class="srx-summary-menu-panel">
                        <button type="button"
                                class="srx-summary-menu-danger status-btn"
                                data-status="4">
                            Servis Kaydını İptal Et
                        </button>
                    </div>
                </details>
            }
        </div>

        <div class="srx-estimate-box">
            <span>Tahmini Fiyat Verildi</span>
            <strong>@FormatMoney(estimatedTotal)</strong>
        </div>

        <div class="srx-summary-lines">

            <div>
                <span>Ara Toplam</span>
                <strong class="summary-total"
                        data-total="@subTotal">
                    @FormatMoney(subTotal)
                </strong>
            </div>

            <div>
                <span>KDV (%20)</span>
                <strong class="summary-vat"
                        data-vat="@vatTotal">
                    @FormatMoney(vatTotal)
                </strong>
            </div>

        </div>

        <div class="srx-grand-total">
            <span>Genel Toplam</span>
            <strong class="summary-grand-total"
                    data-grand-total="@grandTotal">
                @FormatMoney(grandTotal)
            </strong>
        </div>

        <div class="srx-summary-main-actions">
            @if (Model.ActiveInvoiceId.HasValue)
            {
                <a href="/Invoices/Detail/@Model.ActiveInvoiceId"
                   class="srx-primary-action">
                    <span class="srx-action-text-full">@(Model.ActiveInvoiceStatus == 1 ? "Taslak Faturaya Git" : "Faturaya Git")</span>
                    <span class="srx-action-text-short">Faturaya Geç</span>
                </a>
            }
            else
            {
                <a href="/Invoices/CreateFromServiceRecord/@Model.Id"
                   class="srx-primary-action">
                    <span class="srx-action-text-full">Fatura Taslağına Geç</span>
                    <span class="srx-action-text-short">Faturaya Geç</span>
                </a>
            }

            @if (Model.Status == 1 || Model.Status == 2)
            {
                <button type="button"
                        class="srx-secondary-action success status-btn srx-complete-action"
                        data-status="3">
                    Servisi Tamamla
                </button>
            }
            else if (Model.Status == 3 || Model.Status == 4)
            {
                <button type="button"
                        class="srx-secondary-action status-btn srx-complete-action"
                        data-status="1">
                    Tekrar Aktif Yap
                </button>
            }
        </div>

        <div class="srx-quick-actions-grid">

            <button type="button"
                    class="srx-quick-action-card"
                    data-action="open-photo-modal">
                <span class="srx-quick-icon">IMG</span>
                <span class="srx-quick-copy">
                    <strong>Fotoğraflar</strong>
                    <small id="photoActionCount">@Model.Images.Count fotoğraf</small>
                </span>
            </button>

            <a href="/service-pdf/create/@Model.Id"
               target="_blank"
               class="srx-quick-action-card">
                <span class="srx-quick-icon">PDF</span>
                <span class="srx-quick-copy">
                    <strong>PDF Oluştur</strong>
                    <small>Servis belgesi</small>
                </span>
            </a>

            <div class="srx-qr-action-stack"
                 id="qrActionStack"
                 data-qr-bound="@Model.HasAssignedQrCode.ToString().ToLowerInvariant()">
                <button type="button"
                        class="srx-quick-action-card srx-qr-scan-action @(Model.HasAssignedQrCode ? "is-hidden" : "")"
                        id="qrScanButton"
                        onclick="startQrScanner(@Model.VehicleId, this)">
                    <span class="srx-quick-icon">QR</span>
                    <span class="srx-quick-copy">
                        <strong class="srx-quick-title">QR Tara</strong>
                        <small>Araca kod bağla</small>
                    </span>
                </button>

                <div class="srx-quick-action-card srx-qr-bound-control @(Model.HasAssignedQrCode ? "" : "is-hidden")"
                     id="qrBoundControl">
                    <span class="srx-quick-icon success">QR</span>
                    <span class="srx-quick-copy">
                        <strong class="srx-qr-bound-pill"
                                id="qrBoundButton">
                            QR Bağlı
                        </strong>
                    </span>

                    <button type="button"
                            class="srx-qr-change-action"
                            id="qrChangeButton"
                            onclick="confirmChangeQrAndStart(@Model.VehicleId, this)">
                        Değiştir
                    </button>
                </div>
            </div>

        </div>

        <div id="qrAssignModal" class="srx-qr-modal" aria-hidden="true">
            <button type="button"
                    class="srx-qr-close"
                    onclick="closeQrAssignModal()"
                    aria-label="QR kamerayı kapat">
                ×
            </button>

            <div class="srx-qr-modal-shell" role="dialog" aria-modal="true" aria-label="QR Tara">
                <div class="srx-qr-scan-panel">
                    <div id="qr-modal-reader" class="srx-qr-modal-reader"></div>
                    <div class="srx-qr-scan-frame" aria-hidden="true"></div>

                    <div id="qr-modal-error" class="srx-qr-error-panel" hidden>
                        <p id="qr-modal-result"></p>
                        <button type="button"
                                class="srx-qr-retry"
                                onclick="retryQrAssignScanner()">
                            Tekrar Dene
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </section>

</aside>
