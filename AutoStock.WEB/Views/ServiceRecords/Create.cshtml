            function prepareFormDataForSubmit(form) {
                const formData = new FormData(form);

                const activeCustomerName = getValueFromActiveCustomer("CustomerName");
                const activePhone = getValueFromActiveCustomer("CustomerPhoneNumber");
                const activeEmail = getValueFromActiveCustomer("CustomerEmail");
                const activeVehicleDeliveredBy = getValueFromActiveCustomer("VehicleDeliveredBy");

                if (activeCustomerName) {
                    formData.set("CustomerName", activeCustomerName);
                }

                if (activePhone) {
                    formData.set("CustomerPhoneNumber", activePhone);
                }

                formData.set("CustomerEmail", activeEmail || "");
                formData.set("VehicleDeliveredBy", activeVehicleDeliveredBy || "");

                const mileageInput = get("Mileage");

                if (mileageInput) {
                    formData.set("Mileage", mileageInput.value.replace(/\D/g, ""));
                }

                const customerType = get("CustomerType")?.value || "1";
                formData.set("CustomerType", customerType);

                return formData;
            }

            async function saveServiceRecord() {
                saveCreateFormDraft();

                if (isServiceRecordSaving || isServiceRecordCreated) {
                    return;
                }

                const form = get("serviceCreateForm");

                if (!form) return;

                const formData = prepareFormDataForSubmit(form);

                const customerName = formData.get("CustomerName")?.toString().trim();
                const customerPhone = formData.get("CustomerPhoneNumber")?.toString().trim();

                if (!customerName) {
                    showToast("Müşteri / cari adı zorunludur.", "error");
                    return;
                }

                if (!customerPhone) {
                    showToast("İletişim telefonu zorunludur.", "error");
                    return;
                }

                if (Number(formData.get("CustomerType")) === 2 &&
                    !formData.get("VehicleDeliveredBy")?.toString().trim()) {
                    showToast("Kurumsal müşterilerde aracı getiren / ilgili kişi zorunludur.", "error");
                    return;
                }

                isServiceRecordSaving = true;

                const saveButton = document.querySelector(".btn-primary");
                const originalText = saveButton?.innerText;

                if (saveButton) {
                    saveButton.disabled = true;
                    saveButton.innerText = "Kaydediliyor...";
                }

                try {
                    const response = await fetch(form.action, {
                        method: "POST",
                        body: formData,
                        headers: {
                            "X-Requested-With": "XMLHttpRequest"
                        }
                    });

                    const result = await response.json();

                    if (!response.ok || result.success === false) {
                        if (result.validationErrors) {
                            showValidationErrors(result.validationErrors);
                        }

                        showToast(result.message || "Servis kaydı oluşturulamadı.", "error");

                        return;
                    }

                    clearValidationErrors();

                    isServiceRecordCreated = true;

                    if (saveButton) {
                        saveButton.innerText = "Kayıt Oluşturuldu";
                    }

                    localStorage.removeItem(DRAFT_KEY);
                    localStorage.removeItem(REQUEST_ITEMS_DRAFT_KEY);

                    showToast(result.message || "Servis kaydı başarıyla oluşturuldu.", "success");
                }
                catch {
                    showToast("Beklenmeyen bir hata oluştu.", "error");
                }
                finally {
                    isServiceRecordSaving = false;

                    if (!isServiceRecordCreated && saveButton) {
                        saveButton.disabled = false;
                        saveButton.innerText = originalText || "Kaydı Oluştur";
                    }
                }
            }

            async function createPdfDraft() {
                const requestItems = [];

                document.querySelectorAll("#requestItemsContainer .request-item").forEach(item => {
                    requestItems.push({
                        title: item.dataset.title || "",
                        note: item.dataset.note || "",
                        estimatedAmount: Number(item.dataset.estimatedAmount || 0)
                    });
                });

                const brandSelect = get("brandSelect");
                const modelSelect = get("modelSelect");

                const request = {
                    workshopName: "Sente360",
                    serviceAdvisorName: document.querySelector(".summary-value")?.innerText || "",

                    customerName: getValueFromActiveCustomer("CustomerName"),
                    customerPhone: getValueFromActiveCustomer("CustomerPhoneNumber"),
                    customerEmail: getValueFromActiveCustomer("CustomerEmail"),

                    plate: get("Plate")?.value?.trim()?.toUpperCase() || "",

                    brand: brandSelect?.options[brandSelect.selectedIndex]?.text || "",
                    model: modelSelect?.options[modelSelect.selectedIndex]?.text || "",

                    modelYear: get("ModelYear")?.value?.trim() || "",
                    mileage: get("Mileage")?.value?.trim() || "",
                    chassisNumber: get("ChassisNumber")?.value?.trim() || "",

                    note: get("requestNoteInput")?.value?.trim() || "",

                    requestItems: requestItems
                };

                const response = await fetch("/quick-offer-pdf/create", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(request)
                });

                if (!response.ok) {
                    const errorText = await response.text();

                    alert("PDF oluşturulurken hata oluştu:\n" + errorText);

                    return;
                }

                const blob = await response.blob();
                const disposition = response.headers.get("Content-Disposition");

                let fileName = "hizli-teklif.pdf";

                if (disposition && disposition.includes("filename")) {
                    const match = disposition.match(/filename\*?=(?:UTF-8'')?["']?([^;"']+)/i);

                    if (match?.[1]) {
                        fileName = decodeURIComponent(match[1].replace(/"/g, ""));
                    }
                }

                const url = window.URL.createObjectURL(blob);
                const a = document.createElement("a");

                a.href = url;
                a.download = fileName;

                document.body.appendChild(a);
                a.click();
                a.remove();

                window.URL.revokeObjectURL(url);
            }

            function initializeInputMasks() {
                document.querySelectorAll(`[name="CustomerPhoneNumber"]`).forEach(phoneInput => {
                    phoneInput.addEventListener("beforeinput", function (e) {
                        if (e.inputType === "insertText" && !/^\d$/.test(e.data)) {
                            e.preventDefault();
                            showTemporaryInvalid(phoneInput);
                        }
                    });

                    phoneInput.addEventListener("paste", function (e) {
                        const pastedText = (e.clipboardData || window.clipboardData).getData("text");
                        const digits = pastedText.replace(/\D/g, "").slice(0, 11);

                        if (pastedText !== digits) {
                            e.preventDefault();
                            this.value = formatPhone(digits);
                            showTemporaryInvalid(phoneInput);
                        }
                    });

                    phoneInput.addEventListener("input", function () {
                        this.value = formatPhone(this.value);
                    });
                });

                const chassisNumberInput = get("ChassisNumber");

                chassisNumberInput?.addEventListener("input", function () {
                    this.value = this.value
                        .toUpperCase()
                        .replace(/[^A-Z0-9]/g, "")
                        .slice(0, 17);
                });

                const plateInput = get("Plate");

                plateInput?.addEventListener("beforeinput", function (e) {
                    if (e.inputType === "insertText" && !/^[a-zA-Z0-9]$/.test(e.data)) {
                        e.preventDefault();
                        showTemporaryInvalid(this);
                    }
                });

                plateInput?.addEventListener("input", function () {
                    this.value = this.value
                        .toUpperCase()
                        .replace(/[^A-Z0-9]/g, "");
                });

                const modelYearInput = get("ModelYear");

                modelYearInput?.addEventListener("beforeinput", function (e) {
                    if (e.inputType === "insertText" && !/^\d$/.test(e.data)) {
                        e.preventDefault();
                        showTemporaryInvalid(this);
                    }
                });

                modelYearInput?.addEventListener("input", function () {
                    this.value = this.value.replace(/\D/g, "").slice(0, 4);
                });

                const mileageInput = get("Mileage");

                mileageInput?.addEventListener("beforeinput", function (e) {
                    if (e.inputType === "insertText" && !/^\d$/.test(e.data)) {
                        e.preventDefault();
                        showTemporaryInvalid(this);
                    }
                });

                mileageInput?.addEventListener("input", function () {
                    const digits = this.value.replace(/\D/g, "").slice(0, 8);
                    this.value = digits.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
                });

                const requestEstimatedInput = get("requestEstimatedInput");

                requestEstimatedInput?.addEventListener("input", function () {
                    const digits = this.value.replace(/\D/g, "");

                    if (!digits) {
                        this.value = "";
                        return;
                    }

                    this.value = Number(digits).toLocaleString("tr-TR");
                });
            }

            function initializeCustomerSearch() {
                const customerSearchInput = get("customerSearchInput") || firstByName("CustomerName");
                const customerResults = get("customerSearchResults");

                if (!customerSearchInput || !customerResults) return;

                customerSearchInput.addEventListener("input", function () {
                    clearTimeout(customerSearchTimeout);

                    const query = this.value.trim();

                    if (query.length < 2) {
                        customerResults.style.display = "none";
                        customerResults.innerHTML = "";
                        return;
                    }

                    customerSearchTimeout = setTimeout(async () => {
                        const response = await fetch(`/ServiceRecords/SearchCustomers?query=${encodeURIComponent(query)}`);

                        if (!response.ok) return;

                        const customers = await response.json();

                        customerResults.innerHTML = "";

                        if (!customers.length) {
                            customerResults.style.display = "none";
                            return;
                        }

                        customers.forEach(customer => {
                            const item = document.createElement("div");
                            item.className = "customer-search-item";

                            item.innerHTML = `
                                <strong>${customer.name}</strong>
                                <span>${customer.phoneNumber ?? "-"} ${customer.email ?? ""}</span>
                            `;

                            item.addEventListener("click", () => {
                                customerSearchInput.value = customer.name ?? "";

                                const container = getActiveCustomerContainer();

                                const phoneInput = container.querySelector(`[name="CustomerPhoneNumber"]`);
                                const emailInput = container.querySelector(`[name="CustomerEmail"]`);

                                if (phoneInput) phoneInput.value = customer.phoneNumber ?? "";
                                if (emailInput) emailInput.value = customer.email ?? "";

                                customerResults.style.display = "none";

                                saveCreateFormDraft();
                            });

                            customerResults.appendChild(item);
                        });

                        customerResults.style.display = "block";
                    }, 300);
                });

                document.addEventListener("click", function (e) {
                    if (!customerResults.contains(e.target) && e.target !== customerSearchInput) {
                        customerResults.style.display = "none";
                    }
                });

                document.addEventListener("keydown", function (e) {
                    if (e.ctrlKey && e.key.toLowerCase() === "k") {
                        e.preventDefault();
                        customerSearchInput.focus();
                    }
                });
            }

