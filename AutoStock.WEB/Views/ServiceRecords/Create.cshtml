@model AutoStock.WEB.Models.ServiceRecords.CreateServiceRecordViewModel

@{
    ViewData["Title"] = "Yeni Servis Girişi";
}


<style>
    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        background: radial-gradient(circle at top left, rgba(37, 99, 235, .08), transparent 30rem), radial-gradient(circle at top right, rgba(22, 163, 74, .07), transparent 28rem), #f3f6fb;
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: #0f172a;
    }

    .page {
        width: min(1280px, calc(100% - 44px));
        margin: 0 auto;
        padding: 30px 0 56px;
    }

    .premium-header {
        margin-bottom: 26px;
        padding: 30px 34px;
        border-radius: 30px;
        background: radial-gradient(circle at 88% 30%, rgba(255,255,255,.18), transparent 18rem), linear-gradient(135deg, #07111f 0%, #111827 44%, #2554d8 100%);
        color: white;
        box-shadow: 0 26px 70px rgba(15, 23, 42, .22);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 22px;
    }

    .premium-brand {
        display: flex;
        align-items: center;
        gap: 18px;
        min-width: 0;
    }

    .premium-logo {
        width: 54px;
        height: 54px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #2563eb, #16a34a);
        color: white;
        font-weight: 950;
        font-size: 22px;
        flex-shrink: 0;
        box-shadow: 0 18px 40px rgba(37, 99, 235, .28);
    }

    .premium-eyebrow {
        display: inline-flex;
        margin-bottom: 7px;
        padding: 6px 11px;
        border-radius: 999px;
        background: rgba(255,255,255,.13);
        border: 1px solid rgba(255,255,255,.18);
        color: rgba(255,255,255,.82);
        font-size: 12px;
        font-weight: 850;
        letter-spacing: .2px;
    }

    .premium-header h1 {
        margin: 0;
        font-size: 34px;
        line-height: 1.04;
        letter-spacing: -1.4px;
    }

    .premium-header p {
        margin: 10px 0 0;
        max-width: 720px;
        color: rgba(255,255,255,.72);
        font-size: 15px;
        line-height: 1.55;
    }

    .premium-home {
        width: 52px;
        height: 52px;
        display: grid;
        place-items: center;
        border-radius: 17px;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.18);
        color: white;
        text-decoration: none;
        font-size: 21px;
        flex-shrink: 0;
        transition: .18s ease;
    }

        .premium-home:hover {
            background: rgba(255,255,255,.22);
            transform: translateY(-2px);
        }

    .layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 350px;
        gap: 24px;
        align-items: start;
    }

    .main-flow {
        display: grid;
        gap: 18px;
        overflow: visible;
    }

    .card,
    .summary {
        background: rgba(255,255,255,.94);
        border: 1px solid #e2e8f0;
        border-radius: 26px;
        box-shadow: 0 18px 46px rgba(15, 23, 42, .07);
        backdrop-filter: blur(18px);
        overflow: visible;
    }

    .card {
        padding: 22px;
    }

    .section-title {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
    }

    .section-icon {
        width: 38px;
        height: 38px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        font-size: 18px;
        flex-shrink: 0;
    }

        .section-icon.customer {
            background: #e0e7ff;
            color: #2563eb;
        }

        .section-icon.vehicle {
            background: #dcfce7;
            color: #16a34a;
        }

        .section-icon.request {
            background: #f3e8ff;
            color: #9333ea;
        }

    .section-title h3,
    .summary h3 {
        margin: 0;
        font-size: 20px;
        letter-spacing: -.45px;
        color: #0f172a;
    }

    .section-title p {
        margin: 3px 0 0;
        color: #64748b;
        font-size: 13px;
        font-weight: 650;
    }

    .form-grid,
    .vehicle-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
    }

    .request-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 220px 116px;
        gap: 14px;
        align-items: end;
    }

    .form-field {
        position: relative;
        min-width: 0;
    }

        .form-field.full {
            grid-column: 1 / -1;
        }

    input,
    select,
    textarea {
        width: 100%;
        min-height: 52px;
        border: 1px solid #dbe3ef;
        border-radius: 16px;
        background: #f8fafc;
        padding: 18px 15px 9px;
        font: inherit;
        font-size: 15px;
        color: #0f172a;
        outline: none;
        transition: border-color .18s ease, box-shadow .18s ease, background .18s ease;
    }

    textarea {
        min-height: 118px;
        resize: vertical;
        line-height: 1.5;
    }

        input:hover,
        select:hover,
        textarea:hover {
            border-color: #cbd5e1;
            background: white;
        }

        input:focus,
        select:focus,
        textarea:focus {
            border-color: #2563eb;
            background: white;
            box-shadow: 0 0 0 4px rgba(37, 99, 235, .10);
        }

    .form-field label {
        position: absolute;
        top: 15px;
        left: 14px;
        margin: 0;
        padding: 0 6px;
        border-radius: 8px;
        background: #f8fafc;
        color: #64748b;
        font-size: 14px;
        font-weight: 780;
        pointer-events: none;
        transition: .18s ease;
        max-width: calc(100% - 28px);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .form-field input:focus + label,
    .form-field input:not(:placeholder-shown) + label,
    .form-field textarea:focus + label,
    .form-field textarea:not(:placeholder-shown) + label,
    .form-field select + label {
        top: -8px;
        left: 12px;
        background: white;
        color: #2563eb;
        font-size: 11px;
        font-weight: 850;
    }

    .required {
        color: #ef4444;
    }

    .field-error,
    .field-validation-error {
        display: block;
        margin-top: 6px;
        color: #dc2626;
        font-size: 12px;
        font-weight: 750;
    }

    .input-invalid {
        border-color: #ef4444 !important;
        background: #fff7f7 !important;
        box-shadow: 0 0 0 4px rgba(239, 68, 68, .10) !important;
    }

    .form-field.customer-search-wrapper {
        position: relative;
        z-index: 9999;
        overflow: visible;
    }

        .form-field.customer-search-wrapper .customer-search-results {
            position: absolute;
            top: calc(100% + 8px);
            left: 0;
            right: 0;
            width: 100%;
            background: white;
            border: 1px solid #dbe2f0;
            border-radius: 18px;
            box-shadow: 0 18px 42px rgba(15, 23, 42, 0.14);
            z-index: 99999;
            overflow: hidden;
            display: none;
        }

    .customer-search-item {
        padding: 15px 18px;
        cursor: pointer;
        border-bottom: 1px solid #eef2f7;
        background: white;
        transition: .18s ease;
    }

        .customer-search-item:last-child {
            border-bottom: none;
        }

        .customer-search-item:hover {
            background: #f8fafc;
        }

        .customer-search-item strong {
            display: block;
            font-size: 14px;
            color: #0f172a;
        }

        .customer-search-item span {
            display: block;
            margin-top: 4px;
            font-size: 12px;
            color: #64748b;
            font-weight: 650;
        }

    .btn-add-request {
        width: 100%;
        min-height: 52px;
        border: none;
        border-radius: 16px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: white;
        font: inherit;
        font-size: 15px;
        font-weight: 900;
        cursor: pointer;
        box-shadow: 0 14px 28px rgba(37, 99, 235, .20);
        transition: .18s ease;
    }

        .btn-add-request:hover {
            transform: translateY(-1px);
            box-shadow: 0 18px 34px rgba(37, 99, 235, .26);
        }

    .request-items {
        display: grid;
        gap: 12px;
        margin-top: 16px;
    }

    .request-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        padding: 15px 16px;
        border-radius: 18px;
        background: #f8fafc;
        border: 1px solid #dbe3ef;
    }

        .request-item strong {
            display: block;
            color: #0f172a;
            font-size: 15px;
        }

        .request-item span,
        .request-item small {
            display: block;
            margin-top: 5px;
            color: #64748b;
            font-size: 13px;
            font-weight: 700;
        }

    .request-remove {
        border: none;
        background: #fee2e2;
        color: #b91c1c;
        width: 36px;
        height: 36px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 950;
        flex-shrink: 0;
    }

    .summary {
        position: sticky;
        top: 24px;
        padding: 22px;
    }

    .summary-head {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
    }

    .summary-icon {
        width: 38px;
        height: 38px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        background: #ffedd5;
        color: #f97316;
        font-size: 18px;
        flex-shrink: 0;
    }

    .summary-subtitle {
        margin-top: 3px;
        color: #64748b;
        font-size: 13px;
        font-weight: 650;
    }

    .summary-line {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        padding: 13px 0;
        border-bottom: 1px solid #e2e8f0;
        font-size: 14px;
    }

        .summary-line span {
            color: #64748b;
            font-weight: 760;
        }

        .summary-line strong {
            text-align: right;
            font-weight: 900;
            color: #0f172a;
        }

    .status-pill {
        display: inline-flex;
        align-items: center;
        padding: 5px 10px;
        border-radius: 999px;
        background: #dcfce7;
        color: #15803d;
        font-size: 12px;
        font-weight: 900;
    }

    .total {
        margin: 20px 0;
        padding: 20px;
        border-radius: 20px;
        background: linear-gradient(135deg, rgba(37,99,235,.08), rgba(37,99,235,.02));
        border: 1px solid rgba(37,99,235,.40);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.6);
    }

        .total span {
            color: #1d4ed8;
            font-size: 13px;
            font-weight: 900;
        }

        .total strong {
            display: block;
            margin-top: 8px;
            font-size: 30px;
            line-height: 1;
            letter-spacing: -1.1px;
            color: #0f172a;
        }

    .quick-actions {
        margin-top: 18px;
        padding-top: 18px;
        border-top: 1px solid #e2e8f0;
        display: grid;
        gap: 10px;
    }

    .quick-title {
        margin: 0 0 2px;
        font-size: 16px;
        font-weight: 950;
        letter-spacing: -.3px;
        color: #0f172a;
    }

    .quick-action {
        width: 100%;
        min-height: 62px;
        padding: 12px 14px;
        border-radius: 16px;
        border: 1px solid #dbe3ef;
        background: #f8fafc;
        display: flex;
        align-items: center;
        gap: 12px;
        text-align: left;
        cursor: pointer;
        transition: .18s ease;
        color: inherit;
        text-decoration: none;
    }

        .quick-action:hover {
            background: white;
            border-color: #cbd5e1;
            transform: translateY(-1px);
        }

    .quick-action-icon {
        width: 36px;
        height: 36px;
        display: grid;
        place-items: center;
        border-radius: 13px;
        background: #eef2ff;
        color: #2563eb;
        font-size: 18px;
        flex-shrink: 0;
    }

    .quick-action strong {
        display: block;
        font-size: 14px;
        font-weight: 950;
        color: #0f172a;
    }

    .quick-action span {
        display: block;
        margin-top: 3px;
        color: #64748b;
        font-size: 12px;
        font-weight: 700;
    }

    .summary-buttons {
        display: grid;
        gap: 12px;
        margin-top: 18px;
    }

    .btn-primary,
    .btn-secondary {
        width: 100%;
        min-height: 54px;
        border-radius: 16px;
        font: inherit;
        font-size: 15px;
        font-weight: 950;
        cursor: pointer;
        transition: .18s ease;
    }

    .btn-primary {
        border: none;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: white;
        box-shadow: 0 14px 28px rgba(37, 99, 235, .24);
    }

    .btn-secondary {
        border: 1px solid #dbe3ef;
        background: white;
        color: #334155;
    }

        .btn-primary:hover,
        .btn-secondary:hover {
            transform: translateY(-1px);
        }

    .toast-message {
        position: fixed;
        right: 24px;
        bottom: 24px;
        min-width: 280px;
        max-width: 420px;
        padding: 14px 18px;
        border-radius: 14px;
        color: #fff;
        font-size: 14px;
        font-weight: 600;
        box-shadow: 0 18px 45px rgba(15, 23, 42, .22);
        opacity: 0;
        pointer-events: none;
        transform: translateY(20px);
        transition: all .25s ease;
        z-index: 999999;
    }

        .toast-message.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast-message.success {
            background: linear-gradient(135deg, #16a34a, #22c55e);
        }

        .toast-message.error {
            background: linear-gradient(135deg, #dc2626, #ef4444);
        }

        .toast-message.info {
            background: linear-gradient(135deg, #2563eb, #38bdf8);
        }

    @@media (max-width: 1180px) {
        .layout {
            grid-template-columns: 1fr;
        }

        .summary {
            position: static;
        }
    }

    @@media (max-width: 900px) {
        .page {
            width: min(100% - 28px, 1280px);
            padding-top: 18px;
        }

        .premium-header {
            padding: 24px;
            border-radius: 26px;
            align-items: flex-start;
        }

        .premium-brand {
            align-items: flex-start;
        }

        .premium-header h1 {
            font-size: 28px;
        }

        .premium-header p {
            font-size: 14px;
        }

        .form-grid,
        .vehicle-grid,
        .request-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 600px) {
        .page {
            width: 100%;
            padding: 14px;
        }

        .premium-header {
            margin-bottom: 18px;
            padding: 20px;
        }

        .premium-logo {
            width: 48px;
            height: 48px;
            border-radius: 16px;
        }

        .premium-home {
            width: 44px;
            height: 44px;
            border-radius: 15px;
            font-size: 18px;
        }

        .card,
        .summary {
            border-radius: 22px;
            padding: 18px;
        }

            .section-title h3,
            .summary h3 {
                font-size: 19px;
            }

        input,
        select,
        textarea {
            min-height: 52px;
            font-size: 15px;
        }

        .total strong {
            font-size: 28px;
        }
    }

    .main-flow .card {
        position: relative;
        z-index: 1;
    }

        .main-flow .card:first-child {
            z-index: 9999;
        }

    .customer-extra-toggle {
        grid-column: 1 / -1;
        margin-top: 4px;
    }

        .customer-extra-toggle button {
            border: none;
            background: #eff6ff;
            color: #2563eb;
            padding: 11px 16px;
            border-radius: 999px;
            font-weight: 900;
            cursor: pointer;
        }

    .customer-extra-panel {
        grid-column: 1 / -1;
        display: none;
        margin-top: 14px;
        padding-top: 18px;
        border-top: 1px solid #e5e7eb;
    }

        .customer-extra-panel.active {
            display: block;
        }

    .customer-type-switch {
        display: inline-flex;
        gap: 8px;
        padding: 6px;
        background: #f1f5f9;
        border-radius: 999px;
        margin-bottom: 16px;
    }

        .customer-type-switch button {
            border: none;
            padding: 9px 16px;
            border-radius: 999px;
            background: transparent;
            color: #64748b;
            font-weight: 900;
            cursor: pointer;
        }

            .customer-type-switch button.active {
                background: #2563eb;
                color: white;
            }

    .corporate-fields {
        display: none;
    }

        .corporate-fields.active {
            display: block;
        }

    .form-field.full {
        grid-column: 1 / -1;
    }

    .service-stepper {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        margin-bottom: 22px;
    }

    .step-tab {
        border: 1px solid #dbe4f0;
        background: #ffffff;
        color: #64748b;
        border-radius: 18px;
        padding: 14px 16px;
        font-weight: 900;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

        .step-tab span {
            width: 28px;
            height: 28px;
            border-radius: 999px;
            background: #eef2ff;
            color: #2563eb;
            display: grid;
            place-items: center;
            font-size: 13px;
        }

        .step-tab.active {
            background: #2563eb;
            color: white;
            border-color: #2563eb;
            box-shadow: 0 14px 30px rgba(37, 99, 235, .22);
        }

            .step-tab.active span {
                background: white;
                color: #2563eb;
            }

    .service-step {
        display: none;
    }

        .service-step.active {
            display: block;
        }

    .step-actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 22px;
    }

    .step-next,
    .step-back {
        border: none;
        border-radius: 16px;
        padding: 14px 22px;
        font-weight: 950;
        cursor: pointer;
    }

    .step-next {
        background: #2563eb;
        color: white;
    }

    .step-back {
        background: #f1f5f9;
        color: #334155;
    }

    @@media (max-width: 760px) {
        .service-stepper {
            grid-template-columns: 1fr 1fr;
        }

        .step-tab {
            font-size: 13px;
            padding: 12px;
        }

        .step-actions {
            flex-direction: column;
        }

        .step-next,
        .step-back {
            width: 100%;
        }
    }
</style>

<div class="page">

    <section class="premium-header">
        <div class="premium-brand">
            <div class="premium-logo">S</div>

            <div>
                <span class="premium-eyebrow">SERVİS KAYITLARI</span>
                <h1>Yeni Servis Girişi</h1>
                <p>Müşteri, araç ve servis taleplerini hızlıca kaydedin. Gerekirse servis formunu PDF olarak oluşturun.</p>
            </div>
        </div>
        <a asp-controller="Dashboard"
               asp-action="Index"
               class="premium-home"
               title="Ana sayfa">
            ⌂
        </a>
    </section>

    <div id="toastMessage" class="toast-message"></div>

    <form asp-action="Create" method="post" id="serviceCreateForm">
        <div class="layout">

            <main class="main-flow">

                <div class="service-stepper">
                    <button type="button" class="step-tab active" data-step="1" onclick="goToStep(1)">
                        <span>1</span> Müşteri
                    </button>

                    <button type="button" class="step-tab" data-step="2" onclick="goToStep(2)">
                        <span>2</span> Araç
                    </button>

                    <button type="button" class="step-tab" data-step="3" onclick="goToStep(3)">
                        <span>3</span> Talepler
                    </button>

                    <button type="button" class="step-tab" data-step="4" onclick="goToStep(4)">
                        <span>4</span> Özet
                    </button>
                </div>

                <section class="card service-step active" data-step="1">
                    <div class="section-title">
                        <div class="section-icon customer">♙</div>
                        <div>
                            <h3>Müşteri Bilgileri</h3>
                            <p>Müşteri iletişim bilgilerini girin.</p>
                        </div>
                    </div>

                    <div class="form-grid">

                        <div class="form-field customer-search-wrapper">

                            <input asp-for="CustomerName"
                                   id="customerSearchInput"
                                   autocomplete="off"
                                   placeholder=" " />

                            <label>
                                Ad Soyad / Firma Adı <span class="required">*</span>
                            </label>

                            <div id="customerSearchResults"
                                 class="customer-search-results">
                            </div>

                        </div>

                        <div class="form-field">
                            <input asp-for="CustomerPhoneNumber" placeholder=" " autocomplete="off" inputmode="numeric" />
                            <label>Telefon Numarası <span class="required">*</span></label>
                            <span asp-validation-for="CustomerPhoneNumber" class="field-error"></span>
                        </div>

                        <div class="form-field">
                            <input asp-for="CustomerEmail" placeholder=" " autocomplete="off" />
                            <label>Mail Adresi</label>
                        </div>
                        <div class="customer-extra-toggle">
                            <button type="button" onclick="toggleCustomerExtra()">
                                + Detaylı Müşteri Bilgisi
                            </button>
                        </div>

                        <div id="customerExtraPanel" class="customer-extra-panel">
                            <div class="customer-type-switch">
                                <button type="button"
                                        class="active"
                                        data-type="1"
                                        onclick="setCustomerType(1, this)">
                                    Bireysel
                                </button>

                                <button type="button"
                                        data-type="2"
                                        onclick="setCustomerType(2, this)">
                                    Kurumsal
                                </button>
                            </div>

                            <input type="hidden" asp-for="CustomerType" id="CustomerType" />

                            <div id="corporateFields" class="corporate-fields">
                                <div class="form-grid">
                                    <div class="form-field">
                                        <input asp-for="CompanyName" placeholder=" " />
