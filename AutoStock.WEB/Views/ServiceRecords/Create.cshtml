                        </div>

                        <div class="form-field">
                            <input asp-for="Mileage" placeholder=" " autocomplete="off" inputmode="numeric" />
                            <label>Kilometre</label>
                        </div>

                        <div class="form-field">
                            <input asp-for="ChassisNumber" placeholder=" " autocomplete="off" />
                            <label>Şasi No</label>
                        </div>
                    </div>

                    <div class="step-actions">
                        <button type="button" class="step-back" onclick="goToStep(1)">
