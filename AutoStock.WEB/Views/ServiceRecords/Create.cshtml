                    </div>

                    <div id="requestItemsContainer"
                         class="request-items">
                    </div>

                    <div class="step-actions">
                        <button type="button"
                                class="step-back"
                                onclick="goToStep(2)">
                            ← Geri
                        </button>

                        <button type="button"
                                class="step-next"
                                onclick="goToStep(4)">
                            Özete Geç →
