            document.addEventListener("DOMContentLoaded", async function () {
                if (get("CustomerType") && !get("CustomerType").value) {
                    get("CustomerType").value = 1;
                }

                setCustomerType(
                    Number(get("CustomerType")?.value || 1),
                    document.querySelector(`.customer-type-switch button[data-type="${get("CustomerType")?.value || 1}"]`)
                );

                await loadLocationData();

                initializeDraftAutoSave();
                initializeInputMasks();
                initializeCustomerSearch();
                initializeVehicleBrandModel();
                initializeLocationEvents();

                await restoreCreateFormDraft();
                restoreRequestItemsDraft();

                updateRequestSummary();
            });

            function toTitleCase(text) {

    return text
        .toLocaleLowerCase("tr-TR")
        .split(" ")
        .map(word =>
            word.charAt(0).toLocaleUpperCase("tr-TR") +
            word.slice(1))
        .join(" ");
}
