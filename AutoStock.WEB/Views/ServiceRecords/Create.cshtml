@model AutoStock.WEB.Models.ServiceRecords.CreateServiceRecordViewModel

@{
    ViewData["Title"] = "Yeni Servis Girişi";
}

<link rel="stylesheet" href="~/css/service-record-create.css" asp-append-version="true" />

<div class="page">

    <section class="premium-header">
        <div class="premium-brand">
            <div class="premium-logo">S</div>

            <div>
                <span class="premium-eyebrow">SERVİS KAYITLARI</span>
                <h1>Yeni Servis Girişi</h1>
                <p>
                    Müşteri, araç ve servis taleplerini hızlıca kaydedin.
                    Kaydı açmadan önce servis ön kabul formunu kontrol edin.
                </p>
            </div>
        </div>

        <a asp-controller="Dashboard"
           asp-action="Index"
           class="premium-home"
           title="Ana sayfa">
            ⌂
        </a>
    </section>

    <div id="toastMessage" class="toast-message"></div>

    <input type="hidden"
           id="ServiceAdvisorNameForPreview"
           value="@Model.ServiceAdvisorName" />

    <form asp-action="Create"
          method="post"
          id="serviceCreateForm"
          autocomplete="off">

        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="CustomerType" id="CustomerType" />
        <input type="hidden" id="CustomerSubType" name="CustomerSubType" value="individual" />

        <input type="hidden" id="SelectedCustomerId" name="SelectedCustomerId" />
        <input type="hidden" id="SelectedVehicleId" name="SelectedVehicleId" />
        <input type="hidden" id="VehicleOwnershipConfirmed" name="VehicleOwnershipConfirmed" value="false" />
        <input type="hidden" id="VehicleOwnershipAction" name="VehicleOwnershipAction" />

        <div class="layout" id="createLayout">

            <main class="main-flow">

                <div class="service-stepper">
                    <button type="button"
                            class="step-tab active"
                            data-step="1"
                            onclick="goToStep(1)">
                        <span>👤</span>
                        <strong>Müşteri Bilgisi</strong>
                    </button>

                    <button type="button"
                            class="step-tab"
                            data-step="2"
                            onclick="goToStep(2)">
                        <span>🚘</span>
                        <strong>Araç Bilgisi</strong>
                    </button>

                    <button type="button"
                            class="step-tab"
                            data-step="3"
                            onclick="goToStep(3)">
                        <span>☷</span>
                        <strong>Şikayet & Talep</strong>
                    </button>

                    <button type="button"
                            class="step-tab"
                            data-step="4"
                            onclick="goToStep(4)">
                        <span>✓</span>
                        <strong>Özet & Onay</strong>
                    </button>
                </div>

                <section class="card service-step active" data-step="1">
                    <div class="section-title">
                        <div class="section-icon customer">♙</div>
                        <div>
                            <h3>Müşteri Bilgileri</h3>
                            <p>Kayıtlı müşteri arayın veya hızlı müşteri bilgisi girin.</p>
                        </div>
                    </div>

                    <div id="customerStepStatus"
                         class="step-validation-status"
                         role="status"
                         aria-live="polite"
                         hidden>
                    </div>

                    <div class="form-grid">

                        <div class="quick-customer-fields" id="quickCustomerFields">

                            <div class="form-field customer-search-wrapper">
                                <input asp-for="CustomerName"
                                       id="MainCustomerName"
                                       class="js-title-case"
                                       autocomplete="off"
                                       placeholder=" " />

                                <label>
                                    Müşteri / Plaka Ara <span class="required">*</span>
                                </label>

                                <span asp-validation-for="CustomerName" class="field-error"></span>

                                <div id="customerSearchResults"
                                     class="customer-search-results">
                                </div>
                            </div>

                            <div class="form-field">
                                <input name="VehicleDeliveredBy"
                                       id="VehicleDeliveredBy"
                                       class="js-title-case"
                                       placeholder=" "
                                       autocomplete="off" />
                                <label>Aracı Getiren</label>
                            </div>

                            <div class="form-field">
                                <input asp-for="CustomerPhoneNumber"
                                       id="MainCustomerPhoneNumber"
                                       placeholder=" "
                                       autocomplete="off"
                                       inputmode="numeric" />
                                <label>Telefon Numarası <span class="required">*</span></label>
                                <span asp-validation-for="CustomerPhoneNumber" class="field-error"></span>
                            </div>

                            <div class="form-field">
                                <input asp-for="CustomerEmail"
                                       id="MainCustomerEmail"
                                       class="js-email-lower"
                                       placeholder=" "
                                       autocomplete="off" />
                                <label>Mail Adresi</label>
                            </div>

                        </div>

                        <div id="selectedCustomerCard" class="selected-card">
                            <div>
                                <strong id="selectedCustomerNameText">Seçili müşteri</strong>
                                <span id="selectedCustomerInfoText">-</span>
                            </div>

                            <button type="button" onclick="clearSelectedCustomer()">
                                Değiştir
                            </button>
                        </div>

                        <div class="customer-extra-toggle">
                            <button type="button" onclick="toggleCustomerExtra()">
                                <span class="customer-extra-toggle-icon" aria-hidden="true">+</span>
                                <span class="customer-extra-toggle-text">
                                    <strong>Müşteri tipini ve fatura bilgilerini düzenle</strong>
                                    <small>Bireysel, şahıs firması veya kurumsal bilgileri kontrol edin</small>
                                </span>
                            </button>
                        </div>

                        <div id="customerExtraPanel" class="customer-extra-panel">

                            <div class="customer-extra-header">
                                <div>
                                    <strong>Müşteri Tipi ve Cari Bilgiler</strong>
                                    <p style="margin:4px 0 0; color:#64748b; font-size:13px; font-weight:700;">
                                        Müşteri tipini, fatura/cari ve servis iletişim bilgilerini kontrol edin.
                                    </p>
                                </div>

                                <button type="button"
                                        class="customer-extra-back"
                                        onclick="backToQuickCustomer()">
                                    Kapat
                                </button>
                            </div>

                            <div class="customer-type-switch">
                                <button type="button"
                                        class="active"
                                        data-type="1"
                                        onclick="setCustomerType(1, this)">
                                    Bireysel
                                </button>

                                <button type="button"
                                        data-type="2"
                                        onclick="setCustomerType(2, this)">
                                    Kurumsal
                                </button>
                            </div>

                            <div id="individualSubType" class="individual-subtype active">
                                <div class="customer-subtype-switch">
                                    <button type="button"
                                            class="active"
                                            data-subtype="individual"
                                            onclick="setCustomerSubType('individual', this)">
                                        Bireysel Müşteri
                                    </button>

                                    <button type="button"
                                            data-subtype="sole"
                                            onclick="setCustomerSubType('sole', this)">
                                        Şahıs Firması
                                    </button>
                                </div>
                            </div>

                            <div id="individualFields" class="individual-fields active">
                                <div class="form-grid">
                                    <div class="form-field">
                                        <input name="CustomerName"
                                               id="IndividualCustomerName"
                                               class="js-title-case"
                                               placeholder=" "
                                               autocomplete="off" />
                                        <label>Ad Soyad <span class="required">*</span></label>
                                    </div>

                                    <div class="form-field">
                                        <input name="CustomerPhoneNumber"
                                               id="IndividualCustomerPhoneNumber"
                                               placeholder=" "
                                               autocomplete="off"
                                               inputmode="numeric" />
                                        <label>Telefon Numarası <span class="required">*</span></label>
                                    </div>

                                    <div class="form-field">
                                        <input name="CustomerEmail"
                                               id="IndividualCustomerEmail"
                                               class="js-email-lower"
                                               placeholder=" "
                                               autocomplete="off" />
                                        <label>Mail Adresi</label>
                                    </div>

                                    <div class="form-field">
                                        <input id="IndividualNationalIdentityNumber"
                                               name="NationalIdentityNumber"
                                               placeholder=" "
                                               autocomplete="off"
                                               inputmode="numeric"
                                               maxlength="11" />
                                        <label>TC Kimlik No</label>
                                    </div>

                                    <div class="form-field">
                                        <select name="AddressCity" id="IndividualAddressCity">
                                            <option value="">İl seçiniz</option>
                                        </select>
                                        <label>Adres İli</label>
                                    </div>

                                    <div class="form-field">
                                        <select name="AddressDistrict" id="IndividualAddressDistrict">
                                            <option value="">Önce il seçiniz</option>
                                        </select>
                                        <label>Adres İlçesi</label>
                                    </div>

                                    <div class="form-field full">
                                        <textarea name="CustomerAddress"
                                                  id="IndividualCustomerAddress"
                                                  placeholder=" "></textarea>
                                        <label>Açık Adres</label>
                                    </div>
                                </div>
                            </div>

                            <div id="soleFields" class="sole-fields">

                                <div class="form-block-title">Cari / Fatura Bilgileri</div>

                                <div class="form-grid">

                                    <div class="form-field">
                                        <input id="SoleCustomerName"
                                               name="CustomerName"
                                               class="js-title-case"
                                               placeholder=" "
                                               autocomplete="off" />
                                        <label>Müşteri / Cari Adı <span class="required">*</span></label>
                                    </div>

                                    <div class="form-field">
                                        <input id="SoleCompanyName"
                                               name="CompanyName"
                                               class="js-title-case"
                                               placeholder=" "
                                               autocomplete="off" />
                                        <label>İşletme Adı</label>
                                    </div>

                                    <div class="form-field">
                                        <input id="SoleNationalIdentityNumber"
                                               name="NationalIdentityNumber"
                                               placeholder=" "
                                               autocomplete="off"
                                               inputmode="numeric"
                                               maxlength="11" />
                                        <label>TC Kimlik No</label>
                                    </div>

                                    <div class="form-field">
                                        <select id="SoleTaxOfficeCity"
                                                name="TaxOfficeCity">
                                            <option value="">İl seçiniz</option>
                                        </select>
                                        <label>Vergi Dairesi İli</label>
                                    </div>

                                    <div class="form-field">
                                        <select id="SoleTaxOfficeSelect"
                                                name="TaxOffice">
                                            <option value="">Vergi dairesi seçiniz</option>
                                        </select>
                                        <label>Vergi Dairesi</label>
                                    </div>

                                    <div class="form-field">
                                        <input id="SoleTaxNumber"
                                               name="TaxNumber"
                                               placeholder=" "
                                               autocomplete="off"
                                               inputmode="numeric" />
                                        <label>Vergi No</label>
                                    </div>

                                    <div class="form-field">
                                        <select id="SoleAddressCity"
                                                name="AddressCity">
                                            <option value="">İl seçiniz</option>
                                        </select>
                                        <label>Adres İli</label>
                                    </div>

                                    <div class="form-field">
                                        <select id="SoleAddressDistrict"
                                                name="AddressDistrict">
                                            <option value="">Önce il seçiniz</option>
                                        </select>
                                        <label>Adres İlçesi</label>
                                    </div>

                                    <div class="form-field full">
                                        <textarea id="SoleCustomerAddress"
                                                  name="CustomerAddress"
                                                  placeholder=" "></textarea>
                                        <label>Açık Adres</label>
                                    </div>

                                </div>

                                <div class="form-block-title with-space">
                                    Servis İletişim Bilgileri
                                </div>

                                <div class="form-grid">

                                    <div class="form-field">
                                        <input id="SoleVehicleDeliveredBy"
                                               name="VehicleDeliveredBy"
                                               class="js-title-case"
                                               placeholder=" "
                                               autocomplete="off" />

                                        <label>
                                            Aracı Getiren / İlgili Kişi
                                            <span class="required">*</span>
                                        </label>
                                    </div>

                                    <div class="form-field">
                                        <input id="SoleCustomerPhoneNumber"
                                               name="CustomerPhoneNumber"
                                               placeholder=" "
                                               autocomplete="off"
                                               inputmode="numeric" />

                                        <label>
                                            İletişim Telefonu
                                            <span class="required">*</span>
                                        </label>
                                    </div>

                                    <div class="form-field">
                                        <input id="SoleCustomerEmail"
                                               name="CustomerEmail"
                                               class="js-email-lower"
                                               placeholder=" "
                                               autocomplete="off" />

                                        <label>İletişim Maili</label>
                                    </div>

                                </div>

                            </div>

                            <div id="corporateFields" class="corporate-fields">

                                <div class="form-block-title">
                                    Cari / Fatura Bilgileri
                                </div>

                                <div class="form-grid">

                                    <div class="form-field">
                                        <input id="CorporateCustomerName"
                                               name="CustomerName"
                                               class="js-title-case"
                                               placeholder=" "
                                               autocomplete="off" />

                                        <label>
                                            Müşteri / Cari Adı
                                            <span class="required">*</span>
                                        </label>
                                    </div>

                                    <div class="form-field">
                                        <input id="CorporateCompanyName"
                                               name="CompanyName"
                                               class="js-title-case"
                                               placeholder=" "
                                               autocomplete="off" />

                                        <label>Firma Ünvanı</label>
                                    </div>

                                    <div class="form-field">
                                        <input id="CorporateAuthorizedPersonName"
                                               name="AuthorizedPersonName"
                                               class="js-title-case"
                                               placeholder=" "
                                               autocomplete="off" />

                                        <label>Firma Yetkilisi</label>
                                    </div>

                                    <div class="form-field">
                                        <select id="CorporateTaxOfficeCity"
                                                name="TaxOfficeCity">
                                            <option value="">İl seçiniz</option>
                                        </select>
                                        <label>Vergi Dairesi İli</label>
                                    </div>

                                    <div class="form-field">
                                        <select id="CorporateTaxOfficeSelect"
                                                name="TaxOffice">
                                            <option value="">Vergi dairesi seçiniz</option>
                                        </select>
                                        <label>Vergi Dairesi</label>
                                    </div>

                                    <div class="form-field">
                                        <input id="CorporateTaxNumber"
                                               name="TaxNumber"
                                               placeholder=" "
                                               autocomplete="off"
                                               inputmode="numeric" />
                                        <label>Vergi No</label>
                                    </div>

                                    <div class="form-field">
                                        <select id="CorporateAddressCity"
                                                name="AddressCity">
                                            <option value="">İl seçiniz</option>
                                        </select>
                                        <label>Adres İli</label>
                                    </div>

                                    <div class="form-field">
                                        <select id="CorporateAddressDistrict"
                                                name="AddressDistrict">
                                            <option value="">Önce il seçiniz</option>
                                        </select>
                                        <label>Adres İlçesi</label>
                                    </div>

                                    <div class="form-field full">
                                        <textarea id="CorporateCustomerAddress"
                                                  name="CustomerAddress"
                                                  placeholder=" "></textarea>
                                        <label>Açık Adres</label>
                                    </div>

                                </div>

                                <div class="form-block-title with-space">
                                    Servis İletişim Bilgileri
                                </div>

                                <div class="form-grid">

                                    <div class="form-field">
                                        <input id="CorporateVehicleDeliveredBy"
                                               name="VehicleDeliveredBy"
                                               class="js-title-case"
                                               placeholder=" "
                                               autocomplete="off" />

                                        <label>
                                            Aracı Getiren / İlgili Kişi
                                            <span class="required">*</span>
                                        </label>
                                    </div>

                                    <div class="form-field">
                                        <input id="CorporateCustomerPhoneNumber"
                                               name="CustomerPhoneNumber"
                                               placeholder=" "
                                               autocomplete="off"
                                               inputmode="numeric" />

                                        <label>
                                            İletişim Telefonu
                                            <span class="required">*</span>
                                        </label>
                                    </div>

                                    <div class="form-field">
                                        <input id="CorporateCustomerEmail"
                                               name="CustomerEmail"
                                               class="js-email-lower"
                                               placeholder=" "
                                               autocomplete="off" />

                                        <label>İletişim Maili</label>
                                    </div>

                                </div>

                            </div>
                        </div>

                    </div>

                    <div class="step-actions">
                        <button type="button" class="step-next" onclick="goToStep(2)">
                            Araç Bilgilerine Geç →
                        </button>
                    </div>
                </section>

                
                <section class="card service-step service-vehicle-step" data-step="2">
                    <div class="section-title">
                        <div class="section-icon vehicle">▣</div>
                        <div>
                            <h3>Araç Bilgileri</h3>
                            <p>Plaka, marka, model ve varsa versiyon/motor bilgisini girin.</p>
                        </div>
                    </div>

                    <div class="vehicle-create-grid">
                        <div class="form-field vehicle-plate-field">
                            <input asp-for="Plate"
                                   id="Plate"
                                   placeholder=" "
                                   autocomplete="off"
                                   maxlength="12" />
                            <label asp-for="Plate">Plaka <span class="required">*</span></label>
                            <span asp-validation-for="Plate" class="field-error"></span>

                            <div id="vehicleSearchResults"
                                 class="vehicle-search-results">
                            </div>
                        </div>

                        <div class="form-field">
                            <select asp-for="VehicleBrandId" id="brandSelect">
                                <option value="">Marka seçiniz</option>
                                @foreach (var brand in Model.Brands)
                                {
                                    <option value="@brand.Id">@brand.Name</option>
                                }
                            </select>
                            <label asp-for="VehicleBrandId">Marka</label>
                            <span asp-validation-for="VehicleBrandId" class="field-error"></span>
                        </div>

                        <div class="form-field">
                            <select asp-for="VehicleModelId" id="modelSelect">
                                <option value="">Önce marka seçiniz</option>
                            </select>
                            <label asp-for="VehicleModelId">Model</label>
                            <span asp-validation-for="VehicleModelId" class="field-error"></span>
                        </div>

                        <div class="form-field vehicle-variant-field">
                            <select asp-for="VehicleVariantId" id="VehicleVariantId">
                                <option value="">Versiyon seçmek zorunlu değil</option>
                            </select>
                            <label for="VehicleVariantId">Versiyon / Motor</label>
                            <button type="button"
                                    class="vehicle-help-trigger"
                                    onclick="openMissingVehicleHelpModal()"
                                    aria-label="Aracı listede bulamadım">
                                ?
                            </button>
                            <span asp-validation-for="VehicleVariantId" class="field-error"></span>
                        </div>

                        <div class="form-field">
                            <input asp-for="ModelYear"
                                   id="ModelYear"
                                   placeholder=" "
                                   inputmode="numeric"
                                   maxlength="4" />
                            <label asp-for="ModelYear">Model Yılı</label>
                            <span asp-validation-for="ModelYear" class="field-error"></span>
                        </div>

                        <div class="form-field">
                            <input asp-for="Mileage"
                                   id="Mileage"
                                   placeholder=" "
                                   inputmode="numeric" />
                            <label asp-for="Mileage">Kilometre</label>
                            <span asp-validation-for="Mileage" class="field-error"></span>
                        </div>

                        <div class="form-field">
                            <select asp-for="FuelLevel" id="FuelLevel">
                                <option value="">Yakıt seçiniz</option>
                                <option value="Empty">Boş</option>
                                <option value="Quarter">1/4</option>
                                <option value="Half">1/2</option>
                                <option value="ThreeQuarters">3/4</option>
                                <option value="Full">Dolu</option>
                            </select>
                            <label asp-for="FuelLevel">Yakıt Durumu</label>
                            <span asp-validation-for="FuelLevel" class="field-error"></span>
                        </div>

                        <div class="form-field">
                            <input asp-for="ChassisNumber"
                                   id="ChassisNumber"
                                   placeholder=" "
                                   maxlength="17"
                                   autocomplete="off" />
                            <label asp-for="ChassisNumber">Şasi No</label>
                            <span asp-validation-for="ChassisNumber" class="field-error"></span>
                        </div>
                    </div>

                    <div id="vehicleTechnicalPreview"
                         class="vehicle-technical-preview"
                         hidden>
                        <div>
                            <span>Yakıt</span>
                            <strong id="vehiclePreviewFuelType">-</strong>
                        </div>
                        <div>
                            <span>Şanzıman</span>
                            <strong id="vehiclePreviewTransmissionType">-</strong>
                        </div>
                        <div>
                            <span>Motor</span>
                            <strong id="vehiclePreviewEngine">-</strong>
                        </div>
                        <div>
                            <span>Kasa</span>
                            <strong id="vehiclePreviewBodyType">-</strong>
                        </div>
                    </div>

                    <div id="selectedVehicleCard" class="selected-card">
                        <div>
                            <strong id="selectedVehiclePlateText">Seçili araç</strong>
                            <span id="selectedVehicleInfoText">-</span>
                        </div>

                        <button type="button" onclick="clearSelectedVehicle()">
                            Değiştir
                        </button>
                    </div>

                    <input type="hidden" asp-for="FuelType" id="FuelType" />
                    <input type="hidden" asp-for="TransmissionType" id="TransmissionType" />
                    <input type="hidden" asp-for="BodyType" id="BodyType" />
                    <input type="hidden" asp-for="EngineCapacityCc" id="EngineCapacityCc" />
                    <input type="hidden" asp-for="EnginePowerHp" id="EnginePowerHp" />
                    <input type="hidden" asp-for="EngineCode" id="EngineCode" />

                    <div id="missingVehicleHelpModal"
                         class="vehicle-help-modal-backdrop"
                         hidden
                         aria-hidden="true">
                        <div class="vehicle-help-modal"
                             role="dialog"
                             aria-modal="true"
                             aria-labelledby="missingVehicleHelpTitle">

                            <button type="button"
                                    class="vehicle-help-close"
                                    onclick="closeMissingVehicleHelpModal()"
                                    aria-label="Kapat">
                                ×
                            </button>

                            <div class="vehicle-help-modal-visual">
                                <div class="vehicle-help-icon">?</div>
                                <span>ARAÇ KATALOĞU</span>
                            </div>

                            <div class="vehicle-help-content">
                                <h2 id="missingVehicleHelpTitle">Aracı listede bulamadınız mı?</h2>

                                <p>
                                    Eklenmesini istediğiniz marka, model veya versiyon bilgisini yazın.
                                    Servis kaydını bekletmemek için en yakın marka/model seçimiyle devam edebilirsiniz.
                                </p>

                                <label class="vehicle-help-note-label" for="MissingVehicleNote">
                                    Eklenmesini istediğiniz araç bilgisi
                                </label>

                                <textarea id="MissingVehicleNote"
                                          name="MissingVehicleNote"
                                          rows="4"
                                          placeholder="Örn: Renault Boreal Iconic E-Tech 160"></textarea>

                                <div class="vehicle-help-info">
                                    Talebiniz Sente360 Destek ekibine iletilir. En yakın marka/model seçimiyle servis kaydına devam edebilirsiniz.
                                </div>

                                <div id="MissingVehicleSupportStatus"
                                     class="vehicle-help-status"
                                     role="status"
                                     aria-live="polite"
                                     hidden>
                                </div>

                                <div class="vehicle-help-actions">
                                    <button type="button"
                                            class="vehicle-help-secondary"
                                            onclick="closeMissingVehicleHelpModal()">
                                        Vazgeç
                                    </button>

                                    <button type="button"
                                            id="MissingVehicleSubmitButton"
                                            class="vehicle-help-primary"
                                            onclick="submitMissingVehicleSupportRequest()">
                                        Talebi Gönder
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="step-actions">
                        <button type="button" class="step-back" onclick="goToStep(1)">
                            ← Geri
                        </button>

                        <button type="button" class="step-next" onclick="goToStep(3)">
                            Taleplere Geç →
                        </button>
                    </div>
                </section>

<section class="card service-step" data-step="3">
                    <div class="section-title">
                        <div class="section-icon request">☷</div>

                        <div>
                            <h3>Şikayet / Talepler</h3>
                            <p>Müşteri talebini, ön notu ve varsa tahmini fiyatı ekleyin.</p>
                        </div>
                    </div>

                    <div class="request-grid">

                        <div class="form-field">
                            <input type="text"
                                   id="requestInput"
                                   list="requestSuggestions"
                                   placeholder=" "
                                   autocomplete="off" />

                            <label>Şikayet / İşlem Talebi</label>

                            <datalist id="requestSuggestions">
                                <option value="Genel bakım"></option>
                                <option value="Yağ değişimi"></option>
                                <option value="Fren kontrolü"></option>
                                <option value="Klima arızası"></option>
                                <option value="Motordan ses geliyor"></option>
                                <option value="Su eksiltme"></option>
                            </datalist>
                        </div>

                        <div class="form-field">
                            <input type="text"
                                   id="requestEstimatedInput"
                                   placeholder=" "
                                   autocomplete="off" />

                            <label>Tahmini Fiyat</label>
                        </div>

                        <button type="button"
                                class="btn-add-request"
                                onclick="addRequestItem()">
                            + Ekle
                        </button>

                        <div class="form-field full">
                            <textarea id="requestNoteInput"
                                      placeholder=" "
                                      maxlength="500"></textarea>

                            <label>Ön Not</label>
                        </div>

                    </div>

                    <div id="requestItemsContainer"
                         class="request-items">
                    </div>

                    <div class="step-actions">
                        <button type="button"
                                class="step-back"
                                onclick="goToStep(2)">
                            ← Geri
                        </button>

                        <button type="button"
                                class="step-next"
                                onclick="goToStep(4)">
                            Önizlemeye Geç →
                        </button>
                    </div>
                </section>

                <section class="card service-step" data-step="4">
                    <div class="section-title">
                        <div class="section-icon request">▤</div>

                        <div>
                            <h3>Önizleme & Onay</h3>
                            <p>Servis ön kabul formunu kaydı açmadan önce son kez kontrol edin.</p>
                        </div>
                    </div>

                    <div class="preview-layout">

                        <div class="preview-paper-wrap">
                            <div class="service-paper compact-preaccept">

                                <div class="compact-form-header">

                                    <div class="compact-workshop">
                                        <div class="compact-logo">
                                            🚗
                                        </div>

                                        <div>
                                            <h2 id="previewWorkshopName">
                                                @(string.IsNullOrWhiteSpace(Model.WorkshopDisplayName)
                                                    ? "Servis adı belirtilmedi"
                                                    : Model.WorkshopDisplayName)
                                            </h2>

                                            <p>
                                                <span id="previewWorkshopAddress">
                                                    @(string.IsNullOrWhiteSpace(Model.WorkshopAddressText)
                                                        ? "Servis adresi belirtilmedi"
                                                        : Model.WorkshopAddressText)
                                                </span><br />
                                                Tel:
                                                <span id="previewWorkshopPhone">
                                                    @(string.IsNullOrWhiteSpace(Model.WorkshopPhoneText)
                                                        ? "Telefon belirtilmedi"
                                                        : Model.WorkshopPhoneText)
                                                </span>
                                            </p>
                                        </div>
                                    </div>

                                    <div class="compact-doc-info">
                                        <h3>SERVİS ÖN KABUL FORMU</h3>

                                        <div class="compact-doc-line">
                                            No: <strong>TASLAK</strong>
                                        </div>

                                        <div class="compact-doc-line">
                                            Tarih: <strong id="previewDateText">-</strong>
                                        </div>
                                    </div>

                                </div>

                                <div class="compact-info-band">

                                    <div class="compact-line">
                                        <strong>Müşteri:</strong>
                                        <span id="previewCustomerName">Belirtilmedi</span>

                                        <strong>Tel:</strong>
                                        <span id="previewCustomerPhone">Belirtilmedi</span>

                                        <strong>Getiren:</strong>
                                        <span id="previewDeliveredBy">Belirtilmedi</span>
                                    </div>

                                    <div class="compact-line">
                                        <strong>Araç:</strong>
                                        <span id="previewPlate">---</span>

                                        <strong>Marka/Model:</strong>
                                        <span id="previewBrandModel">---</span>

                                        <strong>KM:</strong>
                                        <span id="previewMileage">---</span>

                                        <strong>Yakıt:</strong>
                                        <span id="previewFuelLevel">---</span>

                                        <strong>Şasi:</strong>
                                        <span id="previewChassis">---</span>
                                    </div>

                                </div>

                                <div class="compact-main-title">
                                    YAPILACAK İŞLEMLER / MÜŞTERİ TALEPLERİ
                                </div>

                                <table id="previewRequestTable" class="compact-request-table">
                                    <colgroup>
                                        <col style="width:34px;" />
                                        <col />
                                        <col class="compact-price-col" />
                                    </colgroup>

                                    <thead id="previewRequestTableHead">
                                        <tr>
                                            <th>No</th>
                                            <th>İşlem / Talep</th>
                                            <th class="compact-request-price">Tahmini</th>
                                        </tr>
                                    </thead>

                                    <tbody id="previewRequestTableBody">
                                        <tr class="compact-empty-row">
                                            <td colspan="3">İşlem belirtilmedi.</td>
                                        </tr>
                                    </tbody>
                                </table>

                                <div class="compact-footer-note">
                                    <span>
                                        Bu belge ön bilgilendirme amaçlıdır. Kesin teşhis, parça/işçilik ve nihai tutar servis incelemesi sonrası değişebilir.
                                    </span>

                                    <strong>Sente360 ile oluşturulmuştur.</strong>
                                </div>

                            </div>
                        </div>

                        <aside class="preview-side">
                            <h3>Her şey hazır mı?</h3>
                            <p>
                                Bilgileri kontrol ettikten sonra servis kaydını açabilirsiniz.
                                Yazdır seçeneği kaydı oluşturur ve gerçek servis PDF’ini yeni sekmede açar.
                            </p>

                            <div class="preview-checklist">
                                <div class="preview-check">
                                    <span>✓</span>
                                    Müşteri bilgilerini kontrol et
                                </div>

                                <div class="preview-check">
                                    <span>✓</span>
                                    Araç/plaka bilgisini kontrol et
                                </div>

                                <div class="preview-check">
                                    <span>✓</span>
                                    Şikayet/talep listesini kontrol et
                                </div>
                            </div>

                            <div class="preview-actions">
                                <button type="button"
                                        class="btn-print-save js-create-action"
                                        onclick="saveServiceRecord('print', this)">
                                    Yazdır ve Kaydı Aç
                                </button>

                                <button type="button"
                                        class="btn-photo-save js-create-action"
                                        onclick="saveServiceRecord('photos', this)">
                                    Kaydı Aç ve Fotoğraf Ekle
                                </button>

                                <button type="button"
                                        class="btn-open-save js-create-action"
                                        onclick="saveServiceRecord('detail', this)">
                                    Sadece Kaydı Aç
                                </button>

                                <button type="button"
                                        class="btn-reset-draft"
                                        onclick="resetCreateFormDraft()">
                                    Formu Sıfırla / Yeni Kayıt
                                </button>
                            </div>

                            <div id="createdResult" class="created-result">
                                <strong>Kayıt oluşturuldu.</strong>
                                <span id="createdResultText">Servis kaydı başarıyla oluşturuldu.</span>

                                <div class="created-actions">
                                    <a id="goDetailLink" href="#">Servis Kaydına Git</a>
                                    <a asp-controller="ServiceRecords"
                                       asp-action="Index">
                                        Servis Kayıtları
                                    </a>
                                    <button type="button" id="openCreatedPdfButton">
                                        PDF Aç
                                    </button>
                                </div>
                            </div>
                        </aside>

                    </div>

                    <div class="step-actions">
                        <button type="button"
                                class="step-back"
                                onclick="goToStep(3)">
                            ← Geri
                        </button>
                    </div>
                </section>

            </main>

            <aside class="summary">
                <div class="summary-head">
                    <div class="summary-icon">▤</div>
                    <div>
                        <h3>Servis Özeti</h3>
                        <div class="summary-subtitle">Kaydetmeden önce bilgileri kontrol edin.</div>
                    </div>
                </div>

                <div class="summary-line">
                    <span>Servis danışmanı</span>
                    <strong>@Model.ServiceAdvisorName</strong>
                </div>

                <div class="summary-line">
                    <span>Belge tipi</span>
                    <strong>Ön Kabul Formu</strong>
                </div>

                <div class="summary-line">
                    <span>Durum</span>
                    <strong><span class="status-pill">Açık Kayıt</span></strong>
                </div>

                <div class="summary-line">
                    <span>Talep / İşlem Sayısı</span>
                    <strong id="requestCountText">0</strong>
                </div>

                <div class="summary-line">
                    <span>Tahmini Toplam</span>
                    <strong id="estimatedTotalText">0,00 ₺</strong>
                </div>

                <div class="total">
                    <span>Tahmini Toplam (TRY)</span>
                    <strong id="estimatedTotalBox">0,00 ₺</strong>
                </div>

                <div class="summary-quick-actions">
                    <h3>Hızlı İşlemler</h3>

                    <button type="button"
                            class="sr-quick-card sr-quick-card-preview"
                            onclick="goToStep(4)">
                        <span class="sr-quick-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24">
                                <path d="M7 3.75h7.25L19 8.5v11.75H7V3.75Z"></path>
                                <path d="M14 3.75V8.5H19"></path>
                                <path d="M9.75 12h6.5"></path>
                                <path d="M9.75 15h6.5"></path>
                                <path d="M9.75 18h4.25"></path>
                            </svg>
                        </span>

                        <span class="sr-quick-text">
                            <strong>Form Önizleme</strong>
                            <small>Kaydı açmadan önce servis formunu kontrol et</small>
                        </span>
                    </button>

                    <button type="button"
                            class="sr-quick-card sr-quick-card-reset"
                            onclick="resetCreateFormDraft()">
                        <span class="sr-quick-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24">
                                <path d="M4.75 11.5A7.25 7.25 0 1 1 7 16.75"></path>
                                <path d="M4.75 6.75v4.75H9.5"></path>
                            </svg>
                        </span>

                        <span class="sr-quick-text">
                            <strong>Formu Sıfırla</strong>
                            <small>Yarım kalan taslağı temizle ve yeni kayıt başlat</small>
                        </span>
                    </button>
                </div>

               
            </aside>

        </div>
    </form>
</div>

<div id="ownershipModalBackdrop" class="modal-backdrop-custom">
    <div class="ownership-modal">
        <button type="button"
                class="ownership-close"
                onclick="closeOwnershipModal()"
                aria-label="Pencereyi kapat">
            ×
        </button>

        <h3>Araç sistemde kayıtlı bulundu</h3>

        <div class="ownership-modal-card">
            <strong id="ownershipModalVehicleText">Araç</strong>
            <span id="ownershipModalCustomerText">Kayıtlı müşteri bilgisi bulunamadı.</span>
        </div>

        <div class="ownership-actions">
            <button type="button"
                    class="ownership-primary"
                    onclick="continueWithRegisteredVehicleCustomer()">
                <strong>Kayıtlı müşteriyle devam et</strong>
                <span>Müşteri ve araç bilgileri birlikte doldurulur.</span>
            </button>

            <button type="button"
                    class="ownership-secondary"
                    onclick="createNewCustomerForVehicle()">
                <strong>Yeni müşteri oluştur</strong>
                <span>Müşteri alanları temizlenir, araç bilgileri korunur.</span>
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/service-record-create.js" asp-append-version="true"></script>
}
