            </main>

            <aside class="summary">
                <div class="summary-head">
                    <div class="summary-icon">▤</div>
                    <div>
                        <h3>Servis Özeti</h3>
                        <div class="summary-subtitle">Kaydetmeden önce bilgileri kontrol edin.</div>
                    </div>
                </div>

                <div class="summary-line">
                    <span>Servis danışmanı</span>
                    <strong>@Model.ServiceAdvisorName</strong>
                </div>

                <div class="summary-line">
                    <span>Belge tipi</span>
                    <strong>Servis Formu</strong>
                </div>

                <div class="summary-line">
                    <span>Durum</span>
                    <strong><span class="status-pill">Açık Kayıt</span></strong>
                </div>

                <div class="summary-line">
                    <span>Talep / İşlem Sayısı</span>
                    <strong id="requestCountText">0</strong>
                </div>

                <div class="summary-line">
                    <span>Tahmini Toplam</span>
                    <strong id="estimatedTotalText">0,00 ₺</strong>
                </div>

                <div class="total">
                    <span>Tahmini Toplam (TRY)</span>
                    <strong id="estimatedTotalBox">0,00 ₺</strong>
                </div>

                <div class="quick-actions">
                    <h4 class="quick-title">Hızlı İşlemler</h4>

                    <button type="button" class="quick-action" onclick="createPdfDraft()">
                        <span class="quick-action-icon">📄</span>
                        <span>
                            <strong>PDF Oluştur</strong>
                            <span>Hızlı teklif formunu PDF olarak oluştur</span>
                        </span>
                    </button>
