                <div class="summary-buttons">
                    <button type="button" class="btn-primary" onclick="saveServiceRecord()">
                        Kaydı Oluştur
                    </button>

                    
                </div>
            </aside>

        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const DRAFT_KEY = "sente360_create_service_draft";
        const brandSelect = document.getElementById("brandSelect");
        const modelSelect = document.getElementById("modelSelect");

        const customerSearchInput = document.getElementById("customerSearchInput");
        const customerNameInput = document.getElementById("CustomerName");
        const customerPhoneInput = document.getElementById("CustomerPhoneNumber");
        const customerEmailInput = document.getElementById("CustomerEmail");
        const chassisNumberInput = document.getElementById("ChassisNumber");
        const customerResults = document.getElementById("customerSearchResults");

        const requestItemsContainer = document.getElementById("requestItemsContainer");
        const requestCountText = document.getElementById("requestCountText");
        const estimatedTotalText = document.getElementById("estimatedTotalText");
        const estimatedTotalBox = document.getElementById("estimatedTotalBox");
       
                if (chassisNumberInput) {
            chassisNumberInput.addEventListener("input", function () {
                this.value = this.value
                    .toUpperCase()
                    .replace(/[^A-Z0-9]/g, "")
                    .slice(0, 17);
            });
        }

        let customerSearchTimeout;
        let requestIndex = 0;

        const formatter = new Intl.NumberFormat("tr-TR", {
            style: "currency",
            currency: "TRY"
        });

                const requestEstimatedInput = document.getElementById("requestEstimatedInput");

        if (requestEstimatedInput) {
            requestEstimatedInput.addEventListener("input", function () {
                const digits = this.value.replace(/\D/g, "");

                if (!digits) {
                    this.value = "";
                    return;
                }

                this.value = Number(digits).toLocaleString("tr-TR");
            });
        }

        function get(id) {
            return document.getElementById(id);
        }

        function setInputError(input, hasError) {
            if (!input) return;

            if (hasError) {
                input.classList.add("input-invalid");
            } else {
                input.classList.remove("input-invalid");
            }
        }

        function showTemporaryInvalid(input) {
            if (!input) return;

            input.classList.add("input-invalid");

            setTimeout(() => {
                input.classList.remove("input-invalid");
            }, 1500);
        }

        function formatPhone(digits) {
            if (digits.length > 9) {
                return digits.replace(/(\d{4})(\d{3})(\d{2})(\d{0,2})/, "$1 $2 $3 $4").trim();
            }

            if (digits.length > 7) {
                return digits.replace(/(\d{4})(\d{3})(\d{0,2})/, "$1 $2 $3").trim();
            }

            if (digits.length > 4) {
                return digits.replace(/(\d{4})(\d{0,3})/, "$1 $2").trim();
            }

            return digits;
        }

        function updateRequestSummary() {
            const requestItems = requestItemsContainer.querySelectorAll(".request-item");
            let total = 0;

            requestItems.forEach(item => {
                const amount = Number(item.dataset.estimatedAmount || 0);
                total += amount;
            });

            requestCountText.innerText = requestItems.length;
            estimatedTotalText.innerText = formatter.format(total);
            estimatedTotalBox.innerText = formatter.format(total);
        }

                function getPlateValue() {
            const plateInput = document.getElementById("Plate");
            return plateInput ? plateInput.value.trim().toUpperCase().replace(/[^A-Z0-9]/g, "") : "";
        }

        function requirePlate() {
            const plate = getPlateValue();

            if (!plate) {
                const plateInput = document.getElementById("Plate");
                showTemporaryInvalid(plateInput);
                plateInput?.focus();
                alert("Bu işlem için önce plaka girmelisin.");
                return null;
            }

            return plate;
        }

        function openVehicleHistory() {
            const plate = requirePlate();
            if (!plate) return;

            window.location.href = `/ServiceRecords/VehicleHistory?plate=${encodeURIComponent(plate)}`;
        }

        function openQrAssign() {
            const plate = requirePlate();
            if (!plate) return;

            window.location.href = `/VehicleQr/Assign?plate=${encodeURIComponent(plate)}`;
        }

                async function createPdfDraft() {
            const requestItems = [];

            document.querySelectorAll("#requestItemsContainer .request-item").forEach(item => {
                requestItems.push({
                    title: item.dataset.title || "",
                    note: item.dataset.note || "",
                    estimatedAmount: Number(item.dataset.estimatedAmount || 0)
                });
            });

            const request = {
                workshopName: "Sente360",

                serviceAdvisorName:
                    document.querySelector(".summary-value")?.innerText || "",

                customerName: get("CustomerName")?.value?.trim() || "",
                customerPhone: get("CustomerPhoneNumber")?.value?.trim() || "",
                customerEmail: get("CustomerEmail")?.value?.trim() || "",

                plate: get("Plate")?.value?.trim()?.toUpperCase() || "",

                brand: brandSelect.options[brandSelect.selectedIndex]?.text || "",
                model: modelSelect.options[modelSelect.selectedIndex]?.text || "",

                modelYear: get("ModelYear")?.value?.trim() || "",
                mileage: get("Mileage")?.value?.trim() || "",
                chassisNumber: get("ChassisNumber")?.value?.trim() || "",

                note: get("requestNoteInput")?.value?.trim() || "",

                requestItems: requestItems
            };

            const response = await fetch("/quick-offer-pdf/create", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(request)
            });

            if (!response.ok) {
                const errorText = await response.text();

                alert("PDF oluşturulurken hata oluştu:\n" + errorText);

                return;
            }

                    const blob = await response.blob();

        const disposition = response.headers.get("Content-Disposition");

        let fileName = "hizli-teklif.pdf";

        if (disposition && disposition.includes("filename")) {
            const match = disposition.match(/filename\*?=(?:UTF-8'')?["']?([^;"']+)/i);

            if (match?.[1]) {
                fileName = decodeURIComponent(match[1].replace(/"/g, ""));
            }
        }

        const url = window.URL.createObjectURL(blob);

        const a = document.createElement("a");

        a.href = url;
        a.download = fileName;

            document.body.appendChild(a);

            a.click();

            a.remove();

            window.URL.revokeObjectURL(url);
        }

        brandSelect.addEventListener("change", async function () {
            const brandId = this.value;

            modelSelect.innerHTML = '<option value="">Model yükleniyor...</option>';

            if (!brandId) {
                modelSelect.innerHTML = '<option value="">Önce marka seçiniz</option>';
                return;
            }

            const response = await fetch(`/ServiceRecords/GetModels?brandId=${brandId}`);

            if (!response.ok) {
                modelSelect.innerHTML = '<option value="">Model bulunamadı</option>';
                return;
            }

            const models = await response.json();

            modelSelect.innerHTML = '<option value="">Model seçiniz</option>';

            models.forEach(model => {
                const option = document.createElement("option");
                option.value = model.id;
                option.textContent = model.name;
                modelSelect.appendChild(option);
            });
        });

        customerSearchInput.addEventListener("input", function () {
            clearTimeout(customerSearchTimeout);

            const query = this.value.trim();

            if (query.length < 2) {
                customerResults.style.display = "none";
                customerResults.innerHTML = "";
                return;
            }

            customerSearchTimeout = setTimeout(async () => {
                const response = await fetch(`/ServiceRecords/SearchCustomers?query=${encodeURIComponent(query)}`);

                if (!response.ok) {
                    return;
                }

                const customers = await response.json();

                customerResults.innerHTML = "";

                if (!customers.length) {
                    customerResults.style.display = "none";
                    return;
                }

                customers.forEach(customer => {
                    const item = document.createElement("div");
                    item.className = "customer-search-item";

                    item.innerHTML = `
                        <strong>${customer.name}</strong>
                        <span>${customer.phoneNumber ?? "-"} ${customer.email ?? ""}</span>
                    `;

                           item.addEventListener("click", () => {
            customerSearchInput.value = customer.name ?? "";
            customerPhoneInput.value = customer.phoneNumber ?? "";
            customerEmailInput.value = customer.email ?? "";

            customerResults.style.display = "none";
        });
                    customerResults.appendChild(item);
                });

                customerResults.style.display = "block";

            }, 300);
        });

        document.addEventListener("click", function (e) {
            if (!customerResults.contains(e.target) && e.target !== customerSearchInput) {
                customerResults.style.display = "none";
            }
        });

        document.addEventListener("keydown", function (e) {
            if (e.ctrlKey && e.key.toLowerCase() === "k") {
                e.preventDefault();
                customerSearchInput.focus();
            }
        });

               function addRequestItem(titleFromDraft = null, noteFromDraft = null, estimatedFromDraft = null) {

            const titleInput = document.getElementById("requestInput");
            const noteInput = document.getElementById("requestNoteInput");
            const estimatedInput = document.getElementById("requestEstimatedInput");

            const title = (titleFromDraft ?? titleInput.value).trim();
            const note = (noteFromDraft ?? noteInput.value).trim();

            const estimatedAmount = (
                estimatedFromDraft ??
                estimatedInput.value.replace(/\D/g, "")
            );

            if (!title) {
                showTemporaryInvalid(titleInput);
                titleInput.focus();
                return;
            }

            const numericAmount = Number(estimatedAmount || 0);

            const item = document.createElement("div");

            item.className = "request-item";

            item.dataset.estimatedAmount = numericAmount;
            item.dataset.title = title;
            item.dataset.note = note;

            item.innerHTML = `
                <div>
                    <strong>${title}</strong>

                    ${note ? `<span>${note}</span>` : ""}

                    ${numericAmount
                        ? `<small>Tahmini: ${formatter.format(numericAmount)}</small>`
                        : ""
                    }

                    <input type="hidden"
                           name="RequestItems[${requestIndex}].Title"
                           value="${title}" />

                    <input type="hidden"
                           name="RequestItems[${requestIndex}].Note"
                           value="${note}" />

                    <input type="hidden"
                           name="RequestItems[${requestIndex}].EstimatedAmount"
                           value="${numericAmount}" />
                </div>

                <button type="button" class="request-remove">✕</button>
            `;

            item.querySelector(".request-remove")
                .addEventListener("click", () => {

                    item.remove();

                    updateRequestSummary();

                    saveRequestItemsDraft();
                });

            requestItemsContainer.appendChild(item);

            requestIndex++;

            titleInput.value = "";
            noteInput.value = "";
            estimatedInput.value = "";

            updateRequestSummary();

            saveRequestItemsDraft();
        }

        customerPhoneInput.addEventListener("beforeinput", function (e) {
            if (e.inputType === "insertText" && !/^\d$/.test(e.data)) {
                e.preventDefault();
                showTemporaryInvalid(customerPhoneInput);
            }
        });

        customerPhoneInput.addEventListener("paste", function (e) {
            const pastedText = (e.clipboardData || window.clipboardData).getData("text");
            const digits = pastedText.replace(/\D/g, "").slice(0, 11);

            if (pastedText !== digits) {
                e.preventDefault();
                this.value = formatPhone(digits);
                showTemporaryInvalid(customerPhoneInput);
            }
        });

        customerPhoneInput.addEventListener("input", function () {
            const digits = this.value.replace(/\D/g, "").slice(0, 11);
            this.value = formatPhone(digits);
        });

        get("Plate").addEventListener("beforeinput", function (e) {
            if (e.inputType === "insertText" && !/^[a-zA-Z0-9]$/.test(e.data)) {
                e.preventDefault();
                showTemporaryInvalid(this);
            }
        });

        get("Plate").addEventListener("input", function () {
            this.value = this.value
                .toUpperCase()
                .replace(/[^A-Z0-9]/g, "");
        });

        get("ModelYear").addEventListener("beforeinput", function (e) {
            if (e.inputType === "insertText" && !/^\d$/.test(e.data)) {
                e.preventDefault();
                showTemporaryInvalid(this);
            }
        });

        get("ModelYear").addEventListener("input", function () {
            this.value = this.value.replace(/\D/g, "").slice(0, 4);
        });

        get("Mileage").addEventListener("beforeinput", function (e) {
            if (e.inputType === "insertText" && !/^\d$/.test(e.data)) {
                e.preventDefault();
                showTemporaryInvalid(this);
            }
        });

        get("Mileage").addEventListener("input", function () {
            const digits = this.value.replace(/\D/g, "").slice(0, 8);
            this.value = digits.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
        });
                const serviceCreateForm = document.getElementById("serviceCreateForm");

       

        updateRequestSummary();

                let isServiceRecordSaving = false;
        let isServiceRecordCreated = false;

        async function saveServiceRecord() {

            if (isServiceRecordSaving || isServiceRecordCreated) {
                return;
            }

            isServiceRecordSaving = true;

            const saveButton = document.querySelector(".btn-primary");
            const originalText = saveButton?.innerText;

            if (saveButton) {
                saveButton.disabled = true;
                saveButton.innerText = "Kaydediliyor...";
            }

            try {

                const form = document.getElementById("serviceCreateForm");
                const formData = new FormData(form);

                const mileageInput = document.getElementById("Mileage");

                if (mileageInput) {
                    formData.set("Mileage", mileageInput.value.replace(/\D/g, ""));
                }

                        const estimatedPriceInput = document.getElementById("requestEstimatedInput");

        if (estimatedPriceInput) {
            formData.set(
                "EstimatedPrice",
                estimatedPriceInput.value.replace(/\./g, "")
            );
        }

                const response = await fetch(form.action, {
                    method: "POST",
                    body: formData,
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    }
                });

                const result = await response.json();

                if (!response.ok || result.success === false) {

                    if (result.validationErrors) {
                        showValidationErrors(result.validationErrors);
                    }

                    showToast(
                        result.message || "Servis kaydı oluşturulamadı.",
                        "error"
                    );

                    return;
                }

                clearValidationErrors();

                isServiceRecordCreated = true;

                if (saveButton) {
                    saveButton.innerText = "Kayıt Oluşturuldu";
                }
                localStorage.removeItem(DRAFT_KEY);
                localStorage.removeItem(REQUEST_ITEMS_DRAFT_KEY);

                showToast(
                    result.message || "Servis kaydı başarıyla oluşturuldu.",
                    "success"
                );

            }
            catch (error) {

                showToast(
                    "Beklenmeyen bir hata oluştu.",
                    "error"
                );

            }
            finally {

                isServiceRecordSaving = false;

                if (!isServiceRecordCreated && saveButton) {
                    saveButton.disabled = false;
                    saveButton.innerText = originalText || "Kaydı Oluştur";
                }
            }
        }

                function showToast(message, type = "info") {
            const toast = document.getElementById("toastMessage");

            if (!toast) return;

            toast.className = `toast-message ${type}`;
            toast.innerText = message;

            requestAnimationFrame(() => {
                toast.classList.add("show");
            });

            setTimeout(() => {
                toast.classList.remove("show");
            }, 3200);
        }

                function clearValidationErrors() {
            document.querySelectorAll("[data-valmsg-for]").forEach(x => {
                x.innerText = "";
            });
        }

        function showValidationErrors(errors) {
            clearValidationErrors();

            Object.keys(errors).forEach(key => {
                const messageEl = document.querySelector(`[data-valmsg-for="${key}"]`);

                if (messageEl) {
                    messageEl.innerText = errors[key][0];
                }
            });
        }

                const estimatedPriceInput = document.getElementById("estimatedPriceInput");

        if (estimatedPriceInput) {

            estimatedPriceInput.addEventListener("input", function () {

                let value = this.value.replace(/\D/g, "");

                if (!value) {
                    this.value = "";
                    return;
                }

                this.value = Number(value).toLocaleString("tr-TR");
            });

        }

                function toggleCustomerExtra() {
            const panel = document.getElementById("customerExtraPanel");
            panel?.classList.toggle("active");
        }

        function setCustomerType(type, button) {
            const input = document.getElementById("CustomerType");
            const corporateFields = document.getElementById("corporateFields");

            if (input) {
                input.value = type;
            }

            document.querySelectorAll(".customer-type-switch button")
                .forEach(x => x.classList.remove("active"));

            button.classList.add("active");

            if (corporateFields) {
                corporateFields.classList.toggle("active", type === 2);
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            const input = document.getElementById("CustomerType");
            if (input && !input.value) {
                input.value = 1;
            }
        });

                function goToStep(step) {
            document.querySelectorAll(".service-step").forEach(section => {
                section.classList.toggle("active", Number(section.dataset.step) === step);
            });

            document.querySelectorAll(".step-tab").forEach(tab => {
                tab.classList.toggle("active", Number(tab.dataset.step) === step);
            });

            window.scrollTo({
                top: 0,
                behavior: "smooth"
            });

            saveCreateFormDraft();
        }

                function saveCreateFormDraft() {

            const form = document.getElementById("serviceCreateForm");

            if (!form) return;

            const formData = {};

            form.querySelectorAll("input, textarea, select").forEach(el => {

                if (!el.name) return;

                if (el.type === "checkbox") {
                    formData[el.name] = el.checked;
                }
                else {
                    formData[el.name] = el.value;
                }
            });

            localStorage.setItem(DRAFT_KEY, JSON.stringify(formData));
        }

                function initializeDraftAutoSave() {

            const form = document.getElementById("serviceCreateForm");

            if (!form) return;

            form.querySelectorAll("input, textarea, select").forEach(el => {

                el.addEventListener("input", saveCreateFormDraft);
                el.addEventListener("change", saveCreateFormDraft);
            });
        }

                      function restoreCreateFormDraft() {

            const draft = localStorage.getItem(DRAFT_KEY);

            if (!draft) return;

            const data = JSON.parse(draft);

            Object.keys(data).forEach(key => {

                if (key.startsWith("RequestItems")) {
                    return;
                }

                const el = document.querySelector(`[name="${key}"]`);

                if (!el) return;

                if (el.type === "checkbox") {
                    el.checked = data[key];
                }
                else {
                    el.value = data[key];
                }
            });

            console.log("Taslak geri yüklendi.");
        }
                const REQUEST_ITEMS_DRAFT_KEY = "sente360_request_items_draft";

        function saveRequestItemsDraft() {

            const items = [];

            document.querySelectorAll(".request-item").forEach(item => {

                items.push({
                    title: item.dataset.title || "",
                    note: item.dataset.note || "",
                    estimatedAmount: item.dataset.estimatedAmount || "0"
                });
            });

            localStorage.setItem(
                REQUEST_ITEMS_DRAFT_KEY,
                JSON.stringify(items)
            );
        }

        function restoreRequestItemsDraft() {

            const raw = localStorage.getItem(
                REQUEST_ITEMS_DRAFT_KEY
            );

            if (!raw) return;

            const items = JSON.parse(raw);

            items.forEach(x => {

                addRequestItem(
                    x.title,
                    x.note,
                    x.estimatedAmount
                );
            });

            updateRequestSummary();
        }
           
                document.addEventListener("DOMContentLoaded", () => {

            initializeDraftAutoSave();

            restoreCreateFormDraft();

            restoreRequestItemsDraft();
        });

                setTimeout(() => {
            const raw = localStorage.getItem(DRAFT_KEY);
            if (!raw) return;

            const draft = JSON.parse(raw);
            const fields = draft.fields || draft;

            if (!fields.VehicleBrandId || !fields.VehicleModelId) return;

            brandSelect.value = fields.VehicleBrandId;
            brandSelect.dispatchEvent(new Event("change"));

            setTimeout(() => {
                modelSelect.value = fields.VehicleModelId;
            }, 700);
        }, 300);

    </script>
