@model AutoStock.Web.Models.ServiceRecords.ServiceRecordIndexViewModel

@{
    ViewData["Title"] = "Servis Kayıtları";

    var query = Model.Query;
    var paged = Model.ServiceRecords;
}

<div class="page">
    <div class="premium-header">
        <div class="premium-brand">
            <a asp-controller="Dashboard"
               asp-action="Index"
               class="premium-logo premium-logo-link"
               title="Ana sayfa">
                ⌂
            </a>

            <div>
                <span class="premium-eyebrow">SERVİS KAYITLARI</span>
                <h1>Servis Kayıtları</h1>
                <p>Plaka, müşteri, telefon veya kayıt numarası ile servis sürecini hızlıca bulun.</p>
            </div>
        </div>

        <a href="/ServiceRecords/Create" class="premium-home" title="Yeni servis kaydı oluştur">+</a>
    </div>

    @if (TempData["SuccessMessage"] is not null)
    {
        <div class="alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] is not null)
    {
        <div class="alert-error">@Html.Raw(TempData["ErrorMessage"])</div>
    }

    <div class="filter-panel">
        <form method="get" action="/ServiceRecords" class="filter-form">
            <div class="filter-group search-group">
                <label>Arama</label>
                <input type="text"
                       name="Search"
                       value="@query.Search"
                       placeholder="Plaka, müşteri, telefon, kayıt no..." />
            </div>

            <div class="filter-group">
                <label>Durum</label>
                <select name="StatusFilter">
                    <option value="active" selected="@(query.StatusFilter == "active")">Aktif</option>
                    <option value="completed" selected="@(query.StatusFilter == "completed")">Tamamlandı</option>
                    <option value="cancelled" selected="@(query.StatusFilter == "cancelled")">İptal</option>
                    <option value="all" selected="@(query.StatusFilter == "all")">Tümü</option>
                </select>
            </div>

            <div class="filter-group">
                <label>Başlangıç</label>
                <input type="date"
                       name="CreatedFrom"
                       value="@query.CreatedFrom?.ToString("yyyy-MM-dd")" />
            </div>

            <div class="filter-group">
                <label>Bitiş</label>
                <input type="date"
                       name="CreatedTo"
                       value="@query.CreatedTo?.ToString("yyyy-MM-dd")" />
            </div>

            <div class="filter-group">
                <label>Sayfa</label>
                <select name="PageSize">
                    <option value="10" selected="@(query.PageSize == 10)">10</option>
                    <option value="20" selected="@(query.PageSize == 20)">20</option>
                    <option value="50" selected="@(query.PageSize == 50)">50</option>
                    <option value="100" selected="@(query.PageSize == 100)">100</option>
                </select>
            </div>

            <input type="hidden" name="PageNumber" value="1" />

            <div class="filter-actions">
                <button type="submit" class="btn-filter">Filtrele</button>
                <a href="/ServiceRecords" class="btn-clear">Temizle</a>
            </div>
        </form>
    </div>

    <div class="panel">
        <div class="panel-summary">
            @if (paged.TotalCount > 0)
            {
                <span>
                    @paged.TotalCount kayıt içinden
                    @paged.FirstItemNumber - @paged.LastItemNumber arası gösteriliyor.
                </span>
            }
            else
            {
                <span>Kayıt bulunamadı.</span>
            }
        </div>

        <div class="record-list">
            @foreach (var record in paged.Items)
            {
                <a class="record-card" href="/ServiceRecords/Detail/@record.Id">
                    <div class="record-main">
                        <div class="record-number">
                            @(string.IsNullOrWhiteSpace(record.RecordNumber) ? $"SR-{record.Id}" : record.RecordNumber)
                        </div>

                        <strong class="customer-name">@record.CustomerName</strong>
                        <span class="customer-phone">@record.CustomerPhone</span>
                    </div>

                    <div class="vehicle-block">
                        <strong class="plate-badge">@record.VehiclePlate</strong>
                        <span>@record.VehicleBrandName @record.VehicleModelName</span>
                    </div>

                    <div class="amount-block">
                        <strong>@record.TotalAmount.ToString("N2") ₺</strong>
                        <span>@record.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>

                    <div class="record-status status-@record.Status">
                        @(record.Status switch
                        {
                            1 => "Aktif",
                            2 => "Aktif",
                            3 => "Tamamlandı",
                            4 => "İptal",
                            _ => "Bilinmiyor"
                        })
                    </div>
                </a>
            }

            @if (!paged.Items.Any())
            {
                <div class="empty-state">
                    Kriterlere uygun servis kaydı bulunamadı.
                </div>
            }
        </div>

        @if (paged.TotalPages > 1)
        {
            <div class="pagination-wrapper">
                <a class="pagination-btn @(paged.HasPreviousPage ? "" : "disabled")"
                   href="@(paged.HasPreviousPage
                                           ? Url.Action("Index", "ServiceRecords", new
                                           {
                                               Search = query.Search,
                                               StatusFilter = query.StatusFilter,
                                               CreatedFrom = query.CreatedFrom?.ToString("yyyy-MM-dd"),
                                               CreatedTo = query.CreatedTo?.ToString("yyyy-MM-dd"),
                                               PageNumber = paged.PageNumber - 1,
                                               PageSize = query.PageSize
                                           })
                                       : "#")">
                    Önceki
                </a>

                <div class="pagination-pages">
                    @for (var page = 1; page <= paged.TotalPages; page++)
                    {
                        if (page == 1 ||
                            page == paged.TotalPages ||
                            Math.Abs(page - paged.PageNumber) <= 2)
                        {
                            <a class="pagination-page @(page == paged.PageNumber ? "active" : "")"
                               href="@Url.Action("Index", "ServiceRecords", new
                               {
                                   Search = query.Search,
                                   StatusFilter = query.StatusFilter,
                                   CreatedFrom = query.CreatedFrom?.ToString("yyyy-MM-dd"),
                                   CreatedTo = query.CreatedTo?.ToString("yyyy-MM-dd"),
                                   PageNumber = page,
                                   PageSize = query.PageSize
                               })">
                                @(page)
                            </a>
                        }
                    }
                </div>

                <a class="pagination-btn @(paged.HasNextPage ? "" : "disabled")"
                   href="@(paged.HasNextPage
                                           ? Url.Action("Index", "ServiceRecords", new
                                           {
                                               Search = query.Search,
                                               StatusFilter = query.StatusFilter,
                                               CreatedFrom = query.CreatedFrom?.ToString("yyyy-MM-dd"),
                                               CreatedTo = query.CreatedTo?.ToString("yyyy-MM-dd"),
                                               PageNumber = paged.PageNumber + 1,
                                               PageSize = query.PageSize
                                           })
                                       : "#")">
                    Sonraki
                </a>
            </div>
        }
    </div>
</div>

<style>
    .page {
        width: min(1420px, calc(100% - 48px));
        margin: 0 auto;
        padding: 36px 0 60px;
    }

    .premium-header {
        margin-bottom: 28px;
        padding: 32px 36px;
        border-radius: 32px;
        background: linear-gradient(135deg, #07111f 0%, #111827 42%, #1d4ed8 100%);
        color: white;
        box-shadow: 0 28px 80px rgba(15, 23, 42, .24);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .premium-brand {
        display: flex;
        align-items: center;
        gap: 22px;
    }

    .premium-logo {
        width: 54px;
        height: 54px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #2563eb, #16a34a);
        color: white;
        font-weight: 950;
        font-size: 22px;
    }

    .premium-logo-link {
        text-decoration: none;
        cursor: pointer;
        transition: .18s ease;
    }

        .premium-logo-link:hover {
            transform: translateY(-2px) scale(1.03);
            box-shadow: 0 22px 46px rgba(37, 99, 235, .36);
        }

    .premium-eyebrow {
        display: inline-flex;
        margin-bottom: 7px;
        padding: 6px 11px;
        border-radius: 999px;
        background: rgba(255,255,255,.13);
        border: 1px solid rgba(255,255,255,.18);
        color: rgba(255,255,255,.80);
        font-size: 12px;
        font-weight: 800;
    }

    .premium-header h1 {
        margin: 0;
        font-size: 36px;
        letter-spacing: -1.5px;
    }

    .premium-header p {
        margin: 10px 0 0;
        color: rgba(255,255,255,.72);
    }

    .premium-home {
        width: 54px;
        height: 54px;
        display: grid;
        place-items: center;
        border-radius: 18px;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.18);
        color: white;
        text-decoration: none;
        font-size: 30px;
        font-weight: 900;
    }

    .filter-panel {
        background: rgba(255,255,255,.94);
        border: 1px solid #e2e8f0;
        border-radius: 26px;
        padding: 20px;
        margin-bottom: 18px;
        box-shadow: 0 18px 45px rgba(15, 23, 42, .07);
    }

    .filter-form {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr .8fr auto;
        gap: 12px;
        align-items: end;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 7px;
    }

        .filter-group label {
            font-size: 13px;
            font-weight: 900;
            color: #334155;
        }

        .filter-group input,
        .filter-group select {
            height: 44px;
            border: 1px solid #cbd5e1;
            border-radius: 14px;
            padding: 0 13px;
            background: white;
            color: #0f172a;
            font-weight: 700;
            outline: none;
        }

            .filter-group input:focus,
            .filter-group select:focus {
                border-color: #2563eb;
                box-shadow: 0 0 0 4px rgba(37, 99, 235, .11);
            }

    .filter-actions {
        display: flex;
        gap: 10px;
    }

    .btn-filter,
    .btn-clear {
        height: 44px;
        padding: 0 18px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        text-decoration: none;
        border: none;
        cursor: pointer;
        white-space: nowrap;
    }

    .btn-filter {
        background: #2563eb;
        color: white;
    }

    .btn-clear {
        background: #f1f5f9;
        color: #334155;
        border: 1px solid #cbd5e1;
    }

    .panel {
        background: rgba(255,255,255,.92);
        border: 1px solid #e2e8f0;
        border-radius: 30px;
        padding: 0;
        box-shadow: 0 22px 55px rgba(15, 23, 42, .08);
        overflow: hidden;
    }

    .panel-summary {
        padding: 16px 24px;
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        color: #64748b;
        font-size: 14px;
        font-weight: 900;
    }

    .record-list {
        display: grid;
        gap: 12px;
        padding: 24px;
    }

    .record-card {
        display: grid;
        grid-template-columns: 1.5fr 1.2fr 1fr 128px;
        gap: 18px;
        align-items: center;
        padding: 18px;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        color: #0f172a;
        text-decoration: none;
        transition: .18s ease;
    }

        .record-card:hover {
            background: white;
            border-color: #2563eb;
            transform: translateY(-1px);
            box-shadow: 0 12px 28px rgba(15, 23, 42, .08);
        }

        .record-card strong {
            display: block;
            font-size: 15px;
            font-weight: 900;
        }

        .record-card span {
            display: block;
            margin-top: 5px;
            color: #64748b;
            font-size: 13px;
            font-weight: 700;
        }

    .record-number {
        display: inline-flex;
        margin-bottom: 8px;
        padding: 5px 9px;
        border-radius: 999px;
        background: #e0f2fe;
        color: #075985;
        font-size: 12px;
        font-weight: 950;
    }

    .customer-name {
        font-size: 18px !important;
        letter-spacing: -.2px;
    }

    .customer-phone {
        color: #475569 !important;
    }

    .plate-badge {
        display: inline-flex !important;
        width: fit-content;
        padding: 8px 12px;
        border-radius: 12px;
        background: #0f172a;
        color: white;
        font-size: 20px !important;
        letter-spacing: 1px;
        line-height: 1;
    }

    .amount-block strong {
        font-size: 17px !important;
    }

    .record-status {
        justify-self: end;
        min-width: 118px;
        padding: 9px 14px;
        border-radius: 999px;
        text-align: center;
        font-size: 13px;
        font-weight: 900;
    }

        .record-status.status-1,
        .record-status.status-2 {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .record-status.status-3 {
            background: #dcfce7;
            color: #15803d;
        }

        .record-status.status-4 {
            background: #fee2e2;
            color: #b91c1c;
        }

    .empty-state {
        padding: 40px;
        border-radius: 22px;
        background: #f8fafc;
        color: #64748b;
        text-align: center;
        font-weight: 800;
    }

    .alert-error,
    .alert-success {
        margin-bottom: 20px;
        padding: 16px 18px;
        border-radius: 18px;
        font-weight: 800;
    }

    .alert-error {
        background: #fee2e2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    .alert-success {
        background: #dcfce7;
        border: 1px solid #bbf7d0;
        color: #166534;
    }

    .pagination-wrapper {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 18px 24px;
        border-top: 1px solid #e2e8f0;
        background: white;
    }

    .pagination-pages {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .pagination-page,
    .pagination-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 38px;
        height: 38px;
        padding: 0 12px;
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        color: #334155;
        text-decoration: none;
        font-weight: 900;
        font-size: 13px;
    }

        .pagination-page.active {
            background: #2563eb;
            color: white;
            border-color: #2563eb;
        }

        .pagination-btn.disabled {
            pointer-events: none;
            opacity: .45;
        }

    @@media (max-width: 1100px) {
        .filter-form {
            grid-template-columns: 1fr 1fr;
        }

        .filter-actions {
            grid-column: span 2;
        }
    }

    @@media (max-width: 900px) {
        .record-card {
            grid-template-columns: 1fr;
        }

        .record-status {
            justify-self: start;
        }

        .page {
            width: min(100% - 28px, 1420px);
            padding-top: 20px;
        }

        .premium-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 18px;
        }

        .filter-form {
            grid-template-columns: 1fr;
        }

        .filter-actions {
            grid-column: auto;
            flex-direction: column;
        }

        .pagination-wrapper {
            flex-direction: column;
        }
    }
</style>

<script>
    window.addEventListener("pageshow", function (event) {
        const navigation = performance.getEntriesByType("navigation")[0];

        if (event.persisted || navigation?.type === "back_forward") {
            window.location.reload();
        }
    });
</script>