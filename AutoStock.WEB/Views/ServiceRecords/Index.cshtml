@model AutoStock.Web.Models.ServiceRecords.ServiceRecordIndexViewModel

@using AutoStock.WEB.Models.Shared

@{
    ViewData["Title"] = "Servis Kayıtları";

    var query = Model.Query;
    var paged = Model.ServiceRecords;

    var currentStatus = string.IsNullOrWhiteSpace(query.StatusFilter)
        ? "active"
        : query.StatusFilter;

    var hasAdvancedFilter =
        currentStatus != "active" ||
        query.CreatedFrom.HasValue ||
        query.CreatedTo.HasValue ||
        query.PageSize != 10;
}

<div class="srv-page">
    <section class="srv-hero">
        <div class="srv-hero-left">
            <a asp-controller="Dashboard"
               asp-action="Index"
               class="srv-home-btn"
               title="Ana sayfa">
                ⌂
            </a>

            <div>
                <span class="srv-eyebrow">SENTE360</span>
                <h1>Servis Kayıtları</h1>
                <p>Açık iş emirleri ve geçmiş servis kayıtları.</p>
            </div>
        </div>

        <a href="/ServiceRecords/Create" class="srv-create-btn">
            <span>+</span>
            <strong>Yeni Kayıt Aç</strong>
        </a>
    </section>

    @if (TempData["SuccessMessage"] is not null)
    {
        <div class="srv-alert srv-alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] is not null)
    {
        <div class="srv-alert srv-alert-error">@Html.Raw(TempData["ErrorMessage"])</div>
    }

    <section class="srv-filter-shell">
        <form method="get" action="/ServiceRecords" id="serviceRecordFilterForm">
            <input type="hidden" name="PageNumber" value="1" />
            <input type="hidden" name="StatusFilter" id="StatusFilter" value="@currentStatus" />

            <div class="srv-search-row">
                <div class="srv-search-box">
                    <span class="srv-search-icon">⌕</span>
                    <input type="text"
                           name="Search"
                           value="@query.Search"
                           placeholder="Plaka, müşteri, telefon veya kayıt no ara..." />
                </div>

                <button type="submit" class="srv-search-submit">
                    Ara
                </button>

                <button type="button"
                        class="srv-filter-toggle @(hasAdvancedFilter ? "is-open" : "")"
                        data-filter-toggle
                        aria-expanded="@(hasAdvancedFilter ? "true" : "false")">
                    <span>☷</span>
                    <strong>Filtreler</strong>
                    <em>⌄</em>
                </button>
            </div>

            <div class="srv-advanced-filters @(hasAdvancedFilter ? "is-open" : "")" data-filter-panel>
                <div class="srv-filter-section">
                    <label>Durum</label>

                    <div class="srv-status-chips">
                        <button type="button"
                                class="srv-status-chip @(currentStatus == "active" ? "active" : "")"
                                data-status-value="active">
                            Aktif
                        </button>

                        <button type="button"
                                class="srv-status-chip @(currentStatus == "completed" ? "active" : "")"
                                data-status-value="completed">
                            Tamamlandı
                        </button>

                        <button type="button"
                                class="srv-status-chip @(currentStatus == "cancelled" ? "active" : "")"
                                data-status-value="cancelled">
                            İptal
                        </button>

                        <button type="button"
                                class="srv-status-chip @(currentStatus == "all" ? "active" : "")"
                                data-status-value="all">
                            Tümü
                        </button>
                    </div>
                </div>

                <div class="srv-filter-section">
                    <label>Başlangıç</label>
                    <input type="date"
                           name="CreatedFrom"
                           value="@query.CreatedFrom?.ToString("yyyy-MM-dd")" />
                </div>

                <div class="srv-filter-section">
                    <label>Bitiş</label>
                    <input type="date"
                           name="CreatedTo"
                           value="@query.CreatedTo?.ToString("yyyy-MM-dd")" />
                </div>

                <div class="srv-filter-section">
                    <label>Sayfa</label>
                    <select name="PageSize">
                        <option value="10" selected="@(query.PageSize == 10)">10</option>
                        <option value="20" selected="@(query.PageSize == 20)">20</option>
                        <option value="50" selected="@(query.PageSize == 50)">50</option>
                        <option value="100" selected="@(query.PageSize == 100)">100</option>
                    </select>
                </div>

                <div class="srv-filter-actions">
                    <button type="submit" class="srv-apply-btn">Filtrele</button>
                    <a href="/ServiceRecords" class="srv-clear-btn">Temizle</a>
                </div>
            </div>
        </form>
    </section>

    <section class="srv-list-shell">
        <div class="srv-list-toolbar">
            <div class="srv-list-summary">
                @if (paged.TotalCount > 0)
                {
                    <span>
                        <strong>@paged.TotalCount</strong> kayıt içinden
                        <strong>@paged.FirstItemNumber - @paged.LastItemNumber</strong> arası gösteriliyor.
                    </span>
                }
                else
                {
                    <span>Kayıt bulunamadı.</span>
                }
            </div>

            @if (paged.TotalPages > 1)
            {
                <div class="srv-top-pager">
                    <a class="srv-top-nav @(paged.HasPreviousPage ? "" : "disabled")"
                       href="@(paged.HasPreviousPage
                                              ? Url.Action("Index", "ServiceRecords", new
                                              {
                                                  Search = query.Search,
                                                  StatusFilter = currentStatus,
                                                  CreatedFrom = query.CreatedFrom?.ToString("yyyy-MM-dd"),
                                                  CreatedTo = query.CreatedTo?.ToString("yyyy-MM-dd"),
                                                  PageNumber = paged.PageNumber - 1,
                                                  PageSize = query.PageSize
                                              })
                                          : "#")">
                        ‹
                    </a>

                    <div class="srv-top-page-list">
                        @for (var pageNumber = 1; pageNumber <= paged.TotalPages; pageNumber++)
                        {
                            if (pageNumber == 1 ||
                                pageNumber == paged.TotalPages ||
                                Math.Abs(pageNumber - paged.PageNumber) <= 1)
                            {
                                <a class="srv-top-page @(pageNumber == paged.PageNumber ? "active" : "")"
                                   href="@Url.Action("Index", "ServiceRecords", new
                                   {
                                       Search = query.Search,
                                       StatusFilter = currentStatus,
                                       CreatedFrom = query.CreatedFrom?.ToString("yyyy-MM-dd"),
                                       CreatedTo = query.CreatedTo?.ToString("yyyy-MM-dd"),
                                       PageNumber = pageNumber,
                                       PageSize = query.PageSize
                                   })">
                                    @pageNumber
                                </a>
                            }
                        }
                    </div>

                    <a class="srv-top-nav @(paged.HasNextPage ? "" : "disabled")"
                       href="@(paged.HasNextPage
                                              ? Url.Action("Index", "ServiceRecords", new
                                              {
                                                  Search = query.Search,
                                                  StatusFilter = currentStatus,
                                                  CreatedFrom = query.CreatedFrom?.ToString("yyyy-MM-dd"),
                                                  CreatedTo = query.CreatedTo?.ToString("yyyy-MM-dd"),
                                                  PageNumber = paged.PageNumber + 1,
                                                  PageSize = query.PageSize
                                              })
                                          : "#")">
                        ›
                    </a>
                </div>
            }
        </div>

       

        <div class="srv-list">
            @foreach (var record in paged.Items)
            {
                var recordNumber = string.IsNullOrWhiteSpace(record.RecordNumber)
                    ? $"SR-{record.Id}"
                    : record.RecordNumber;

                var vehicleTitle = $"{record.VehicleBrandName} {record.VehicleModelName}".Trim();

                var statusText = record.Status switch
                {
                    1 => "AKTİF",
                    2 => "İŞLEMDE",
                    3 => "TAMAMLANDI",
                    4 => "İPTAL",
                    _ => "BİLİNMİYOR"
                };

                var statusClass = record.Status switch
                {
                    1 => "status-open",
                    2 => "status-progress",
                    3 => "status-completed",
                    4 => "status-cancelled",
                    _ => "status-unknown"
                };

                var vatIncludedTotal = Math.Round(record.TotalAmount * 1.20m, 2);

                <a class="srv-card" href="/ServiceRecords/Detail/@record.Id">
                    <div class="srv-card-plate-block">
                        <div class="srv-plate">
                            <span>TR</span>
                            <strong>@record.VehiclePlate</strong>
                        </div>

                        <div class="srv-car-name">
                            <span>▱</span>
                            <strong>@(string.IsNullOrWhiteSpace(vehicleTitle) ? "Araç bilgisi yok" : vehicleTitle)</strong>
                        </div>
                    </div>

                    <div class="srv-card-info">
                        <div class="srv-info-line">
                            <span class="srv-mini-icon">♙</span>
                            <strong>@record.CustomerName</strong>
                        </div>

                        <div class="srv-info-line">
                            <span class="srv-mini-icon">☎</span>
                            <span>@record.CustomerPhone</span>
                            @await Html.PartialAsync("_ContactActions", new ContactActionsViewModel
                            {
                                PhoneNumber = record.CustomerPhone,
                                CustomerName = record.CustomerName,
                                Plate = record.VehiclePlate,
                                ServiceStatus = record.Status == 3 ? "Completed" : record.Status.ToString(),
                                Variant = "compact"
                            })
                        </div>

                        <div class="srv-info-line srv-date-line">
                            <span class="srv-mini-icon">▣</span>
                            <span>@record.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                    </div>

                    <div class="srv-card-code">
                        <strong>@recordNumber</strong>
                    </div>

                    <div class="srv-card-amount">
                        <strong>@SenteMoney.Format(vatIncludedTotal)</strong>
                        <small>KDV dahil</small>
                    </div>

                    <div class="srv-card-status">
                        <span class="srv-status-pill @statusClass">@statusText</span>
                    </div>

                    <div class="srv-card-arrow">
                        →
                    </div>
                </a>
            }

            @if (!paged.Items.Any())
            {
                <div class="srv-empty">
                    <div class="srv-empty-icon">⌕</div>
                    <strong>Kayıt bulunamadı</strong>
                    <span>Arama veya filtre kriterlerini değiştirerek tekrar deneyebilirsin.</span>
                </div>
            }
        </div>

        @if (paged.TotalPages > 1)
        {
            <div class="srv-pagination">
                <a class="srv-page-btn @(paged.HasPreviousPage ? "" : "disabled")"
                   href="@(paged.HasPreviousPage
                                              ? Url.Action("Index", "ServiceRecords", new
                                              {
                                                  Search = query.Search,
                                                  StatusFilter = currentStatus,
                                                  CreatedFrom = query.CreatedFrom?.ToString("yyyy-MM-dd"),
                                                  CreatedTo = query.CreatedTo?.ToString("yyyy-MM-dd"),
                                                  PageNumber = paged.PageNumber - 1,
                                                  PageSize = query.PageSize
                                              })
                                          : "#")">
                    Önceki
                </a>

                <div class="srv-page-numbers">
                    @for (var pageNumber = 1; pageNumber <= paged.TotalPages; pageNumber++)
                    {
                        if (pageNumber == 1 ||
                            pageNumber == paged.TotalPages ||
                            Math.Abs(pageNumber - paged.PageNumber) <= 2)
                        {
                            <a class="srv-page-number @(pageNumber == paged.PageNumber ? "active" : "")"
                               href="@Url.Action("Index", "ServiceRecords", new
                               {
                                   Search = query.Search,
                                   StatusFilter = currentStatus,
                                   CreatedFrom = query.CreatedFrom?.ToString("yyyy-MM-dd"),
                                   CreatedTo = query.CreatedTo?.ToString("yyyy-MM-dd"),
                                   PageNumber = pageNumber,
                                   PageSize = query.PageSize
                               })">
                                @pageNumber
                            </a>
                        }
                    }
                </div>

                <a class="srv-page-btn @(paged.HasNextPage ? "" : "disabled")"
                   href="@(paged.HasNextPage
                                              ? Url.Action("Index", "ServiceRecords", new
                                              {
                                                  Search = query.Search,
                                                  StatusFilter = currentStatus,
                                                  CreatedFrom = query.CreatedFrom?.ToString("yyyy-MM-dd"),
                                                  CreatedTo = query.CreatedTo?.ToString("yyyy-MM-dd"),
                                                  PageNumber = paged.PageNumber + 1,
                                                  PageSize = query.PageSize
                                              })
                                          : "#")">
                    Sonraki
                </a>
            </div>
        }
    </section>
</div>

<style>
    .srv-page {
        width: min(1280px, calc(100% - 56px));
        margin: 0 auto;
        padding: 30px 0 64px;
    }

    .srv-hero {
        margin-bottom: 22px;
        padding: 24px 28px;
        border-radius: 30px;
        background: radial-gradient(circle at 78% 40%, rgba(255,255,255,.16), transparent 30%), linear-gradient(135deg, #07111f 0%, #111827 48%, #4f46e5 100%);
        color: #fff;
        box-shadow: 0 26px 70px rgba(15, 23, 42, .20);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 22px;
        overflow: hidden;
    }

    .srv-hero-left {
        display: flex;
        align-items: center;
        gap: 18px;
        min-width: 0;
    }

    .srv-home-btn {
        width: 54px;
        height: 54px;
        flex: 0 0 54px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #2563eb, #16a34a);
        color: white;
        text-decoration: none;
        font-size: 24px;
        font-weight: 950;
        box-shadow: 0 18px 36px rgba(37, 99, 235, .25);
    }

    .srv-eyebrow {
        display: inline-flex;
        margin-bottom: 8px;
        padding: 6px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.18);
        color: rgba(255,255,255,.82);
        font-size: 12px;
        font-weight: 950;
        letter-spacing: .2px;
    }

    .srv-hero h1 {
        margin: 0;
        font-size: clamp(30px, 4vw, 42px);
        line-height: 1;
        letter-spacing: -1.6px;
    }

    .srv-hero p {
        margin: 10px 0 0;
        color: rgba(255,255,255,.72);
        font-size: 15px;
    }

    .srv-create-btn {
        height: 56px;
        padding: 0 22px;
        border-radius: 18px;
        background: #4f46e5;
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
        font-size: 16px;
        box-shadow: 0 18px 34px rgba(79, 70, 229, .36);
        white-space: nowrap;
    }

        .srv-create-btn span {
            font-size: 28px;
            line-height: 1;
        }

        .srv-create-btn strong {
            font-weight: 950;
        }

    .srv-filter-shell {
        margin-bottom: 22px;
        padding: 20px;
        border-radius: 26px;
        background: rgba(255,255,255,.96);
        border: 1px solid #dbe3ef;
        box-shadow: 0 18px 42px rgba(15, 23, 42, .07);
    }

    .srv-search-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto auto;
        gap: 10px;
        align-items: center;
    }

    .srv-search-box {
        position: relative;
        min-width: 0;
    }

    .srv-search-icon {
        position: absolute;
        left: 18px;
        top: 50%;
        transform: translateY(-50%);
        color: #8aa0bd;
        font-size: 24px;
        pointer-events: none;
    }

    .srv-search-box input {
        width: 100%;
        height: 56px;
        padding: 0 18px 0 52px;
        border-radius: 18px;
        border: 1px solid #d4deeb;
        background: #f8fafc;
        color: #0f172a;
        font-size: 16px;
        font-weight: 750;
        outline: none;
        box-sizing: border-box;
    }

        .srv-search-box input::placeholder {
            color: #8aa0bd;
            font-weight: 700;
        }

        .srv-search-box input:focus {
            background: white;
            border-color: #4f46e5;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, .10);
        }

    .srv-search-submit,
    .srv-filter-toggle {
        height: 56px;
        border-radius: 18px;
        border: 1px solid #c7d2fe;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        cursor: pointer;
        font-size: 15px;
        font-weight: 950;
        white-space: nowrap;
    }

    .srv-search-submit {
        padding: 0 22px;
        background: #4f46e5;
        color: white;
        border-color: #4f46e5;
        box-shadow: 0 12px 24px rgba(79, 70, 229, .20);
    }

    .srv-filter-toggle {
        padding: 0 18px;
        background: #f8fafc;
        color: #312e81;
    }

        .srv-filter-toggle span {
            font-size: 18px;
        }

        .srv-filter-toggle em {
            font-style: normal;
            transition: .18s ease;
        }

        .srv-filter-toggle.is-open em {
            transform: rotate(180deg);
        }

    .srv-advanced-filters {
        display: none;
        margin-top: 18px;
        padding-top: 18px;
        border-top: 1px solid #e2e8f0;
        grid-template-columns: 1.3fr .8fr .8fr .55fr auto;
        gap: 14px;
        align-items: end;
    }

        .srv-advanced-filters.is-open {
            display: grid;
        }

    .srv-filter-section {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 9px;
    }

        .srv-filter-section label {
            color: #64748b;
            font-size: 12px;
            font-weight: 950;
            letter-spacing: .7px;
            text-transform: uppercase;
        }

        .srv-filter-section input,
        .srv-filter-section select {
            width: 100%;
            height: 46px;
            padding: 0 14px;
            border-radius: 15px;
            border: 1px solid #d4deeb;
            background: #f8fafc;
            color: #0f172a;
            font-size: 15px;
            font-weight: 800;
            outline: none;
            box-sizing: border-box;
        }

    .srv-status-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 9px;
    }

    .srv-status-chip {
        height: 36px;
        padding: 0 16px;
        border: none;
        border-radius: 999px;
        background: #f1f5f9;
        color: #334155;
        font-size: 13px;
        font-weight: 900;
        cursor: pointer;
    }

        .srv-status-chip.active {
            background: #0f172a;
            color: white;
        }

    .srv-filter-actions {
        display: flex;
        gap: 10px;
    }

    .srv-apply-btn,
    .srv-clear-btn {
        height: 46px;
        padding: 0 18px;
        border-radius: 15px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-size: 14px;
        font-weight: 950;
        white-space: nowrap;
    }

    .srv-apply-btn {
        border: none;
        background: #4f46e5;
        color: white;
        cursor: pointer;
    }

    .srv-clear-btn {
        border: 1px solid #d4deeb;
        background: #f8fafc;
        color: #4f46e5;
    }

    .srv-list-shell {
        border-radius: 28px;
    }

    .srv-list-summary {
        margin-bottom: 12px;
        color: #64748b;
        font-size: 14px;
        font-weight: 850;
    }

        .srv-list-summary strong {
            color: #334155;
        }

    .srv-list {
        display: grid;
        gap: 14px;
    }

    .srv-card {
        min-height: 96px;
        padding: 20px 24px;
        border-radius: 24px;
        border: 1px solid #dbe3ef;
        background: white;
        color: #0f172a;
        text-decoration: none;
        display: grid;
        grid-template-columns: 230px minmax(220px, 1fr) 160px 130px 140px 42px;
        gap: 22px;
        align-items: center;
        box-shadow: 0 10px 26px rgba(15, 23, 42, .045);
        transition: .16s ease;
    }

        .srv-card:hover {
            transform: translateY(-2px);
            border-color: #c7d2fe;
            box-shadow: 0 18px 38px rgba(15, 23, 42, .08);
        }

    .srv-card-plate-block {
        min-width: 0;
    }

    .srv-plate {
        width: fit-content;
        max-width: 100%;
        min-height: 48px;
        border-radius: 6px;
        border: 2px solid #0f172a;
        background: white;
        display: inline-flex;
        align-items: stretch;
        overflow: hidden;
    }

        .srv-plate span {
            width: 34px;
            display: grid;
            place-items: start center;
            padding-top: 6px;
            background: #1d4ed8;
            color: white;
            font-size: 10px;
            font-weight: 950;
        }

        .srv-plate strong {
            padding: 0 16px;
            display: flex;
            align-items: center;
            color: #020617;
            font-size: 23px;
            font-weight: 950;
            letter-spacing: 1.2px;
            white-space: nowrap;
        }

    .srv-car-name {
        margin-top: 9px;
        display: flex;
        align-items: center;
        gap: 8px;
        color: #526782;
        font-size: 14px;
        font-weight: 800;
    }

    .srv-card-info {
        min-width: 0;
        display: grid;
        gap: 8px;
    }

    .srv-info-line {
        min-width: 0;
        display: flex;
        align-items: center;
        gap: 10px;
        color: #4b617c;
        font-size: 14px;
        font-weight: 800;
    }

        .srv-info-line strong {
            color: #0f172a;
            font-size: 16px;
            font-weight: 950;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

    .srv-mini-icon {
        width: 18px;
        color: #8aa0bd;
        text-align: center;
        flex: 0 0 18px;
    }

    .srv-card-code strong,
    .srv-card-amount strong {
        color: #8aa0bd;
        font-size: 14px;
        font-weight: 950;
        white-space: nowrap;
    }

    .srv-card-amount strong {
        color: #0f172a;
    }

    .srv-card-amount small {
        display: block;
        margin-top: 5px;
        color: #8aa0bd;
        font-size: 11px;
        font-weight: 900;
        white-space: nowrap;
    }

    .srv-card-status {
        display: flex;
        justify-content: flex-end;
    }

    .srv-status-pill {
        min-width: 104px;
        height: 32px;
        padding: 0 12px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 950;
        white-space: nowrap;
    }

        .srv-status-pill.status-open,
        .srv-status-pill.status-progress {
            background: #dbeafe;
            color: #1d4ed8;
            border: 1px solid #bfdbfe;
        }

        .srv-status-pill.status-completed {
            background: #bbf7d0;
            color: #047857;
            border: 1px solid #86efac;
        }

        .srv-status-pill.status-cancelled {
            background: #fee2e2;
            color: #b91c1c;
            border: 1px solid #fecaca;
        }

        .srv-status-pill.status-unknown {
            background: #f1f5f9;
            color: #475569;
            border: 1px solid #cbd5e1;
        }

    .srv-card-arrow {
        width: 42px;
        height: 42px;
        border-radius: 999px;
        display: grid;
        place-items: center;
