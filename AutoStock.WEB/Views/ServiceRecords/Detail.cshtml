@model AutoStock.WEB.Models.ServiceRecords.ServiceRecordDetailViewModel

@{
    ViewData["Title"] = "Servis Detayı";
}

<div class="page">

    <div class="premium-header">
        <div class="premium-brand">
            <div class="premium-logo">S</div>

            <div>
                <span class="premium-eyebrow">SERVİS DETAYI</span>

                <h1>@Model.RecordNumber</h1>

                <p>
                    @Model.CustomerName -
                    @Model.VehiclePlate
                </p>
            </div>
        </div>

        <a href="/ServiceRecords" class="premium-home">
            ←
        </a>
    </div>

    <div class="detail-layout">

        <div class="detail-main">

            <div class="panel">

                <div class="section-title">
                    Müşteri / Araç Bilgileri
                </div>

                <div class="info-grid">

                    <div class="info-card">
                        <label>Müşteri</label>
                        <strong>@Model.CustomerName</strong>
                    </div>

                    <div class="info-card">
                        <label>Telefon</label>
                        <strong>@Model.CustomerPhone</strong>
                    </div>

                    <div class="info-card">
                        <label>Plaka</label>
                        <strong>@Model.VehiclePlate</strong>
                    </div>

                    <div class="info-card">
                        <label>Araç</label>
                        <strong>
                            @Model.VehicleBrandName
                            @Model.VehicleModelName
                        </strong>
                    </div>

                    <div class="info-card">
                        <label>Kilometre</label>
                        <strong>@Model.Mileage</strong>
                    </div>

                    <div class="info-card">
                        <label>Kayıt Tarihi</label>
                        <strong>
                            @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                        </strong>
                    </div>

                </div>

            </div>

            <div class="panel">

                <div class="section-title">
                    Müşteri Şikayeti
                </div>

                <div class="note-box">
                    @(string.IsNullOrWhiteSpace(Model.CustomerComplaint)
                        ? "Şikayet girilmemiş."
                        : Model.CustomerComplaint)
                </div>

            </div>

            <div class="panel">

                <div class="section-title">
                    Servis Kabul Notu
                </div>

                <div class="note-box">
                    @(string.IsNullOrWhiteSpace(Model.ServiceReceptionNote)
                        ? "Not girilmemiş."
                        : Model.ServiceReceptionNote)
                </div>

            </div>

            <div class="panel">

                <div class="section-title">
                    Şikayet / Talepler
                </div>

                @if (Model.RequestItems.Any())
                {
                    <div class="request-detail-list">

                        @foreach (var item in Model.RequestItems)
                        {
                            <div class="request-detail-card collapsed"
                                 data-request-id="@item.Id"
                                 id="request-item-@item.Id">

                                <div class="request-card-top">

                                    <button type="button"
                                            class="request-accordion-header"
                                            onclick="toggleRequestCard(this)">

                                        <strong>@item.Title</strong>

                                        <span class="accordion-arrow">›</span>

                                    </button>

                                    <button type="button"
                                            class="request-delete-btn"
                                            onclick="deleteRequestItem(@item.Id, this)">
                                        Sil
                                    </button>

                                </div>
                                <div class="request-accordion-body">

                                    @{
                                        var itemOperations = Model.Operations
                                            .Where(x => x.ServiceRequestItemId == item.Id)
                                            .ToList();

                                        var itemTotal = itemOperations.Sum(x => x.TotalPrice);
                                    }

                                    <div class="request-operation-area">

                                        <div class="request-operation-header">
                                            <strong>Yapılan İşlemler</strong>
                                            <span data-total="@itemTotal">Toplam: @itemTotal.ToString("N2") ₺</span>
                                        </div>

                                        @if (itemOperations.Any())
                                        {
                                            <div class="request-operation-list">
                                                @foreach (var operation in itemOperations)
                                                {
                                                    <div class="request-operation-item" id="operation-item-@operation.Id">
                                                        <div>
                                                            <strong>@operation.Description</strong>
                                                            <span>@(operation.Type == 1 ? "Parça" : "İşçilik")</span>
                                                        </div>

                                                        <div>
                                                            <strong>@operation.TotalPrice.ToString("N2") ₺</strong>
                                                            <span>@operation.Quantity adet × @operation.UnitPrice.ToString("N2") ₺</span>
                                                        </div>

                                                        <button type="button"
                                                                class="operation-delete-btn"
                                                                onclick="deleteOperation(@operation.Id, this)">
                                                            Sil
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="mini-empty">
                                                Bu talep için henüz işlem eklenmedi.
                                            </div>
                                        }

                                    </div>

                                    <form asp-action="AddOperation"
                                          method="post"
                                          class="add-operation-form ajax-operation-form">

                                        <input type="hidden" name="ServiceRecordId" value="@Model.Id" />
                                        <input type="hidden" name="ServiceRequestItemId" value="@item.Id" />

                                        <div class="operation-form-row">

                                            <div class="type-toggle">

                                                <input type="radio"
                                                       id="partType_@item.Id"
                                                       name="Type"
                                                       value="1"
                                                       checked />

                                                <label for="partType_@item.Id">
                                                    Parça
                                                </label>

                                                <input type="radio"
                                                       id="laborType_@item.Id"
                                                       name="Type"
                                                       value="2" />

                                                <label for="laborType_@item.Id">
                                                    İşçilik
                                                </label>

                                            </div>

                                            <div class="form-field">
                                                <input name="Description" placeholder=" " />
                                                <label>İşlem Açıklaması</label>
                                            </div>

                                            <div class="form-field">
                                                <input name="Quantity" type="number" value="1" min="1" placeholder=" " />
                                                <label>Adet</label>
                                            </div>

                                            <div class="form-field">
                                                <input name="UnitPrice" type="number" step="0.01" min="0" placeholder=" " />
                                                <label>Birim Fiyat</label>
                                            </div>

                                            <button type="submit" class="btn-primary">
                                                + İşlem
                                            </button>

                                        </div>

                                        <div class="form-field operation-note-field">
                                            <textarea name="Note" placeholder=" "></textarea>
                                            <label>İşlem Notu</label>
                                        </div>

                                    </form>

                                </div>

                            </div>
                        }

                    </div>
                }
                else
                {
                    <div class="empty-state">
                        Bu servis kaydı için talep girilmemiş.
                    </div>
                }

            </div>

            <div class="panel">

                <div class="section-title">
                    Ek Talep / İşlem Ekle
                </div>

                <form asp-action="AddRequestItem"
                      method="post"
                      class="add-request-form ajax-request-form">

                    <input type="hidden" name="serviceRecordId" value="@Model.Id" />

                    <div class="request-builder-detail">

                        <div class="form-field">
                            <input name="Title"
                                   list="detailRequestSuggestions"
                                   placeholder=" " />
                            <label>Talep / İşlem</label>

                            <datalist id="detailRequestSuggestions">
                                <option value="Genel bakım"></option>
                                <option value="Yağ değişimi"></option>
                                <option value="Fren kontrolü"></option>
                                <option value="Klima arızası"></option>
                                <option value="Rot balans kontrolü"></option>
                                <option value="Far ayarı"></option>
                            </datalist>
                        </div>

                        <div class="form-field">
                            <input name="EstimatedAmount"
                                   type="number"
                                   step="0.01"
                                   placeholder=" " />
                            <label>Tahmini Fiyat</label>
                        </div>

                        <button type="submit" class="btn-primary">
                            + Talep Ekle
                        </button>

                    </div>

                    <div class="form-field add-request-note">
                        <textarea name="Note" placeholder=" "></textarea>
                        <label>Ön Not</label>
                    </div>

                </form>

            </div>

            <div class="panel">

                <div class="section-title">
                    İşlemler
                </div>

                @if (Model.Operations.Any())
                {
                    <div class="operation-list">
                        @foreach (var operation in Model.Operations)
                        {
                            <div class="operation-card">
                                <div>
                                    <strong>@operation.Description</strong>
                                    <span>@(operation.Type == 1 ? "Parça" : "İşçilik")</span>
                                </div>

                                <div>
                                    <strong>@operation.Quantity Adet</strong>
                                    <span>Birim: @operation.UnitPrice.ToString("N2") ₺</span>
                                </div>

                                <div>
                                    <strong>@operation.TotalPrice.ToString("N2") ₺</strong>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        Henüz işlem eklenmedi.
                    </div>
                }

            </div>

          

        <div class="detail-sidebar">

            <div class="summary-card">

                <div class="summary-label">
                    Toplam Tutar
                </div>

                    <div class="summary-total" data-total="@Model.TotalAmount">
                        @Model.TotalAmount.ToString("N2") ₺
                    </div>

                    <div class="summary-status status-@Model.Status">
                        @(Model.Status switch
                        {
                            1 => "Açık Kayıt",
                            2 => "İşlemde",
                            3 => "Tamamlandı",
                            4 => "İptal Edildi",
                            _ => "Bilinmiyor"
                        })
                    </div>

                    <div class="status-actions" data-record-id="@Model.Id">

                        @if (Model.Status == 1)
                        {
                            <button type="button" class="status-btn warning" data-status="2">
                                İşleme Al
                            </button>

                            <button type="button" class="status-btn danger" data-status="4">
                                İptal Et
                            </button>
                        }
                        else if (Model.Status == 2)
                        {
                            <button type="button" class="status-btn success" data-status="3">
                                Tamamla
                            </button>

                            <button type="button" class="status-btn danger" data-status="4">
                                İptal Et
                            </button>
                        }
                        else if (Model.Status == 3 || Model.Status == 4)
                        {
                            <button type="button" class="status-btn primary" data-status="1">
                                Tekrar Aç
                            </button>
                        }

                    </div>

                    <a href="/service-pdf/create/@Model.Id"
                           class="pdf-btn"
                           target="_blank">
                        PDF Oluştur
                    </a>

                    <div class="qr-assign-box">
                        <div class="qr-title">Araç QR Kodu</div>

                        <button type="button"
                                id="start-qr-scan-btn"
                                onclick="startQrScanner(@Model.VehicleId, this)">
                            QR Kod Tara
                        </button>

                        <div id="qr-reader" style="display:none;"></div>

                        <div id="qr-scan-result" class="qr-scan-result"></div>
                    </div>
            </div>

        </div>

    </div>

</div>

<style>
    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        background: radial-gradient(circle at top left, rgba(37, 99, 235, .10), transparent 28rem), radial-gradient(circle at top right, rgba(22, 163, 74, .10), transparent 28rem), #f3f6fb;
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: #0f172a;
    }

    .page {
        width: min(1450px, calc(100% - 48px));
        margin: 0 auto;
        padding: 36px 0 60px;
    }

    .premium-header {
        margin-bottom: 28px;
        padding: 32px 36px;
        border-radius: 32px;
        background: linear-gradient(135deg, #07111f 0%, #111827 42%, #1d4ed8 100%);
        color: white;
        box-shadow: 0 28px 80px rgba(15, 23, 42, .24);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
    }

    .premium-brand {
        display: flex;
        align-items: center;
        gap: 22px;
    }

    .premium-logo {
        width: 54px;
        height: 54px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #2563eb, #16a34a);
        color: white;
        font-weight: 950;
        font-size: 22px;
        flex-shrink: 0;
    }

    .premium-eyebrow {
        display: inline-flex;
        margin-bottom: 7px;
        padding: 6px 11px;
        border-radius: 999px;
        background: rgba(255,255,255,.13);
        border: 1px solid rgba(255,255,255,.18);
        color: rgba(255,255,255,.80);
        font-size: 12px;
        font-weight: 800;
    }

    .premium-header h1 {
        margin: 0;
        font-size: 36px;
        letter-spacing: -1.5px;
        line-height: 1.05;
    }

    .premium-header p {
        margin: 10px 0 0;
        color: rgba(255,255,255,.72);
    }

    .premium-home {
        width: 54px;
        height: 54px;
        display: grid;
        place-items: center;
        border-radius: 18px;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.18);
        color: white;
        text-decoration: none;
        font-size: 28px;
        font-weight: 900;
        flex-shrink: 0;
    }

    .detail-layout {
    display: grid;
    grid-template-columns: minmax(0, 980px) 340px;
    gap: 24px;
    align-items: start;
    justify-content: center;
            }

    .detail-main {
        display: grid;
        gap: 20px;
    }

    .panel {
        padding: 24px;
        border-radius: 30px;
        background: rgba(255,255,255,.94);
        border: 1px solid #e2e8f0;
        box-shadow: 0 22px 55px rgba(15, 23, 42, .08);
    }

    .section-title {
        margin: 0 0 18px;
        font-size: 24px;
        font-weight: 900;
        color: #0f172a;
        letter-spacing: -.5px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 18px;
    }

    .btn-primary,
    .btn-save-request {
        border: none;
        border-radius: 16px;
        color: white;
        padding: 13px 18px;
        font-size: 14px;
        font-weight: 900;
        cursor: pointer;
        transition: .18s ease;
        white-space: nowrap;
    }

    .btn-primary {
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        box-shadow: 0 12px 24px rgba(37, 99, 235, .18);
    }

    .btn-save-request {
        background: linear-gradient(135deg, #16a34a, #15803d);
        box-shadow: 0 12px 24px rgba(22, 163, 74, .18);
    }

        .btn-primary:hover,
        .btn-save-request:hover {
            transform: translateY(-1px);
            filter: brightness(.96);
        }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
    }

    .info-card,
    .note-box,
    .operation-card,
    .request-detail-card,
    .empty-state {
        border-radius: 20px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
    }

    .info-card {
        padding: 18px;
    }

        .info-card label {
            display: block;
            margin-bottom: 8px;
            color: #64748b;
            font-size: 13px;
            font-weight: 800;
        }

        .info-card strong {
            color: #0f172a;
            font-size: 15px;
            font-weight: 900;
        }

    .note-box {
        padding: 18px;
        color: #0f172a;
        line-height: 1.7;
        font-weight: 600;
    }

    .form-field {
        position: relative;
        min-width: 0;
    }

        .form-field input,
        .form-field textarea {
            width: 100%;
            min-height: 54px;
            border: 1px solid #dbe3ef;
            border-radius: 16px;
            background: white;
            padding: 20px 15px 10px;
            font: inherit;
            font-size: 15px;
            color: #0f172a;
            outline: none;
            transition: .18s ease;
        }

        .form-field textarea {
            min-height: 96px;
            resize: vertical;
            line-height: 1.45;
        }

            .form-field input:focus,
            .form-field textarea:focus {
                border-color: #2563eb;
                background: white;
                box-shadow: 0 0 0 4px rgba(37, 99, 235, .11);
            }

        .form-field label {
            position: absolute;
            top: 16px;
            left: 15px;
            padding: 0 6px;
            border-radius: 8px;
            background: white;
            color: #64748b;
            font-size: 14px;
            font-weight: 800;
            pointer-events: none;
            transition: .18s ease;
        }

        .form-field input:focus + label,
        .form-field input:not(:placeholder-shown) + label,
        .form-field textarea:focus + label,
        .form-field textarea:not(:placeholder-shown) + label {
            top: -8px;
            left: 12px;
            color: #2563eb;
            font-size: 11px;
        }

    .request-detail-list,
    .operation-list {
        display: grid;
        gap: 14px;
    }

    .request-detail-card {
        padding: 18px;
    }

    .request-detail-main {
        display: flex;
        justify-content: space-between;
        gap: 18px;
        align-items: flex-start;
        margin-bottom: 16px;
    }

        .request-detail-main strong {
            display: block;
            font-size: 16px;
            font-weight: 900;
            color: #0f172a;
        }

        .request-detail-main span {
            display: block;
            margin-top: 6px;
            color: #64748b;
            font-size: 13px;
            font-weight: 700;
        }

    .request-detail-meta {
        text-align: right;
        min-width: 170px;
    }

    .request-status {
        display: inline-flex !important;
        margin-top: 8px !important;
        padding: 7px 11px;
        border-radius: 999px;
        font-size: 12px !important;
        font-weight: 900 !important;
    }

        .request-status.open {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .request-status.resolved {
            background: #dcfce7;
            color: #15803d;
        }

    .request-update-form {
        display: grid;
        gap: 14px;
    }

    .request-repair-area {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 190px;
        gap: 14px;
    }

    .request-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
    }

    .resolved-check {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #334155;
        font-size: 14px;
        font-weight: 800;
    }

        .resolved-check input {
            width: 18px;
            height: 18px;
            accent-color: #16a34a;
        }

    .add-request-form {
        display: grid;
        gap: 14px;
    }

    .request-builder-detail {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 220px 170px;
        gap: 14px;
        align-items: center;
    }

    .add-request-note textarea {
        min-height: 110px;
    }

    .operation-card {
        display: grid;
        grid-template-columns: 1.5fr 1fr 150px;
        gap: 18px;
        align-items: center;
        padding: 18px;
    }

        .operation-card strong {
            display: block;
            color: #0f172a;
            font-weight: 900;
        }

        .operation-card span {
            display: block;
            margin-top: 5px;
            color: #64748b;
            font-size: 13px;
            font-weight: 700;
        }

    .empty-state {
        padding: 30px;
        border-style: dashed;
        text-align: center;
        color: #64748b;
        font-weight: 800;
    }

    .summary-card {
        position: sticky;
        top: 24px;
        padding: 28px;
        border-radius: 30px;
        background: linear-gradient(180deg, #0f172a, #111827);
        color: white;
        box-shadow: 0 25px 60px rgba(15, 23, 42, .24);
    }

    .summary-label {
        color: rgba(255,255,255,.70);
        font-size: 14px;
        font-weight: 800;
    }

    .summary-total {
        margin-top: 14px;
        font-size: 42px;
        font-weight: 950;
        letter-spacing: -2px;
    }

    .summary-status {
        margin-top: 18px;
        padding: 12px 14px;
        border-radius: 16px;
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.08);
        text-align: center;
        font-weight: 800;
    }

    @@media (max-width: 800px) {
        .detail-layout {
            grid-template-columns: 1fr;
        }

        .summary-card {
            position: static;
        }

        .info-grid {
            grid-template-columns: 1fr;
        }

        .operation-card {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 900px) {
        .page {
            width: min(100% - 28px, 1450px);
            padding-top: 20px;
        }

        .premium-header {
            padding: 24px;
            border-radius: 26px;
            align-items: flex-start;
        }

            .premium-header h1 {
                font-size: 28px;
            }

        .premium-brand {
            align-items: flex-start;
        }

        .request-detail-main,
        .request-actions {
            display: grid;
        }

        .request-detail-meta {
            text-align: left;
            min-width: 0;
        }

        .request-repair-area,
        .request-builder-detail {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 600px) {
        .page {
            width: 100%;
            padding: 14px;
        }

        .panel {
            padding: 16px;
            border-radius: 22px;
        }

        .premium-logo,
        .premium-home {
            width: 46px;
            height: 46px;
            border-radius: 15px;
        }

        .section-title {
            font-size: 21px;
        }
    }

    .premium-header {
        max-width: 1344px;
        margin-left: auto;
        margin-right: auto;
    }

    .detail-main {
        width: 100%;
        max-width: 980px;
    }

    .detail-sidebar {
        width: 340px;
    }

            .detail-layout {
                width: min(980px, 100%);
                margin: 0 auto;
                display: block;
            }

            .request-operation-area {
                margin-top: 16px;
                padding: 16px;
                border-radius: 18px;
                background: white;
                border: 1px solid #e2e8f0;
            }

            .request-operation-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                gap: 14px;
                margin-bottom: 12px;
            }

                .request-operation-header strong {
                    font-size: 14px;
                    font-weight: 900;
                    color: #0f172a;
                }

                .request-operation-header span {
                    font-size: 13px;
                    font-weight: 900;
                    color: #16a34a;
                }

            .request-operation-list {
                display: grid;
                gap: 10px;
            }

            .request-operation-item {
                display: grid;
                grid-template-columns: minmax(0, 1fr) auto auto;
                align-items: center;
                gap: 16px;
                padding: 13px 14px;
                border-radius: 15px;
                background: #f8fafc;
                border: 1px solid #e2e8f0;
            }

                .request-operation-item strong {
                    display: block;
