@model AutoStock.WEB.Models.ServiceRecords.ServiceRecordDetailViewModel

@{
    ViewData["Title"] = "Servis Detayı";

    string GetStatusText(int status)
    {
        return status switch
        {
            1 => "Açık Kayıt",
            2 => "İşlemde",
            3 => "Tamamlandı",
            4 => "İptal Edildi",
            _ => "Bilinmiyor"
        };
    }
}

<div class="page">

    <section class="premium-header">
        <a href="/ServiceRecords" class="header-back" title="Geri dön">
            ←
        </a>

        <div class="header-content">
            <span class="header-badge">SERVİS DETAYI</span>
            <h1>@Model.RecordNumber</h1>

            <div class="header-meta">
                <span>@Model.CustomerName</span>
                <span>•</span>
                <span>@Model.VehiclePlate</span>
            </div>
        </div>

        <button type="button" class="header-more" title="İşlemler">
            ...
        </button>
    </section>

    <section class="top-grid">

        <div class="panel">
            <div class="panel-title">
                <span class="title-icon">👤</span>
                <h2>Müşteri / Araç Bilgileri</h2>
            </div>

            <div class="info-grid">
                <div class="info-card">
                    <span class="info-icon">👤</span>
                    <div>
                        <label>Müşteri</label>
                        <strong>@Model.CustomerName</strong>
                    </div>
                </div>

                <div class="info-card">
                    <span class="info-icon">☎</span>
                    <div>
                        <label>Telefon</label>
                        <strong>@Model.CustomerPhone</strong>
                    </div>
                </div>

                <div class="info-card">
                    <span class="info-icon">▣</span>
                    <div>
                        <label>Plaka</label>
                        <strong>@Model.VehiclePlate</strong>
                    </div>
                </div>

                <div class="info-card">
                    <span class="info-icon">🚘</span>
                    <div>
                        <label>Araç</label>
                        <strong>@Model.VehicleBrandName @Model.VehicleModelName</strong>
                    </div>
                </div>

                <div class="info-card">
                    <span class="info-icon">🏷</span>
                    <div>
                        <label>Marka / Model</label>
                        <strong>@Model.VehicleBrandName / @Model.VehicleModelName</strong>
                    </div>
                </div>

                <div class="info-card">
                    <span class="info-icon">↗</span>
                    <div>
                        <label>Kilometre</label>
                        <strong>@((Model.Mileage ?? 0).ToString("N0")) km</strong>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ChassisNumber))
                {
                    <div class="info-card">
                        <span class="info-icon">#</span>
                        <div>
                            <label>Şasi No</label>
                            <strong>@Model.ChassisNumber</strong>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="panel">
            <div class="panel-title">
                <span class="title-icon">ⓘ</span>
                <h2>Servis Bilgileri</h2>
            </div>

            <div class="service-info-list">
                <div>
                    <span>Servis Kayıt No</span>
                    <strong>@Model.RecordNumber</strong>
                </div>

                <div>
                    <span>Kayıt Tarihi</span>
                    <strong>@Model.CreatedAt.AddHours(3).ToString("dd.MM.yyyy HH:mm")</strong>
                </div>

                <div>
                    <span>Son Güncelleme</span>
                    <strong>@(Model.UpdatedAt?.AddHours(3).ToString("dd.MM.yyyy HH:mm") ?? "-")</strong>
                </div>

                <div>
                    <span>Oluşturan</span>
                    <strong>Sistem</strong>
                </div>

                <div>
                    <span>Belge Tipi</span>
                    <strong>Servis Formu</strong>
                </div>

                <div>
                    <span>Durum</span>
                    <strong class="status-pill status-@Model.Status">@GetStatusText(Model.Status)</strong>
                </div>
            </div>
        </div>

    </section>

    <section class="content-grid">

        <main class="main-area">

            <div class="panel complaint-panel">
                <div class="panel-title">
                    <span class="title-icon">💬</span>
                    <h2>Müşteri Şikayeti / Servis Kabul Notu</h2>
                </div>

                <div class="note-grid">
                    <div class="note-box">
                        <label>Müşteri Şikayeti</label>
                        <p>
                            @(string.IsNullOrWhiteSpace(Model.CustomerComplaint)
                                ? "Şikayet girilmemiş."
                                : Model.CustomerComplaint)
                        </p>
                    </div>

                    <div class="note-box">
                        <label>Servis Kabul Notu</label>
                        <p>
                            @(string.IsNullOrWhiteSpace(Model.ServiceReceptionNote)
                                ? "Not girilmemiş."
                                : Model.ServiceReceptionNote)
                        </p>
                    </div>
                </div>
            </div>

            <div class="panel requests-panel">

                <div class="requests-header">
                    <div class="panel-title no-margin">
                        <span class="title-icon">🧾</span>
                        <h2>Şikayet / Talepler ve İşlemler</h2>
                    </div>

                    <button type="button" class="outline-btn" onclick="focusAddRequest()">
                        + Talep / Şikayet Ekle
                    </button>
                </div>

                @if (Model.RequestItems.Any())
                {
                    <div class="request-detail-list">
                        @foreach (var item in Model.RequestItems)
                        {
                            var itemOperations = Model.Operations
                                .Where(x => x.ServiceRequestItemId == item.Id)
                                .ToList();

                            var itemTotal = itemOperations.Sum(x => x.TotalPrice);

                            <div class="request-detail-card @(item == Model.RequestItems.First() ? "" : "collapsed")"
                                 data-request-id="@item.Id"
                                 id="request-item-@item.Id">

                                <div class="request-card-top">
                                    <button type="button"
                                            class="request-accordion-header"
                                            onclick="toggleRequestCard(this)">
                                        <div>
                                            <strong>@item.Title</strong>

                                            @if (!string.IsNullOrWhiteSpace(item.Note))
                                            {
                                                <span>@item.Note</span>
                                            }
                                        </div>

                                        <div class="request-right">
                                            @if ((item.EstimatedAmount ?? 0) > 0)
                                            {
                                                <span class="estimate-pill">
                                                    Tahmini: @((item.EstimatedAmount ?? 0).ToString("N2")) ₺
                                                </span>
                                            }

                                            <span class="accordion-arrow">⌄</span>
                                        </div>
                                    </button>

                                    <button type="button"
                                            class="request-delete-btn"
                                            onclick="deleteRequestItem(@item.Id, this)">
                                        Sil
                                    </button>
                                </div>

                                <div class="request-accordion-body">

                                    <div class="request-operation-area">
                                        <div class="request-operation-header">
                                            <strong>Yapılan İşlemler</strong>
                                            <span data-total="@itemTotal">Toplam: @itemTotal.ToString("N2") ₺</span>
                                        </div>

                                        @if (itemOperations.Any())
                                        {
                                            <div class="operation-table request-operation-list">
                                                <div class="operation-table-head">
                                                    <span>Tür</span>
                                                    <span>Açıklama</span>
                                                    <span>Miktar</span>
                                                    <span>Birim Fiyat</span>
                                                    <span>Toplam</span>
                                                    <span></span>
                                                </div>

                                                @foreach (var operation in itemOperations)
                                                {
                                                    <div class="operation-table-row request-operation-item" id="operation-item-@operation.Id">
                                                        <span>
                                                            <b class="type-badge @(operation.Type == 1 ? "part" : "labor")">
                                                                @(operation.Type == 1 ? "Parça" : "İşçilik")
                                                            </b>
                                                        </span>

                                                        <span>
                                                            <strong>@operation.Description</strong>

                                                            @if (!string.IsNullOrWhiteSpace(operation.Note))
                                                            {
                                                                <small>@operation.Note</small>
                                                            }
                                                        </span>

                                                        <span>@operation.Quantity.ToString("N2")</span>
                                                        <span>@operation.UnitPrice.ToString("N2") ₺</span>
                                                        <span><strong>@operation.TotalPrice.ToString("N2") ₺</strong></span>

                                                        <span>
                                                            <button type="button"
                                                                    class="icon-delete-btn"
                                                                    onclick="deleteOperation(@operation.Id, this)">
                                                                Sil
                                                            </button>
                                                        </span>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="mini-empty">
                                                Bu talep için henüz işlem eklenmedi.
                                            </div>
                                        }
                                    </div>

                                    <form asp-action="AddOperation"
                                          method="post"
                                          class="add-operation-form ajax-operation-form">

                                        <input type="hidden" name="ServiceRecordId" value="@Model.Id" />
                                        <input type="hidden" name="ServiceRequestItemId" value="@item.Id" />

                                        <div class="operation-form-row">

                                            <div class="type-toggle">
                                                <input type="radio"
                                                       id="partType_@item.Id"
                                                       name="Type"
                                                       value="1"
                                                       checked />

                                                <label for="partType_@item.Id">Parça</label>

                                                <input type="radio"
                                                       id="laborType_@item.Id"
                                                       name="Type"
                                                       value="2" />

                                                <label for="laborType_@item.Id">İşçilik</label>
                                            </div>

                                            <div class="form-field">
                                                <input name="Description" placeholder=" " />
                                                <label>İşçilik veya parça açıklaması</label>
                                            </div>

                                            <div class="form-field">
                                                <input name="Quantity" type="number" value="1" min="1" step="0.01" placeholder=" " />
                                                <label>Miktar</label>
                                            </div>

                                            <div class="form-field">
                                                <input name="UnitPrice" type="number" step="0.01" min="0" placeholder=" " />
                                                <label>Birim Fiyat</label>
                                            </div>

                                            <button type="submit" class="btn-primary">
                                                + Ekle
                                            </button>
                                        </div>

                                        <div class="form-field operation-note-field">
                                            <textarea name="Note" placeholder=" "></textarea>
                                            <label>İşlem Notu</label>
                                        </div>
                                    </form>

                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="request-detail-list">
                        <div class="empty-state">
                            Bu servis kaydı için talep girilmemiş.
                        </div>
                    </div>
                }
            </div>

            <div class="panel add-request-panel" id="addRequestPanel">
                <div class="panel-title">
                    <span class="title-icon">＋</span>
                    <h2>Ek Talep / İşlem Ekle</h2>
                </div>

                <form asp-action="AddRequestItem"
                      method="post"
                      class="add-request-form ajax-request-form">

                    <input type="hidden" name="serviceRecordId" value="@Model.Id" />

                    <div class="request-builder-detail">

                        <div class="form-field">
                            <input name="Title"
                                   list="detailRequestSuggestions"
                                   placeholder=" " />
                            <label>Talep / İşlem</label>

                            <datalist id="detailRequestSuggestions">
                                <option value="Genel bakım"></option>
                                <option value="Yağ değişimi"></option>
                                <option value="Fren kontrolü"></option>
                                <option value="Klima arızası"></option>
                                <option value="Rot balans kontrolü"></option>
                                <option value="Far ayarı"></option>
                            </datalist>
                        </div>

                        <div class="form-field">
                            <input name="EstimatedAmount"
                                   type="number"
                                   step="0.01"
                                   placeholder=" " />
                            <label>Tahmini Fiyat</label>
                        </div>

                        <button type="submit" class="btn-primary">
                            + Talep Ekle
                        </button>
                    </div>

                    <div class="form-field add-request-note">
                        <textarea name="Note" placeholder=" "></textarea>
                        <label>Ön Not</label>
                    </div>

                </form>
            </div>

        </main>

        <aside class="side-area">

            <div class="side-card total-card">
                <div class="side-title">
                    <span class="title-icon purple">₺</span>
                    <h3>Toplam Özet</h3>
                </div>

                <div class="total-row">
                    <span>Tahmini Toplam</span>
                    <strong>@Model.RequestItems.Sum(x => x.EstimatedAmount ?? 0).ToString("N2") ₺</strong>
                </div>

                <div class="total-row">
                    <span>Gerçek Toplam</span>
                    <strong class="summary-total" data-total="@Model.TotalAmount">
                        @Model.TotalAmount.ToString("N2") ₺
                    </strong>
                </div>
            </div>

            <div class="side-card status-card">
                <div class="side-title">
                    <span class="title-icon orange">⚑</span>
                    <h3>Durum Yönetimi</h3>
                </div>

                <div class="mini-status-current">
                    <span>Mevcut Durum</span>
                    <strong class="summary-status status-@Model.Status">
                        @GetStatusText(Model.Status)
                    </strong>
                </div>

                <div class="status-steps">
                    <div class="step @(Model.Status >= 1 && Model.Status != 4 ? "active" : "")">
                        <span>1</span>
                        <small>Açık</small>
                    </div>

                    <div class="step @(Model.Status >= 2 && Model.Status != 4 ? "active" : "")">
                        <span>2</span>
                        <small>İşlemde</small>
                    </div>

                    <div class="step @(Model.Status == 3 ? "active" : "")">
                        <span>3</span>
                        <small>Tamamlandı</small>
                    </div>

                    <div class="step @(Model.Status == 4 ? "danger active" : "")">
                        <span>4</span>
                        <small>İptal</small>
                    </div>
                </div>

                <div class="status-actions" data-record-id="@Model.Id">
                    @if (Model.Status == 1)
                    {
                        <button type="button" class="status-btn success" data-status="2">
                            İşleme Al
                        </button>

                        <button type="button" class="status-btn danger" data-status="4">
                            İptal Et
                        </button>
                    }
                    else if (Model.Status == 2)
                    {
                        <button type="button" class="status-btn primary" data-status="3">
                            Tamamla
                        </button>

                        <button type="button" class="status-btn danger" data-status="4">
                            İptal Et
                        </button>
                    }
                    else if (Model.Status == 3 || Model.Status == 4)
                    {
                        <button type="button" class="status-btn primary full" data-status="1">
                            Tekrar Aç
                        </button>
                    }
                </div>
            </div>

            <div class="side-card action-card">
                <div>
                    <strong>Final Servis PDF</strong>
                    <span>Bu servis kaydı için final PDF oluşturun.</span>
                </div>

                <a href="/service-pdf/create/@Model.Id"
                       class="small-action-btn"
                       target="_blank">
                    PDF Oluştur
                </a>
            </div>

            <div class="side-card action-card">
                <div>
                    <strong>QR Eşleştirme</strong>
                    <span>Müşteri QR kodunu tarayarak araçla eşleştirin.</span>
                </div>

                <button type="button"
                        class="small-action-btn"
                        id="start-qr-scan-btn"
                        onclick="startQrScanner(@Model.VehicleId, this)">
                    QR Tara
                </button>

                <div id="qr-reader" style="display:none;"></div>
                <div id="qr-scan-result" class="qr-scan-result"></div>
            </div>

            <div class="qr-note">
                💡 QR eşleştirme işlemi müşteriye araç teslimi sırasında yapılmalıdır.
            </div>

        </aside>

    </section>

    <div class="page-footer">
        🛡 Kayıt ve işlemler sistem tarafından güvenli şekilde kaydedilmektedir.
    </div>

</div>

<div id="toastMessage" class="toast-message"></div>

<style>
    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        background: radial-gradient(circle at top left, rgba(37, 99, 235, .10), transparent 30rem), radial-gradient(circle at top right, rgba(22, 163, 74, .08), transparent 28rem), #f4f7fb;
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: #0f172a;
    }

    .page {
        width: min(1540px, calc(100% - 48px));
        margin: 0 auto;
        padding: 26px 0 42px;
    }

    .premium-header {
        min-height: 116px;
        padding: 28px;
        border-radius: 28px;
        background: linear-gradient(135deg, #07111f 0%, #111827 42%, #1d4ed8 100%);
        color: white;
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        align-items: center;
        gap: 22px;
        box-shadow: 0 28px 80px rgba(15, 23, 42, .22);
    }

    .header-back,
    .header-more {
        width: 54px;
        height: 54px;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,.14);
        background: rgba(255,255,255,.11);
        color: white;
        display: grid;
        place-items: center;
        text-decoration: none;
        font-size: 28px;
        font-weight: 900;
    }

    .header-more {
        cursor: pointer;
        font-size: 22px;
    }

    .header-badge {
        display: inline-flex;
        margin-bottom: 7px;
        padding: 6px 11px;
        border-radius: 999px;
        background: rgba(255,255,255,.13);
        border: 1px solid rgba(255,255,255,.18);
        color: rgba(255,255,255,.82);
        font-size: 12px;
        font-weight: 900;
        letter-spacing: .4px;
    }

    .premium-header h1 {
        margin: 0;
        font-size: 32px;
        line-height: 1.05;
        letter-spacing: -1px;
    }

    .header-meta {
        margin-top: 10px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        color: rgba(255,255,255,.82);
        font-size: 14px;
        font-weight: 700;
    }

    .top-grid {
        margin-top: 20px;
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(420px, .9fr);
        gap: 18px;
    }

    .content-grid {
        margin-top: 18px;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 470px;
        gap: 18px;
        align-items: start;
    }

    .main-area,
    .side-area {
        display: grid;
        gap: 18px;
    }

    .side-area {
        position: sticky;
        top: 18px;
    }

    .panel,
    .side-card {
        border-radius: 24px;
        background: rgba(255,255,255,.94);
        border: 1px solid #e2e8f0;
        box-shadow: 0 20px 50px rgba(15, 23, 42, .07);
    }

    .panel {
        padding: 24px;
    }

    .side-card {
        padding: 20px;
    }

    .panel-title,
    .side-title {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 18px;
    }

        .panel-title.no-margin {
            margin-bottom: 0;
        }

        .panel-title h2,
        .side-title h3 {
            margin: 0;
            font-size: 18px;
            font-weight: 950;
            letter-spacing: -.3px;
        }

    .title-icon,
    .info-icon {
        width: 34px;
        height: 34px;
        border-radius: 12px;
        display: grid;
        place-items: center;
        background: #eef4ff;
        color: #1d4ed8;
        box-shadow: 0 8px 18px rgba(37, 99, 235, .10);
        flex-shrink: 0;
        font-weight: 950;
    }

        .title-icon.purple {
            background: #f3e8ff;
            color: #7e22ce;
        }

        .title-icon.orange {
            background: #fff7ed;
            color: #ea580c;
        }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
    }

    .info-card {
        min-height: 76px;
        padding: 15px;
        border-radius: 18px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .info-card label,
        .note-box label {
            display: block;
            margin-bottom: 5px;
            color: #64748b;
            font-size: 12px;
            font-weight: 900;
        }

        .info-card strong {
            display: block;
            color: #0f172a;
            font-size: 14px;
            font-weight: 950;
            word-break: break-word;
        }

    .service-info-list {
        display: grid;
        gap: 14px;
    }

        .service-info-list > div,
        .total-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 18px;
        }

            .service-info-list span,
            .total-row span {
                color: #64748b;
                font-size: 13px;
                font-weight: 850;
            }

            .service-info-list strong,
            .total-row strong {
                color: #0f172a;
                font-size: 13px;
                font-weight: 950;
                text-align: right;
            }

    .status-pill,
    .summary-status {
        display: inline-flex;
        justify-content: center;
        align-items: center;
        padding: 7px 12px;
        border-radius: 999px;
        font-size: 12px !important;
        font-weight: 950 !important;
    }

    .status-1 {
        background: #dcfce7;
        color: #15803d !important;
    }

    .status-2 {
        background: #fef3c7;
        color: #b45309 !important;
    }

    .status-3 {
        background: #dbeafe;
        color: #1d4ed8 !important;
    }

    .status-4 {
        background: #fee2e2;
        color: #b91c1c !important;
    }

    .note-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    .note-box {
        padding: 16px;
        border-radius: 18px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
    }

        .note-box p {
            margin: 0;
            color: #0f172a;
            font-size: 14px;
            line-height: 1.6;
            font-weight: 650;
        }

    .requests-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        margin-bottom: 18px;
    }

    .outline-btn {
        height: 42px;
        padding: 0 16px;
        border-radius: 12px;
        border: 1px solid #93c5fd;
        background: white;
        color: #1d4ed8;
        font-weight: 950;
        cursor: pointer;
    }

    .request-detail-list {
        display: grid;
        gap: 12px;
    }

    .request-detail-card {
        border-radius: 18px;
        background: #f8fbff;
        border: 1px solid #bfdbfe;
        overflow: hidden;
    }

    .request-card-top {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: stretch;
    }

    .request-accordion-header {
        border: none;
        width: 100%;
        background: transparent;
        cursor: pointer;
        padding: 16px 18px;
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: center;
        text-align: left;
    }

        .request-accordion-header strong {
            display: block;
            font-size: 15px;
            font-weight: 950;
