                    font-weight: 900;
                    color: #0f172a;
                }

                .request-operation-header span {
                    font-size: 13px;
                    font-weight: 900;
                    color: #16a34a;
                }

            .request-operation-list {
                display: grid;
                gap: 10px;
            }

            .request-operation-item {
                display: flex;
                justify-content: space-between;
                gap: 16px;
                padding: 13px 14px;
                border-radius: 15px;
                background: #f8fafc;
