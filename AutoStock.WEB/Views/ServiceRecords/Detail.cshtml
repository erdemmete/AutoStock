@model AutoStock.WEB.Models.ServiceRecords.ServiceRecordDetailViewModel

@{
    ViewData["Title"] = "Servis Detayı";

    string GetStatusText(int status)
    {
        return status switch
        {
            1 => "Aktif",
            2 => "Aktif",
            3 => "Tamamlandı",
            4 => "İptal",
            _ => "Bilinmiyor"
        };
    }

    string GetStatusClass(int status)
    {
        return status switch
        {
            1 => "active",
            2 => "active",
            3 => "completed",
            4 => "cancelled",
            _ => "unknown"
        };
    }

    string GetInvoiceStatusText(int status)
    {
        return status switch
        {
            1 => "Taslak",
            2 => "Kesildi",
            3 => "İptal",
            _ => "Bilinmiyor"
        };
    }

    string FormatMoney(decimal value)
    {
        return value.ToString("N2") + " ₺";
    }

    var estimatedTotal = Model.RequestItems.Sum(x => x.EstimatedAmount ?? 0);
    var subTotal = Model.TotalAmount;
    var vatTotal = subTotal * 0.20m;
    var grandTotal = subTotal + vatTotal;
}

<div class="srx-page">

    <div id="toastMessage" class="srx-toast"></div>

    <header class="srx-page-header">

        <a href="/ServiceRecords"
           class="srx-back-btn"
           title="Servis kayıtlarına dön">
            ←
        </a>

        <div class="srx-header-main">
            <div class="srx-header-title-row">
                <h1>Kayıt @Model.RecordNumber</h1>

                <span class="srx-status-badge @GetStatusClass(Model.Status)">
                    @GetStatusText(Model.Status)
                </span>
            </div>

            <p>
                @Model.CreatedAt.AddHours(3).ToString("dd MMMM yyyy") tarihinde açıldı.
            </p>
        </div>

        <a asp-controller="Dashboard"
           asp-action="Index"
           class="srx-home-btn"
           title="Ana sayfa">
            ⌂
        </a>

    </header>

    <section class="srx-info-card collapsed">

        <button type="button"
                class="srx-info-summary"
                data-action="toggle-info">

            <div class="srx-info-summary-left">
                <span class="srx-info-icon">♙</span>

                <strong>@Model.CustomerName</strong>

                <span class="srx-dot">•</span>

                <span class="srx-plate">@Model.VehiclePlate</span>

                <span>@Model.VehicleBrandName @Model.VehicleModelName</span>
            </div>

            <div class="srx-info-summary-right">
                <span>Müşteri ve Araç Detayları</span>
                <span class="srx-chevron">⌃</span>
            </div>

        </button>

        <div class="srx-info-body">

            <div class="srx-info-column">
                <h3>Müşteri Bilgileri</h3>

                <div class="srx-info-grid">
                    <span>Ad Soyad</span>
                    <strong>@Model.CustomerName</strong>

                    <span>Telefon</span>
                    <strong>@Model.CustomerPhone</strong>

                    @if (!string.IsNullOrWhiteSpace(Model.CustomerEmail))
                    {
                        <span>E-posta</span>
                        <strong>@Model.CustomerEmail</strong>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.CompanyName))
                    {
                        <span>Firma</span>
                        <strong>@Model.CompanyName</strong>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.AuthorizedPersonName))
                    {
                        <span>Yetkili</span>
                        <strong>@Model.AuthorizedPersonName</strong>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.TaxOffice))
                    {
                        <span>Vergi Dairesi</span>
                        <strong>@Model.TaxOffice</strong>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.TaxNumber))
                    {
                        <span>Vergi No</span>
                        <strong>@Model.TaxNumber</strong>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.NationalIdentityNumber))
                    {
                        <span>TC Kimlik No</span>
                        <strong>@Model.NationalIdentityNumber</strong>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.CustomerAddress)
                        || !string.IsNullOrWhiteSpace(Model.AddressDistrict)
                        || !string.IsNullOrWhiteSpace(Model.AddressCity))
                    {
                        <span>Adres</span>
                        <strong>
                            @Model.CustomerAddress
                            @if (!string.IsNullOrWhiteSpace(Model.AddressDistrict)
                                || !string.IsNullOrWhiteSpace(Model.AddressCity))
                            {
                                <small>
                                    @Model.AddressDistrict / @Model.AddressCity
                                </small>
                            }
                        </strong>
                    }
                </div>
            </div>

            <div class="srx-info-column">
                <h3>Araç Bilgileri</h3>

                <div class="srx-info-grid">
                    <span>Marka/Model</span>
                    <strong>@Model.VehicleBrandName @Model.VehicleModelName</strong>

                    <span>Plaka</span>
                    <strong>@Model.VehiclePlate</strong>

                    <span>Kilometre</span>
                    <strong>@((Model.Mileage ?? 0).ToString("N0")) km</strong>

                    @if (!string.IsNullOrWhiteSpace(Model.ChassisNumber))
                    {
                        <span>Şasi No</span>
                        <strong>@Model.ChassisNumber</strong>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.VehicleDeliveredBy))
                    {
                        <span>Aracı Getiren</span>
                        <strong>@Model.VehicleDeliveredBy</strong>
                    }
                </div>
            </div>

        </div>

        @if (!string.IsNullOrWhiteSpace(Model.CustomerComplaint)
            || !string.IsNullOrWhiteSpace(Model.ServiceReceptionNote))
        {
            <div class="srx-note-strip">
                @if (!string.IsNullOrWhiteSpace(Model.CustomerComplaint))
                {
                    <div>
                        <span>Müşteri Şikayeti</span>
                        <p>@Model.CustomerComplaint</p>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.ServiceReceptionNote))
                {
                    <div>
                        <span>Servis Kabul Notu</span>
                        <p>@Model.ServiceReceptionNote</p>
                    </div>
                }
            </div>
        }

    </section>

    <section class="srx-workspace">

        <main class="srx-work-main">

            <div class="srx-request-list" id="requestList">

                @if (Model.RequestItems.Any())
                {
                    @foreach (var request in Model.RequestItems)
                    {
                        var requestOperations = Model.Operations
                            .Where(x => x.ServiceRequestItemId == request.Id)
                            .OrderBy(x => x.Id)
                            .ToList();

                        var requestTotal = requestOperations.Sum(x => x.TotalPrice);

                        <article class="srx-request-card"
                                 id="request-item-@request.Id"
                                 data-request-id="@request.Id"
                                 data-expanded="false">

                            <header class="srx-request-header">

                                <button type="button"
                                        class="srx-request-title-btn"
                                        data-action="toggle-request">

                                    <span class="srx-request-alert">!</span>

                                    <div>
                                        <h2>@request.Title</h2>

                                        @if (!string.IsNullOrWhiteSpace(request.Note))
                                        {
                                            <p>@request.Note</p>
                                        }
                                    </div>

                                </button>

                                <div class="srx-request-header-actions">

                                    @if ((request.EstimatedAmount ?? 0) > 0)
                                    {
                                        <span class="srx-estimate-pill">
                                            Tahmini: @FormatMoney(request.EstimatedAmount ?? 0)
                                        </span>
                                    }

                                    <button type="button"
                                            class="srx-icon-btn"
                                            data-action="delete-request"
                                            data-request-id="@request.Id"
                                            title="Talebi sil">
                                        🗑
                                    </button>

                                </div>

                            </header>

                            <div class="srx-request-body">

                                <div class="srx-operation-grid"
                                     data-operation-list
                                     data-request-id="@request.Id">

                                    <div class="srx-operation-head">
                                        <span>Tür</span>
                                        <span>Açıklama</span>
                                        <span>Miktar</span>
                                        <span>Br. Fiyat</span>
                                        <span>Toplam</span>
                                        <span></span>
                                    </div>

                                    @if (requestOperations.Any())
                                    {
                                        @foreach (var operation in requestOperations)
                                        {
                                            var typeClass = operation.Type == 1 ? "part" : "labor";
                                            var typeText = operation.Type == 1 ? "Parça" : "İşçilik";

                                            <div class="srx-operation-row request-operation-item"
                                                 id="operation-item-@operation.Id"
                                                 data-operation-id="@operation.Id">

                                                <div>
                                                    <span class="srx-type-badge @typeClass">
                                                        @typeText
                                                    </span>
                                                </div>

                                                <div class="srx-operation-description">
                                                    <strong>@operation.Description</strong>

                                                    @if (!string.IsNullOrWhiteSpace(operation.Note))
                                                    {
                                                        <small>@operation.Note</small>
                                                    }
                                                </div>

                                                <div>@operation.Quantity.ToString("N2")</div>

                                                <div>@FormatMoney(operation.UnitPrice)</div>

                                                <div>
                                                    <strong>@FormatMoney(operation.TotalPrice)</strong>
                                                </div>

                                                <div class="srx-operation-actions">
                                                    <button type="button"
                                                            class="srx-row-delete"
                                                            data-action="delete-operation"
                                                            data-operation-id="@operation.Id"
                                                            title="İşlemi sil">
                                                        Sil
                                                    </button>
                                                </div>

                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="srx-operation-empty">
                                            Bu şikayet için henüz işlem eklenmedi.
                                        </div>
                                    }

                                </div>

                                <button type="button"
                                        class="srx-add-operation-trigger"
                                        data-action="show-operation-form">
                                    + Şikayete işlem ekle
                                </button>

                                <form asp-action="AddOperation"
                                      method="post"
                                      class="srx-operation-form ajax-operation-form"
                                      data-request-id="@request.Id"
                                      hidden>

                                    <input type="hidden"
                                           name="ServiceRecordId"
                                           value="@Model.Id" />

                                    <input type="hidden"
                                           name="ServiceRequestItemId"
                                           value="@request.Id" />

                                    <input type="hidden"
                                           name="StockItemId"
                                           class="srx-stock-item-id" />

                                    <div class="srx-operation-editor">

                                        <div class="srx-type-switch">

                                            <input type="radio"
                                                   id="partType_@request.Id"
                                                   name="Type"
                                                   value="1"
                                                   checked />

                                            <label for="partType_@request.Id">
                                                Parça
                                            </label>

                                            <input type="radio"
                                                   id="laborType_@request.Id"
                                                   name="Type"
                                                   value="2" />

                                            <label for="laborType_@request.Id">
                                                İşçilik
                                            </label>

                                        </div>

                                        <div class="srx-search-box">

                                            <input type="text"
                                                   name="Description"
                                                   class="srx-operation-search-input"
                                                   placeholder="Parça adı, kodu veya işlem açıklaması..."
                                                   autocomplete="off" />

                                            <div class="srx-search-results"></div>

                                        </div>

                                        <input type="number"
                                               name="Quantity"
                                               class="srx-qty-input"
                                               value="1"
                                               min="1"
                                               step="0.01"
                                               placeholder="Miktar" />

                                        <div class="srx-money-input">
                                            <input type="text"
                                                   name="UnitPrice"
                                                   class="srx-price-input"
                                                   inputmode="decimal"
                                                   autocomplete="off"
                                                   placeholder="Fiyat" />

                                            <span>₺</span>
                                        </div>

                                        <button type="submit"
                                                class="srx-add-row-btn">
                                            Ekle
                                        </button>

                                    </div>

                                    <input type="text"
                                           name="Note"
                                           class="srx-operation-note"
                                           placeholder="İşlem notu opsiyonel" />

                                </form>

                            </div>

                        </article>
                    }
                }
                else
                {
                    <div class="srx-empty-requests">
                        Bu servis kaydı için henüz şikayet / talep girilmemiş.
                    </div>
                }

            </div>

            <section class="srx-new-request-card" id="newRequestCard">

                <button type="button"
                        class="srx-new-request-trigger"
                        data-action="toggle-new-request">
                    + Yeni Şikayet Ekle
                </button>

                <form asp-action="AddRequestItem"
                      method="post"
                      class="srx-new-request-form ajax-request-form"
                      hidden>

                    <input type="hidden"
                           name="serviceRecordId"
                           value="@Model.Id" />

                    <input type="text"
                           name="Title"
                           list="requestSuggestions"
                           placeholder="Şikayet / talep başlığı" />

                    <input type="number"
                           name="EstimatedAmount"
                           min="0"
                           step="0.01"
                           placeholder="Tahmini fiyat" />

                    <input type="text"
                           name="Note"
                           placeholder="Ön not opsiyonel" />

                    <button type="submit">
                        Kaydet
                    </button>

                    <button type="button"
                            data-action="cancel-new-request">
                        Vazgeç
                    </button>

                    <datalist id="requestSuggestions">
                        <option value="Genel bakım"></option>
                        <option value="Yağ değişimi"></option>
                        <option value="Fren kontrolü"></option>
                        <option value="Klima arızası"></option>
                        <option value="Rot balans kontrolü"></option>
                        <option value="Far ayarı"></option>
                    </datalist>

                </form>

            </section>

        </main>

        <aside class="srx-side-panel">

            <section class="srx-summary-card">

                <h2>Servis Özeti</h2>

                <div class="srx-estimate-box">
                    <span>Tahmini Fiyat Verildi</span>
                    <strong>@FormatMoney(estimatedTotal)</strong>
                </div>

                <div class="srx-summary-lines">

                    <div>
                        <span>Ara Toplam</span>
                        <strong class="summary-total"
                                data-total="@subTotal">
                            @FormatMoney(subTotal)
                        </strong>
                    </div>

                    <div>
                        <span>KDV (%20)</span>
                        <strong class="summary-vat"
                                data-vat="@vatTotal">
                            @FormatMoney(vatTotal)
                        </strong>
                    </div>

                </div>

                <div class="srx-grand-total">
                    <span>Genel Toplam</span>
                    <strong class="summary-grand-total"
                            data-grand-total="@grandTotal">
                        @FormatMoney(grandTotal)
                    </strong>
                </div>

                @if (Model.ActiveInvoiceId.HasValue)
                {
                    <a href="/Invoices/Detail/@Model.ActiveInvoiceId"
                       class="srx-primary-action">
                        @(Model.ActiveInvoiceStatus == 1 ? "Taslak Faturaya Git" : "Faturaya Git")
                    </a>
                }
                else
                {
                    <a href="/Invoices/CreateFromServiceRecord/@Model.Id"
                       class="srx-primary-action">
                        Fatura Taslağına Geç
                    </a>
                }

                <div class="srx-action-grid">

                    <a href="/service-pdf/create/@Model.Id"
                       target="_blank"
                       class="srx-secondary-action">
                        PDF Oluştur
                    </a>

                    <button type="button"
                            class="srx-secondary-action"
                            id="start-qr-scan-btn"
                            onclick="startQrScanner(@Model.VehicleId, this)">
                        QR Tara
                    </button>

                    @if (Model.Status == 1 || Model.Status == 2)
                    {
                        <button type="button"
                                class="srx-secondary-action success status-btn"
                                data-status="3">
                            Servisi Tamamla
                        </button>

                        <button type="button"
                                class="srx-secondary-action danger status-btn"
                                data-status="4">
                            İptal Et
                        </button>
                    }
                    else if (Model.Status == 3 || Model.Status == 4)
                    {
                        <button type="button"
                                class="srx-secondary-action status-btn wide"
                                data-status="1">
                            Tekrar Aktif Yap
                        </button>
                    }

                </div>

                <div id="qr-reader" class="srx-qr-reader" hidden></div>
                <div id="qr-scan-result" class="srx-qr-result"></div>

            </section>

        </aside>

    </section>

</div>

<style>
    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        background: #f4f7fb;
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: #0f172a;
    }

    button,
    input,
    textarea {
        font: inherit;
    }

    button {
        cursor: pointer;
    }

    a {
        color: inherit;
    }

    .srx-page {
        width: min(1360px, calc(100% - 48px));
        margin: 0 auto;
        padding: 30px 0 54px;
    }

    .srx-page-header {
        display: grid;
        grid-template-columns: 42px minmax(0, 1fr) 42px;
        gap: 16px;
        align-items: start;
        margin-bottom: 24px;
    }

    .srx-back-btn,
    .srx-home-btn {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        text-decoration: none;
        color: #64748b;
        background: transparent;
        border: 1px solid transparent;
        font-size: 22px;
        transition: .18s ease;
    }

        .srx-back-btn:hover,
        .srx-home-btn:hover {
            background: white;
            border-color: #e2e8f0;
            color: #2563eb;
        }

    .srx-header-main {
        min-width: 0;
    }

    .srx-header-title-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px;
    }

        .srx-header-title-row h1 {
            margin: 0;
            color: #0f172a;
            font-size: 25px;
            line-height: 1.1;
            letter-spacing: -.7px;
            font-weight: 950;
        }

    .srx-header-main p {
        margin: 7px 0 0;
        color: #64748b;
        font-size: 14px;
        font-weight: 650;
    }

    .srx-status-badge {
        display: inline-flex;
        align-items: center;
        min-height: 24px;
        padding: 4px 11px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 900;
    }

        .srx-status-badge.active {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .srx-status-badge.completed {
            background: #dcfce7;
            color: #15803d;
        }

        .srx-status-badge.cancelled {
            background: #fee2e2;
            color: #b91c1c;
        }

    .srx-secondary-action.success:hover {
        border-color: #bbf7d0;
        color: #15803d;
    }

    .srx-info-card {
        margin-bottom: 24px;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        background: white;
        box-shadow: 0 10px 28px rgba(15, 23, 42, .05);
        overflow: hidden;
    }

    .srx-info-summary {
        width: 100%;
        min-height: 54px;
        padding: 0 24px;
        border: none;
        background: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 18px;
        color: #0f172a;
    }

    .srx-info-summary-left {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
        color: #334155;
        font-size: 14px;
        font-weight: 750;
    }

    .srx-info-icon {
        color: #94a3b8;
        font-size: 18px;
        flex-shrink: 0;
    }

    .srx-dot {
        color: #cbd5e1;
        font-weight: 950;
    }

    .srx-plate {
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        border-radius: 7px;
        background: #e2e8f0;
        color: #0f172a;
        font-weight: 950;
        letter-spacing: .3px;
    }

    .srx-info-summary-right {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #4f46e5;
        font-size: 13px;
        font-weight: 850;
        white-space: nowrap;
    }

    .srx-chevron {
        font-size: 17px;
        transition: .18s ease;
    }

    .srx-info-card.collapsed .srx-info-body,
    .srx-info-card.collapsed .srx-note-strip {
        display: none;
    }

    .srx-info-card.collapsed .srx-chevron {
        transform: rotate(180deg);
    }

    .srx-info-body {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 56px;
        padding: 22px 24px 26px;
        border-top: 1px solid #eef2f7;
    }

    .srx-info-column h3 {
        margin: 0 0 14px;
        color: #94a3b8;
        font-size: 12px;
        font-weight: 950;
        text-transform: uppercase;
        letter-spacing: .8px;
    }

    .srx-info-grid {
        display: grid;
        grid-template-columns: 180px minmax(0, 1fr);
        row-gap: 14px;
        column-gap: 28px;
        align-items: start;
    }

        .srx-info-grid span {
            color: #64748b;
            font-size: 13px;
            font-weight: 750;
        }

        .srx-info-grid strong {
            color: #0f172a;
            font-size: 14px;
            font-weight: 900;
            word-break: break-word;
        }

        .srx-info-grid small {
            display: block;
            margin-top: 4px;
            color: #64748b;
            font-size: 12px;
            font-weight: 700;
        }

    .srx-note-strip {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        padding: 0 24px 24px;
    }

        .srx-note-strip div {
            padding: 14px 16px;
            border-radius: 14px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
        }

        .srx-note-strip span {
            display: block;
            margin-bottom: 6px;
            color: #64748b;
            font-size: 12px;
            font-weight: 900;
        }

        .srx-note-strip p {
            margin: 0;
            color: #0f172a;
            font-size: 13px;
            line-height: 1.55;
            font-weight: 650;
        }

    .srx-workspace {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 430px;
        gap: 22px;
        align-items: start;
    }

    .srx-work-main {
        display: grid;
        gap: 18px;
        min-width: 0;
    }

    .srx-request-list {
        display: grid;
        gap: 18px;
    }

    .srx-request-card {
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        background: white;
        box-shadow: 0 10px 28px rgba(15, 23, 42, .045);
        overflow: hidden;
    }

    .srx-request-header {
        min-height: 56px;
        padding: 0 18px 0 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        border-bottom: 1px solid #eef2f7;
    }

    .srx-request-title-btn {
        min-width: 0;
        border: none;
        background: transparent;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0;
        text-align: left;
        color: #0f172a;
    }

    .srx-request-alert {
        width: 15px;
        height: 15px;
        border-radius: 999px;
        border: 1.8px solid #fb3d5d;
        color: #fb3d5d;
        display: inline-grid;
