                    grid-template-columns: 1fr;
                }
            }

            .type-toggle {
                display: grid;
                grid-template-columns: 1fr 1fr;
                border-radius: 16px;
                overflow: hidden;
                border: 1px solid #dbe3ef;
                min-height: 54px;
                background: white;
            }

                .type-toggle input {
                    display: none;
                }

                .type-toggle label {
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    cursor: pointer;
                    font-size: 14px;
                    font-weight: 800;
                    color: #64748b;
                    transition: .2s ease;
                    background: white;
                }

                .type-toggle input:checked + label {
                    background: linear-gradient(135deg, #2563eb, #1d4ed8);
