@model AutoStock.WEB.Models.ServiceRecords.ServiceRecordDetailViewModel

@{
    ViewData["Title"] = "Servis Detayı";
}

<link rel="stylesheet" href="~/css/service-record-detail.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/service-record-detail-clean.css" asp-append-version="true" />

<div class="srx-page srx-clean-detail">

    <div id="toastMessage" class="srx-toast"></div>

    @await Html.PartialAsync("~/Views/ServiceRecords/Partials/Detail/_DetailHeader.cshtml", Model)

    @await Html.PartialAsync("~/Views/ServiceRecords/Partials/Detail/_CustomerVehicleInfo.cshtml", Model)

    <section class="srx-workspace">

        <main class="srx-work-main">

            @await Html.PartialAsync("~/Views/ServiceRecords/Partials/Detail/_RequestList.cshtml", Model)

            @await Html.PartialAsync("~/Views/ServiceRecords/Partials/Detail/_NewRequestForm.cshtml", Model)

            @await Html.PartialAsync("~/Views/ServiceRecords/Partials/Detail/_DeletedRequests.cshtml", Model)

        </main>

        @await Html.PartialAsync("~/Views/ServiceRecords/Partials/Detail/_SummaryPanel.cshtml", Model)

    </section>

</div>

@await Html.PartialAsync("~/Views/ServiceRecords/Partials/Detail/_PhotoModal.cshtml", Model)

<script src="https://unpkg.com/html5-qrcode"></script>

<script>
    window.serviceRecordDetailConfig = {
        serviceRecordId: @Model.Id,
        vehicleId: @Model.VehicleId,
        photoUploadUrl: "/ServiceRecords/@Model.Id/Photos",
        photoContentBaseUrl: "/ServiceRecords/Photos",
        photoDeleteBaseUrl: "/ServiceRecords/Photos"
    };
</script>

<script src="~/js/service-record-detail.js" asp-append-version="true"></script>
<script src="~/js/service-record-detail-clean.js" asp-append-version="true"></script>
