    <script>
            function toggleRequestCard(button) {
                const card = button.closest(".request-detail-card");
                card.classList.toggle("collapsed");
            }

            function formatMoney(value) {
                return Number(value || 0).toLocaleString("tr-TR", {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                }) + " ₺";
            }

            function setButtonLoading(button, isLoading, loadingText) {
                if (!button) return;

                if (isLoading) {
                    button.dataset.originalText = button.textContent;
                    button.disabled = true;
                    button.textContent = loadingText;
                    return;
                }

                button.disabled = false;
                button.textContent = button.dataset.originalText || button.textContent;
            }

            function updateSummaryTotal(value) {
                const summaryTotal = document.querySelector(".summary-total");

                if (!summaryTotal) return;

                summaryTotal.dataset.total = value;
                summaryTotal.textContent = formatMoney(value);
            }

                        async function assignQrCode(vehicleId, button) {
                const input = document.getElementById("qr-code-input");
                const code = input?.value?.trim();

                if (!code) {
                    alert("QR kod giriniz.");
                    return;
                }

                button.disabled = true;
                button.textContent = "Atanıyor...";

                const formData = new FormData();
                formData.append("vehicleId", vehicleId);
                formData.append("code", code);

                const response = await fetch("/ServiceRecords/AssignQrCode", {
                    method: "POST",
                    body: formData
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    alert(errorText || "QR atanırken hata oluştu.");

                    button.disabled = false;
                    button.textContent = "QR Ata";
                    return;
                }

                alert("QR kod araca başarıyla atandı.");

                button.textContent = "Atandı";
                input.disabled = true;
            }

            function bindOperationForms() {
                document.querySelectorAll(".ajax-operation-form").forEach(form => {
                    if (form.dataset.bound === "true") return;

                    form.dataset.bound = "true";

                    form.addEventListener("submit", async function (e) {
                        e.preventDefault();

                        if (form.dataset.submitting === "true") {
                            return;
                        }

                        form.dataset.submitting = "true";

                        const submitButton = form.querySelector('button[type="submit"]');
                        setButtonLoading(submitButton, true, "Ekleniyor...");

                        try {
                            const formData = new FormData(form);

                            const response = await fetch(form.action, {
                                method: "POST",
                                body: formData
                            });

                            if (!response.ok) {
                                alert("İşlem eklenemedi.");
                                return;
                            }

                            const operation = await response.json();

                            const card = form.closest(".request-detail-card");
                            const empty = card.querySelector(".mini-empty");
                            const totalText = card.querySelector(".request-operation-header span");

                            if (empty) {
                                empty.remove();
                            }

                            let operationList = card.querySelector(".request-operation-list");

                            if (!operationList) {
                                const area = card.querySelector(".request-operation-area");

                                operationList = document.createElement("div");
                                operationList.className = "request-operation-list";

                                area.appendChild(operationList);
                            }

                            const item = document.createElement("div");
                            item.className = "request-operation-item";
                            item.id = `operation-item-${operation.id}`;

                            const typeText = operation.type == 1 ? "Parça" : "İşçilik";

                            item.innerHTML = `
                                <div>
                                    <strong>${operation.description}</strong>
                                    <span>${typeText}</span>
                                </div>

                                <div>
                                    <strong>${formatMoney(operation.totalPrice)}</strong>
                                    <span>${operation.quantity} adet × ${formatMoney(operation.unitPrice)}</span>
                                </div>

                                <button type="button"
                                        class="operation-delete-btn"
                                        onclick="deleteOperation(${operation.id}, this)">
                                    Sil
                                </button>
                            `;

                            operationList.appendChild(item);

                            const currentTotal = Number(totalText.dataset.total || "0");
                            const newTotal = currentTotal + Number(operation.totalPrice || 0);

                            totalText.dataset.total = newTotal;
                            totalText.textContent = `Toplam: ${formatMoney(newTotal)}`;

                            const summaryTotal = document.querySelector(".summary-total");

                            if (summaryTotal) {
                                const currentSummaryTotal = Number(summaryTotal.dataset.total || "0");
                                const newSummaryTotal = currentSummaryTotal + Number(operation.totalPrice || 0);

                                updateSummaryTotal(newSummaryTotal);
                            }

                            form.reset();

                            const quantityInput = form.querySelector('input[name="Quantity"]');

                            if (quantityInput) {
                                quantityInput.value = 1;
                            }
                        }
                        finally {
                            form.dataset.submitting = "false";
                            setButtonLoading(submitButton, false);
                        }
                    });
                });
            }

            document.addEventListener("submit", async function (e) {
                const form = e.target;

                if (!form.classList.contains("ajax-request-form")) {
                    return;
                }

                e.preventDefault();

                if (form.dataset.submitting === "true") {
                    return;
                }

                form.dataset.submitting = "true";

                const submitButton = form.querySelector('button[type="submit"]');
                setButtonLoading(submitButton, true, "Ekleniyor...");

                try {
                    const formData = new FormData(form);

                    const response = await fetch(form.action, {
                        method: "POST",
                        body: formData
                    });

                    if (!response.ok) {
                        alert("Talep eklenemedi.");
                        return;
                    }

                    const requestItem = await response.json();

                    let list = document.querySelector(".request-detail-list");

                    const emptyState = document.querySelector(".empty-state");

                    if (!list) {
                        const panel = form.closest(".panel").previousElementSibling;

                        list = document.createElement("div");
                        list.className = "request-detail-list";

                        if (emptyState) {
                            emptyState.replaceWith(list);
                        }
                    }

                    const card = document.createElement("div");
                    card.className = "request-detail-card collapsed";
                    card.dataset.requestId = requestItem.id;
                    card.id = `request-item-${requestItem.id}`;

                    const estimatedText = requestItem.estimatedAmount
                        ? `Tahmini: ${formatMoney(requestItem.estimatedAmount)}`
                        : "";

                    card.innerHTML = `
                        <div class="request-card-top">
                            <button type="button"
                                    class="request-accordion-header"
                                    onclick="toggleRequestCard(this)">
                                <strong>${requestItem.title}</strong>
                                <span class="accordion-arrow">›</span>
                            </button>

                            <button type="button"
                                    class="request-delete-btn"
                                    onclick="deleteRequestItem(${requestItem.id}, this)">
                                Sil
                            </button>
                        </div>

                        <div class="request-accordion-body">
                            <div class="request-info-line">
                                ${requestItem.note ? `<span>${requestItem.note}</span>` : ""}
                                ${estimatedText ? `<strong>${estimatedText}</strong>` : ""}
                            </div>

                            <div class="request-operation-area">
                                <div class="request-operation-header">
                                    <strong>Yapılan İşlemler</strong>
                                    <span data-total="0">Toplam: 0,00 ₺</span>
                                </div>

                                <div class="mini-empty">
                                    Bu talep için henüz işlem eklenmedi.
                                </div>
                            </div>

                            <form action="/ServiceRecords/AddOperation"
                                  method="post"
                                  class="add-operation-form ajax-operation-form">

                                <input type="hidden" name="ServiceRecordId" value="${formData.get("serviceRecordId")}" />
                                <input type="hidden" name="ServiceRequestItemId" value="${requestItem.id}" />

                                <div class="operation-form-row">
                                    <div class="type-toggle">
                                        <input type="radio" id="partType_${requestItem.id}" name="Type" value="1" checked />
                                        <label for="partType_${requestItem.id}">Parça</label>

                                        <input type="radio" id="laborType_${requestItem.id}" name="Type" value="2" />
                                        <label for="laborType_${requestItem.id}">İşçilik</label>
                                    </div>

                                    <div class="form-field">
                                        <input name="Description" placeholder=" " />
                                        <label>İşlem Açıklaması</label>
                                    </div>

                                    <div class="form-field">
                                        <input name="Quantity" type="number" value="1" min="1" placeholder=" " />
                                        <label>Adet</label>
                                    </div>

                                    <div class="form-field">
                                        <input name="UnitPrice" type="number" step="0.01" min="0" placeholder=" " />
                                        <label>Birim Fiyat</label>
                                    </div>

                                    <button type="submit" class="btn-primary">
                                        + İşlem
                                    </button>
                                </div>

                                <div class="form-field operation-note-field">
                                    <textarea name="Note" placeholder=" "></textarea>
                                    <label>İşlem Notu</label>
                                </div>
                            </form>
                        </div>
                    `;

                    if (list) {
                        list.appendChild(card);
                    }

                    form.reset();
                    bindOperationForms();
                }
                finally {
                    form.dataset.submitting = "false";
                    setButtonLoading(submitButton, false);
                }
            });

            async function deleteOperation(operationId, button) {
                const confirmed = confirm("Bu işlemi silmek istediğinize emin misiniz?");

                if (!confirmed) {
                    return;
                }

                setButtonLoading(button, true, "Siliniyor...");

                try {
                    const formData = new FormData();
                    formData.append("operationId", operationId);

                    const response = await fetch("/ServiceRecords/DeleteOperation", {
                        method: "POST",
                        body: formData
                    });

                    if (!response.ok) {
                        alert("İşlem silinirken hata oluştu.");
                        return;
                    }

                    const result = await response.json();

                    if (!result.isSuccess) {
                        alert(result.errorMessage || "İşlem silinemedi.");
                        return;
                    }

                    const item = document.getElementById(`operation-item-${operationId}`);
                    const card = button.closest(".request-detail-card");

                    if (item) {
                        item.remove();
                    }

                    const totalText = card.querySelector(".request-operation-header span");

                    if (totalText) {
                        totalText.dataset.total = result.data.requestItemTotal;
                        totalText.textContent = `Toplam: ${formatMoney(result.data.requestItemTotal)}`;
                    }

                    updateSummaryTotal(result.data.recordTotal);

                    const operationList = card.querySelector(".request-operation-list");

                    if (operationList && operationList.children.length === 0) {
                        operationList.remove();

                        const area = card.querySelector(".request-operation-area");

                        const empty = document.createElement("div");
                        empty.className = "mini-empty";
                        empty.textContent = "Bu talep için henüz işlem eklenmedi.";

                        area.appendChild(empty);
                    }
                }
                finally {
                    if (document.body.contains(button)) {
                        setButtonLoading(button, false);
                    }
                }
            }

            async function deleteRequestItem(requestItemId, button) {
                const confirmed = confirm(
                    "Bu talep ve bağlı işlemler silinecek. Devam etmek istiyor musunuz?"
                );

                if (!confirmed) {
                    return;
                }

                setButtonLoading(button, true, "Siliniyor...");

                try {
                    const formData = new FormData();
                    formData.append("requestItemId", requestItemId);

                    const response = await fetch("/ServiceRecords/DeleteRequestItem", {
                        method: "POST",
                        body: formData
                    });

                    if (!response.ok) {
                        alert("Talep silinirken hata oluştu.");
                        return;
                    }

                    const result = await response.json();

                    if (!result.isSuccess) {
                        alert(result.errorMessage || "Talep silinemedi.");
                        return;
                    }

                    const card = document.getElementById(`request-item-${requestItemId}`);

                    if (card) {
                        card.remove();
                    }

                    updateSummaryTotal(result.data.recordTotal);

                    const requestList = document.querySelector(".request-detail-list");

                    if (requestList && requestList.children.length === 0) {
                        requestList.innerHTML = `
                            <div class="empty-state">
                                Bu servis kaydı için talep girilmemiş.
                            </div>
                        `;
                    }
                }
                finally {
                    if (document.body.contains(button)) {
                        setButtonLoading(button, false);
                    }
                }
            }

            function getStatusButtons(status) {
                if (status == "1") {
                    return `
                        <button type="button" class="status-btn warning" data-status="2">İşleme Al</button>
                        <button type="button" class="status-btn danger" data-status="4">İptal Et</button>
                    `;
                }

                if (status == "2") {
                    return `
                        <button type="button" class="status-btn success" data-status="3">Tamamla</button>
                        <button type="button" class="status-btn danger" data-status="4">İptal Et</button>
                    `;
                }

                if (status == "3" || status == "4") {
                    return `
                        <button type="button" class="status-btn primary" data-status="1">Tekrar Aç</button>
                    `;
                }

                return "";
            }

            function bindStatusButtons() {
                document.querySelectorAll(".status-btn").forEach(button => {
                    button.onclick = async function () {
                        if (button.dataset.loading === "true") {
                            return;
                        }

                        button.dataset.loading = "true";
                        setButtonLoading(button, true, "Güncelleniyor...");

                        try {
                            const statusActions = button.closest(".status-actions");
                            const serviceRecordId = statusActions.dataset.recordId;
                            const status = button.dataset.status;

                            const formData = new FormData();
                            formData.append("ServiceRecordId", serviceRecordId);
                            formData.append("Status", status);

                            const response = await fetch("/ServiceRecords/UpdateStatus", {
                                method: "POST",
                                body: formData
                            });

                            if (!response.ok) {
                                alert("Durum güncellenirken hata oluştu.");
                                return;
                            }

                            const summaryStatus = document.querySelector(".summary-status");

                            const statusMap = {
                                "1": "Açık Kayıt",
                                "2": "İşlemde",
                                "3": "Tamamlandı",
                                "4": "İptal Edildi"
                            };

                            summaryStatus.className = `summary-status status-${status}`;
                            summaryStatus.textContent = statusMap[status] ?? "Bilinmiyor";

                            statusActions.innerHTML = getStatusButtons(status);
                            bindStatusButtons();
                        }
                        finally {
                            if (document.body.contains(button)) {
                                button.dataset.loading = "false";
                                setButtonLoading(button, false);
                            }
                        }
                    };
                });
            }

            bindOperationForms();
            bindStatusButtons();

        <script src="https://unpkg.com/html5-qrcode"></script>

        <script>
                let qrScanner = null;
                let qrScanLocked = false;

                async function startQrScanner(vehicleId, button) {
                    if (qrScanLocked) {
                        return;
                    }

                    const reader = document.getElementById("qr-reader");
                    const resultBox = document.getElementById("qr-scan-result");

                    reader.style.display = "block";
                    resultBox.textContent = "Kamera açılıyor...";

                    button.disabled = true;
                    button.textContent = "Taranıyor...";

                                    

               

                    

                    

               try {

                    await navigator.mediaDevices.getUserMedia({
                    video: true
                });
                const cameras = await Html5Qrcode.getCameras();

                if (!cameras || cameras.length === 0) {
                    resultBox.textContent = "Kamera bulunamadı.";
                    button.disabled = false;
                    button.textContent = "QR Kod Tara";
                    qrScanLocked = false;
                    return;
                }

                qrScanner = new Html5Qrcode("qr-reader"); 
                                await qrScanner.start(
                    selectedCamera.id,
                    {
                        fps: 10,
                        qrbox: {
                            width: 220,
                            height: 220
                        }
                    },
                    async function (decodedText) {
                        if (qrScanLocked) {
                            return;
                        }

                        qrScanLocked = true;

                        resultBox.textContent = `QR okundu: ${decodedText}`;

                        await qrScanner.stop();

                        reader.style.display = "none";

                        await assignScannedQrCode(
                            vehicleId,
                            decodedText,
                            button,
                            resultBox
                        );
                    }
                );
                    } catch (error) {
                        resultBox.textContent = "Kamera açılamadı. Tarayıcı iznini kontrol edin.";
                        button.disabled = false;
                        button.textContent = "QR Kod Tara";
                        qrScanLocked = false;
                    }
                }

                async function assignScannedQrCode(vehicleId, code, button, resultBox) {
                    button.textContent = "Atanıyor...";

                    const formData = new FormData();
                    formData.append("vehicleId", vehicleId);
                    formData.append("code", code.trim());

                    const response = await fetch("/ServiceRecords/AssignQrCode", {
                        method: "POST",
                        body: formData
                    });

                    if (!response.ok) {
                        const errorText = await response.text();

                        resultBox.textContent = errorText || "QR atanırken hata oluştu.";

                        button.disabled = false;
                        button.textContent = "Tekrar Tara";
                        qrScanLocked = false;

                        return;
                    }

                    resultBox.textContent = "QR kod araca başarıyla atandı.";
                    button.textContent = "QR Atandı";
                }
        </script>

    </script>

   