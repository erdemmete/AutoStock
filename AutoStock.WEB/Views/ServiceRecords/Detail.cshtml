@model AutoStock.WEB.Models.ServiceRecords.ServiceRecordDetailViewModel

@{
    ViewData["Title"] = "Servis Detayı";

    string GetStatusText(int status)
    {
        return status switch
        {
            1 => "Aktif",
            2 => "Aktif",
            3 => "Tamamlandı",
            4 => "İptal",
            _ => "Bilinmiyor"
        };
    }

    string GetStatusClass(int status)
    {
        return status switch
        {
            1 => "active",
            2 => "active",
            3 => "completed",
            4 => "cancelled",
            _ => "unknown"
        };
    }

    string GetInvoiceStatusText(int status)
    {
        return status switch
        {
            1 => "Taslak",
            2 => "Kesildi",
            3 => "İptal",
            _ => "Bilinmiyor"
        };
    }

    string FormatMoney(decimal value)
    {
        return value.ToString("N2") + " ₺";
    }

    var estimatedTotal = Model.RequestItems.Sum(x => x.EstimatedAmount ?? 0);
    var subTotal = Model.TotalAmount;
    var vatTotal = subTotal * 0.20m;
    var grandTotal = subTotal + vatTotal;
}

<div class="srx-page">

    <div id="toastMessage" class="srx-toast"></div>

    <header class="srx-page-header">

        <a href="/ServiceRecords"
           class="srx-back-btn"
           title="Servis kayıtlarına dön">
            ←
        </a>

        <div class="srx-header-main">
            <div class="srx-header-title-row">
                <h1>Kayıt @Model.RecordNumber</h1>

                <span class="srx-status-badge @GetStatusClass(Model.Status)">
                    @GetStatusText(Model.Status)
                </span>
            </div>

            <p>
                @Model.CreatedAt.ToString("dd MMMM yyyy") tarihinde açıldı.
            </p>
        </div>

        <a asp-controller="Dashboard"
           asp-action="Index"
           class="srx-home-btn"
           title="Ana sayfa">
            ⌂
        </a>

    </header>

    <section class="srx-info-card collapsed">

        <button type="button"
                class="srx-info-summary"
                data-action="toggle-info">

            <div class="srx-info-summary-left">
                <span class="srx-info-icon">♙</span>

                <strong>@Model.CustomerName</strong>

                <span class="srx-dot">•</span>

                <span class="srx-plate">@Model.VehiclePlate</span>

                <span>@Model.VehicleBrandName @Model.VehicleModelName</span>
            </div>

            <div class="srx-info-summary-right">
                <span>Müşteri ve Araç Detayları</span>
                <span class="srx-chevron">⌃</span>
            </div>

        </button>

        <div class="srx-info-body">

            <div class="srx-info-column">
                <h3>Müşteri Bilgileri</h3>

                <div class="srx-info-grid">
                    <span>Ad Soyad</span>
                    <strong>@Model.CustomerName</strong>

                    <span>Telefon</span>
                    <strong>@Model.CustomerPhone</strong>

                    @if (!string.IsNullOrWhiteSpace(Model.CustomerEmail))
                    {
                        <span>E-posta</span>
                        <strong>@Model.CustomerEmail</strong>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.CompanyName))
                    {
                        <span>Firma</span>
                        <strong>@Model.CompanyName</strong>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.AuthorizedPersonName))
                    {
                        <span>Yetkili</span>
                        <strong>@Model.AuthorizedPersonName</strong>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.TaxOffice))
                    {
                        <span>Vergi Dairesi</span>
                        <strong>@Model.TaxOffice</strong>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.TaxNumber))
                    {
                        <span>Vergi No</span>
                        <strong>@Model.TaxNumber</strong>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.NationalIdentityNumber))
                    {
                        <span>TC Kimlik No</span>
                        <strong>@Model.NationalIdentityNumber</strong>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.CustomerAddress)
                        || !string.IsNullOrWhiteSpace(Model.AddressDistrict)
                        || !string.IsNullOrWhiteSpace(Model.AddressCity))
                    {
                        <span>Adres</span>
                        <strong>
                            @Model.CustomerAddress
                            @if (!string.IsNullOrWhiteSpace(Model.AddressDistrict)
                                || !string.IsNullOrWhiteSpace(Model.AddressCity))
                            {
                                <small>
                                    @Model.AddressDistrict / @Model.AddressCity
                                </small>
                            }
                        </strong>
                    }
                </div>
            </div>

            <div class="srx-info-column">
                <h3>Araç Bilgileri</h3>

                <div class="srx-info-grid">
                    <span>Marka/Model</span>
                    <strong>@Model.VehicleBrandName @Model.VehicleModelName</strong>

                    <span>Plaka</span>
                    <strong>@Model.VehiclePlate</strong>

                    <span>Kilometre</span>
                    <strong>@((Model.Mileage ?? 0).ToString("N0")) km</strong>

                    @if (!string.IsNullOrWhiteSpace(Model.ChassisNumber))
                    {
                        <span>Şasi No</span>
                        <strong>@Model.ChassisNumber</strong>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.VehicleDeliveredBy))
                    {
                        <span>Aracı Getiren</span>
                        <strong>@Model.VehicleDeliveredBy</strong>
                    }
                </div>
            </div>

        </div>

        @if (!string.IsNullOrWhiteSpace(Model.CustomerComplaint)
            || !string.IsNullOrWhiteSpace(Model.ServiceReceptionNote))
        {
            <div class="srx-note-strip">
                @if (!string.IsNullOrWhiteSpace(Model.CustomerComplaint))
                {
                    <div>
                        <span>Müşteri Şikayeti</span>
                        <p>@Model.CustomerComplaint</p>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.ServiceReceptionNote))
                {
                    <div>
                        <span>Servis Kabul Notu</span>
                        <p>@Model.ServiceReceptionNote</p>
                    </div>
                }
            </div>
        }

    </section>

    <section class="srx-workspace">

        <main class="srx-work-main">

            <section class="srx-request-list" id="requestList">

                @if (Model.RequestItems.Any())
                {
                    var requestIndex = 0;

                    @foreach (var request in Model.RequestItems)
                    {
                        requestIndex++;

                        var requestOperations = Model.Operations
                            .Where(x => x.ServiceRequestItemId == request.Id)
                            .OrderBy(x => x.Id)
                            .ToList();

                        var requestTotal = requestOperations.Sum(x => x.TotalPrice);

                        var requestEstimatedAmountValue = (request.EstimatedAmount ?? 0)
                            .ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

                        <article class="srx-request-card"
                                 id="request-item-@request.Id"
                                 data-request-id="@request.Id"
                                 data-expanded="false">

                            <header class="srx-request-card-header">

                                <button type="button"
                                        class="srx-request-summary"
                                        data-action="toggle-request">

                                    <span class="srx-request-number">@requestIndex</span>

                                    <span class="srx-request-title-block">
                                        <strong class="srx-request-title-text">@request.Title</strong>

                                        @if (!string.IsNullOrWhiteSpace(request.Note))
                                        {
                                            <small class="srx-request-note-text">@request.Note</small>
                                        }
                                        else
                                        {
                                            <small class="srx-request-note-text muted">Ön not girilmemiş.</small>
                                        }
                                    </span>

                                </button>

                                <div class="srx-request-card-actions">

                                    <button type="button"
                                            class="srx-request-toggle-btn"
                                            data-action="toggle-request"
                                            data-role="toggle-request-text">
                                        İşlemleri Aç
                                    </button>

                                    <button type="button"
                                            class="srx-secondary-mini-btn"
                                            data-action="edit-request">
                                        Düzenle
                                    </button>

                                    <button type="button"
                                            class="srx-secondary-mini-btn danger"
                                            data-action="delete-request"
                                            data-request-id="@request.Id">
                                        Sil
                                    </button>

                                </div>

                            </header>

                            <div class="srx-request-card-meta">

                                <span>
                                    <strong>@requestOperations.Count</strong>
                                    işlem
                                </span>

                                <span>
                                    İşlem toplamı
                                    <strong>@FormatMoney(requestTotal)</strong>
                                </span>

                                <span>
                                    Durum
                                    <strong>@(request.IsResolved ? "Çözüldü" : "Açık")</strong>
                                </span>

                            </div>

                            <div class="srx-request-card-body">

                                <form action="/ServiceRecords/UpdateRequestItem"
                                      method="post"
                                      class="srx-request-edit-form ajax-request-edit-form"
                                      data-request-id="@request.Id"
                                      hidden>

                                    <input type="hidden"
                                           name="ServiceRequestItemId"
                                           value="@request.Id" />

                                    <div class="srx-form-grid request-edit-grid">

                                        <label>
                                            <span>Şikayet / Talep Başlığı</span>
                                            <input type="text"
                                                   name="Title"
                                                   value="@request.Title"
                                                   autocomplete="off"
                                                   placeholder="Örn: Motor arıza ışığı yanıyor" />
                                        </label>

                                        <label>
                                            <span>Ön Not</span>
                                            <textarea name="Note"
                                                      rows="2"
                                                      placeholder="Örn: OBD kontrolü yapılacak.">@request.Note</textarea>
                                        </label>

                                        <label>
                                            <span>Tahmini Fiyat</span>
                                            <input type="number"
                                                   name="EstimatedAmount"
                                                   value="@requestEstimatedAmountValue"
                                                   min="0"
                                                   step="0.01"
                                                   placeholder="Opsiyonel" />
                                        </label>

                                    </div>

                                    <div class="srx-form-actions">
                                        <button type="submit"
                                                class="srx-primary-mini-btn">
                                            Şikayeti Kaydet
                                        </button>

                                        <button type="button"
                                                class="srx-secondary-mini-btn"
                                                data-action="cancel-edit-request">
                                            Vazgeç
                                        </button>
                                    </div>

                                </form>

                                <div class="srx-request-detail-strip">

                                    <div>
                                        <span>Tahmini Fiyat</span>
                                        <strong>@FormatMoney(request.EstimatedAmount ?? 0)</strong>
                                    </div>

                                    <div>
                                        <span>Gerçekleşen İşlem Toplamı</span>
                                        <strong>@FormatMoney(requestTotal)</strong>
                                    </div>

                                    <div>
                                        <span>İşlem Sayısı</span>
                                        <strong>@requestOperations.Count</strong>
                                    </div>

                                </div>

                                <section class="srx-operation-area">

                                    <div class="srx-operation-area-header">
                                        <div>
                                            <span>Yapılan İşlemler</span>
                                            <strong>Parça ve işçilik kayıtları</strong>
                                        </div>
                                    </div>

                                    <div class="srx-operation-list"
                                         data-operation-list
                                         data-request-id="@request.Id">

                                        @if (requestOperations.Any())
                                        {
                                            @foreach (var operation in requestOperations)
                                            {
                                                var typeClass = operation.Type == 1 ? "part" : "labor";
                                                var typeText = operation.Type == 1 ? "Parça" : "İşçilik";

                                                var operationQuantityValue = operation.Quantity
                                                    .ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

                                                var operationUnitPriceValue = operation.UnitPrice
                                                    .ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

                                                <article class="srx-operation-card request-operation-item"
                                                         id="operation-item-@operation.Id"
                                                         data-operation-id="@operation.Id">

                                                    <div class="srx-operation-display">

                                                        <div class="srx-operation-main">

                                                            <span class="srx-type-badge @typeClass">
                                                                @typeText
                                                            </span>

                                                            <div class="srx-operation-copy">
                                                                <strong>@operation.Description</strong>

                                                                @if (!string.IsNullOrWhiteSpace(operation.Note))
                                                                {
                                                                    <small>@operation.Note</small>
                                                                }
                                                                else
                                                                {
                                                                    <small class="muted">Not yok</small>
                                                                }
                                                            </div>

                                                        </div>

                                                        <div class="srx-operation-price">
                                                            <strong>@FormatMoney(operation.TotalPrice)</strong>
                                                            <span>@operation.Quantity.ToString("N2") × @FormatMoney(operation.UnitPrice)</span>
                                                        </div>

                                                        <div class="srx-operation-actions">

                                                            <button type="button"
                                                                    class="srx-secondary-mini-btn"
                                                                    data-action="edit-operation">
                                                                Düzenle
                                                            </button>

                                                            <button type="button"
                                                                    class="srx-secondary-mini-btn danger"
                                                                    data-action="delete-operation"
                                                                    data-operation-id="@operation.Id">
                                                                Sil
                                                            </button>

                                                        </div>

                                                    </div>

                                                    <form action="/ServiceRecords/UpdateOperation"
                                                          method="post"
                                                          class="srx-operation-edit-form ajax-operation-edit-form"
                                                          data-operation-id="@operation.Id"
                                                          hidden>

                                                        <input type="hidden"
                                                               name="OperationId"
                                                               value="@operation.Id" />

                                                        <input type="hidden"
                                                               name="ServiceRecordId"
                                                               value="@Model.Id" />

                                                        <input type="hidden"
                                                               name="ServiceRequestItemId"
                                                               value="@request.Id" />

                                                        <input type="hidden"
                                                               name="StockItemId"
                                                               class="srx-stock-item-id" />

                                                        <div class="srx-operation-editor">

                                                            <div class="srx-type-switch">

                                                                <input type="radio"
                                                                       id="editPart_@operation.Id"
                                                                       name="Type"
                                                                       value="1"
                                                                @(operation.Type == 1 ? "checked" : "") />

                                                                <label for="editPart_@operation.Id" title="Parça">
                                                                    P
                                                                </label>

                                                                <input type="radio"
                                                                       id="editLabor_@operation.Id"
                                                                       name="Type"
                                                                       value="2"
                                                                @(operation.Type == 2 ? "checked" : "") />

                                                                <label for="editLabor_@operation.Id" title="İşçilik">
                                                                    İ
                                                                </label>

                                                            </div>

                                                            <div class="srx-search-box">

                                                                <input type="text"
                                                                       name="Description"
                                                                       class="srx-operation-search-input"
                                                                       value="@operation.Description"
                                                                       autocomplete="off"
                                                                       placeholder="Parça adı, kodu veya işlem açıklaması..." />

                                                                <div class="srx-search-results"></div>

                                                            </div>

                                                            <input type="number"
                                                                   name="Quantity"
                                                                   class="srx-qty-input"
                                                                   value="@operationQuantityValue"
                                                                   min="1"
                                                                   step="1"
                                                                   placeholder="Miktar" />

                                                            <div class="srx-money-input">

                                                                <input type="text"
                                                                       name="UnitPrice"
                                                                       class="srx-price-input"
                                                                       value="@operationUnitPriceValue"
                                                                       inputmode="decimal"
                                                                       autocomplete="off"
                                                                       placeholder="Fiyat" />

                                                                <span>₺</span>

                                                            </div>

                                                        </div>

                                                        <input type="text"
                                                               name="Note"
                                                               class="srx-operation-note"
                                                               value="@operation.Note"
                                                               placeholder="İşlem notu opsiyonel" />

                                                        <div class="srx-form-actions">
                                                            <button type="submit"
                                                                    class="srx-primary-mini-btn">
                                                                İşlemi Kaydet
                                                            </button>

                                                            <button type="button"
                                                                    class="srx-secondary-mini-btn"
                                                                    data-action="cancel-edit-operation">
                                                                Vazgeç
                                                            </button>
                                                        </div>

                                                    </form>

                                                </article>
                                            }
                                        }
                                        else
                                        {
                                            <div class="srx-operation-empty">
                                                <strong>Henüz işlem eklenmedi.</strong>
                                                <span>Bu şikayetin altına parça veya işçilik ekleyin.</span>
                                            </div>
                                        }

                                    </div>

                                </section>

                                <button type="button"
                                        class="srx-add-operation-trigger"
                                        data-action="show-operation-form">
                                    + Bu Şikayete Parça / İşçilik Ekle
                                </button>

                                <form asp-action="AddOperation"
                                      method="post"
                                      class="srx-operation-form ajax-operation-form"
                                      data-request-id="@request.Id"
                                      hidden>

                                    <input type="hidden"
                                           name="ServiceRecordId"
                                           value="@Model.Id" />

                                    <input type="hidden"
                                           name="ServiceRequestItemId"
                                           value="@request.Id" />

                                    <input type="hidden"
                                           name="StockItemId"
                                           class="srx-stock-item-id" />

                                    <div class="srx-operation-editor">

                                        <div class="srx-type-switch">

                                            <input type="radio"
                                                   id="partType_@request.Id"
                                                   name="Type"
                                                   value="1"
                                                   checked />

                                            <label for="partType_@request.Id" title="Parça">
                                                P
                                            </label>

                                            <input type="radio"
                                                   id="laborType_@request.Id"
                                                   name="Type"
                                                   value="2" />

                                            <label for="laborType_@request.Id" title="İşçilik">
                                                İ
                                            </label>

                                        </div>

                                        <div class="srx-search-box">

                                            <input type="text"
                                                   name="Description"
                                                   class="srx-operation-search-input"
                                                   placeholder="Parça adı, kodu veya işlem açıklaması..."
                                                   autocomplete="off" />

                                            <div class="srx-search-results"></div>

                                        </div>

                                        <input type="number"
                                               name="Quantity"
                                               class="srx-qty-input"
                                               value="1"
                                               min="1"
                                               step="1"
                                               placeholder="Miktar" />

                                        <div class="srx-money-input">

                                            <input type="text"
                                                   name="UnitPrice"
                                                   class="srx-price-input"
                                                   inputmode="decimal"
                                                   autocomplete="off"
                                                   placeholder="Fiyat" />

                                            <span>₺</span>

                                        </div>

                                        <button type="submit"
                                                class="srx-add-row-btn">
                                            Ekle
                                        </button>

                                    </div>

                                    <input type="text"
                                           name="Note"
                                           class="srx-operation-note"
                                           placeholder="İşlem notu opsiyonel" />

                                </form>

                            </div>

                        </article>
                    }
                }
                else
                {
                    <div class="srx-empty-requests">
                        <strong>Henüz şikayet / talep girilmemiş.</strong>
                        <span>Servis kaydına başlamak için yeni şikayet ekleyin.</span>
                    </div>
                }

            </section>

            <section class="srx-new-request-card" id="newRequestCard">

                <button type="button"
                        class="srx-new-request-trigger"
                        data-action="toggle-new-request">
                    <strong>+ Yeni Şikayet / Talep Ekle</strong>
                </button>

                <form asp-action="AddRequestItem"
                      method="post"
                      class="srx-new-request-form ajax-request-form"
                      hidden>

                    <input type="hidden"
                           name="serviceRecordId"
                           value="@Model.Id" />

                    <div class="srx-form-grid new-request-grid">

                        <label>
                            <span>Şikayet / Talep Başlığı</span>
                            <input type="text"
                                   name="Title"
                                   list="requestSuggestions"
                                   placeholder="Örn: Motor arıza ışığı yanıyor" />
                        </label>

                        <label>
                            <span>Ön Not</span>
                            <input type="text"
                                   name="Note"
                                   placeholder="Örn: OBD kontrolü yapılacak" />
                        </label>

                        <label>
                            <span>Tahmini Fiyat</span>
                            <input type="number"
                                   name="EstimatedAmount"
                                   min="0"
                                   step="0.01"
                                   placeholder="Opsiyonel" />
                        </label>

                    </div>

                    <div class="srx-form-actions">
                        <button type="submit"
                                class="srx-primary-mini-btn">
                            Şikayeti Kaydet
                        </button>

                        <button type="button"
                                class="srx-secondary-mini-btn"
                                data-action="cancel-new-request">
                            Vazgeç
                        </button>
                    </div>

                    <datalist id="requestSuggestions">
                        <option value="Genel bakım"></option>
                        <option value="Yağ değişimi"></option>
                        <option value="Fren kontrolü"></option>
                        <option value="Klima arızası"></option>
                        <option value="Rot balans kontrolü"></option>
                        <option value="Far ayarı"></option>
                        <option value="Motor arıza ışığı yanıyor"></option>
                        <option value="Motordan ses geliyor"></option>
                    </datalist>

                </form>

            </section>

            @if (Model.DeletedRequestItems.Any())
            {
                <section class="srx-deleted-requests-card">

                    <button type="button"
                            class="srx-deleted-requests-toggle"
                            data-action="toggle-deleted-requests">
                        <span>Silinen Şikayetler</span>
                        <strong>@Model.DeletedRequestItems.Count</strong>
                    </button>

                    <div class="srx-deleted-requests-panel"
                         id="deletedRequestsPanel"
                         hidden>

                        @foreach (var deletedRequest in Model.DeletedRequestItems)
                        {
                            <div class="srx-deleted-request-row"
                                 id="deleted-request-@deletedRequest.Id">

                                <div>
                                    <strong>@deletedRequest.Title</strong>

                                    @if (!string.IsNullOrWhiteSpace(deletedRequest.Note))
                                    {
                                        <small>@deletedRequest.Note</small>
                                    }

                                    <span>
                                        @(deletedRequest.DeletedAt.HasValue
                                            ? deletedRequest.DeletedAt.Value.ToString("dd.MM.yyyy HH:mm")
                                            : "Silinme tarihi yok")

                                        @if (deletedRequest.DeletedOperationCount > 0)
                                        {
                                            <text> • @deletedRequest.DeletedOperationCount işlem de pasife alınmış</text>
                                        }
                                    </span>
                                </div>

                                <button type="button"
                                        class="srx-restore-request-btn"
                                        data-action="restore-request"
                                        data-request-id="@deletedRequest.Id">
                                    Geri Al
                                </button>

                            </div>
                        }

                    </div>

                </section>
            }

        </main>

        <aside class="srx-side-panel">

            <section class="srx-summary-card">

                <h2>Servis Özeti</h2>

                <div class="srx-estimate-box">
                    <span>Tahmini Fiyat Verildi</span>
                    <strong>@FormatMoney(estimatedTotal)</strong>
                </div>

                <div class="srx-summary-lines">

                    <div>
                        <span>Ara Toplam</span>
                        <strong class="summary-total"
                                data-total="@subTotal">
                            @FormatMoney(subTotal)
                        </strong>
                    </div>

                    <div>
                        <span>KDV (%20)</span>
                        <strong class="summary-vat"
                                data-vat="@vatTotal">
                            @FormatMoney(vatTotal)
                        </strong>
                    </div>

                </div>

                <div class="srx-grand-total">
                    <span>Genel Toplam</span>
                    <strong class="summary-grand-total"
                            data-grand-total="@grandTotal">
                        @FormatMoney(grandTotal)
                    </strong>
                </div>

                @if (Model.ActiveInvoiceId.HasValue)
                {
                    <a href="/Invoices/Detail/@Model.ActiveInvoiceId"
                       class="srx-primary-action">
                        @(Model.ActiveInvoiceStatus == 1 ? "Taslak Faturaya Git" : "Faturaya Git")
                    </a>
                }
                else
                {
                    <a href="/Invoices/CreateFromServiceRecord/@Model.Id"
                       class="srx-primary-action">
                        Fatura Taslağına Geç
                    </a>
                }

                <div class="srx-action-grid">

                    <a href="/service-pdf/create/@Model.Id"
                       target="_blank"
                       class="srx-secondary-action">
                        PDF Oluştur
                    </a>

