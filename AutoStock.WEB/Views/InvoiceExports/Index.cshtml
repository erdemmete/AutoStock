@model AutoStock.WEB.Models.Invoices.InvoiceExportIndexViewModel
@using AutoStock.Services.Dtos.Invoices

@{
    ViewData["Title"] = "Faturalar";

    var preview = Model.Preview;
    var query = Model.Query;
    var items = preview.Items ?? new List<InvoiceExportItemDto>();
    var activeTab = string.IsNullOrWhiteSpace(query.Tab) ? "prepare" : query.Tab!;

    string DateValue(DateTime? value) => value.HasValue ? value.Value.ToString("yyyy-MM-dd") : string.Empty;

    string PresetClass(string preset) =>
        string.Equals(query.Preset, preset, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;

    string TabClass(string tab) =>
        string.Equals(activeTab, tab, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;

    string TabUrl(string tab) => Url.Action("Index", "InvoiceExports", new
    {
        query.StartDate,
        query.EndDate,
        query.Preset,
        Tab = tab
    }) ?? "#";

    string DisplayDocumentNo(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "-";

        var trimmed = value.Trim();
        return trimmed.StartsWith("MAT-", StringComparison.OrdinalIgnoreCase) ||
               trimmed.StartsWith("FAT-", StringComparison.OrdinalIgnoreCase)
            ? $"SHO-{trimmed[4..]}"
            : trimmed;
    }

    string TabLabel(string tab) => tab switch
    {
        "waiting" => "Fatura Bekleyenler",
        "customer" => "Müşteriye İletilecekler",
        "completed" => "Tamamlananlar",
        _ => "Gönderilecek Özetler"
    };

    int TabCount(string tab) => tab switch
    {
        "waiting" => preview.WaitingCount,
        "customer" => preview.CustomerShareCount,
        "completed" => preview.CompletedCount,
        _ => preview.PrepareCount
    };
}

<div class="invexp-page">
    <section class="invexp-topbar">
        <div class="invexp-titleline">
            <a asp-controller="Invoices" asp-action="Index" class="invexp-back" aria-label="Geri dön">‹</a>
            <h1>Faturalar</h1>
        </div>
    </section>

    <section class="invexp-controls">
        <div class="invexp-mobile-tab">
            <label for="invoiceExportTabSelect">Durum</label>
            <select id="invoiceExportTabSelect" data-tab-select>
                <option value="@TabUrl("prepare")" selected="@(activeTab == "prepare")">Gönderilecek Özetler (@preview.PrepareCount)</option>
                <option value="@TabUrl("waiting")" selected="@(activeTab == "waiting")">Fatura Bekleyenler (@preview.WaitingCount)</option>
                <option value="@TabUrl("customer")" selected="@(activeTab == "customer")">Müşteriye İletilecekler (@preview.CustomerShareCount)</option>
                <option value="@TabUrl("completed")" selected="@(activeTab == "completed")">Tamamlananlar (@preview.CompletedCount)</option>
            </select>
        </div>

        <nav class="invexp-tabs" aria-label="Fatura durumları">
            <a class="@TabClass("prepare")" href="@TabUrl("prepare")">Gönderilecek Özetler <span>@preview.PrepareCount</span></a>
            <a class="@TabClass("waiting")" href="@TabUrl("waiting")">Fatura Bekleyenler <span>@preview.WaitingCount</span></a>
            <a class="@TabClass("customer")" href="@TabUrl("customer")">Müşteriye İletilecekler <span>@preview.CustomerShareCount</span></a>
            <a class="@TabClass("completed")" href="@TabUrl("completed")">Tamamlananlar <span>@preview.CompletedCount</span></a>
        </nav>

        <button type="button" class="invexp-filter-toggle" data-filter-toggle>Filtrele</button>

        <div class="invexp-filter-shell" data-filter-panel>
            <div class="invexp-quick-presets">
                <a class="@PresetClass("this-week")" href="@Url.Action("Index", "InvoiceExports", new { Preset = "this-week", Tab = activeTab })">Bu Hafta</a>
                <a class="@PresetClass("this-month")" href="@Url.Action("Index", "InvoiceExports", new { Preset = "this-month", Tab = activeTab })">Bu Ay</a>
                <a class="@PresetClass("last-month")" href="@Url.Action("Index", "InvoiceExports", new { Preset = "last-month", Tab = activeTab })">Geçen Ay</a>
            </div>

            <form method="get" asp-controller="InvoiceExports" asp-action="Index" class="invexp-filter-form">
                <input type="hidden" name="Preset" value="custom" />
                <input type="hidden" name="Tab" value="@activeTab" />

                <label class="invexp-date-field">
                    <span>Başlangıç</span>
                    <input type="date" name="StartDate" value="@DateValue(query.StartDate)" />
                </label>

                <label class="invexp-date-field">
                    <span>Bitiş</span>
                    <input type="date" name="EndDate" value="@DateValue(query.EndDate)" />
                </label>

                <button type="submit" class="btn-dark-action">Uygula</button>
            </form>
        </div>
    </section>

    <section class="invexp-list-shell">
        <div class="invexp-bulk-bar">
            @if (activeTab == "prepare")
            {
                <label class="invexp-select-page">
                    <input type="checkbox" data-invexp-select-page />
                    <span>Bu sayfayı seç</span>
                </label>

                <div class="invexp-selected-count" data-invexp-selected-count>0 kayıt seçildi</div>

                <div class="invexp-bulk-actions">
                    <form method="get" asp-controller="InvoiceExports" asp-action="Download" id="downloadDocumentsForm">
                        <input type="hidden" name="StartDate" value="@DateValue(query.StartDate)" />
                        <input type="hidden" name="EndDate" value="@DateValue(query.EndDate)" />
                        <input type="hidden" name="Preset" value="@query.Preset" />
                        <input type="hidden" name="Tab" value="@query.Tab" />
                        <div data-invexp-download-inputs></div>
                        <button type="submit" class="btn-secondary-action" data-invexp-download disabled>Belgeleri İndir</button>
                    </form>

                    <button type="button"
                            class="btn-primary-action"
                            data-bs-toggle="modal"
                            data-bs-target="#sendPreparationModal"
                            data-invexp-selected-send
                            disabled>
                        Fatura İçin Gönder
                    </button>
                </div>
            }
            else
            {
                <strong>@TabLabel(activeTab)</strong>
                <span>@TabCount(activeTab) kayıt</span>
            }
        </div>

        @if (!items.Any())
        {
            <div class="invexp-empty">
                <div>⌕</div>
                <strong>Kayıt bulunamadı</strong>
                <span>Tarih aralığını veya durumu değiştirerek tekrar deneyebilirsiniz.</span>
            </div>
        }
        else
        {
            <div class="invexp-table-wrap">
                <table class="invexp-table">
                    <thead>
                        <tr>
                            @if (activeTab == "prepare")
                            {
                                <th class="select-col"></th>
                            }
                            <th>Belge No</th>
                            <th>Tarih</th>
                            <th>Müşteri</th>
                            <th>Plaka</th>
                            <th class="num">Tutar</th>
                            @if (activeTab == "waiting")
                            {
                                <th>Alıcı</th>
                                <th>Gönderim</th>
                                <th>Aksiyon</th>
                            }
                            @if (activeTab == "customer" || activeTab == "completed")
                            {
                                <th>Fatura</th>
                                <th>Aksiyon</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in items)
                        {
                            var canSelect = activeTab == "prepare" && item.Status == 2;
                            var displayNo = DisplayDocumentNo(item.InvoiceNumber);
                            var shareUrl = !string.IsNullOrWhiteSpace(item.OfficialInvoiceShareToken)
                                ? $"{Context.Request.Scheme}://{Context.Request.Host}{Url.Action("PublicInvoiceFile", "AccountingInvoiceRequests", new { shareToken = item.OfficialInvoiceShareToken })}"
                                : string.Empty;
                            var whatsappText = Uri.EscapeDataString($"Merhaba, aracınıza ait faturaya aşağıdaki bağlantıdan ulaşabilirsiniz.\n\n{shareUrl}");

                            <tr>
                                @if (activeTab == "prepare")
                                {
                                    <td class="select-col">
                                        @if (canSelect)
                                        {
                                            <input type="checkbox"
                                                   class="invexp-row-check"
                                                   value="@item.InvoiceId"
                                                   aria-label="@displayNo seç" />
                                        }
                                    </td>
                                }
                                <td><a href="/Invoices/Detail/@item.InvoiceId" class="invexp-link">@displayNo</a></td>
                                <td>@item.InvoiceDate.ToString("dd.MM.yyyy")</td>
                                <td><strong>@item.CustomerTitle</strong></td>
                                <td>@(string.IsNullOrWhiteSpace(item.Plate) ? "-" : item.Plate)</td>
                                <td class="num strong">@SenteMoney.Format(item.GrandTotal)</td>
                                @if (activeTab == "waiting")
                                {
                                    var uploadUrl = !string.IsNullOrWhiteSpace(item.BatchToken)
                                        ? $"{Context.Request.Scheme}://{Context.Request.Host}{Url.Action("PublicBatch", "AccountingInvoiceRequests", new { batchToken = item.BatchToken })}"
                                        : string.Empty;
                                    <td>@(item.RecipientEmail ?? "-")</td>
                                    <td>@(item.AccountingSentAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(uploadUrl))
                                        {
                                            <button type="button" class="mini-btn" data-copy-text="@uploadUrl">Bağlantıyı Kopyala</button>
                                        }
                                    </td>
                                }
                                @if (activeTab == "customer" || activeTab == "completed")
                                {
                                    <td>@(item.OfficialInvoiceNumber ?? "-")</td>
                                    <td class="action-cell">
                                        @if (!string.IsNullOrWhiteSpace(shareUrl))
                                        {
                                            <a class="mini-btn primary" href="https://wa.me/?text=@whatsappText" target="_blank">WhatsApp</a>
                                            <a class="mini-btn" href="mailto:?subject=@Uri.EscapeDataString($"{displayNo} fatura bağlantısı")&body=@Uri.EscapeDataString($"Merhaba,\n\nFaturaya aşağıdaki bağlantıdan ulaşabilirsiniz:\n\n{shareUrl}")">E-posta</a>
                                            <a class="mini-btn" href="@shareUrl" target="_blank">Görüntüle</a>
                                            <button type="button" class="mini-btn" data-copy-text="@shareUrl">Kopyala</button>
                                            @if (activeTab == "customer" && item.OfficialInvoiceDocumentId.HasValue)
                                            {
                                                <button type="button"
                                                        class="mini-btn"
                                                        data-mark-delivered
                                                        data-document-id="@item.OfficialInvoiceDocumentId"
                                                        data-channel="WhatsApp">
                                                    İletildi
                                                </button>
                                            }
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="invexp-mobile-list">
                @foreach (var item in items)
                {
                    var canSelect = activeTab == "prepare" && item.Status == 2;
                    var displayNo = DisplayDocumentNo(item.InvoiceNumber);
                    var shareUrl = !string.IsNullOrWhiteSpace(item.OfficialInvoiceShareToken)
                        ? $"{Context.Request.Scheme}://{Context.Request.Host}{Url.Action("PublicInvoiceFile", "AccountingInvoiceRequests", new { shareToken = item.OfficialInvoiceShareToken })}"
                        : string.Empty;
                    var uploadUrl = !string.IsNullOrWhiteSpace(item.BatchToken)
                        ? $"{Context.Request.Scheme}://{Context.Request.Host}{Url.Action("PublicBatch", "AccountingInvoiceRequests", new { batchToken = item.BatchToken })}"
                        : string.Empty;
                    var whatsappText = Uri.EscapeDataString($"Merhaba, aracınıza ait faturaya aşağıdaki bağlantıdan ulaşabilirsiniz.\n\n{shareUrl}");

                    <article class="invexp-mobile-row">
                        <div class="mobile-mainline">
                            @if (canSelect)
                            {
                                <input type="checkbox"
                                       class="invexp-row-check"
                                       value="@item.InvoiceId"
                                       aria-label="@displayNo seç" />
                            }
                            <a href="/Invoices/Detail/@item.InvoiceId">@displayNo</a>
                            <strong>@SenteMoney.Format(item.GrandTotal)</strong>
                        </div>
                        <div class="mobile-subline">
                            <span>@item.CustomerTitle</span>
                            <span>@(string.IsNullOrWhiteSpace(item.Plate) ? "-" : item.Plate)</span>
                        </div>
                        <div class="mobile-date">@item.InvoiceDate.ToString("dd.MM.yyyy")</div>

                        @if (activeTab == "waiting")
                        {
                            <div class="mobile-actions">
                                <span>@(item.RecipientEmail ?? "-")</span>
                                @if (!string.IsNullOrWhiteSpace(uploadUrl))
                                {
                                    <button type="button" class="mini-btn" data-copy-text="@uploadUrl">Bağlantıyı Kopyala</button>
                                }
                            </div>
                        }

                        @if ((activeTab == "customer" || activeTab == "completed") && !string.IsNullOrWhiteSpace(shareUrl))
                        {
                            <div class="mobile-actions">
                                <a class="mini-btn primary" href="https://wa.me/?text=@whatsappText" target="_blank">WhatsApp</a>
                                <a class="mini-btn" href="mailto:?subject=@Uri.EscapeDataString($"{displayNo} fatura bağlantısı")&body=@Uri.EscapeDataString($"Merhaba,\n\nFaturaya aşağıdaki bağlantıdan ulaşabilirsiniz:\n\n{shareUrl}")">E-posta</a>
                                <a class="mini-btn" href="@shareUrl" target="_blank">Görüntüle</a>
                                @if (activeTab == "customer" && item.OfficialInvoiceDocumentId.HasValue)
                                {
                                    <button type="button"
                                            class="mini-btn"
                                            data-mark-delivered
                                            data-document-id="@item.OfficialInvoiceDocumentId"
                                            data-channel="WhatsApp">
                                        İletildi
                                    </button>
                                }
                            </div>
                        }
                    </article>
                }
            </div>
        }
    </section>
</div>

@if (activeTab == "prepare")
{
    <div class="invexp-sticky-actions" data-invexp-sticky hidden>
        <span data-invexp-sticky-count>0 kayıt seçildi</span>
        <button type="submit" form="downloadDocumentsForm" class="btn-secondary-action">İndir</button>
        <button type="button"
                class="btn-primary-action"
                data-bs-toggle="modal"
                data-bs-target="#sendPreparationModal">
            Fatura İçin Gönder
        </button>
    </div>
}

<div class="modal fade" id="sendPreparationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content invexp-modal">
            <form method="post" asp-controller="InvoiceExports" asp-action="SendEmail" id="sendPreparationForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="StartDate" value="@DateValue(query.StartDate)" />
                <input type="hidden" name="EndDate" value="@DateValue(query.EndDate)" />
                <input type="hidden" name="Preset" value="@query.Preset" />
                <input type="hidden" name="Tab" value="@query.Tab" />
                <div data-invexp-selected-inputs></div>

                <div class="modal-header">
                    <div>
                        <span class="modal-eyebrow">FATURA</span>
                        <h5 class="modal-title">Fatura İçin Gönder</h5>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="modal-info" data-invexp-modal-summary>Seçilen kayıtlar için tek yükleme bağlantısı oluşturulacak.</div>
                    <div class="field">
                        <label>Faturayı hazırlayacak kişinin e-posta adresi</label>
                        <input type="email" name="ToEmail" placeholder="ornek@firma.com" required />
                    </div>
                    <div class="field">
                        <label>Not</label>
                        <textarea name="Message" rows="3" placeholder="İsteğe bağlı kısa not"></textarea>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="modal-btn soft" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="modal-btn primary">Gönder</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .invexp-page{width:min(1280px,calc(100% - 44px));margin:0 auto;padding:18px 0 76px;color:#0f172a}
    .invexp-topbar{margin-bottom:12px}
    .invexp-titleline{display:flex;align-items:center;gap:12px}
    .invexp-titleline h1{margin:0;font-size:30px;font-weight:950;letter-spacing:-.5px}
    .invexp-back{width:38px;height:38px;display:inline-grid;place-items:center;border-radius:13px;background:#eff6ff;color:#2563eb;text-decoration:none;font-size:26px;font-weight:950}
    .btn-primary-action,.btn-secondary-action,.btn-dark-action{min-height:40px;border:0;border-radius:13px;padding:0 14px;font-size:13px;font-weight:950;white-space:nowrap}
    .btn-primary-action{background:#2563eb;color:#fff;box-shadow:0 10px 20px rgba(37,99,235,.16)}
    .btn-secondary-action{background:#fff;color:#334155;border:1px solid #dbe3ef}
    .btn-dark-action{background:#0f172a;color:#fff}
    button:disabled{opacity:.45;cursor:not-allowed;box-shadow:none}
    .invexp-controls{display:grid;gap:10px;margin-bottom:12px}
    .invexp-tabs{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:8px}
    .invexp-tabs a{min-height:44px;padding:0 12px;border-radius:15px;background:#fff;border:1px solid #dbe3ef;color:#334155;text-decoration:none;font-size:12px;font-weight:950;display:flex;align-items:center;justify-content:space-between;gap:8px}
    .invexp-tabs a.active{background:#eff6ff;border-color:#bfdbfe;color:#2563eb}
    .invexp-tabs span{min-width:26px;height:26px;border-radius:999px;background:#f1f5f9;display:grid;place-items:center;color:#64748b}
    .invexp-mobile-tab{display:none}
    .invexp-filter-toggle{display:none}
    .invexp-filter-shell{padding:10px;border-radius:18px;background:#fff;border:1px solid #dbe3ef;display:flex;align-items:end;justify-content:space-between;gap:10px;box-shadow:0 12px 30px rgba(15,23,42,.05)}
    .invexp-quick-presets{display:flex;gap:7px;flex-wrap:wrap}
    .invexp-quick-presets a{min-height:34px;padding:0 12px;border-radius:999px;background:#f8fafc;border:1px solid #dbe3ef;color:#334155;text-decoration:none;font-size:12px;font-weight:900;display:inline-flex;align-items:center}
    .invexp-quick-presets a.active{background:#eff6ff;color:#2563eb;border-color:#bfdbfe}
    .invexp-filter-form{display:grid;grid-template-columns:repeat(2,minmax(138px,180px)) auto;gap:8px;align-items:end}
    .invexp-date-field span,.field label{display:block;margin-bottom:4px;color:#64748b;font-size:11px;font-weight:950}
    .invexp-date-field input,.field input,.field textarea{width:100%;min-height:38px;border-radius:12px;border:1px solid #dbe3ef;background:#f8fafc;padding:0 11px;color:#0f172a;font-size:13px;font-weight:800;outline:none}
    .field textarea{min-height:78px;padding-top:10px;resize:vertical}
    .invexp-list-shell{border-radius:22px;background:#fff;border:1px solid #dbe3ef;box-shadow:0 16px 38px rgba(15,23,42,.065);overflow:hidden}
    .invexp-bulk-bar{min-height:58px;padding:10px 14px;border-bottom:1px solid #e2e8f0;background:#f8fafc;display:flex;align-items:center;gap:10px;flex-wrap:wrap}
    .invexp-bulk-bar strong{font-weight:950}.invexp-bulk-bar span{color:#64748b;font-size:13px;font-weight:850}
    .invexp-select-page{min-height:36px;display:inline-flex;align-items:center;gap:8px;padding:0 12px;border-radius:13px;background:#fff;border:1px solid #dbe3ef;color:#334155;font-size:12px;font-weight:900;cursor:pointer}
    .invexp-select-page input,.invexp-row-check{width:18px;height:18px;accent-color:#2563eb}
    .invexp-selected-count{color:#64748b;font-size:13px;font-weight:900}
    .invexp-bulk-actions{margin-left:auto;display:flex;align-items:center;gap:8px}
    .invexp-table{width:100%;border-collapse:collapse}
    .invexp-table th,.invexp-table td{padding:12px 14px;border-bottom:1px solid #edf2f7;text-align:left;vertical-align:middle;font-size:13px}
    .invexp-table th{background:#fff;color:#64748b;font-size:11px;font-weight:950;text-transform:uppercase;letter-spacing:.25px}
    .invexp-table td{color:#334155;font-weight:800}
    .invexp-table .select-col{width:44px;text-align:center}
    .invexp-table .num{text-align:right;white-space:nowrap}
    .strong{font-weight:950;color:#0f172a}
    .invexp-link{color:#2563eb;font-weight:950;text-decoration:none}
    .action-cell{white-space:nowrap}
    .mini-btn{min-height:32px;margin:2px;padding:0 10px;border-radius:10px;border:1px solid #dbe3ef;background:#fff;color:#334155;text-decoration:none;font-size:12px;font-weight:950;display:inline-flex;align-items:center;justify-content:center}
    .mini-btn.primary{background:#22c55e;color:#fff;border-color:#22c55e}
    .invexp-mobile-list{display:none}
    .invexp-empty{padding:46px 20px;display:grid;place-items:center;text-align:center;color:#64748b}
    .invexp-empty div{width:54px;height:54px;margin-bottom:10px;border-radius:18px;display:grid;place-items:center;background:#f1f5f9;color:#94a3b8;font-size:26px}
    .invexp-empty strong{display:block;color:#0f172a;font-size:18px;font-weight:950;margin-bottom:4px}
    .invexp-modal{border:0;border-radius:22px;overflow:hidden;box-shadow:0 24px 80px rgba(15,23,42,.25)}
    .modal-eyebrow{display:block;color:#2563eb;font-size:11px;font-weight:950;margin-bottom:4px}
    .modal-header,.modal-footer{border-color:#e2e8f0}.modal-info{padding:13px;border-radius:15px;background:#f8fafc;border:1px solid #e2e8f0;color:#64748b;font-size:13px;font-weight:850}.modal-body{display:grid;gap:12px}
    .modal-btn{min-height:40px;border-radius:13px;padding:0 15px;border:0;font-size:13px;font-weight:950}.modal-btn.soft{background:#f1f5f9;color:#334155}.modal-btn.primary{background:#2563eb;color:#fff}
    .invexp-sticky-actions{position:fixed;left:12px;right:12px;bottom:12px;z-index:1030;min-height:58px;padding:10px;border-radius:18px;background:#0f172a;color:#fff;box-shadow:0 18px 52px rgba(15,23,42,.28);display:none;align-items:center;gap:8px}
    .invexp-sticky-actions span{margin-right:auto;font-size:13px;font-weight:950}.invexp-sticky-actions .btn-secondary-action{background:#1e293b;color:#fff;border-color:#334155}
    @@media(max-width:900px){.invexp-page{width:min(100% - 24px,1280px);padding-top:12px}.invexp-tabs{grid-template-columns:repeat(2,minmax(0,1fr))}.invexp-filter-shell{align-items:stretch;flex-direction:column}.invexp-filter-form{grid-template-columns:1fr 1fr auto}}
    @@media(max-width:720px){
        .invexp-page{width:100%;padding:10px 10px 92px}.invexp-titleline h1{font-size:26px}.invexp-tabs{display:none}.invexp-mobile-tab{display:grid;gap:5px}.invexp-mobile-tab label{font-size:11px;font-weight:950;color:#64748b}.invexp-mobile-tab select{width:100%;height:44px;border-radius:15px;border:1px solid #dbe3ef;background:#fff;padding:0 12px;font-size:14px;font-weight:950;color:#0f172a}
        .invexp-filter-toggle{display:block;width:100%;height:40px;border-radius:14px;border:1px solid #dbe3ef;background:#fff;color:#334155;font-size:13px;font-weight:950}.invexp-filter-shell{display:none}.invexp-filter-shell.open{display:flex}.invexp-filter-form{grid-template-columns:1fr}.invexp-quick-presets a{flex:1;justify-content:center}
        .invexp-bulk-bar{min-height:50px}.invexp-bulk-actions{display:none}.invexp-table-wrap{display:none}.invexp-mobile-list{display:grid;gap:0}.invexp-mobile-row{padding:12px 14px;border-bottom:1px solid #edf2f7;background:#fff}.mobile-mainline{display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:9px}.mobile-mainline a{min-width:0;color:#2563eb;text-decoration:none;font-size:14px;font-weight:950;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.mobile-mainline strong{font-size:14px;font-weight:950;white-space:nowrap}.mobile-subline{margin-top:7px;display:flex;align-items:center;gap:8px;color:#475569;font-size:12px;font-weight:850}.mobile-subline span{min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.mobile-date{margin-top:4px;color:#94a3b8;font-size:11px;font-weight:900}.mobile-actions{margin-top:9px;display:flex;gap:6px;flex-wrap:wrap;align-items:center}.mobile-actions>span{font-size:12px;color:#64748b;font-weight:850}.mini-btn{min-height:34px}.invexp-sticky-actions:not([hidden]){display:flex}
    }
</style>

<script>
    (() => {
        const rowChecks = Array.from(document.querySelectorAll(".invexp-row-check"));
        const selectPage = document.querySelector("[data-invexp-select-page]");
        const selectedCount = document.querySelector("[data-invexp-selected-count]");
        const sendButton = document.querySelector("[data-invexp-selected-send]");
        const downloadButton = document.querySelector("[data-invexp-download]");
        const selectedInputs = document.querySelector("[data-invexp-selected-inputs]");
        const downloadInputs = document.querySelector("[data-invexp-download-inputs]");
        const modal = document.getElementById("sendPreparationModal");
        const modalSummary = document.querySelector("[data-invexp-modal-summary]");
        const form = document.getElementById("sendPreparationForm");
        const submitButton = form?.querySelector("button[type='submit']");
        const sticky = document.querySelector("[data-invexp-sticky]");
        const stickyCount = document.querySelector("[data-invexp-sticky-count]");
        let submitInProgress = false;

        function selectedIds() {
            return [...new Set(rowChecks.filter(x => x.checked).map(x => Number(x.value)).filter(x => Number.isInteger(x) && x > 0))];
        }

        function setHiddenInputs(target, ids) {
            if (!target) return;
            target.innerHTML = "";
            ids.forEach(id => {
                const input = document.createElement("input");
                input.type = "hidden";
                input.name = "InvoiceIds";
                input.value = String(id);
                target.appendChild(input);
            });
        }

        function syncDuplicateChecks(source) {
            rowChecks
                .filter(x => x !== source && x.value === source.value)
                .forEach(x => x.checked = source.checked);
        }

        function update() {
            const ids = selectedIds();
            const count = ids.length;
            const text = count === 1 ? "1 kayıt seçildi" : `${count} kayıt seçildi`;
            if (selectedCount) selectedCount.textContent = text;
            if (stickyCount) stickyCount.textContent = text;
            if (sendButton) {
                sendButton.disabled = count === 0;
                sendButton.textContent = count ? `Fatura İçin Gönder (${count})` : "Fatura İçin Gönder";
            }
            if (downloadButton) {
                downloadButton.disabled = count === 0;
                downloadButton.textContent = count ? `Belgeleri İndir (${count})` : "Belgeleri İndir";
            }
            if (selectPage) {
                const uniqueValues = [...new Set(rowChecks.map(x => x.value))];
                selectPage.checked = uniqueValues.length > 0 && uniqueValues.every(value => rowChecks.some(x => x.value === value && x.checked));
                selectPage.indeterminate = count > 0 && !selectPage.checked;
            }
            if (sticky) sticky.hidden = count === 0;
            setHiddenInputs(downloadInputs, ids);
        }

        rowChecks.forEach(check => check.addEventListener("change", () => {
            syncDuplicateChecks(check);
            update();
        }));

        selectPage?.addEventListener("change", () => {
            rowChecks.forEach(check => check.checked = selectPage.checked);
            update();
        });

        document.querySelector("[data-tab-select]")?.addEventListener("change", event => {
            const url = event.target.value;
            if (url) window.location.href = url;
        });

        document.querySelector("[data-filter-toggle]")?.addEventListener("click", () => {
            document.querySelector("[data-filter-panel]")?.classList.toggle("open");
        });

        modal?.addEventListener("show.bs.modal", () => {
            submitInProgress = false;
            const ids = selectedIds();
            setHiddenInputs(selectedInputs, ids);
            if (modalSummary) modalSummary.textContent = `${ids.length} servis hesap özeti için tek yükleme bağlantısı oluşturulacak.`;
            if (submitButton) {
                submitButton.disabled = false;
                submitButton.textContent = "Gönder";
            }
        });

        form?.addEventListener("submit", event => {
            if (submitInProgress) {
                event.preventDefault();
                return;
            }
            submitInProgress = true;
            if (submitButton) {
                submitButton.disabled = true;
                submitButton.textContent = "Gönderiliyor...";
            }
        });

        document.querySelectorAll("[data-mark-delivered]").forEach(button => {
            button.addEventListener("click", async () => {
                const documentId = Number(button.getAttribute("data-document-id"));
                if (!documentId) return;

                const confirmed = window.SenteConfirm
                    ? await window.SenteConfirm.show({
                        title: "Müşteriye iletildi mi?",
                        message: "Bu faturayı müşteriye iletildi olarak işaretlemek istiyor musunuz?",
                        confirmText: "İşaretle",
                        cancelText: "Vazgeç"
                    })
                    : window.confirm("Bu faturayı müşteriye iletildi olarak işaretlemek istiyor musunuz?");

                if (!confirmed) return;

                button.disabled = true;
                const response = await fetch(`/AccountingInvoiceRequests/OfficialDocument/${documentId}/MarkDelivered`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ channel: button.getAttribute("data-channel") || "WhatsApp" })
                });

                if (response.ok) {
                    window.location.reload();
                    return;
                }

                button.disabled = false;
                if (window.SenteToast) window.SenteToast.error("İletim bilgisi kaydedilemedi.");
            });
        });

        document.querySelectorAll("[data-copy-text]").forEach(button => {
            button.addEventListener("click", async () => {
                const text = button.getAttribute("data-copy-text") || "";
                if (!text) return;

                try {
                    await navigator.clipboard.writeText(text);
                    if (window.SenteToast) window.SenteToast.show("Bağlantı kopyalandı.", "success");
                    else button.textContent = "Kopyalandı";
                } catch {
                    if (window.SenteToast) window.SenteToast.error("Bağlantı kopyalanamadı.");
                }
            });
        });

        update();
    })();
</script>
