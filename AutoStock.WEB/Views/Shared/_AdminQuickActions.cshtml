@{
    var userRole = Context.Session.GetString("UserRole");
    var fullName = Context.Session.GetString("FullName");
}

@if (userRole == "Admin")
{
    <div class="admin-quick-actions">
        <div class="admin-quick-user">
            <strong>@(string.IsNullOrWhiteSpace(fullName) ? "Admin" : fullName)</strong>
            <span>Admin Panel</span>
        </div>

        <div class="admin-quick-links">
            <a href="/Admin/Dashboard" class="admin-quick-link">
                Ana Sayfa
            </a>

            <a href="/Admin/Workshops" class="admin-quick-link">
                Servisler
            </a>

            <a href="/AdminSupportRequests/Index" class="admin-quick-link">
                Destek Talepleri
            </a>

            <div class="admin-quick-notification">
                @await Component.InvokeAsync("NotificationBell")
            </div>

            <form asp-controller="Auth"
                  asp-action="Logout"
                  method="post"
                  class="admin-quick-logout-form">
                @Html.AntiForgeryToken()

                <button type="submit" class="admin-quick-logout">
                    Çıkış Yap
                </button>
            </form>
        </div>
    </div>

    <style>
        .admin-quick-notification {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            height: 42px;
        }

            .admin-quick-notification .s360-notification-bell,
            .admin-quick-notification .notification-bell-button,
            .admin-quick-notification a {
                flex: 0 0 auto;
            }

        @@media (max-width: 768px) {
            .admin-quick-actions {
                gap: 10px;
                align-items: flex-start;
            }

            .admin-quick-links {
                flex-wrap: wrap;
                justify-content: flex-end;
            }

            .admin-quick-notification {
                height: 40px;
            }
        }
    </style>
}