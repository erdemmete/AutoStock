@model AutoStock.Services.Dtos.Notifications.NotificationHeaderDto

@{
    var unreadCount = Model?.UnreadCount ?? 0;
    var items = Model?.Items ?? new List<AutoStock.Services.Dtos.Notifications.NotificationListItemDto>();
}

<div class="s360-notification-shell" data-s360-notification>
    <button type="button"
            class="s360-notification-trigger"
            data-s360-notification-trigger
            aria-label="Bildirimler"
            title="Bildirimler">
        <span class="s360-notification-icon">🔔</span>

        @if (unreadCount > 0)
        {
            <strong class="s360-notification-count">
                @(unreadCount > 99 ? "99+" : unreadCount.ToString())
            </strong>
        }
    </button>

    <div class="s360-notification-panel" data-s360-notification-panel>
        <div class="s360-notification-head">
            <div>
                <strong>Bildirimler</strong>
                <span>@(unreadCount > 0 ? $"{unreadCount} okunmamış bildirim" : "Yeni bildirim yok")</span>
            </div>

            @if (unreadCount > 0)
            {
                <form method="post" action="/Notifications/ReadAll">
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                    <button type="submit">Tümünü okundu yap</button>
                </form>
            }
        </div>

        <div class="s360-notification-list">
            @if (!items.Any())
            {
                <div class="s360-notification-empty">
                    <strong>Bildirim yok</strong>
                    <span>Destek yanıtları, fatura yüklemeleri ve önemli iş akışları burada görünecek.</span>
                </div>
            }
            else
            {
                foreach (var item in items)
                {
                    var actionUrl = string.IsNullOrWhiteSpace(item.ActionUrl)
                        ? "/Notifications"
                        : item.ActionUrl;

                    <form method="post"
                          action="/Notifications/@item.Id/Read"
                          class="s360-notification-item @(item.IsRead ? "is-read" : "is-unread")">
                        <input type="hidden" name="returnUrl" value="@actionUrl" />

                        <button type="submit">
                            <span class="s360-notification-dot"></span>

                            <span class="s360-notification-content">
                                <strong>@item.Title</strong>
                                <em>@item.Message</em>
                                <small>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                            </span>
                        </button>
                    </form>
                }
            }
        </div>

        <a href="/Notifications" class="s360-notification-all">
            Tüm bildirimleri gör
        </a>
    </div>
</div>

<style>
    .s360-notification-shell {
        position: relative;
        display: inline-flex;
        z-index: 1000;
    }

    .s360-notification-trigger {
        position: relative;
        width: 48px;
        height: 48px;
        min-width: 48px;
        border: 1px solid #dbe3ef;
        border-radius: 18px;
        background: #ffffff;
        color: #0f172a;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: 0 14px 34px rgba(15, 23, 42, .10);
        transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease;
    }

        .s360-notification-trigger:hover {
            transform: translateY(-1px);
            border-color: #c7d2fe;
            box-shadow: 0 18px 40px rgba(15, 23, 42, .14);
        }

    .s360-notification-icon {
        width: 27px;
        height: 27px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #eef2ff;
        color: #4f46e5;
        font-size: 18px;
        line-height: 1;
    }

    .s360-notification-count {
        position: absolute;
        top: -8px;
        right: -8px;
        min-width: 22px;
        height: 22px;
        padding: 0 6px;
        border-radius: 999px;
        background: #ef4444;
        color: #ffffff;
        border: 2px solid #ffffff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 950;
        line-height: 1;
        box-shadow: 0 8px 18px rgba(239, 68, 68, .28);
    }

    .s360-notification-panel {
        position: absolute;
        top: calc(100% + 12px);
        right: 0;
        width: min(390px, calc(100vw - 24px));
        border-radius: 24px;
        background: #ffffff;
        border: 1px solid #dbe3ef;
        box-shadow: 0 26px 70px rgba(15, 23, 42, .22);
        overflow: hidden;
        display: none;
        z-index: 100000;
    }

    .s360-notification-shell.is-open .s360-notification-panel {
        display: block;
    }

    .s360-notification-head {
        padding: 16px;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
    }

        .s360-notification-head strong {
            display: block;
            color: #0f172a;
            font-size: 17px;
            font-weight: 950;
        }

        .s360-notification-head span {
            display: block;
            margin-top: 4px;
            color: #64748b;
            font-size: 13px;
            font-weight: 800;
        }

        .s360-notification-head form {
            margin: 0;
        }

        .s360-notification-head button {
            border: none;
            background: #eef2ff;
            color: #4f46e5;
            border-radius: 999px;
            height: 32px;
            padding: 0 12px;
            font-size: 12px;
            font-weight: 950;
            cursor: pointer;
            white-space: nowrap;
        }

    .s360-notification-list {
        max-height: 420px;
        overflow: auto;
    }

    .s360-notification-item {
        margin: 0;
        border-bottom: 1px solid #eef2f7;
    }

        .s360-notification-item button {
            width: 100%;
            border: none;
            background: #ffffff;
            padding: 14px 16px;
            display: grid;
            grid-template-columns: 10px minmax(0, 1fr);
            gap: 10px;
            text-align: left;
            cursor: pointer;
        }

        .s360-notification-item.is-unread button {
            background: linear-gradient(90deg, rgba(79, 70, 229, .08), #ffffff 62%);
        }

        .s360-notification-item button:hover {
            background: #f8fafc;
        }

    .s360-notification-dot {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        margin-top: 6px;
        background: transparent;
    }

    .s360-notification-item.is-unread .s360-notification-dot {
        background: #4f46e5;
    }

    .s360-notification-content {
        min-width: 0;
        display: grid;
        gap: 4px;
    }

        .s360-notification-content strong {
            color: #0f172a;
            font-size: 14px;
            font-weight: 950;
            line-height: 1.2;
        }

        .s360-notification-content em {
            color: #475569;
            font-style: normal;
            font-size: 13px;
            font-weight: 750;
            line-height: 1.35;
        }

        .s360-notification-content small {
            color: #94a3b8;
            font-size: 12px;
            font-weight: 850;
        }

    .s360-notification-empty {
        padding: 28px 18px;
        text-align: center;
        display: grid;
        gap: 6px;
    }

        .s360-notification-empty strong {
            color: #0f172a;
            font-size: 15px;
            font-weight: 950;
        }

        .s360-notification-empty span {
            color: #64748b;
            font-size: 13px;
            line-height: 1.4;
            font-weight: 750;
        }

    .s360-notification-all {
        height: 46px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8fafc;
        color: #4f46e5;
        text-decoration: none;
        font-size: 14px;
        font-weight: 950;
    }

        .s360-notification-all:hover {
            background: #eef2ff;
            color: #4f46e5;
            text-decoration: none;
        }

    @@media (max-width: 860px) {
        .s360-notification-trigger {
            width: 44px;
            height: 44px;
            min-width: 44px;
            border-radius: 16px;
        }

        .s360-notification-icon {
            width: 25px;
            height: 25px;
            font-size: 17px;
        }

        .s360-notification-panel {
            position: fixed;
            top: 70px;
            right: 12px;
            left: 12px;
            width: auto;
            max-height: calc(100vh - 90px);
        }

        .s360-notification-list {
            max-height: calc(100vh - 210px);
        }
    }
</style>

<script>
    if (!window.s360NotificationBellBound) {
        window.s360NotificationBellBound = true;

        document.addEventListener("click", function (event) {
            const trigger = event.target.closest("[data-s360-notification-trigger]");
            const shell = event.target.closest("[data-s360-notification]");

            if (trigger) {
                event.preventDefault();
                event.stopPropagation();

                const currentShell = trigger.closest("[data-s360-notification]");

                document.querySelectorAll("[data-s360-notification].is-open").forEach(function (item) {
                    if (item !== currentShell) {
                        item.classList.remove("is-open");
                    }
                });

                currentShell.classList.toggle("is-open");
                return;
            }

            if (!shell) {
                document.querySelectorAll("[data-s360-notification].is-open").forEach(function (item) {
                    item.classList.remove("is-open");
                });
            }
        });

        document.addEventListener("keydown", function (event) {
            if (event.key === "Escape") {
                document.querySelectorAll("[data-s360-notification].is-open").forEach(function (item) {
                    item.classList.remove("is-open");
                });
            }
        });
    }
</script>