@{
    Layout = null;

    const string whatsappPhone = "905384427271";
    const string contactPhone = "0538 442 72 71";
    const string contactEmail = "erdem.mete@bilisimart.com";
    const string siteUrl = "https://sente360.com/";
    const string bilisimartUrl = "https://www.bilisimart.com/";
    var whatsappMessage = Uri.EscapeDataString("Merhaba, Sente360 için tanıtım görüşmesi planlamak istiyorum.");
    var whatsappUrl = $"https://wa.me/{whatsappPhone}?text={whatsappMessage}";
    var loginUrl = Url.Action("Login", "Auth") ?? "/Auth/Login";
    var metaDescription = "Sente360; oto servisler için araç kabul, müşteri ve araç geçmişi, servis işlemleri, fotoğraf kaydı, belge çıktıları, hesap takibi, stok ve fatura süreçlerini tek yerde toplayan web tabanlı servis yönetim platformudur.";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sente360 | Oto servis yönetim platformu</title>
    <meta name="description" content="@metaDescription" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="@siteUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@siteUrl" />
    <meta property="og:title" content="Sente360 | Oto servis yönetim platformu" />
    <meta property="og:description" content="@metaDescription" />
    <meta property="og:site_name" content="Sente360" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
    <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@type": "SoftwareApplication",
          "name": "Sente360",
          "applicationCategory": "BusinessApplication",
          "operatingSystem": "Web",
          "url": "@siteUrl",
          "description": "@metaDescription",
          "creator": {
            "@@type": "Organization",
            "name": "Bilişimart",
            "url": "@bilisimartUrl"
          }
        }
    </script>
</head>
<body>
    <header class="landing-header">
        <div class="landing-header-top">
            <a class="brand" href="/" aria-label="Sente360 ana sayfa">
                <span class="brand-mark">S</span>
                <span>Sente360</span>
            </a>

            <details class="mobile-menu">
                <summary aria-label="Menüyü aç">
                    <span></span>
                    <span></span>
                    <span></span>
                </summary>

                <nav class="mobile-menu-panel" aria-label="Mobil menü">
                    <a href="#ozellikler" onclick="this.closest('details').removeAttribute('open')">Özellikler</a>
                    <a href="#nasil-calisir" onclick="this.closest('details').removeAttribute('open')">Nasıl Çalışır</a>
                    <a href="#kimler-icin" onclick="this.closest('details').removeAttribute('open')">Kimler İçin</a>
                    <a href="#iletisim" onclick="this.closest('details').removeAttribute('open')">İletişim</a>
                    <a class="mobile-menu-primary" href="@whatsappUrl" target="_blank" rel="noopener">WhatsApp’tan Görüşme Planla</a>
                    <a href="@loginUrl">Giriş Yap</a>
                </nav>
            </details>
        </div>

        <nav class="landing-nav" aria-label="Ana menü">
            <a href="#ozellikler">Özellikler</a>
            <a href="#nasil-calisir">Nasıl Çalışır?</a>
            <a href="#kimler-icin">Kimler İçin?</a>
            <a href="#iletisim">İletişim</a>
            <a class="nav-contact" href="@whatsappUrl" target="_blank" rel="noopener">WhatsApp’tan Görüşme Planla</a>
            <a class="nav-login" href="@loginUrl">Giriş Yap</a>
        </nav>
    </header>

    <main>
        <section class="hero-section" id="tanitim">
            <div class="hero-copy">
                <p class="eyebrow">Oto servis yönetim platformu</p>
                <h1>Sente360, oto servisinizin araç kabulden fatura takibine kadar tüm servis sürecini dijitalleştirir.</h1>
                <p class="hero-text">
                    Araç kabul, müşteri ve araç geçmişi, servis işlemleri, fotoğraf kaydı,
                    belge çıktıları, hesap takibi, stok ve fatura süreçlerini tek yerde toplayan
                    web tabanlı yönetim platformu.
                </p>

                <div class="hero-actions">
                    <a class="primary-action" href="@whatsappUrl" target="_blank" rel="noopener">WhatsApp’tan Tanıtım Görüşmesi Planla</a>
                    <a class="secondary-action" href="@loginUrl">Giriş Yap</a>
                </div>
            </div>

            <div class="hero-product" aria-label="Sente360 ürün önizlemesi">
                <div class="hero-window">
                    <div class="window-bar">
                        <span></span>
                        <strong>Servis Akışı</strong>
                        <small>Hızlı kayıt</small>
                    </div>

                    <div class="metric-strip">
                        <div>
                            <span>Açık Kayıt</span>
                            <strong>14</strong>
                        </div>
                        <div>
                            <span>Bugünkü Kabul</span>
                            <strong>6</strong>
                        </div>
                        <div>
                            <span>Hazır Araç</span>
                            <strong>3</strong>
                        </div>
                    </div>

                    <div class="service-card active">
                        <div>
                            <strong>34 SNT 360</strong>
                            <span>Fren kontrolü ve bakım talebi</span>
                        </div>
                        <em>İşlemde</em>
                    </div>

                    <div class="service-card">
                        <div>
                            <strong>06 SRV 145</strong>
                            <span>Yağ bakımı, filtre ve genel kontrol</span>
                        </div>
                        <em>Bekliyor</em>
                    </div>

                    <div class="mini-panel">
                        <div>
                            <span>Belge</span>
                            <strong>Ön kabul hazır</strong>
                        </div>
                        <div>
                            <span>Bildirim</span>
                            <strong>PDF yüklendi</strong>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="trust-tags" aria-label="Sente360 güven etiketleri">
            <span><strong>Servis kaydı</strong><small>Araç kabulünü ve işlem sürecini hızlıca başlatın.</small></span>
            <span><strong>Müşteri ve araç bilgisi</strong><small>Geçmiş kayıtları, talepleri ve araç detaylarını düzenli tutun.</small></span>
            <span><strong>Hesap özeti ve fatura takibi</strong><small>Tahsilat ve fatura sürecini birlikte izleyin.</small></span>
            <span><strong>Stok yönetimi</strong><small>Parça ve sarf malzemesi hareketlerini servis akışıyla bağlayın.</small></span>
            <span><strong>Sente360 Destek</strong><small>Sorularınızı ve destek taleplerinizi panelden iletin; Sente360 ekibinden dönüş alın.</small></span>
        </section>

        <section class="content-band problem-band">
            <div class="section-heading">
                <p class="eyebrow">Problem</p>
                <h2>Defter, WhatsApp ve dağınık notlarla servis takibi zorlaşır.</h2>
            </div>

            <ul class="problem-list">
                <li>Eski araç geçmişini bulmak zaman alır.</li>
                <li>Müşteri talepleri ve yapılan işlemler karışabilir.</li>
                <li>Fotoğraflar personel telefonunda kalır.</li>
                <li>Fiyat, işçilik ve parça kayıtları dağınık ilerler.</li>
                <li>Müşteriye profesyonel belge sunmak zorlaşır.</li>
            </ul>
        </section>

        <section class="content-band" id="ozellikler">
            <div class="section-heading">
                <p class="eyebrow">Özellikler</p>
                <h2>Sente360 servis akışınızı baştan sona düzenler.</h2>
                <p>
                    Dağınık servis kayıtlarını tek yerde toplayın; müşteri, araç, işlem,
                    fotoğraf ve belge geçmişine ekip olarak düzenli şekilde erişin.
                </p>
            </div>

            <div class="feature-grid">
                <article>
                    <span>01</span>
                    <h3>Hızlı araç kabul</h3>
                    <p>Plaka, müşteri ve araç bilgileriyle servis kaydını hızlıca başlatın.</p>
                </article>
                <article>
                    <span>02</span>
                    <h3>Müşteri ve araç geçmişi</h3>
                    <p>Önceki gelişleri, işlemleri ve belge kayıtlarını aynı yerde görün.</p>
                </article>
                <article>
                    <span>03</span>
                    <h3>Şikayet/talep bazlı kayıt</h3>
                    <p>Müşteri taleplerini servis kaydı içinde düzenli başlıklar halinde takip edin.</p>
                </article>
                <article>
                    <span>04</span>
                    <h3>Fotoğraf kayıtları</h3>
                    <p>Teslim alma ve işlem fotoğraflarını servis kaydına bağlayın.</p>
                </article>
                <article>
                    <span>05</span>
                    <h3>Servis ön kabul ve kayıt belgeleri</h3>
                    <p>Araç kabul ve servis işlem kayıtlarını müşteriye düzenli belge olarak sunun.</p>
                </article>
                <article>
                    <span>06</span>
                    <h3>Hesap özeti ve fatura</h3>
                    <p>Parça, işçilik, hesap özeti ve fatura takibi adımlarını servis kaydının devamında yürütün.</p>
                </article>
                <article>
                    <span>07</span>
                    <h3>QR ile araç geçmişi</h3>
                    <p>Araç geçmişine QR kod ile daha hızlı erişim sağlayın.</p>
                </article>
                <article>
                    <span>08</span>
                    <h3>Destek ve bildirim merkezi</h3>
                    <p>Katalog, fatura ve kullanım taleplerinizi Sente360 Destek üzerinden iletin; yanıtları ve önemli bildirimleri panelden takip edin.</p>
                </article>
            </div>
        </section>

        <section class="content-band process-band" id="nasil-calisir">
            <div class="section-heading">
                <p class="eyebrow">Nasıl Çalışır</p>
                <h2>Servis akışı hızlı kabulden belge ve faturaya uzanır.</h2>
                <p>
                    Amaç her adımı büyütmek değil; aracı hızlı bulmak, işlemi kaybetmeden yürütmek
                    ve servis sonunda müşteriye düzenli belge ile net hesap sunmaktır.
                </p>
            </div>

            <ol class="timeline">
                <li>
                    <span>1</span>
                    <div>
                        <h3>Araç plaka veya QR ile bulunur</h3>
                        <p>Gelen araç hızlıca sisteme tanıtılır ya da mevcut geçmişi açılır.</p>
                    </div>
                </li>
                <li>
                    <span>2</span>
                    <div>
                        <h3>Servis kaydı hızlıca başlatılır</h3>
                        <p>Şikayet, talep, fotoğraf ve ilk notlar aynı kayıt altında toplanır.</p>
                    </div>
                </li>
                <li>
                    <span>3</span>
                    <div>
                        <h3>İşlem, parça ve işçilik eklenir</h3>
                        <p>Yapılan işlemler, kullanılan parçalar ve işçilik kalemleri düzenli ilerler.</p>
                    </div>
                </li>
                <li>
                    <span>4</span>
                    <div>
                        <h3>PDF servis çıktısı paylaşılır</h3>
                        <p>İşlem tamamlanınca servis kaydı PDF olarak araç sahibine iletilebilir.</p>
                    </div>
                </li>
                <li>
                    <span>5</span>
                    <div>
                        <h3>Hesap özeti ve fatura süreci takip edilir</h3>
                        <p>Servis hesabı netleştirilir, fatura takibi ve muhasebe PDF süreci düzenli şekilde izlenir.</p>
                    </div>
                </li>
                <li>
                    <span>6</span>
                    <div>
                        <h3>Geçmiş sonraki gelişte hazırdır</h3>
                        <p>Aynı araç geldiğinde geçmiş işlemler ve belgeler tekrar kolayca görüntülenir.</p>
                    </div>
                </li>
            </ol>
        </section>

        <section class="product-story">
            <div class="section-heading">
                <p class="eyebrow">Tek panelden takip</p>
                <h2>Servis kabul, işlem takibi, bildirim ve fatura akışı aynı düzen içinde ilerler.</h2>
            </div>

            <div class="flow-mockup">
                <aside>
                    <strong>Sente360</strong>
                    <span>Genel Bakış</span>
                    <span>Servis Akışı</span>
                    <span>Hesap İşlemleri</span>
                    <span>Fatura Takibi</span>
                    <span>Destek</span>
                </aside>

                <div class="mock-main">
                    <div class="mock-toolbar">
                        <div>
                            <span>Bugün</span>
                            <strong>Günlük servis akışı</strong>
                        </div>
                        <em>3 yeni bildirim</em>
                    </div>

                    <div class="mock-stats">
                        <article><span>Bekleyen</span><strong>8</strong></article>
                        <article><span>İşlemde</span><strong>14</strong></article>
                        <article><span>Takipte</span><strong>5</strong></article>
                    </div>

                    <div class="mock-row">
                        <strong>34 ABC 123</strong>
                        <span>Kaporta kontrolü</span>
                        <em>Fotoğraf eklendi</em>
                    </div>
                    <div class="mock-row">
                        <strong>35 KLM 789</strong>
                        <span>Periyodik bakım</span>
                        <em>Fatura takibi</em>
                    </div>
                    <div class="mock-row">
                        <strong>16 SRV 040</strong>
                        <span>Elektrik arıza kontrolü</span>
                        <em>Destek yanıtı</em>
                    </div>
                </div>
            </div>
        </section>

        <section class="content-band trust-band">
            <div class="section-heading">
                <p class="eyebrow">Veri düzeni</p>
                <h2>Kayıtlar işletme bazında düzenli ve erişilebilir kalır.</h2>
            </div>
            <div class="trust-layout">
                <p>
                    Sente360’da müşteri, araç, servis kaydı, fotoğraf, belge ve fatura bilgileri
                    işletme düzenine göre tutulur. Ekip içinde kimin hangi işlemleri yapacağı
                    yetki seviyelerine göre ayrıştırılabilir.
                </p>
                <div class="trust-points">
                    <span>İşletmeye özel müşteri ve araç kayıtları</span>
                    <span>Ekip içi yetki seviyelerine göre kullanım</span>
                    <span>Sente360 Destek talepleri ve bildirimlerinde düzenli takip</span>
                </div>
            </div>
        </section>

        <section class="content-band audience-band" id="kimler-icin">
            <div class="section-heading">
                <p class="eyebrow">Kimler için?</p>
                <h2>Farklı servis türleri için düzenli çalışma alanı.</h2>
                <p>Sente360; araç kabul, işlem takibi ve servis geçmişini daha düzenli yönetmek isteyen farklı servis türleri için uygundur.</p>
            </div>

            <div class="audience-grid">
                <article>
                    <span aria-hidden="true">OS</span>
                    <h3>Özel oto servisleri</h3>
                    <p>Araç kabul, servis geçmişi ve müşteri kayıtlarını düzenli tutmak isteyen işletmeler.</p>
                </article>
                <article>
                    <span aria-hidden="true">MB</span>
                    <h3>Mekanik bakım servisleri</h3>
                    <p>Periyodik bakım, parça/işçilik ve işlem kayıtlarını tek yerden takip eden servisler.</p>
                </article>
                <article>
                    <span aria-hidden="true">KB</span>
                    <h3>Kaporta/boya işletmeleri</h3>
                    <p>Teslim alma fotoğrafları, hasar notları ve işlem sürecini kayıt altında tutmak isteyen atölyeler.</p>
                </article>
                <article>
                    <span aria-hidden="true">OE</span>
                    <h3>Oto elektrik servisleri</h3>
                    <p>Arıza talepleri, yapılan işlemler ve araç geçmişini düzenli izlemek isteyen servisler.</p>
                </article>
                <article>
                    <span aria-hidden="true">LB</span>
                    <h3>Lastik/bakım işletmeleri</h3>
                    <p>Hızlı kayıt, müşteri geçmişi ve bakım notlarını pratik şekilde takip etmek isteyen işletmeler.</p>
                </article>
                <article>
                    <span aria-hidden="true">AT</span>
                    <h3>Küçük ve orta ölçekli atölyeler</h3>
                    <p>Defter, WhatsApp ve dağınık notlardan daha düzenli bir sisteme geçmek isteyen ekipler.</p>
                </article>
            </div>
        </section>

        <section class="company-band" aria-label="Bilişimart bilgisi">
            <div class="company-card">
                <div>
                    <p class="eyebrow">Bilişimart ürünü</p>
                    <h2>Sente360, Bilişimart tarafından geliştirilen bir servis yönetim ürünüdür.</h2>
                    <p>
                        Oto servis yönetimi dışında işletmenize özel yazılım, entegrasyon veya süreç
                        otomasyonu ihtiyacınız varsa Bilişimart üzerinden iletişime geçebilirsiniz.
                    </p>
                </div>
                <a class="secondary-action company-link" href="@bilisimartUrl" target="_blank" rel="noopener">Bilişimart’ı ziyaret et</a>
            </div>
        </section>

        <section class="cta-section" id="iletisim">
            <div>
                <p class="eyebrow">İletişim</p>
                <h2>Servisiniz için kısa bir tanıtım görüşmesi planlayalım.</h2>
                <p>Görüşmede hızlı araç kabul, QR/plaka ile geçmiş erişimi, servis PDF’i, hesap özeti ve fatura akışını birlikte gözden geçirebiliriz.</p>
                <div class="contact-links">
                    <a href="tel:+905384427271">@contactPhone</a>
                    <a href="mailto:@contactEmail">@contactEmail</a>
                </div>
            </div>
            <a class="primary-action" href="@whatsappUrl" target="_blank" rel="noopener">WhatsApp’tan Görüşme Planla</a>
        </section>

        <section class="content-band faq-band">
            <div class="section-heading">
                <p class="eyebrow">Sıkça sorulan sorular</p>
                <h2>Tanıtım görüşmesi öncesi merak edilenler.</h2>
            </div>

            <div class="faq-list">
                <details>
                    <summary>Web tabanlı mı?</summary>
                    <p>Evet. Sente360 web tabanlı çalışır; servis kullanıcıları yetkileri dahilinde panelden işlem yapar.</p>
                </details>
                <details>
                    <summary>Tanıtım görüşmesi nasıl ilerler?</summary>
                    <p>WhatsApp üzerinden iletişime geçilir, kısa bir görüşme planlanır ve örnek servis akışı birlikte incelenir.</p>
                </details>
                <details>
                    <summary>Belge çıktısı alınabilir mi?</summary>
                    <p>Servis ön kabul ve servis işlem kayıtları için müşteriye sunulabilecek düzenli belge çıktıları bulunur.</p>
                </details>
                <details>
                    <summary>Araç geçmişi görülebilir mi?</summary>
                    <p>Araç ve müşteri geçmişi servis kayıtlarıyla birlikte tutulur; sonraki gelişlerde daha hızlı erişilebilir.</p>
                </details>
            </div>
        </section>
    </main>

    <footer class="landing-footer">
        <span>Sente360 © 2026</span>
        <div>
            <a href="tel:+905384427271">@contactPhone</a>
            <a href="mailto:@contactEmail">@contactEmail</a>
            <a href="@loginUrl">Giriş Yap</a>
            <a href="@whatsappUrl" target="_blank" rel="noopener">WhatsApp’tan Görüşme Planla</a>
        </div>
    </footer>
</body>
</html>
