@{
    ViewData["Title"] = "Sente360 | Servis Formu";
}

<style>
    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        background: radial-gradient(circle at top left, rgba(37, 99, 235, .10), transparent 28rem), radial-gradient(circle at top right, rgba(22, 163, 74, .10), transparent 28rem), #f3f6fb;
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: #0f172a;
    }

    .page {
        width: min(1420px, calc(100% - 48px));
        margin: 0 auto;
        padding: 36px 0 60px;
    }

    .premium-header {
        position: relative;
        overflow: hidden;
        margin-bottom: 28px;
        padding: 32px 36px;
        border-radius: 32px;
        background: radial-gradient(circle at 92% 35%, rgba(255,255,255,.16), transparent 18rem), linear-gradient(135deg, #07111f 0%, #111827 42%, #1d4ed8 100%);
        color: white;
        box-shadow: 0 28px 80px rgba(15, 23, 42, .24);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .premium-brand {
        display: flex;
        align-items: center;
        gap: 22px;
        position: relative;
        z-index: 1;
    }

    .premium-logo {
        width: 50px;
        height: 50px;
        border-radius: 17px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #2563eb, #16a34a);
        color: white;
        font-weight: 950;
    }

    .premium-eyebrow {
        display: inline-flex;
        margin-bottom: 7px;
        padding: 6px 11px;
        border-radius: 999px;
        background: rgba(255,255,255,.13);
        border: 1px solid rgba(255,255,255,.18);
        color: rgba(255,255,255,.80);
        font-size: 12px;
        font-weight: 800;
    }

    .premium-header h1 {
        margin: 0;
        font-size: 36px;
        line-height: 1;
        letter-spacing: -1.7px;
    }

    .premium-header p {
        margin: 12px 0 0;
        max-width: 700px;
        color: rgba(255,255,255,.72);
        font-size: 15px;
        line-height: 1.55;
    }

    .premium-home {
        width: 54px;
        height: 54px;
        display: grid;
        place-items: center;
        border-radius: 18px;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.18);
        color: white;
        text-decoration: none;
        font-size: 22px;
        position: relative;
        z-index: 1;
    }

    .layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 390px;
        gap: 24px;
        align-items: start;
    }

    .panel {
        background: rgba(255,255,255,.90);
        border: 1px solid #e2e8f0;
        border-radius: 30px;
        padding: 24px;
        box-shadow: 0 22px 55px rgba(15, 23, 42, .08);
        backdrop-filter: blur(18px);
    }

    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
    }

    .card {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        padding: 22px;
        box-shadow: 0 12px 30px rgba(15, 23, 42, .045);
    }

        .card.full {
            grid-column: 1 / -1;
        }

        .card h3,
        .summary h3 {
            margin: 0 0 18px;
            font-size: 21px;
            letter-spacing: -0.5px;
            color: #0f172a;
        }

    .fields {
        display: grid;
        gap: 15px;
    }

    .two {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    label {
        display: block;
        margin-bottom: 8px;
        font-size: 13px;
        font-weight: 800;
        color: #334155;
    }

    input,
    select,
    textarea {
        width: 100%;
        min-height: 52px;
        border: 1px solid #dbe3ef;
        border-radius: 16px;
        background: #f8fafc;
        padding: 13px 15px;
        font: inherit;
        font-size: 15px;
        color: #0f172a;
        outline: none;
        transition: .18s ease;
    }

        input::placeholder,
        textarea::placeholder {
            color: #94a3b8;
        }

        input:focus,
        select:focus,
        textarea:focus {
            border-color: #2563eb;
            background: white;
            box-shadow: 0 0 0 4px rgba(37, 99, 235, .11);
        }

    textarea {
        min-height: 105px;
        resize: vertical;
    }

    .operation-row {
        display: grid;
        grid-template-columns: 130px 1fr 90px 140px 110px;
        gap: 12px;
        align-items: end;
    }

    button {
        border: none;
        border-radius: 16px;
        min-height: 52px;
        padding: 0 20px;
        font: inherit;
        font-weight: 900;
        cursor: pointer;
        transition: .18s ease;
    }

    .btn-blue {
        background: #2563eb;
        color: white;
        box-shadow: 0 12px 25px rgba(37, 99, 235, .20);
    }

        .btn-blue:hover {
            background: #1d4ed8;
            transform: translateY(-1px);
        }

    .btn-green {
        width: 100%;
        min-height: 56px;
        background: #16a34a;
        color: white;
        font-size: 16px;
        border-radius: 18px;
        box-shadow: 0 14px 28px rgba(22, 163, 74, .22);
    }

        .btn-green:hover {
            background: #15803d;
            transform: translateY(-1px);
        }

    .summary {
        position: sticky;
        top: 24px;
        max-width: 390px;
    }

    .summary-line {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        padding: 12px 0;
        border-bottom: 1px solid #e2e8f0;
        font-size: 14px;
    }

        .summary-line span {
            color: #64748b;
            font-weight: 700;
        }

        .summary-line strong {
            text-align: right;
            font-weight: 900;
            color: #0f172a;
        }

    .total {
        margin: 22px 0;
        padding: 22px;
        border-radius: 22px;
        background: linear-gradient(135deg, #0f172a, #1e293b);
        color: white;
    }

        .total span {
            color: rgba(255,255,255,.66);
            font-weight: 700;
        }

        .total strong {
            display: block;
            margin-top: 8px;
            font-size: 32px;
            letter-spacing: -1.3px;
        }

    .operation-list {
        margin-top: 18px;
        display: grid;
        gap: 10px;
    }

    .operation-item {
        position: relative;
        display: block;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        border-radius: 18px;
        padding: 14px;
        transition: .18s ease;
    }

    .badge {
        padding: 8px 11px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 900;
        text-align: center;
    }

        .badge.part {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .badge.labor {
            background: #dcfce7;
            color: #15803d;
        }

    .operation-note {
        display: none;
        margin-top: 12px;
        margin-left: 124px;
        padding: 12px 14px;
        border-radius: 14px;
        background: white;
        border: 1px solid #e2e8f0;
        color: #475569;
        font-size: 13px;
        line-height: 1.55;
    }

        .operation-note.open {
            display: block;
        }

    .delete {
        width: 38px;
        height: 38px;
        min-height: 38px;
        padding: 0;
        border-radius: 14px;
        background: #fee2e2;
        color: #b91c1c;
        font-size: 18px;
        font-weight: 900;
    }

    }

    @@media(max-width: 1150px) {
        .layout {
            grid-template-columns: 1fr;
        }

        .summary {
            position: static;
        }
    }

    @@media(max-width: 800px) {
        .page {
            width: min(100% - 28px, 1420px);
            padding-top: 20px;
        }

        .premium-header {
            padding: 24px;
            align-items: flex-start;
        }

        .premium-logo {
            width: 62px;
            height: 62px;
            border-radius: 22px;
        }

        .premium-header h1 {
            font-size: 29px;
        }

        .grid,
        .two,
        .operation-row {
            grid-template-columns: 150px minmax(280px, 1fr) 110px 170px auto;
        }

        .panel {
            padding: 18px;
            border-radius: 24px;
        }
    }

    .card,
    .panel,
    .summary,
    .premium-header {
        transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease;
    }

        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 18px 42px rgba(15, 23, 42, .075);
            border-color: #cbd5e1;
        }

        .summary:hover {
            box-shadow: 0 28px 70px rgba(15, 23, 42, .11);
        }

    input:hover,
    select:hover,
    textarea:hover {
        border-color: #cbd5e1;
        background: #ffffff;
    }

    input,
    select,
    textarea,
    button {
        transition: border-color .18s ease, box-shadow .18s ease, background .18s ease, transform .18s ease;
    }

    .btn-green {
        background: linear-gradient(135deg, #16a34a, #15803d);
    }

        .btn-green:hover {
            background: linear-gradient(135deg, #15803d, #166534);
            transform: translateY(-2px);
            box-shadow: 0 20px 40px rgba(22, 163, 74, .30);
        }

        .btn-green:active,
        .btn-blue:active {
            transform: translateY(0) scale(.98);
        }

    .premium-home:hover {
        background: rgba(255,255,255,.22);
        transform: translateY(-2px);
        box-shadow: 0 14px 28px rgba(0,0,0,.18);
    }

    .total {
        box-shadow: inset 0 1px 0 rgba(255,255,255,.08), 0 18px 34px rgba(15,23,42,.16);
    }

    .operation-item {
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    }

        .operation-item:hover {
            border-color: #cbd5e1;
            box-shadow: 0 12px 26px rgba(15,23,42,.07);
            transform: translateY(-1px);
        }

    .badge {
        box-shadow: inset 0 1px 0 rgba(255,255,255,.45);
    }

    .delete:hover {
        background: #fecaca;
        transform: scale(1.05);
    }

    .premium-logo {
        transition: transform .22s ease, box-shadow .22s ease;
    }

    .premium-header:hover .premium-logo {
        transform: rotate(-3deg) scale(1.04);
        box-shadow: 0 22px 48px rgba(37, 99, 235, .42);
    }

    .field-error {
        margin-top: 6px;
        color: #dc2626;
        font-size: 12px;
        font-weight: 700;
        display: none;
    }

    .input-invalid {
        border-color: #ef4444 !important;
        background: #fff7f7 !important;
        box-shadow: 0 0 0 4px rgba(239, 68, 68, .10) !important;
    }

    .form-field {
        position: relative;
    }

        .form-field input,
        .form-field select,
        .form-field textarea {
            padding-top: 20px;
        }

        .form-field label {
            position: absolute;
            top: 16px;
            left: 15px;
            margin: 0;
            padding: 0 6px;
            background: #f8fafc;
            color: #64748b;
            font-size: 14px;
            font-weight: 700;
            pointer-events: none;
            transition: .18s ease;
            border-radius: 8px;
        }

        .form-field input:focus + label,
        .form-field input:not(:placeholder-shown) + label,
        .form-field textarea:focus + label,
        .form-field textarea:not(:placeholder-shown) + label {
            top: -8px;
            left: 12px;
            background: white;
            color: #2563eb;
            font-size: 11px;
        }

        .form-field select + label {
            top: -8px;
            left: 12px;
            background: white;
            color: #2563eb;
            font-size: 11px;
        }

        .form-field input:focus,
        .form-field select:focus,
        .form-field textarea:focus {
            transform: translateY(-1px);
        }

    .operation-main {
        display: grid;
        grid-template-columns: 110px 1fr 130px 42px;
        gap: 14px;
        align-items: center;
    }

    .operation-note {
        max-height: 0;
        overflow: hidden;
        font-size: 13px;
        color: #475569;
        margin-left: 90px;
        transition: .25s ease;
    }

        .operation-note.open {
            margin-top: 8px;
            max-height: 200px;
        }

    .operation-info strong {
        display: block;
        font-size: 15px;
        color: #0f172a;
    }

    .operation-info span {
        display: block;
        margin-top: 4px;
        color: #475569;
        font-size: 13px;
    }

    .operation-price {
        text-align: right;
        font-weight: 900;
        color: #0f172a;
    }

    .note-toggle {
        margin-top: 8px;
        border: none;
        background: transparent;
        color: #2563eb;
        font-size: 12px;
        font-weight: 800;
        padding: 0;
        min-height: auto;
    }
    @@media (max-width: 1200px) {
        .page {
            width: min(100% - 32px, 1420px);
        }

        .layout {
            grid-template-columns: 1fr;
        }

        .summary {
            position: static;
            max-width: none;
        }
    }

    @@media (max-width: 900px) {
        .premium-header {
            padding: 24px;
            border-radius: 26px;
        }

        .premium-brand {
            align-items: flex-start;
        }

        .premium-logo {
            width: 62px;
            height: 62px;
            border-radius: 22px;
            font-size: 22px;
            flex-shrink: 0;
        }

        .premium-header h1 {
            font-size: 28px;
            line-height: 1.1;
        }

        .premium-header p {
            font-size: 14px;
        }

        .grid {
            grid-template-columns: 1fr;
        }

        .two {
            grid-template-columns: 1fr;
        }

        .operation-row {
            grid-template-columns: 1fr;
        }

        .btn-blue {
            width: 100%;
        }

        .operation-main {
            grid-template-columns: 1fr auto;
            gap: 12px;
        }

            .operation-main .badge {
                width: fit-content;
            }

        .operation-price {
            text-align: left;
        }

        .delete {
            grid-column: 2;
            grid-row: 1;
        }

        .operation-info {
            grid-column: 1 / -1;
        }

        .operation-note {
            margin-left: 0;
        }
    }

    @@media (max-width: 600px) {
        .page {
            width: 100%;
            padding: 14px;
        }

        .premium-header {
            margin-bottom: 18px;
            padding: 20px;
        }

        .premium-brand {
            gap: 14px;
        }

        .premium-home {
            width: 44px;
            height: 44px;
            border-radius: 15px;
            font-size: 18px;
        }

        .panel {
            padding: 16px;
            border-radius: 22px;
        }

        .card {
            padding: 18px;
            border-radius: 20px;
        }

            .card h3,
            .summary h3 {
                font-size: 20px;
            }

        input,
        select,
        textarea {
            min-height: 50px;
            font-size: 15px;
        }

        .form-field label {
            max-width: calc(100% - 24px);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .summary-line {
            font-size: 14px;
        }

        .total {
            padding: 20px;
        }

            .total strong {
                font-size: 32px;
            }

        .btn-green {
            min-height: 56px;
        }
    }

</style>

<div class="page">

    <section class="premium-header">
        <div class="premium-brand">
            <div class="premium-logo">S360</div>

            <div>
                <div class="premium-eyebrow">Sente360 V1</div>
                <h1>Servis Formu Oluştur</h1>
                <p>Parça, işçilik ve araç bilgilerini tek ekrandan profesyonel PDF formuna dönüştür.</p>
            </div>
        </div>

        <a class="premium-home" href="/Dashboard/Index" title="Ana sayfa">
            <span>⌂</span>
        </a>
    </section>

    <div class="layout">

        <main class="panel">
            <div class="grid">
                <section class="card">
                    <h3>Müşteri Bilgileri</h3>

                    <div class="fields">
                        <div class="form-field">
                            <input id="customerName" placeholder=" " />
                            <label for="customerName">Ad Soyad</label>
                            <div class="field-error" id="customerNameError">Bu alan zorunlu.</div>
                        </div>

                        <div class="form-field">
                            <input id="customerPhone" inputmode="numeric" placeholder=" " />
                            <label for="customerPhone">Cep Numarası</label>
                            <div class="field-error" id="customerPhoneError">Cep numarası sadece rakam içermeli.</div>
                        </div>

                        <div class="form-field">
                            <input id="customerEmail" type="email" placeholder=" " />
                            <label for="customerEmail">Mail Adresi</label>
                        </div>
                    </div>
                </section>

                <section class="card">
                    <h3>Araç Bilgileri</h3>

                    <div class="fields">
                        <div class="form-field">
                            <input id="plate" placeholder=" " />
                            <label for="plate">Plaka</label>
                            <div class="field-error" id="plateError">Plaka boş bırakılamaz.</div>
                        </div>

                        <div class="two">
                            <div class="form-field">
                                <input id="brand" placeholder=" " />
                                <label for="brand">Marka</label>
                            </div>

                            <div class="form-field">
                                <input id="model" placeholder=" " />
                                <label for="model">Model</label>
                            </div>
                        </div>

                        <div class="form-field">
                            <input id="modelYear" inputmode="numeric" pattern="[0-9]*" placeholder=" " />
                            <label for="modelYear">Model Yılı</label>
                            <div class="field-error" id="modelYearError">Model yılı 4 haneli olmalı.</div>
                        </div>
                    </div>
                </section>

                <section class="card full">
                    <h3>Parça / İşçilik</h3>

                    <div class="operation-row">
                        <div class="form-field">
                            <select id="operationType">
                                <option value="Parça">Parça</option>
                                <option value="İşçilik">İşçilik</option>
                            </select>
                            <label for="operationType">Tür</label>
                        </div>

                        <div class="form-field">
                            <select id="operationName">
                                <option value="">İşlem seç</option>
                                <option>Fren disk değişimi</option>
                                <option>Yağ değişimi</option>
                                <option>Filtre değişimi</option>
                                <option>Balata değişimi</option>
                                <option>Lastik değişimi</option>
                                <option>Akü değişimi</option>
                                <option>Genel bakım</option>
                                <option>Diğer</option>
                            </select>
                            <label for="operationName">İşlem</label>
                        </div>

                        <div class="form-field">
                            <input id="operationQty" type="number" value="1" min="1" placeholder=" " />
                            <label for="operationQty">Adet</label>
                        </div>

                        <div class="form-field">
                            <input id="operationPrice" type="number" min="0" placeholder=" " />
                            <label for="operationPrice">Birim Fiyat</label>
                        </div>

                        <button type="button" class="btn-blue" onclick="addOperation()">+ Ekle</button>
                    </div>

                    <div class="form-field" style="margin-top:16px;">
                        <textarea id="notes" placeholder=" "></textarea>
                        <label for="notes">Ek Açıklama</label>
                    </div>

                    <div id="operationList" class="operation-list"></div>
                </section>
            </div>
        </main>

        <aside class="panel summary">
            <h3>Form Özeti</h3>

            <div class="summary-line">
                <span>Müşteri</span>
                <strong id="sumCustomer">—</strong>
            </div>

            <div class="summary-line">
                <span>Telefon</span>
                <strong id="sumPhone">—</strong>
            </div>

            <div class="summary-line">
                <span>Araç</span>
                <strong id="sumVehicle">—</strong>
            </div>

            <div class="summary-line">
                <span>Plaka</span>
                <strong id="sumPlate">—</strong>
            </div>

            <div class="summary-line">
                <span>Parça Sayısı</span>
                <strong id="sumPartCount">0</strong>
            </div>

            <div class="summary-line">
                <span>İşçilik Sayısı</span>
                <strong id="sumLaborCount">0</strong>
            </div>

            <div class="total">
                <span>Toplam Tutar</span>
                <strong id="totalText">₺0,00</strong>
            </div>

            <button class="btn-green" onclick="createPdf()">PDF Oluştur</button>
        </aside>

    </div>
</div>

<script>
    const operations = [];

    const formatter = new Intl.NumberFormat("tr-TR", {
        style: "currency",
        currency: "TRY"
    });

    function get(id) {
        return document.getElementById(id);
    }

    function setError(inputId, messageId, hasError) {
        const input = get(inputId);
        const message = get(messageId);

        if (!input || !message) return;

        if (hasError) {
            input.classList.add("input-invalid");
            message.style.display = "block";
        } else {
            input.classList.remove("input-invalid");
            message.style.display = "none";
        }
    }

    function showTemporaryError(inputId, messageId) {
        setError(inputId, messageId, true);

        setTimeout(() => {
            setError(inputId, messageId, false);
        }, 1500);
    }

    function updateSummary() {
        const brand = get("brand").value.trim();
        const model = get("model").value.trim();

        const total = operations.reduce((sum, x) => sum + (x.quantity * x.unitPrice), 0);
        const partCount = operations.filter(x => x.type === "Parça").length;
        const laborCount = operations.filter(x => x.type === "İşçilik").length;

        get("sumCustomer").innerText = get("customerName").value || "—";
        get("sumPhone").innerText = get("customerPhone").value || "—";
        get("sumVehicle").innerText = `${brand} ${model}`.trim() || "—";
        get("sumPlate").innerText = get("plate").value.toUpperCase() || "—";
        get("sumPartCount").innerText = partCount;
        get("sumLaborCount").innerText = laborCount;
        get("totalText").innerText = formatter.format(total);
    }

    function addOperation() {
        const type = get("operationType").value;
        const name = get("operationName").value;
        const quantity = Number(get("operationQty").value);
        const unitPrice = Number(get("operationPrice").value || 0);

        if (!name) {
            alert("İşlem seçmelisin.");
            return;
        }

        if (quantity <= 0) {
            alert("Adet geçerli olmalı.");
            return;
        }

            const note = get("notes").value.trim();

         operations.push({
             type,
             name,
             quantity,
             unitPrice,
             note
           });

        get("operationName").value = "";
        get("operationQty").value = 1;
        get("operationPrice").value = "";

        renderOperations();
        updateSummary();
    }

    function renderOperations() {
        const list = get("operationList");
        list.innerHTML = "";

        operations.forEach((operation, index) => {
            const total = operation.quantity * operation.unitPrice;

            const div = document.createElement("div");
            div.className = "operation-item";

                  div.innerHTML = `
        <div class="operation-main">
            <span class="badge ${operation.type === "Parça" ? "part" : "labor"}">${operation.type}</span>

            <div class="operation-info">
                <strong>${operation.name}</strong>
                <span>${operation.quantity} adet × ${formatter.format(operation.unitPrice)}</span>
                ${
                    operation.note
                        ? `<button type="button" class="note-toggle" onclick="toggleNote(${index})">Açıklamayı göster</button>`
                        : ""
                }
            </div>

            <div class="operation-price">${formatter.format(total)}</div>

            <button type="button" class="delete" onclick="removeOperation(${index})">×</button>
        </div>

        ${
            operation.note
                ? `<div class="operation-note" id="note-${index}">${operation.note}</div>`
                : ""
        }
    `;

            list.appendChild(div);
        });
    }

    function removeOperation(index) {
        operations.splice(index, 1);
        get("notes").value = "";
        renderOperations();
        updateSummary();
    }

    function formatPhone(digits) {
          if (digits.length > 9) {
        return digits.replace(/(\d{4})(\d{3})(\d{2})(\d{0,2})/, "$1 $2 $3 $4").trim();
    }

    if (digits.length > 7) {
        return digits.replace(/(\d{4})(\d{3})(\d{0,2})/, "$1 $2 $3").trim();
    }

    if (digits.length > 4) {
        return digits.replace(/(\d{4})(\d{0,3})/, "$1 $2").trim();
    }

    return digits;
    }
       
        function toggleNote(index) {
        const note = document.getElementById("note-" + index);
        if (!note) return;

        note.classList.toggle("open");
    }

    async function createPdf() {
        const phoneDigits = get("customerPhone").value.replace(/\D/g, "");

        const isCustomerNameInvalid = get("customerName").value.trim().length === 0;
        const isPlateInvalid = get("plate").value.trim().length === 0;
        const isModelYearInvalid =
            get("modelYear").value.length > 0 && get("modelYear").value.length < 4;
        const isPhoneInvalid =
            phoneDigits.length > 0 && phoneDigits.length < 10;

        setError("customerName", "customerNameError", isCustomerNameInvalid);
        setError("plate", "plateError", isPlateInvalid);
        setError("modelYear", "modelYearError", isModelYearInvalid);
        setError("customerPhone", "customerPhoneError", isPhoneInvalid);

        if (isCustomerNameInvalid || isPlateInvalid || isModelYearInvalid || isPhoneInvalid) {
            alert("Lütfen hatalı alanları düzelt.");
            return;
        }

        if (operations.length === 0) {
            alert("En az bir işlem eklemelisin.");
            return;
        }

        const request = {
            customerName: get("customerName").value.trim(),
            customerPhone: phoneDigits,
            customerEmail: get("customerEmail").value.trim(),
            plate: get("plate").value.trim().toUpperCase(),
            brand: get("brand").value.trim(),
            model: get("model").value.trim(),
            modelYear: get("modelYear").value.trim(),
            notes: get("notes").value.trim(),
            operations: operations
        };

        // const response = await fetch("https://localhost:7263/api/ServicePdfs", {
        //     method: "POST",
        //     headers: {
        //         "Content-Type": "application/json"
        //     },
        //     body: JSON.stringify(request)
        // });
            const response = await fetch("/service-pdf/create", {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify(request)
    });

            if (!response.ok) {
        const errorText = await response.text();
        alert("PDF oluşturulurken hata oluştu:\n" + errorText);
        return;
    }

        const blob = await response.blob();
        const url = window.URL.createObjectURL(blob);

        const a = document.createElement("a");
        a.href = url;
        a.download = "servis-formu.pdf";
        a.click();

        window.URL.revokeObjectURL(url);
    }

    get("customerName").addEventListener("input", function () {
        this.value = this.value.replace(/[^a-zA-ZğüşöçıİĞÜŞÖÇ\s]/g, "");
        setError("customerName", "customerNameError", this.value.trim().length === 0);
        updateSummary();
    });

    get("customerPhone").addEventListener("beforeinput", function (e) {
        if (e.inputType === "insertText" && !/^\d$/.test(e.data)) {
            e.preventDefault();
            showTemporaryError("customerPhone", "customerPhoneError");
        }
    });

    get("customerPhone").addEventListener("paste", function (e) {
        const pastedText = (e.clipboardData || window.clipboardData).getData("text");
        const digits = pastedText.replace(/\D/g, "").slice(0, 11);

        if (pastedText !== digits) {
            e.preventDefault();
            this.value = formatPhone(digits);
            showTemporaryError("customerPhone", "customerPhoneError");
            updateSummary();
        }
    });

    get("customerPhone").addEventListener("input", function () {
        const digits = this.value.replace(/\D/g, "").slice(0, 11);
        this.value = formatPhone(digits);
        updateSummary();
    });

    get("plate").addEventListener("beforeinput", function (e) {
        if (e.inputType === "insertText" && !/^[a-zA-Z0-9]$/.test(e.data)) {
            e.preventDefault();
            showTemporaryError("plate", "plateError");
        }
    });

    get("plate").addEventListener("input", function () {
        this.value = this.value
            .toUpperCase()
            .replace(/[^A-Z0-9]/g, "");

        setError("plate", "plateError", this.value.trim().length === 0);
        updateSummary();
    });

    get("modelYear").addEventListener("beforeinput", function (e) {
        if (e.inputType === "insertText" && !/^\d$/.test(e.data)) {
            e.preventDefault();
            showTemporaryError("modelYear", "modelYearError");
        }
    });

    get("modelYear").addEventListener("input", function () {
        this.value = this.value.replace(/\D/g, "").slice(0, 4);
        setError("modelYear", "modelYearError", this.value.length > 0 && this.value.length < 4);
    });

    ["brand", "model", "customerEmail"].forEach(id => {
        get(id).addEventListener("input", updateSummary);
    });

    get("customerName").addEventListener("blur", function () {
        this.value = this.value
            .toLowerCase()
            .replace(/\b\w/g, char => char.toUpperCase());
    });

    get("brand").addEventListener("input", function () {
        this.value = this.value.toUpperCase();
    });

    get("model").addEventListener("blur", function () {
        this.value = this.value
            .toLowerCase()
            .replace(/\b\w/g, char => char.toUpperCase());
    });

    updateSummary();
</script>