@{
    ViewData["Title"] = "Servis Fişi";
}

<h1>Servis Fişi Oluştur</h1>

<h3>Müşteri</h3>
<input id="customerName" placeholder="Müşteri adı" />
<input id="customerPhone" placeholder="Telefon" />

<h3>Araç</h3>
<input id="plateNumber" placeholder="Plaka" />
<input id="vehicleBrand" placeholder="Marka" />
<input id="vehicleModel" placeholder="Model" />

<h3>İşlem Ekle</h3>

<select id="defaultItem">
    <option value="">Menüden seç</option>
    <option value="Fren balatası">Fren balatası</option>
    <option value="Yağ değişimi">Yağ değişimi</option>
    <option value="Hava filtresi">Hava filtresi</option>
</select>

<input id="description" placeholder="İşlem adı" />
<input id="price" type="number" placeholder="Fiyat" />
<input id="quantity" type="number" value="1" />

<button onclick="addItem()">Ekle</button>

<h3>İşlemler</h3>
<ul id="itemsList"></ul>

<h3>Toplam: <span id="total">0</span> TL</h3>

<textarea id="note" placeholder="Not"></textarea>

<br />
<br />

<button onclick="createPdf()">PDF Oluştur</button>

<script>
    const items = [];

    document.getElementById("defaultItem").addEventListener("change", function () {
        document.getElementById("description").value = this.value;
    });

    function addItem() {
        const description = document.getElementById("description").value;
        const price = Number(document.getElementById("price").value);
        const quantity = Number(document.getElementById("quantity").value);

        if (!description || !price || quantity <= 0) {
            alert("Eksik bilgi");
            return;
        }

        items.push({ description, price, quantity });

        renderItems();
    }

    function renderItems() {
        const list = document.getElementById("itemsList");
        list.innerHTML = "";

        let total = 0;

        items.forEach((item, index) => {
            const itemTotal = item.price * item.quantity;
            total += itemTotal;

            const li = document.createElement("li");
            li.innerHTML = `
                ${item.description} - ${item.price} TL x ${item.quantity} = ${itemTotal} TL
                <button onclick="removeItem(${index})">Sil</button>
            `;
            list.appendChild(li);
        });

        document.getElementById("total").innerText = total;
    }

    function removeItem(index) {
        items.splice(index, 1);
        renderItems();
    }
   
    async function createPdf() {

        const request = {
            customerName: document.getElementById("customerName").value,
            customerPhone: document.getElementById("customerPhone").value,
            plateNumber: document.getElementById("plateNumber").value,
            vehicleBrand: document.getElementById("vehicleBrand").value,
            vehicleModel: document.getElementById("vehicleModel").value,
            note: document.getElementById("note").value,
            items: items
        };

        const response = await fetch("https://localhost:7263/api/ServicePdfs", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify(request)
        });

        const blob = await response.blob();
        const url = window.URL.createObjectURL(blob);

        const a = document.createElement("a");
        a.href = url;
        a.download = "servis-fisi.pdf";
        a.click();

        window.URL.revokeObjectURL(url);
    }
</script>