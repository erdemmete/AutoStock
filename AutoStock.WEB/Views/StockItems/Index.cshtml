@model AutoStock.WEB.Models.StockItems.StockItemIndexViewModel
@using AutoStock.WEB.Models.StockItems

@{
    ViewData["Title"] = "Stok Yönetimi";

    var stocks = Model.Stocks.Items ?? new List<StockItemListViewModel>();
    var query = Model.Query;
    var brands = Model.FilterOptions.Brands ?? new List<string>();

    var pageNumber = Model.Stocks.PageNumber > 0 ? Model.Stocks.PageNumber : query.PageNumber;
    var pageSize = Model.Stocks.PageSize > 0 ? Model.Stocks.PageSize : query.PageSize;
    var totalCount = Model.Stocks.TotalCount;

    var totalPages = pageSize > 0
        ? Math.Max(1, (int)Math.Ceiling(totalCount / (double)pageSize))
        : 1;

    var hasAdvancedFilter =
        !string.IsNullOrWhiteSpace(query.Brand) ||
        query.CriticalOnly ||
        pageSize != 10;

    string FormatCode(string? code)
    {
        return string.IsNullOrWhiteSpace(code) ? "Kodsuz" : code;
    }

    string FormatBrand(string? brand)
    {
        return string.IsNullOrWhiteSpace(brand) ? "Marka yok" : brand;
    }
}

<div class="stk-page">
    <section class="stk-hero">
        <div class="stk-hero-left">
            <a asp-controller="Dashboard"
               asp-action="Index"
               class="stk-home-btn"
               title="Ana sayfa">
                ⌂
            </a>

            <div>
                <span class="stk-eyebrow">SENTE360</span>
                <h1>Stok Yönetimi</h1>
                <p>Yedek parça, sarf malzeme ve stok seviyelerini hızlıca takip edin.</p>
            </div>
        </div>

        <a asp-controller="StockItems"
           asp-action="Create"
           class="stk-create-btn">
            <span>+</span>
            <strong>Yeni Stok Kartı</strong>
        </a>
    </section>

    <section class="stk-filter-shell">
        <form method="get"
              asp-controller="StockItems"
              asp-action="Index"
              id="stockFilterForm">

            <input type="hidden" name="PageNumber" value="1" />

            <div class="stk-search-row">
                <div class="stk-search-box">
                    <span class="stk-search-icon">⌕</span>
                    <input name="Search"
                           value="@query.Search"
                           type="text"
                           placeholder="Stok kodu, adı veya marka ara..." />
                </div>

                <button type="submit" class="stk-search-submit">
                    Ara
                </button>

                <button type="button"
                        class="stk-filter-toggle @(hasAdvancedFilter ? "is-open" : "")"
                        data-filter-toggle
                        aria-expanded="@(hasAdvancedFilter ? "true" : "false")">
                    <span>☷</span>
                    <strong>Filtreler</strong>
                    <em>⌄</em>
                </button>
            </div>

            <div class="stk-advanced-filters @(hasAdvancedFilter ? "is-open" : "")" data-filter-panel>
                <div class="stk-filter-section">
                    <label>Marka</label>

                    <select name="Brand">
                        <option value="">Tüm Markalar</option>

                        @foreach (var brand in brands)
                        {
                            <option value="@brand" selected="@(query.Brand == brand ? "selected" : null)">
                                @brand
                            </option>
                        }
                    </select>
                </div>

                <div class="stk-filter-section">
                    <label>Sayfa Boyutu</label>

                    <select name="PageSize">
                        <option value="10" selected="@(pageSize == 10 ? "selected" : null)">10 kayıt</option>
                        <option value="25" selected="@(pageSize == 25 ? "selected" : null)">25 kayıt</option>
                        <option value="50" selected="@(pageSize == 50 ? "selected" : null)">50 kayıt</option>
                    </select>
                </div>

                <label class="stk-critical-filter">
                    <input type="checkbox"
                           name="CriticalOnly"
                           value="true"
                           checked="@(query.CriticalOnly ? "checked" : null)" />
                    <span>
                        <strong>Kritik seviyedeki stoklar</strong>
                        
                    </span>
                </label>

                <div class="stk-filter-actions">
                    <button type="submit" class="stk-apply-btn">Filtrele</button>

                    <a asp-controller="StockItems"
                       asp-action="Index"
                       class="stk-clear-btn">
                        Temizle
                    </a>
                </div>
            </div>
        </form>
    </section>

    <section class="stk-list-shell">
        <div class="stk-list-toolbar">
            <div class="stk-list-summary">
                @if (totalCount > 0)
                {
                    <span>
                        <strong>@totalCount</strong> stok kartı —
                        <strong>Sayfa @pageNumber / @totalPages</strong>
                    </span>
                }
                else
                {
                    <span>Stok kartı bulunamadı.</span>
                }
            </div>

            @if (totalPages > 1)
            {
                <div class="stk-top-pager">
                    <a class="stk-top-nav @(pageNumber > 1 ? "" : "disabled")"
                       href="@(pageNumber > 1
                                                      ? Url.Action("Index", "StockItems", new
                                                      {
                                                          Search = query.Search,
                                                          Brand = query.Brand,
                                                          CriticalOnly = query.CriticalOnly,
                                                          PageNumber = pageNumber - 1,
                                                          PageSize = pageSize
                                                      })
                                                      : "#")">
                        ‹
                    </a>

                    <div class="stk-top-page-list">
                        @for (var number = 1; number <= totalPages; number++)
                        {
                            if (number == 1 ||
                                number == totalPages ||
                                Math.Abs(number - pageNumber) <= 1)
                            {
                                <a class="stk-top-page @(number == pageNumber ? "active" : "")"
                                   href="@Url.Action("Index", "StockItems", new
                                   {
                                       Search = query.Search,
                                       Brand = query.Brand,
                                       CriticalOnly = query.CriticalOnly,
                                       PageNumber = number,
                                       PageSize = pageSize
                                   })">
                                    @number
                                </a>
                            }
                        }
                    </div>

                    <a class="stk-top-nav @(pageNumber < totalPages ? "" : "disabled")"
                       href="@(pageNumber<totalPages
                                                      ? Url.Action("Index", "StockItems", new
                                                      {
                                                          Search = query.Search,
                                                          Brand = query.Brand,
                                                          CriticalOnly = query.CriticalOnly,
                                                          PageNumber = pageNumber + 1,
                                                          PageSize = pageSize
                                                      })
                              : "#")">
                        ›
                    </a>
                </div>
            }
        </div>

        <div class="stk-list">
            @if (!stocks.Any())
            {
                <div class="stk-empty">
                    <div class="stk-empty-icon">⌕</div>
                    <strong>Stok kartı bulunamadı</strong>
                    <span>Arama veya filtre kriterlerini değiştirerek tekrar deneyebilirsin.</span>
                </div>
            }
            else
            {
                foreach (var item in stocks)
                {
                    var statusText = item.IsCritical ? "KRİTİK" : "NORMAL";
                    var statusClass = item.IsCritical ? "is-critical" : "is-normal";

                    <article class="stk-card">
                        <a asp-controller="StockItems"
                           asp-action="Details"
                           asp-route-id="@item.Id"
                           class="stk-main">
                            <div class="stk-code-box">
                                <span>STOK</span>
                                <strong>@FormatCode(item.Code)</strong>
                            </div>

                            <div class="stk-name-block">
                                <strong>@item.Name</strong>
                                <span>@FormatBrand(item.Brand)</span>
                            </div>
                        </a>

                        <div class="stk-brand-area">
                            <span class="stk-brand-pill @(string.IsNullOrWhiteSpace(item.Brand) ? "muted" : "")">
                                @FormatBrand(item.Brand)
                            </span>
                        </div>

                        <div class="stk-quantity-box @(item.IsCritical ? "danger" : "")">
                            <span>Mevcut Stok</span>
                            <strong>@item.Quantity @item.Unit</strong>
                            <small>Minimum: @item.MinimumQuantity</small>
                        </div>

                        <div class="stk-price-box">
                            <span>Satış Fiyatı</span>
                            <strong>@SenteMoney.Format(item.SalePrice)</strong>
                        </div>

                        <div class="stk-status-area">
                            <span class="stk-status @statusClass">@statusText</span>
                        </div>

                        <div class="stk-actions">
                            <a asp-controller="StockItems"
                               asp-action="Details"
                               asp-route-id="@item.Id"
                               class="stk-detail-btn">
                                Detay
                            </a>
                        </div>
                    </article>
                }
            }
        </div>

        @if (totalPages > 1)
        {
            <div class="stk-pagination">
                <a class="stk-page-btn @(pageNumber > 1 ? "" : "disabled")"
                   href="@(pageNumber > 1
                                              ? Url.Action("Index", "StockItems", new
                                              {
                                                  Search = query.Search,
                                                  Brand = query.Brand,
                                                  CriticalOnly = query.CriticalOnly,
                                                  PageNumber = pageNumber - 1,
                                                  PageSize = pageSize
                                              })
                                              : "#")">
                    Önceki
                </a>

                <div class="stk-page-numbers">
                    @for (var number = 1; number <= totalPages; number++)
                    {
                        if (number == 1 ||
                            number == totalPages ||
                            Math.Abs(number - pageNumber) <= 2)
                        {
                            <a class="stk-page-number @(number == pageNumber ? "active" : "")"
                               href="@Url.Action("Index", "StockItems", new
                               {
                                   Search = query.Search,
                                   Brand = query.Brand,
                                   CriticalOnly = query.CriticalOnly,
                                   PageNumber = number,
                                   PageSize = pageSize
                               })">
                                @number
                            </a>
                        }
                    }
                </div>

                <a class="stk-page-btn @(pageNumber < totalPages ? "" : "disabled")"
                   href="@(pageNumber<totalPages
                                              ? Url.Action("Index", "StockItems", new
                                              {
                                                  Search = query.Search,
                                                  Brand = query.Brand,
                                                  CriticalOnly = query.CriticalOnly,
                                                  PageNumber = pageNumber + 1,
                                                  PageSize = pageSize
                                              })
                          : "#")">
                    Sonraki
                </a>
            </div>
        }
    </section>
</div>

<style>
    .stk-page {
        width: min(1280px, calc(100% - 56px));
        margin: 0 auto;
        padding: 30px 0 64px;
        color: #061936;
    }

    .stk-hero {
        margin-bottom: 22px;
        padding: 24px 28px;
        border-radius: 30px;
        background: radial-gradient(circle at 78% 40%, rgba(255,255,255,.16), transparent 30%), linear-gradient(135deg, #07111f 0%, #111827 48%, #4f46e5 100%);
        color: white;
        box-shadow: 0 26px 70px rgba(15, 23, 42, .20);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 22px;
        overflow: hidden;
    }

    .stk-hero-left {
        display: flex;
        align-items: center;
        gap: 18px;
        min-width: 0;
    }

    .stk-home-btn {
        width: 54px;
        height: 54px;
        flex: 0 0 54px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #2563eb, #16a34a);
        color: white;
        text-decoration: none;
        font-size: 24px;
        font-weight: 950;
        box-shadow: 0 18px 36px rgba(37, 99, 235, .25);
    }

    .stk-eyebrow {
        display: inline-flex;
        margin-bottom: 8px;
        padding: 6px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.18);
        color: rgba(255,255,255,.82);
        font-size: 12px;
        font-weight: 950;
        letter-spacing: .2px;
    }

    .stk-hero h1 {
        margin: 0;
        font-size: clamp(30px, 4vw, 42px);
        line-height: 1;
        letter-spacing: -1.6px;
    }

    .stk-hero p {
        margin: 10px 0 0;
        color: rgba(255,255,255,.72);
        font-size: 15px;
        line-height: 1.45;
    }

    .stk-create-btn {
        height: 56px;
        padding: 0 22px;
        border-radius: 18px;
        background: #4f46e5;
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
        font-size: 16px;
        box-shadow: 0 18px 34px rgba(79, 70, 229, .36);
        white-space: nowrap;
    }

        .stk-create-btn span {
            font-size: 28px;
            line-height: 1;
        }

        .stk-create-btn strong {
            font-weight: 950;
        }

    .stk-filter-shell {
        margin-bottom: 22px;
        padding: 20px;
        border-radius: 26px;
        background: rgba(255,255,255,.96);
        border: 1px solid #dbe3ef;
        box-shadow: 0 18px 42px rgba(15, 23, 42, .07);
    }

    .stk-search-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto auto;
        gap: 10px;
        align-items: center;
    }

    .stk-search-box {
        position: relative;
        min-width: 0;
    }

    .stk-search-icon {
        position: absolute;
        left: 18px;
        top: 50%;
        transform: translateY(-50%);
        color: #8aa0bd;
        font-size: 24px;
        pointer-events: none;
    }

    .stk-search-box input {
        width: 100%;
        height: 56px;
        padding: 0 18px 0 52px;
        border-radius: 18px;
        border: 1px solid #d4deeb;
        background: #f8fafc;
        color: #0f172a;
        font-size: 16px;
        font-weight: 750;
        outline: none;
        box-sizing: border-box;
    }

        .stk-search-box input::placeholder {
            color: #8aa0bd;
            font-weight: 700;
        }

        .stk-search-box input:focus {
            background: white;
            border-color: #4f46e5;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, .10);
        }

    .stk-search-submit,
    .stk-filter-toggle {
        height: 56px;
        border-radius: 18px;
        border: 1px solid #c7d2fe;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        cursor: pointer;
        font-size: 15px;
        font-weight: 950;
        white-space: nowrap;
    }

    .stk-search-submit {
        padding: 0 22px;
        background: #4f46e5;
        color: white;
        border-color: #4f46e5;
        box-shadow: 0 12px 24px rgba(79, 70, 229, .20);
    }

    .stk-filter-toggle {
        padding: 0 18px;
        background: #f8fafc;
        color: #312e81;
    }

        .stk-filter-toggle span {
            font-size: 18px;
        }

        .stk-filter-toggle em {
            font-style: normal;
            transition: .18s ease;
        }

        .stk-filter-toggle.is-open em {
            transform: rotate(180deg);
        }

    .stk-advanced-filters {
        display: none;
        margin-top: 18px;
        padding-top: 18px;
        border-top: 1px solid #e2e8f0;
        grid-template-columns: minmax(220px, .8fr) minmax(180px, .45fr) minmax(230px, .7fr) auto;
        gap: 14px;
        align-items: end;
    }

        .stk-advanced-filters.is-open {
            display: grid;
        }

    .stk-filter-section {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 9px;
    }

        .stk-filter-section label {
            color: #64748b;
            font-size: 12px;
            font-weight: 950;
            letter-spacing: .7px;
            text-transform: uppercase;
        }

        .stk-filter-section select {
            width: 100%;
            height: 46px;
            padding: 0 14px;
            border-radius: 15px;
            border: 1px solid #d4deeb;
            background: #f8fafc;
            color: #0f172a;
            font-size: 15px;
            font-weight: 800;
            outline: none;
            box-sizing: border-box;
        }

    .stk-critical-filter {
        min-height: 46px;
        margin: 0;
        padding: 9px 12px;
        border-radius: 15px;
        border: 1px solid #d4deeb;
        background: #f8fafc;
        color: #0f172a;
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
        user-select: none;
    }

        .stk-critical-filter input {
            width: 18px;
            height: 18px;
            flex: 0 0 auto;
            accent-color: #e11d48;
        }

        .stk-critical-filter span {
            min-width: 0;
            display: grid;
            gap: 2px;
        }

        .stk-critical-filter strong {
            color: #0f172a;
            font-size: 14px;
            font-weight: 950;
            line-height: 1.1;
        }

        .stk-critical-filter small {
            color: #64748b;
            font-size: 12px;
            font-weight: 800;
            line-height: 1.15;
        }

    .stk-filter-actions {
        display: flex;
        gap: 10px;
    }

    .stk-apply-btn,
    .stk-clear-btn {
        height: 46px;
        padding: 0 18px;
        border-radius: 15px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-size: 14px;
        font-weight: 950;
        white-space: nowrap;
    }

    .stk-apply-btn {
        border: none;
        background: #4f46e5;
        color: white;
        cursor: pointer;
    }

    .stk-clear-btn {
        border: 1px solid #d4deeb;
        background: #f8fafc;
        color: #4f46e5;
    }

    .stk-list-toolbar {
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
    }

    .stk-list-summary {
        color: #64748b;
        font-size: 14px;
        font-weight: 850;
    }

        .stk-list-summary strong {
            color: #334155;
        }

    .stk-top-pager {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px;
        border-radius: 999px;
        background: white;
        border: 1px solid #dbe3ef;
        box-shadow: 0 8px 22px rgba(15, 23, 42, .05);
    }

    .stk-top-page-list {
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    .stk-top-nav,
    .stk-top-page {
        width: 34px;
        height: 34px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: #475569;
        font-size: 14px;
        font-weight: 950;
        transition: .15s ease;
    }

    .stk-top-nav {
        font-size: 24px;
        line-height: 1;
        background: #f8fafc;
    }

    .stk-top-page.active {
        background: #4f46e5;
        color: white;
        box-shadow: 0 8px 18px rgba(79, 70, 229, .28);
    }

    .stk-top-nav:not(.disabled):hover,
    .stk-top-page:not(.active):hover {
        background: #eef2ff;
        color: #4f46e5;
    }

    .stk-top-nav.disabled {
        opacity: .35;
        pointer-events: none;
    }

    .stk-list {
        display: grid;
        gap: 14px;
    }

    .stk-card {
        min-height: 92px;
        padding: 20px 24px;
        border-radius: 24px;
        border: 1px solid #dbe3ef;
        background: white;
        color: #0f172a;
        display: grid;
        grid-template-columns: minmax(280px, 1.35fr) 130px minmax(170px, .7fr) minmax(140px, .65fr) 110px 90px;
        gap: 18px;
        align-items: center;
        box-shadow: 0 10px 26px rgba(15, 23, 42, .045);
        transition: .16s ease;
    }

        .stk-card:hover {
            transform: translateY(-2px);
            border-color: #c7d2fe;
            box-shadow: 0 18px 38px rgba(15, 23, 42, .08);
        }

    .stk-main {
        min-width: 0;
        display: flex;
        align-items: center;
        gap: 15px;
        color: inherit;
        text-decoration: none;
    }

    .stk-code-box {
        width: 76px;
        height: 54px;
        flex: 0 0 76px;
        border-radius: 17px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        display: grid;
        align-content: center;
        justify-items: center;
        gap: 2px;
    }

        .stk-code-box span {
            color: #8aa0bd;
            font-size: 10px;
            font-weight: 950;
            letter-spacing: .6px;
        }

        .stk-code-box strong {
            max-width: 68px;
            color: #0f172a;
            font-size: 13px;
            font-weight: 950;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

    .stk-name-block {
        min-width: 0;
    }

        .stk-name-block strong {
            display: block;
            color: #0f172a;
            font-size: 18px;
            font-weight: 950;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .stk-name-block span {
            display: block;
            margin-top: 6px;
            color: #8aa0bd;
            font-size: 13px;
            font-weight: 850;
        }

    .stk-brand-pill {
        min-width: 86px;
        height: 32px;
        padding: 0 12px;
        border-radius: 999px;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        color: #475569;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 950;
        white-space: nowrap;
    }

        .stk-brand-pill.muted {
            color: #94a3b8;
        }

    .stk-quantity-box,
    .stk-price-box {
        padding: 12px 14px;
        border-radius: 18px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
    }

        .stk-quantity-box span,
        .stk-price-box span {
            display: block;
            color: #8aa0bd;
            font-size: 12px;
            font-weight: 900;
            margin-bottom: 5px;
        }

        .stk-quantity-box strong,
        .stk-price-box strong {
            display: block;
            color: #0f172a;
            font-size: 16px;
            font-weight: 950;
            white-space: nowrap;
        }

        .stk-quantity-box small {
            display: block;
            margin-top: 5px;
            color: #64748b;
            font-size: 12px;
            font-weight: 800;
        }

        .stk-quantity-box.danger {
            background: #fff1f2;
            border-color: #fecdd3;
        }

            .stk-quantity-box.danger strong {
                color: #e11d48;
            }

    .stk-status-area {
        display: flex;
        justify-content: flex-start;
    }

    .stk-status {
        min-width: 86px;
        height: 32px;
        padding: 0 12px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 950;
        white-space: nowrap;
    }

        .stk-status.is-normal {
            background: #dcfce7;
            color: #166534;
        }

        .stk-status.is-critical {
