@model AutoStock.WEB.Models.StockItems.StockItemIndexViewModel

@{
    ViewData["Title"] = "Stok Yönetimi";

    var stocks = Model.Stocks.Items;
    var query = Model.Query;
    var brands = Model.FilterOptions.Brands;
    var units = Model.FilterOptions.Units;

    var startPage = Math.Max(1, Model.Stocks.PageNumber - 2);
    var endPage = Math.Min(Model.Stocks.TotalPages, Model.Stocks.PageNumber + 2);
}

<div class="stock-page">
    <div class="stock-header">
        <div class="stock-title-area">
            <div class="stock-icon">
                <span>▱</span>
            </div>

            <div>
                <h1>Stok Yönetimi</h1>
                <p>Sistemde kayıtlı tüm yedek parça ve sarf malzemeleri buradan yönetebilirsiniz.</p>
            </div>
        </div>

        <div class="stock-header-actions">
            <a asp-controller="Dashboard"
               asp-action="Index"
               class="stock-secondary-btn">
                Ana Sayfa
            </a>

            <a asp-controller="StockItems"
               asp-action="Create"
               class="stock-primary-btn">
                <span>+</span>
                Yeni Stok Kartı
            </a>
        </div>
    </div>

    <form class="stock-filter-card"
          method="get"
          asp-controller="StockItems"
          asp-action="Index">

        <div class="stock-search-box">
            <span class="search-icon">⌕</span>
            <input id="stockSearchInput"
                   name="Search"
                   value="@query.Search"
                   type="text"
                   placeholder="Stok kodu, adı veya marka ara..." />
        </div>

        <select id="brandFilter"
                name="Brand"
                class="stock-filter-select">
            <option value="">Tüm Markalar</option>

            @foreach (var brand in brands)
            {
                if (query.Brand == brand)
                {
                    <option value="@brand" selected="selected">@brand</option>
                }
                else
                {
                    <option value="@brand">@brand</option>
                }
            }
        </select>

        <select id="unitFilter"
                name="Unit"
                class="stock-filter-select">
            <option value="">Tüm Birimler</option>

            @foreach (var unit in units)
            {
                if (query.Unit == unit)
                {
                    <option value="@unit" selected="selected">@unit</option>
                }
                else
                {
                    <option value="@unit">@unit</option>
                }
            }
        </select>

        <input type="hidden" name="PageNumber" value="1" />
        <input type="hidden" name="PageSize" value="@query.PageSize" />

        <button type="submit"
                class="stock-filter-button"
                title="Ara">
            ⌕
        </button>

        <a asp-controller="StockItems"
           asp-action="Index"
           class="stock-clear-button"
           title="Filtreleri temizle">
            ×
        </a>
    </form>

    <div class="stock-table-card">
        <div class="table-responsive">
            <table class="stock-table">
                <thead>
                    <tr>
                        <th>Stok Kodu</th>
                        <th>Stok Adı</th>
                        <th>Marka</th>
                        <th>Miktar</th>
                        <th>Fiyat</th>
                        <th>Minimum</th>
                        <th>Durum</th>
                        <th class="text-right">İşlem</th>
                    </tr>
                </thead>

                <tbody id="stockTableBody">
                    @if (!stocks.Any())
                    {
                        <tr>
                            <td colspan="8" class="empty-cell">
                                Henüz stok kartı bulunamadı.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in stocks)
                        {
                            <tr class="stock-row">
                                <td>
                                    <span class="stock-code">@item.Code</span>
                                </td>

                                <td>
                                    <div class="stock-name">@item.Name</div>
                                </td>

                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.Brand))
                                    {
                                        <span class="brand-pill">@item.Brand</span>
                                    }
                                    else
                                    {
                                        <span class="brand-pill muted">Marka yok</span>
                                    }
                                </td>

                                <td>
                                    @if (item.IsCritical)
                                    {
                                        <div class="quantity danger">
                                            <span class="warning-icon">⚠</span>
                                            <strong>@item.Quantity</strong>
                                            <span>@item.Unit</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="quantity">
                                            <strong>@item.Quantity</strong>
                                            <span>@item.Unit</span>
                                        </div>
                                    }
                                </td>

                                <td>
                                    <strong class="price">
                                        ₺@item.SalePrice.ToString("N2")
                                    </strong>
                                </td>

                                <td>
                                    <span class="minimum-text">@item.MinimumQuantity</span>
                                </td>

                                <td>
                                    @if (item.IsCritical)
                                    {
                                        <span class="status-badge danger">Kritik</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge success">Normal</span>
                                    }
                                </td>

                                <td class="text-right">
                                    <a asp-controller="StockItems"
                                       asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="detail-btn">
                                        Detay
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="stock-table-footer">
            <div>
                @if (Model.Stocks.TotalCount > 0)
                {
                    <span>
                        @Model.Stocks.FirstItemNumber - @Model.Stocks.LastItemNumber arası gösteriliyor
                    </span>
                    <span class="footer-muted">(Toplam @Model.Stocks.TotalCount kayıt)</span>
                }
                else
                {
                    <span>0 stok kartı gösteriliyor</span>
                }
            </div>

            <div class="pagination-preview">
                @if (Model.Stocks.HasPreviousPage)
                {
                    <a asp-controller="StockItems"
                       asp-action="Index"
                       asp-route-Search="@query.Search"
                       asp-route-Brand="@query.Brand"
                       asp-route-Unit="@query.Unit"
                       asp-route-PageSize="@query.PageSize"
                       asp-route-PageNumber="@(Model.Stocks.PageNumber - 1)">‹</a>
                }
                else
                {
                    <span class="disabled">‹</span>
                }

                @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
                {
                    if (pageNumber == Model.Stocks.PageNumber)
                    {
                        <span class="active">@pageNumber</span>
                    }
                    else
                    {
                        <a asp-controller="StockItems"
                           asp-action="Index"
                           asp-route-Search="@query.Search"
                           asp-route-Brand="@query.Brand"
                           asp-route-Unit="@query.Unit"
                           asp-route-PageSize="@query.PageSize"
                           asp-route-PageNumber="@pageNumber">@pageNumber</a>
                    }
                }

                @if (Model.Stocks.HasNextPage)
                {
                    <a asp-controller="StockItems"
                       asp-action="Index"
                       asp-route-Search="@query.Search"
                       asp-route-Brand="@query.Brand"
                       asp-route-Unit="@query.Unit"
                       asp-route-PageSize="@query.PageSize"
                       asp-route-PageNumber="@(Model.Stocks.PageNumber + 1)">›</a>
                }
                else
                {
                    <span class="disabled">›</span>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .stock-page {
        padding-top: 28px;
        padding-bottom: 32px;
    }

    .stock-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 32px;
    }

    .stock-title-area {
        display: flex;
        align-items: flex-start;
        gap: 14px;
    }

    .stock-icon {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        background: #eef2ff;
        color: #4f46e5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        font-weight: 800;
    }

    .stock-header h1 {
        margin: 0;
        font-size: 28px;
        font-weight: 800;
        color: #0f172a;
    }

    .stock-header p {
        margin: 8px 0 0;
        color: #64748b;
        font-size: 14px;
    }

    .stock-header-actions {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .stock-primary-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #4f46e5;
        color: #fff;
        border: none;
        border-radius: 13px;
        padding: 13px 20px;
        font-weight: 800;
        text-decoration: none;
        box-shadow: 0 10px 24px rgba(79, 70, 229, .24);
        transition: .18s ease;
        white-space: nowrap;
    }

    .stock-primary-btn:hover {
        background: #4338ca;
        color: #fff;
        transform: translateY(-1px);
    }

    .stock-secondary-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #f8fafc;
        color: #334155;
        border: 1px solid #cfd8e6;
        border-radius: 13px;
        padding: 13px 18px;
        font-weight: 800;
        text-decoration: none;
        transition: .18s ease;
        white-space: nowrap;
    }

    .stock-secondary-btn:hover {
        background: #eef2ff;
        border-color: #c7d2fe;
        color: #4f46e5;
    }

    .stock-filter-card {
        display: grid;
        grid-template-columns: minmax(320px, 1fr) 170px 170px 48px 48px;
        gap: 12px;
        background: #fff;
        border: 1px solid #dbe3ef;
        border-radius: 16px;
        padding: 16px;
        margin-bottom: 24px;
        box-shadow: 0 8px 22px rgba(15, 23, 42, .06);
    }

    .stock-search-box {
        position: relative;
    }

    .search-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        font-size: 22px;
    }

    .stock-search-box input,
    .stock-filter-select {
        width: 100%;
        height: 48px;
        border: 1px solid #cfd8e6;
        border-radius: 13px;
        background: #fff;
        color: #0f172a;
        font-size: 14px;
        outline: none;
    }

    .stock-search-box input {
        padding: 0 16px 0 48px;
    }

    .stock-filter-select {
        padding: 0 14px;
    }

    .stock-search-box input:focus,
    .stock-filter-select:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 3px rgba(79, 70, 229, .12);
    }

    .stock-filter-button,
    .stock-clear-button {
        width: 48px;
        height: 48px;
        border: 1px solid #cfd8e6;
        border-radius: 13px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        text-decoration: none;
        cursor: pointer;
        transition: .18s ease;
    }

    .stock-filter-button {
        background: #f8fafc;
        color: #475569;
        font-size: 20px;
    }

    .stock-filter-button:hover {
        background: #eef2ff;
        border-color: #c7d2fe;
        color: #4f46e5;
    }

    .stock-clear-button {
        background: #fff;
        color: #64748b;
        font-size: 22px;
    }

    .stock-clear-button:hover {
        background: #fff1f2;
        border-color: #fecdd3;
        color: #e11d48;
    }

    .stock-table-card {
        background: #fff;
        border: 1px solid #dbe3ef;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 8px 22px rgba(15, 23, 42, .06);
    }

    .table-responsive {
        width: 100%;
        overflow-x: auto;
    }

    .stock-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 960px;
    }

    .stock-table thead {
        background: #f8fafc;
    }

    .stock-table th {
        padding: 17px 24px;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: #64748b;
        font-weight: 800;
        text-align: left;
        border-bottom: 1px solid #dbe3ef;
    }

    .stock-table td {
        padding: 20px 24px;
        border-bottom: 1px solid #edf2f7;
        vertical-align: middle;
        color: #0f172a;
        font-size: 14px;
    }

    .stock-table tr:last-child td {
        border-bottom: none;
    }

    .stock-row:hover {
        background: #fafbff;
    }

    .stock-code {
        font-weight: 800;
        color: #0f172a;
    }

    .stock-name {
        font-weight: 800;
        color: #0f172a;
    }

    .brand-pill {
        display: inline-flex;
        align-items: center;
        padding: 5px 10px;
        border-radius: 8px;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        color: #475569;
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .brand-pill.muted {
        color: #94a3b8;
    }

    .quantity {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        color: #0f172a;
    }

    .quantity strong {
        font-weight: 800;
    }

    .quantity span {
        color: #64748b;
        font-size: 13px;
    }

    .quantity.danger {
        color: #e11d48;
    }

    .quantity.danger span {
        color: #e11d48;
    }

    .warning-icon {
        font-size: 15px;
    }

    .price {
        font-weight: 800;
        color: #0f172a;
    }

    .minimum-text {
        color: #64748b;
        font-weight: 700;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 800;
    }

    .status-badge.success {
        background: #dcfce7;
        color: #166534;
    }

    .status-badge.danger {
        background: #ffe4e6;
        color: #be123c;
    }

    .detail-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 74px;
        height: 40px;
        border: 1px solid #cfd8e6;
        border-radius: 10px;
        color: #334155;
        background: #fff;
        text-decoration: none;
        font-weight: 800;
        font-size: 13px;
        transition: .18s ease;
    }

    .detail-btn:hover {
        background: #f8fafc;
        color: #0f172a;
    }

    .text-right {
        text-align: right !important;
    }

    .empty-cell {
        padding: 38px !important;
        text-align: center;
        color: #64748b !important;
    }

    .stock-table-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 16px 24px;
        border-top: 1px solid #edf2f7;
        color: #0f172a;
        font-size: 14px;
    }

    .footer-muted {
        color: #64748b;
    }

    .pagination-preview {
        display: inline-flex;
        align-items: center;
        border: 1px solid #cfd8e6;
        border-radius: 10px;
        overflow: hidden;
    }

    .pagination-preview a,
    .pagination-preview span {
        width: 42px;
        height: 36px;
        border-right: 1px solid #cfd8e6;
        background: #fff;
        color: #334155;
        font-weight: 800;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .pagination-preview a:last-child,
    .pagination-preview span:last-child {
        border-right: none;
    }

    .pagination-preview .active {
        background: #4f46e5;
        color: #fff;
    }

    .pagination-preview .disabled {
        color: #94a3b8;
        background: #f8fafc;
    }

    @@media (max-width: 900px) {
        .stock-header {
            align-items: flex-start;
            flex-direction: column;
        }

        .stock-filter-card {
            grid-template-columns: 1fr;
        }

        .stock-filter-button,
        .stock-clear-button {
            width: 100%;
        }

        .stock-table-footer {
            align-items: flex-start;
            flex-direction: column;
        }
    }
</style>