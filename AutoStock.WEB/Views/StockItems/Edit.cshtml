@model AutoStock.WEB.Models.StockItems.EditStockItemViewModel

@{
    ViewData["Title"] = "Stok Kartı Düzenle";
}

<div class="stk-form-page">
    <section class="stk-form-hero">
        <div class="stk-hero-left">
            <a asp-controller="StockItems"
               asp-action="Details"
               asp-route-id="@Model.Id"
               class="stk-home-btn"
               title="Stok detayına dön">
                ←
            </a>

            <div>
                <span class="stk-eyebrow">SENTE360</span>
                <h1>Stok Kartı Düzenle</h1>
                <p>Stok kartı bilgilerini güncelleyin. Miktar değişiklikleri detay ekranından yapılır.</p>
            </div>
        </div>

        <a asp-controller="StockItems"
           asp-action="Details"
           asp-route-id="@Model.Id"
           class="stk-list-btn">
            <span>▦</span>
            <strong>Detaya Dön</strong>
        </a>
    </section>

    <div class="stk-info-alert">
        <div class="stk-info-icon">!</div>
        <div>
            <strong>Stok miktarı bu ekrandan düzenlenmez.</strong>
            <span>Miktar değişikliği için stok detay ekranındaki “Stok Miktarını Düzelt” işlemini kullanın.</span>
        </div>
    </div>

    <form asp-controller="StockItems"
          asp-action="Edit"
          asp-route-id="@Model.Id"
          method="post"
          class="stk-form-shell">

        <input type="hidden" asp-for="Id" />

        <section class="stk-form-card">
            <div class="stk-form-card-head">
                <div>
                    <span class="stk-section-badge">1</span>
                    <h2>Temel Bilgiler</h2>
                    <p>Parça adı, stok kodu, barkod, marka ve birim bilgilerini güncelleyin.</p>
                </div>
            </div>

            <div class="stk-form-grid">
                <div class="stk-field full">
                    <label>Stok Adı</label>
                    <input asp-for="Name"
                           class="stk-input"
                           placeholder="Örn: Motor Yağı 5W-30 (4L)" />
                    <span asp-validation-for="Name" class="stk-validation"></span>
                </div>

                <div class="stk-field">
                    <label>Stok Kodu</label>
                    <input asp-for="Code"
                           class="stk-input"
                           placeholder="Örn: YG-001" />
                    <span asp-validation-for="Code" class="stk-validation"></span>
                </div>

                <div class="stk-field">
                    <label>Barkod</label>
                    <input asp-for="Barcode"
                           class="stk-input"
                           placeholder="Varsa barkod numarası" />
                    <span asp-validation-for="Barcode" class="stk-validation"></span>
                </div>

                <div class="stk-field">
                    <label>Marka</label>
                    <input asp-for="Brand"
                           class="stk-input"
                           placeholder="Örn: Castrol, Bosch, Renault" />
                    <span asp-validation-for="Brand" class="stk-validation"></span>
                </div>

                <div class="stk-field">
                    <label>Birim</label>
                    <input asp-for="Unit"
                           class="stk-input"
                           placeholder="Örn: Adet, Takım, Litre" />
                    <span asp-validation-for="Unit" class="stk-validation"></span>
                </div>
            </div>
        </section>

        <section class="stk-form-card">
            <div class="stk-form-card-head">
                <div>
                    <span class="stk-section-badge">2</span>
                    <h2>Stok Eşiği ve Fiyat</h2>
                    <p>Minimum stok seviyesi, alış ve satış fiyatlarını güncelleyin.</p>
                </div>
            </div>

            <div class="stk-form-grid">
                <div class="stk-field">
                    <label>Minimum Stok</label>
                    <input asp-for="MinimumQuantity"
                           class="stk-input"
                           type="number"
                           step="0.01"
                           min="0"
                           placeholder="0" />
                    <span asp-validation-for="MinimumQuantity" class="stk-validation"></span>
                </div>

                <div class="stk-field">
                    <label>Alış Fiyatı</label>
                    <div class="stk-money-input">
                        <span>₺</span>
                        <input asp-for="PurchasePrice"
                               type="number"
                               step="0.01"
                               min="0"
                               placeholder="0.00" />
                    </div>
                    <span asp-validation-for="PurchasePrice" class="stk-validation"></span>
                </div>

                <div class="stk-field">
                    <label>Satış Fiyatı</label>
                    <div class="stk-money-input">
                        <span>₺</span>
                        <input asp-for="SalePrice"
                               type="number"
                               step="0.01"
                               min="0"
                               placeholder="0.00" />
                    </div>
                    <span asp-validation-for="SalePrice" class="stk-validation"></span>
                </div>
            </div>
        </section>

        <section class="stk-form-actions">
            <a asp-controller="StockItems"
               asp-action="Details"
               asp-route-id="@Model.Id"
               class="stk-secondary-btn">
                Vazgeç
            </a>

            <button type="submit" class="stk-primary-btn">
                Değişiklikleri Kaydet
            </button>
        </section>
    </form>
</div>

<style>
    .stk-form-page {
        width: min(1080px, calc(100% - 56px));
        margin: 0 auto;
        padding: 30px 0 64px;
        color: #061936;
    }

    .stk-form-hero {
        margin-bottom: 16px;
        padding: 24px 28px;
        border-radius: 30px;
        background: radial-gradient(circle at 78% 40%, rgba(255,255,255,.16), transparent 30%), linear-gradient(135deg, #07111f 0%, #111827 48%, #4f46e5 100%);
        color: white;
        box-shadow: 0 26px 70px rgba(15, 23, 42, .20);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 22px;
        overflow: hidden;
    }

    .stk-hero-left {
        display: flex;
        align-items: center;
        gap: 18px;
        min-width: 0;
    }

    .stk-home-btn {
        width: 54px;
        height: 54px;
        flex: 0 0 54px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #2563eb, #16a34a);
        color: white;
        text-decoration: none;
        font-size: 26px;
        font-weight: 950;
        box-shadow: 0 18px 36px rgba(37, 99, 235, .25);
    }

    .stk-eyebrow {
        display: inline-flex;
        margin-bottom: 8px;
        padding: 6px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.18);
        color: rgba(255,255,255,.82);
        font-size: 12px;
        font-weight: 950;
        letter-spacing: .2px;
    }

    .stk-form-hero h1 {
        margin: 0;
        font-size: clamp(30px, 4vw, 42px);
        line-height: 1;
        letter-spacing: -1.6px;
    }

    .stk-form-hero p {
        margin: 10px 0 0;
        color: rgba(255,255,255,.72);
        font-size: 15px;
        line-height: 1.45;
    }

    .stk-list-btn {
        height: 56px;
        padding: 0 22px;
        border-radius: 18px;
        background: #4f46e5;
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
        font-size: 16px;
        box-shadow: 0 18px 34px rgba(79, 70, 229, .36);
        white-space: nowrap;
    }

        .stk-list-btn span {
            font-size: 22px;
            line-height: 1;
        }

        .stk-list-btn strong {
            font-weight: 950;
        }

    .stk-info-alert {
        margin-bottom: 16px;
        padding: 16px 18px;
        border-radius: 22px;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: #1e3a8a;
        display: flex;
        gap: 13px;
        align-items: flex-start;
        box-shadow: 0 10px 26px rgba(15, 23, 42, .045);
    }

    .stk-info-icon {
        width: 34px;
        height: 34px;
        flex: 0 0 34px;
        border-radius: 13px;
        background: white;
        color: #2563eb;
        display: grid;
        place-items: center;
        font-weight: 950;
    }

    .stk-info-alert strong {
        display: block;
        font-size: 14px;
        font-weight: 950;
    }

    .stk-info-alert span {
        display: block;
        margin-top: 4px;
        color: #475569;
        font-size: 13px;
        font-weight: 750;
        line-height: 1.45;
    }

    .stk-form-shell {
        display: grid;
        gap: 16px;
    }

    .stk-form-card {
        padding: 24px;
        border-radius: 26px;
        background: white;
        border: 1px solid #dbe3ef;
        box-shadow: 0 14px 36px rgba(15, 23, 42, .06);
    }

    .stk-form-card-head {
        margin-bottom: 22px;
        padding-bottom: 18px;
        border-bottom: 1px solid #edf2f7;
    }

    .stk-section-badge {
        width: 34px;
        height: 34px;
        margin-bottom: 12px;
        border-radius: 13px;
        display: grid;
        place-items: center;
        background: #eef2ff;
        color: #4f46e5;
        font-size: 15px;
        font-weight: 950;
    }

    .stk-form-card h2 {
        margin: 0;
        color: #0f172a;
        font-size: 24px;
        font-weight: 950;
        letter-spacing: -.7px;
    }

    .stk-form-card p {
        margin: 7px 0 0;
        color: #64748b;
        font-size: 14px;
        line-height: 1.5;
    }

    .stk-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
    }

    .stk-field {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .stk-field.full {
            grid-column: span 2;
        }

        .stk-field label {
            color: #0f172a;
            font-size: 14px;
            font-weight: 950;
        }

    .stk-input,
    .stk-money-input {
        width: 100%;
        height: 54px;
        border-radius: 18px;
        border: 1px solid #d4deeb;
        background: #f8fafc;
        color: #0f172a;
        font-size: 15px;
        font-weight: 750;
        outline: none;
        box-sizing: border-box;
    }

    .stk-input {
        padding: 0 15px;
    }

        .stk-input::placeholder,
        .stk-money-input input::placeholder {
            color: #94a3b8;
            font-weight: 700;
        }

        .stk-input:focus,
        .stk-money-input:focus-within {
            background: white;
            border-color: #4f46e5;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, .10);
        }

    .stk-money-input {
        display: flex;
        align-items: center;
        overflow: hidden;
    }

        .stk-money-input span {
            width: 52px;
            height: 100%;
            flex: 0 0 52px;
            display: grid;
            place-items: center;
            background: #eef2ff;
            color: #4f46e5;
            font-size: 17px;
            font-weight: 950;
            border-right: 1px solid #dbe3ef;
        }

        .stk-money-input input {
            width: 100%;
            height: 100%;
            border: none;
            outline: none;
            background: transparent;
            padding: 0 15px;
            color: #0f172a;
            font-size: 15px;
            font-weight: 750;
        }

    .stk-validation {
        min-height: 16px;
        color: #e11d48;
        font-size: 12px;
        font-weight: 800;
    }

    .stk-form-actions {
        padding: 20px;
        border-radius: 26px;
        background: white;
        border: 1px solid #dbe3ef;
        box-shadow: 0 14px 36px rgba(15, 23, 42, .06);
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }

    .stk-primary-btn,
    .stk-secondary-btn {
        min-height: 52px;
        padding: 0 22px;
        border-radius: 17px;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-size: 15px;
        font-weight: 950;
        cursor: pointer;
        white-space: nowrap;
    }

    .stk-primary-btn {
        background: #4f46e5;
        color: white;
        box-shadow: 0 16px 30px rgba(79, 70, 229, .25);
    }

    .stk-secondary-btn {
        background: #f8fafc;
        color: #334155;
        border: 1px solid #d4deeb;
    }

    @@media (max-width: 920px) {
        .stk-form-page {
            width: min(100% - 24px, 1080px);
            padding: 18px 0 44px;
        }

        .stk-form-hero {
            padding: 18px;
            border-radius: 26px;
            align-items: flex-start;
        }

        .stk-hero-left {
            align-items: flex-start;
            gap: 13px;
        }

        .stk-home-btn {
            width: 46px;
            height: 46px;
            flex-basis: 46px;
            border-radius: 16px;
            margin-top: 3px;
        }

        .stk-form-hero h1 {
            font-size: 30px;
            letter-spacing: -1.2px;
        }

        .stk-form-hero p {
            font-size: 14px;
        }

        .stk-list-btn {
            width: 50px;
            height: 50px;
            padding: 0;
            border-radius: 17px;
            flex: 0 0 50px;
        }

            .stk-list-btn strong {
                display: none;
            }

        .stk-form-card {
            padding: 18px;
            border-radius: 24px;
        }

        .stk-form-grid {
            grid-template-columns: 1fr;
            gap: 14px;
        }

        .stk-field.full {
            grid-column: auto;
        }

        .stk-input,
        .stk-money-input {
            height: 52px;
            border-radius: 18px;
        }

        .stk-form-actions {
            padding: 16px;
            border-radius: 24px;
            display: grid;
            grid-template-columns: 1fr;
        }

        .stk-primary-btn,
        .stk-secondary-btn {
            width: 100%;
            min-height: 52px;
        }

        .stk-primary-btn {
            order: -1;
        }
    }

    @@media (max-width: 460px) {
        .stk-form-page {
            width: min(100% - 18px, 1080px);
            padding-top: 12px;
        }

        .stk-form-hero {
            padding: 16px;
            border-radius: 24px;
        }

        .stk-home-btn {
            width: 42px;
            height: 42px;
            flex-basis: 42px;
            border-radius: 15px;
            font-size: 21px;
        }

        .stk-eyebrow {
            padding: 5px 10px;
            font-size: 11px;
        }

        .stk-form-hero h1 {
            font-size: 27px;
        }

        .stk-form-hero p {
            font-size: 13px;
        }

        .stk-list-btn {
            width: 46px;
            height: 46px;
            flex-basis: 46px;
        }

        .stk-form-card h2 {
            font-size: 22px;
        }

        .stk-info-alert {
            padding: 14px;
            border-radius: 20px;
        }
    }
</style>