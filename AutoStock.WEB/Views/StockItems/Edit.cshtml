@model AutoStock.WEB.Models.StockItems.EditStockItemViewModel

@{
    ViewData["Title"] = "Stok Kartı Düzenle";
}

<div class="page-header">
    <div>
        <h1>Stok Kartı Düzenle</h1>
        <p>Stok kartı bilgilerini güncelleyin. Miktar bu ekrandan değiştirilemez.</p>
    </div>

    <a asp-controller="StockItems"
       asp-action="Details"
       asp-route-id="@Model.Id"
       class="btn btn-secondary">
        Geri
    </a>
</div>

<div class="alert alert-info">
    Mevcut stok miktarı bu ekrandan düzenlenmez. Miktar değişiklikleri için stok detay ekranındaki
    <strong>Stok Düzelt</strong> işlemini kullanın.
</div>

<form asp-controller="StockItems"
      asp-action="Edit"
      asp-route-id="@Model.Id"
      method="post"
      class="card form-card">

    <input type="hidden" asp-for="Id" />

    <div class="form-grid">
        <div class="form-group">
            <label>Stok Adı</label>
            <input asp-for="Name" class="form-control" />
        </div>

        <div class="form-group">
            <label>Stok Kodu</label>
            <input asp-for="Code" class="form-control" />
        </div>

        <div class="form-group">
            <label>Barkod</label>
            <input asp-for="Barcode" class="form-control" />
        </div>

        <div class="form-group">
            <label>Marka</label>
            <input asp-for="Brand" class="form-control" />
        </div>

        <div class="form-group">
            <label>Birim</label>
            <input asp-for="Unit" class="form-control" />
        </div>

        <div class="form-group">
            <label>Alış Fiyatı</label>
            <input asp-for="PurchasePrice" class="form-control" type="number" step="0.01" />
        </div>

        <div class="form-group">
            <label>Satış Fiyatı</label>
            <input asp-for="SalePrice" class="form-control" type="number" step="0.01" />
        </div>

        <div class="form-group">
            <label>Minimum Stok</label>
            <input asp-for="MinimumQuantity" class="form-control" type="number" step="0.01" />
        </div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">
            Güncelle
        </button>
    </div>
</form>