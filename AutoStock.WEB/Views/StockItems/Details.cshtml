@model AutoStock.WEB.Models.StockItems.StockItemDetailViewModel

@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Stok Detayı";

    var isCritical = Model.Quantity <= Model.MinimumQuantity;
    var isOwner = string.Equals(Context.Session.GetString("UserRole"), "Owner", StringComparison.OrdinalIgnoreCase);

    string GetMovementBadgeClass(string? movementType)
    {
        return movementType switch
        {
            "In" => "success",
            "Out" => "danger",
            "Adjustment" => "warning",
            "ServiceUsage" => "primary",
            "ServiceUsageReturn" => "secondary",
            "InvoiceUsage" => "dark",
            "InvoiceCancellation" => "secondary",
            _ => "secondary"
        };
    }

    string GetMovementBadgeText(string? movementType)
    {
        return movementType switch
        {
            "In" => "Giriş",
            "Out" => "Çıkış",
            "Adjustment" => "Düzeltme",
            "ServiceUsage" => "Servis Kullanımı",
            "ServiceUsageReturn" => "Servis İadesi",
            "InvoiceUsage" => "Fatura",
            "InvoiceCancellation" => "Fatura İptali",
            _ => movementType ?? "Bilinmiyor"
        };
    }
}

<div class="stk-detail-page">
    <section class="stk-detail-hero">
        <div class="stk-hero-left">
            <a asp-controller="StockItems"
               asp-action="Index"
               class="stk-home-btn"
               title="Stok listesine dön">
                ←
            </a>

            <div>
                <span class="stk-eyebrow">SENTE360</span>
                <h1>@Model.Name</h1>
                <p>Stok kartı detayları, fiyat bilgileri ve hareket geçmişi.</p>
            </div>
        </div>

        @if (isOwner)
        {
            <a asp-controller="StockItems"
               asp-action="Edit"
               asp-route-id="@Model.Id"
               class="stk-edit-hero-btn">
                <span>✎</span>
                <strong>Düzenle</strong>
            </a>
        }
    </section>

    <section class="stk-summary-grid">
        <article class="stk-summary-card @(isCritical ? "critical" : "")">
            <div class="stk-summary-icon">▦</div>
            <div>
                <span>Mevcut Stok</span>
                <strong>@Model.Quantity @Model.Unit</strong>
                <small>Minimum: @Model.MinimumQuantity @Model.Unit</small>
            </div>
        </article>

        <article class="stk-summary-card">
            <div class="stk-summary-icon blue">₺</div>
            <div>
                <span>Satış Fiyatı</span>
                <strong>@SenteMoney.Format(Model.SalePrice)</strong>
                <small>Güncel satış fiyatı</small>
            </div>
        </article>

        <article class="stk-summary-card">
            <div class="stk-summary-icon purple">₺</div>
            <div>
                <span>Ortalama Maliyet</span>
                <strong>@SenteMoney.Format(Model.PurchasePrice)</strong>
                <small>Paçal alış maliyeti</small>
            </div>
        </article>

        <article class="stk-summary-card @(isCritical ? "critical" : "normal")">
            <div class="stk-summary-icon @(isCritical ? "red" : "green")">
                @(isCritical ? "!" : "✓")
            </div>
            <div>
                <span>Stok Durumu</span>
                <strong>@(isCritical ? "Kritik" : "Normal")</strong>
                <small>@(isCritical ? "Minimum seviyeye ulaştı" : "Stok seviyesi yeterli")</small>
            </div>
        </article>
    </section>

    <section class="stk-detail-grid">
        <article class="stk-info-card">
            <div class="stk-section-head">
                <div>
                    <span class="stk-section-badge">Bilgi</span>
                    <h2>Stok Kartı Bilgileri</h2>
                    <p>Parça veya ürünün temel bilgileri.</p>
                </div>

                @if (isCritical)
                {
                    <span class="stk-status-pill critical">KRİTİK STOK</span>
                }
                else
                {
                    <span class="stk-status-pill normal">NORMAL</span>
                }
            </div>

            <div class="stk-info-grid">
                <div class="stk-info-item">
                    <span>Stok Adı</span>
                    <strong>@Model.Name</strong>
                </div>

                <div class="stk-info-item">
                    <span>Stok Kodu</span>
                    <strong>@Model.Code</strong>
                </div>

                <div class="stk-info-item">
                    <span>Barkod</span>
                    <strong>
                        @if (!string.IsNullOrWhiteSpace(Model.Barcode))
                        {
                            @Model.Barcode
                        }
                        else
                        {
                            <em>Yok</em>
                        }
                    </strong>
                </div>

                <div class="stk-info-item">
                    <span>Marka</span>
                    <strong>
                        @if (!string.IsNullOrWhiteSpace(Model.Brand))
                        {
                            <span class="stk-brand-pill">@Model.Brand</span>
                        }
                        else
                        {
                            <em>Yok</em>
                        }
                    </strong>
                </div>

                <div class="stk-info-item">
                    <span>Birim</span>
                    <strong>@Model.Unit</strong>
                </div>

                <div class="stk-info-item">
                    <span>Oluşturulma</span>
                    <strong>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</strong>
                </div>
            </div>
        </article>

        <aside class="stk-action-card">
            <div class="stk-section-head compact">
                <div>
                    <span class="stk-section-badge">İşlem</span>
                    <h2>Stok İşlemleri</h2>
                    <p>Bu stok kartı üzerinde işlem yapın.</p>
                </div>
            </div>



            <div class="stk-action-list">
                <button type="button"
                        class="stk-action-btn success"
                        onclick="openStockInModal()">
                    Stok Girişi Yap
                </button>

                @if (isOwner)
                {
                    <button type="button"
                            class="stk-action-btn primary"
                            onclick="openAdjustStockModal()">
                        Stok Miktarını Düzelt
                    </button>
                }

                @if (isOwner)
                {
                    <a asp-controller="StockItems"
                       asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="stk-action-btn warning">
                        Stok Kartını Düzenle
                    </a>
                }

                @if (isOwner)
                {
                    <form asp-controller="StockItems"
                          asp-action="SetPassive"
                          asp-route-id="@Model.Id"
                          method="post"
                          onsubmit="return confirm('Bu stok kartını silmek istediğinize emin misiniz?');">

                        <button type="submit" class="stk-action-btn danger">
                            Stok Kartını Sil
                        </button>
                    </form>
                }
            </div>
        </aside>
    </section>

    <section class="stk-movement-card">
        <div class="stk-section-head">
            <div>
                <span class="stk-section-badge">Geçmiş</span>
                <h2>Stok Hareketleri</h2>
                <p>Bu stok kartına ait giriş, çıkış, servis kullanımı ve düzeltme geçmişi.</p>
            </div>
        </div>

        <div class="stk-movement-list">
            @if (!Model.Movements.Any())
            {
                <div class="stk-empty">
                    <div class="stk-empty-icon">⌕</div>
                    <strong>Hareket bulunamadı</strong>
                    <span>Bu stok kartı için henüz hareket kaydı oluşmamış.</span>
                </div>
            }
            else
            {
                foreach (var item in Model.Movements)
                {
                    var badgeClass = GetMovementBadgeClass(item.MovementType);
                    var badgeText = GetMovementBadgeText(item.MovementType);

                    <article class="stk-movement-item">
                        <div class="stk-movement-main">
                            <span class="stk-movement-badge @badgeClass">@badgeText</span>

                            <div>
                                <strong>@item.Quantity</strong>
                                <small>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                            </div>
                        </div>

                        <div class="stk-movement-price">
                            <span>Birim Fiyat</span>

                            @if (item.UnitPrice.HasValue)
                            {
                                <strong>@SenteMoney.Format(item.UnitPrice.Value)</strong>
                            }
                            else
                            {
                                <strong>-</strong>
                            }
                        </div>

                        <div class="stk-movement-desc">
                            <span>Açıklama</span>
                            <strong>@(string.IsNullOrWhiteSpace(item.Description) ? "-" : item.Description)</strong>
                        </div>
                    </article>
                }
            }
        </div>
    </section>
</div>

<div id="stockInModal" class="stk-modal-backdrop">
    <div class="stk-modal-card">
        <div class="stk-modal-head">
            <div>
                <span>Stok Girişi</span>
                <h3>Yeni Stok Girişi</h3>
                <p>Servise gelen yeni parça miktarını ve birim alış fiyatını girin. Ortalama maliyet otomatik hesaplanır.</p>
            </div>

            <button type="button"
                    class="stk-modal-close"
                    onclick="closeStockInModal()">
                ×
            </button>
        </div>

        <form asp-controller="StockItems"
              asp-action="StockIn"
              asp-route-id="@Model.Id"
              method="post">

            <div class="stk-modal-field">
                <label>Giriş Miktarı</label>
                <input name="Quantity"
                       type="number"
                       step="0.01"
                       min="0.01"
                       placeholder="Örn: 17" />
            </div>

            <div class="stk-modal-field">
                <label>Birim Alış Fiyatı</label>
                <input name="UnitPrice"
                       type="text"
                       inputmode="decimal"
                       data-sente-money-input
                       step="0.01"
                       min="0.01"
                       placeholder="Örn: 130" />
            </div>

            <div class="stk-modal-field">
                <label>Açıklama</label>
                <textarea name="Description"
                          rows="3"
                          placeholder="Örn: Tedarikçiden yeni ürün girişi"></textarea>
            </div>

            <div class="stk-modal-note">
                <strong>Paçal maliyet hesabı:</strong>
                Mevcut stok maliyeti ile yeni giriş fiyatı ağırlıklı ortalama olarak hesaplanır.
            </div>

            <div class="stk-modal-actions">
                <button type="button"
                        class="stk-modal-btn soft"
                        onclick="closeStockInModal()">
                    Vazgeç
                </button>

                <button type="submit" class="stk-modal-btn success">
                    Stok Girişini Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

<div id="adjustStockModal" class="stk-modal-backdrop">
    <div class="stk-modal-card">
        <div class="stk-modal-head">
            <div>
                <span>Stok İşlemi</span>
                <h3>Stok Düzelt</h3>
                <p>Mevcut stok miktarını gerçek sayım sonucuna göre güncelle.</p>
            </div>

            <button type="button"
                    class="stk-modal-close"
                    onclick="closeAdjustStockModal()">
                ×
            </button>
        </div>

        <form asp-controller="StockItems"
              asp-action="AdjustStock"
              asp-route-id="@Model.Id"
              method="post">

            <div class="stk-modal-field">
                <label>Yeni Stok Miktarı</label>
                <input name="NewQuantity"
                       type="number"
                       step="0.01"
                       min="0"
                       value="@Model.Quantity" />
            </div>

            <div class="stk-modal-field">
                <label>Açıklama</label>
                <textarea name="Description"
                          rows="3"
                          placeholder="Örn: Depo sayım düzeltmesi"></textarea>
            </div>

            <div class="stk-modal-actions">
                <button type="button"
                        class="stk-modal-btn soft"
                        onclick="closeAdjustStockModal()">
                    Vazgeç
                </button>

                <button type="submit" class="stk-modal-btn primary">
                    Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .stk-detail-page {
        width: min(1280px, calc(100% - 56px));
        margin: 0 auto;
        padding: 30px 0 64px;
        color: #061936;
    }

    .stk-detail-hero {
        margin-bottom: 22px;
        padding: 24px 28px;
        border-radius: 30px;
        background: radial-gradient(circle at 78% 40%, rgba(255,255,255,.16), transparent 30%), linear-gradient(135deg, #07111f 0%, #111827 48%, #4f46e5 100%);
        color: white;
        box-shadow: 0 26px 70px rgba(15, 23, 42, .20);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 22px;
        overflow: hidden;
    }

    .stk-hero-left {
        display: flex;
        align-items: center;
        gap: 18px;
        min-width: 0;
    }

    .stk-home-btn {
        width: 54px;
        height: 54px;
        flex: 0 0 54px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #2563eb, #16a34a);
        color: white;
        text-decoration: none;
        font-size: 26px;
        font-weight: 950;
        box-shadow: 0 18px 36px rgba(37, 99, 235, .25);
    }

    .stk-eyebrow {
        display: inline-flex;
        margin-bottom: 8px;
        padding: 6px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.18);
        color: rgba(255,255,255,.82);
        font-size: 12px;
        font-weight: 950;
        letter-spacing: .2px;
    }

    .stk-detail-hero h1 {
        margin: 0;
        font-size: clamp(30px, 4vw, 42px);
        line-height: 1;
        letter-spacing: -1.6px;
    }

    .stk-detail-hero p {
        margin: 10px 0 0;
        color: rgba(255,255,255,.72);
        font-size: 15px;
        line-height: 1.45;
    }

    .stk-edit-hero-btn {
        height: 56px;
        padding: 0 22px;
        border-radius: 18px;
        background: #4f46e5;
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
        font-size: 16px;
        box-shadow: 0 18px 34px rgba(79, 70, 229, .36);
        white-space: nowrap;
    }

        .stk-edit-hero-btn span {
            font-size: 22px;
        }

        .stk-edit-hero-btn strong {
            font-weight: 950;
        }

    .stk-summary-grid {
        margin-bottom: 18px;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
    }

    .stk-summary-card {
        min-width: 0;
        padding: 20px;
        border-radius: 24px;
        background: white;
        border: 1px solid #dbe3ef;
        box-shadow: 0 12px 30px rgba(15, 23, 42, .06);
        display: flex;
        align-items: center;
        gap: 14px;
    }

        .stk-summary-card.critical {
            background: linear-gradient(135deg, #ffffff 0%, #fff1f2 100%);
        }

        .stk-summary-card.normal {
            background: linear-gradient(135deg, #ffffff 0%, #f0fdf4 100%);
        }

    .stk-summary-icon {
        width: 48px;
        height: 48px;
        flex: 0 0 48px;
        border-radius: 17px;
        display: grid;
        place-items: center;
        background: #eef2ff;
        color: #4f46e5;
        font-size: 22px;
        font-weight: 950;
    }

        .stk-summary-icon.blue {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .stk-summary-icon.purple {
            background: #f3e8ff;
            color: #7c3aed;
        }

        .stk-summary-icon.green {
            background: #dcfce7;
            color: #059669;
        }

        .stk-summary-icon.red {
            background: #ffe4e6;
            color: #e11d48;
        }

    .stk-summary-card span {
        display: block;
        color: #64748b;
        font-size: 12px;
        font-weight: 950;
        margin-bottom: 5px;
    }

    .stk-summary-card strong {
        display: block;
        color: #0f172a;
        font-size: clamp(20px, 2vw, 26px);
        font-weight: 950;
        letter-spacing: -.7px;
        white-space: nowrap;
    }

    .stk-summary-card small {
        display: block;
        margin-top: 5px;
        color: #64748b;
        font-size: 12px;
        font-weight: 800;
    }

    .stk-detail-grid {
        display: grid;
        grid-template-columns: minmax(0, 2fr) minmax(320px, .85fr);
        gap: 18px;
        margin-bottom: 18px;
    }

    .stk-info-card,
    .stk-action-card,
    .stk-movement-card {
        padding: 24px;
        border-radius: 26px;
        background: white;
        border: 1px solid #dbe3ef;
        box-shadow: 0 14px 36px rgba(15, 23, 42, .06);
    }

    .stk-section-head {
        margin-bottom: 22px;
        padding-bottom: 18px;
        border-bottom: 1px solid #edf2f7;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
    }

        .stk-section-head.compact {
            display: block;
        }

    .stk-section-badge {
        display: inline-flex;
        margin-bottom: 10px;
        padding: 6px 11px;
        border-radius: 999px;
        background: #eef2ff;
        color: #4f46e5;
        font-size: 12px;
        font-weight: 950;
    }

    .stk-section-head h2 {
        margin: 0;
        color: #0f172a;
        font-size: 23px;
        font-weight: 950;
        letter-spacing: -.7px;
    }

    .stk-section-head p {
        margin: 7px 0 0;
        color: #64748b;
        font-size: 14px;
        line-height: 1.45;
    }

    .stk-info-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .stk-info-item {
        min-width: 0;
        padding: 15px;
        border-radius: 18px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
    }

        .stk-info-item span {
            display: block;
            color: #8aa0bd;
            font-size: 12px;
            font-weight: 950;
            margin-bottom: 7px;
        }

        .stk-info-item strong {
            display: block;
            color: #0f172a;
            font-size: 15px;
            font-weight: 950;
            word-break: break-word;
        }

        .stk-info-item em {
            color: #94a3b8;
            font-style: normal;
            font-weight: 850;
        }

    .stk-brand-pill {
        width: fit-content;
        max-width: 100%;
        min-height: 30px;
        padding: 0 12px;
        border-radius: 999px;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        color: #475569;
        display: inline-flex;
        align-items: center;
        font-size: 13px;
        font-weight: 950;
    }

    .stk-status-pill {
        min-width: 110px;
        height: 34px;
        padding: 0 12px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 950;
        white-space: nowrap;
    }

        .stk-status-pill.normal {
            background: #dcfce7;
            color: #166534;
        }

        .stk-status-pill.critical {
            background: #ffe4e6;
            color: #be123c;
        }

    .stk-action-card {
        align-self: start;
    }

    .stk-action-list {
        display: grid;
        gap: 11px;
    }

        .stk-action-list form {
            margin: 0;
        }

    .stk-action-btn {
        width: 100%;
        min-height: 48px;
        border-radius: 16px;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-size: 14px;
        font-weight: 950;
        cursor: pointer;
    }

        .stk-action-btn.primary {
            background: #4f46e5;
            color: white;
            box-shadow: 0 14px 26px rgba(79, 70, 229, .22);
        }

        .stk-action-btn.success {
            background: #059669;
            color: white;
            box-shadow: 0 14px 26px rgba(5, 150, 105, .20);
        }

    .stk-modal-btn.success {
        background: #059669;
        color: white;
    }

        .stk-action-btn.warning {
            background: #fef3c7;
            color: #92400e;
            border: 1px solid #fde68a;
        }

        .stk-action-btn.danger {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

    .stk-movement-list {
        display: grid;
        gap: 12px;
    }

    .stk-movement-item {
        padding: 16px;
        border-radius: 22px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        display: grid;
        grid-template-columns: minmax(220px, 1fr) minmax(150px, .55fr) minmax(260px, 1.1fr);
        gap: 14px;
        align-items: center;
    }

    .stk-movement-main {
        min-width: 0;
        display: flex;
        align-items: center;
        gap: 13px;
    }

        .stk-movement-main div {
            min-width: 0;
        }

        .stk-movement-main strong {
            display: block;
            color: #0f172a;
            font-size: 18px;
            font-weight: 950;
        }

        .stk-movement-main small {
            display: block;
            margin-top: 4px;
            color: #64748b;
            font-size: 12px;
            font-weight: 800;
        }

    .stk-movement-badge {
        min-width: 108px;
        height: 34px;
        padding: 0 11px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 950;
        white-space: nowrap;
    }

        .stk-movement-badge.success {
            background: #dcfce7;
            color: #166534;
        }

        .stk-movement-badge.danger {
            background: #ffe4e6;
            color: #be123c;
        }

        .stk-movement-badge.warning {
            background: #fef3c7;
            color: #92400e;
        }

        .stk-movement-badge.primary {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .stk-movement-badge.secondary {
            background: #f1f5f9;
            color: #475569;
        }

        .stk-movement-badge.dark {
            background: #e2e8f0;
            color: #0f172a;
        }

    .stk-movement-price,
    .stk-movement-desc {
        min-width: 0;
    }

        .stk-movement-price span,
        .stk-movement-desc span {
            display: block;
            color: #8aa0bd;
            font-size: 12px;
            font-weight: 950;
            margin-bottom: 5px;
        }

        .stk-movement-price strong,
        .stk-movement-desc strong {
