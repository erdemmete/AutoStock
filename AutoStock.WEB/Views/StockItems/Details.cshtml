@model AutoStock.WEB.Models.StockItems.StockItemDetailViewModel

@{
    ViewData["Title"] = "Stok Detayı";

    var isCritical = Model.Quantity <= Model.MinimumQuantity;
}

<div class="stock-detail-page">
    <div class="stock-detail-header">
        <div>
            <div class="breadcrumb-lite">
                <a asp-controller="Dashboard" asp-action="Index">Ana Sayfa</a>
                <span>/</span>
                <a asp-controller="StockItems" asp-action="Index">Stok Yönetimi</a>
                <span>/</span>
                <strong>@Model.Name</strong>
            </div>

            <h1>@Model.Name</h1>
            <p>Stok kartı detayları, fiyat bilgileri ve hareket geçmişi</p>
        </div>

        <div class="stock-header-actions">
            <a asp-controller="Dashboard"
               asp-action="Index"
               class="stock-secondary-btn">
                Ana Sayfa
            </a>

            <a asp-controller="StockItems"
               asp-action="Index"
               class="stock-secondary-btn">
                Stok Listesi
            </a>
        </div>
    </div>

    <div class="summary-grid">
        <div class="summary-card">
            <span>Mevcut Stok</span>
            <strong class="@(isCritical ? "danger-text" : "")">
                @Model.Quantity @Model.Unit
            </strong>
            <p>Minimum: @Model.MinimumQuantity @Model.Unit</p>
        </div>

        <div class="summary-card">
            <span>Satış Fiyatı</span>
            <strong>₺@Model.SalePrice.ToString("N2")</strong>
            <p>Güncel satış fiyatı</p>
        </div>

        <div class="summary-card">
            <span>Alış Fiyatı</span>
            <strong>₺@Model.PurchasePrice.ToString("N2")</strong>
            <p>Maliyet bilgisi</p>
        </div>

        <div class="summary-card">
            <span>Stok Durumu</span>

            @if (isCritical)
            {
                <strong class="danger-text">Kritik</strong>
                <p>Minimum seviyenin altında veya eşit</p>
            }
            else
            {
                <strong class="success-text">Normal</strong>
                <p>Stok seviyesi yeterli</p>
            }
        </div>
    </div>

    <div class="detail-grid">
        <div class="detail-card">
            <div class="card-title-row">
                <div>
                    <h2>Stok Kartı Bilgileri</h2>
                    <p>Parça veya ürünün temel bilgileri</p>
                </div>

                @if (isCritical)
                {
                    <span class="status-badge danger">Kritik Stok</span>
                }
                else
                {
                    <span class="status-badge success">Normal</span>
                }
            </div>

            <div class="info-grid">
                <div class="info-item">
                    <span>Stok Adı</span>
                    <strong>@Model.Name</strong>
                </div>

                <div class="info-item">
                    <span>Stok Kodu</span>
                    <strong>@Model.Code</strong>
                </div>

                <div class="info-item">
                    <span>Barkod</span>
                    <strong>
                        @if (!string.IsNullOrWhiteSpace(Model.Barcode))
                        {
                            @Model.Barcode
                        }
                        else
                        {
                            <span class="muted-text">Yok</span>
                        }
                    </strong>
                </div>

                <div class="info-item">
                    <span>Marka</span>
                    <strong>
                        @if (!string.IsNullOrWhiteSpace(Model.Brand))
                        {
                            <span class="brand-pill">@Model.Brand</span>
                        }
                        else
                        {
                            <span class="muted-text">Yok</span>
                        }
                    </strong>
                </div>

                <div class="info-item">
                    <span>Birim</span>
                    <strong>@Model.Unit</strong>
                </div>

                <div class="info-item">
                    <span>Oluşturulma</span>
                    <strong>@Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</strong>
                </div>
            </div>
        </div>

        <div class="detail-card danger-zone-card">
            <h2>İşlemler</h2>
            <p>Stok kartı üzerinde yapılabilecek işlemler</p>

            <div class="action-list">
                <button type="button"
                        class="action-button primary"
                        onclick="openAdjustStockModal()">
                    Stok Miktarını Düzelt
                </button>

                <a asp-controller="StockItems"
                   asp-action="Edit"
                   asp-route-id="@Model.Id"
                   class="action-button warning">
                    Stok Kartını Düzenle
                </a>

                <form asp-controller="StockItems"
                      asp-action="SetPassive"
                      asp-route-id="@Model.Id"
                      method="post"
                      onsubmit="return confirm('Bu stok kartını silmek istediğinize emin misiniz?');">

                    <button type="submit" class="action-button danger">
                        Stok Kartını Sil
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="movements-card">
        <div class="card-title-row">
            <div>
                <h2>Stok Hareketleri</h2>
                <p>Bu stok kartına ait giriş, çıkış, servis kullanımı ve düzeltme geçmişi</p>
            </div>
        </div>

        <div class="table-responsive">
            <table class="movement-table">
                <thead>
                    <tr>
                        <th>Tip</th>
                        <th>Miktar</th>
                        <th>Birim Fiyat</th>
                        <th>Açıklama</th>
                        <th>Tarih</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Movements.Any())
                    {
                        <tr>
                            <td colspan="5" class="empty-cell">
                                Hareket bulunamadı.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.Movements)
                        {
                            var badgeClass = item.MovementType switch
                            {
                                "In" => "success",
                                "Out" => "danger",
                                "Adjustment" => "warning",
                                "ServiceUsage" => "primary",
                                "ServiceUsageReturn" => "secondary",
                                "InvoiceUsage" => "dark",
                                "InvoiceCancellation" => "secondary",
                                _ => "secondary"
                            };

                            var badgeText = item.MovementType switch
                            {
                                "In" => "Giriş",
                                "Out" => "Çıkış",
                                "Adjustment" => "Düzeltme",
                                "ServiceUsage" => "Servis",
                                "ServiceUsageReturn" => "Servis İadesi",
                                "InvoiceUsage" => "Fatura",
                                "InvoiceCancellation" => "Fatura İptali",
                                _ => item.MovementType
                            };

                            <tr>
                                <td>
                                    <span class="movement-badge @badgeClass">
                                        @badgeText
                                    </span>
                                </td>

                                <td>
                                    <strong>@item.Quantity</strong>
                                </td>

                                <td>
                                    @if (item.UnitPrice.HasValue)
                                    {
                                        <strong>₺@item.UnitPrice.Value.ToString("N2")</strong>
                                    }
                                    else
                                    {
                                        <span class="muted-text">-</span>
                                    }
                                </td>

                                <td>@item.Description</td>

                                <td>
                                    @item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="adjustStockModal" class="modal-backdrop-custom">
    <div class="modal-card-custom">
        <div class="modal-header-custom">
            <div>
                <h3>Stok Düzelt</h3>
                <p>Mevcut stok miktarını gerçek sayım sonucuna göre güncelle.</p>
            </div>

            <button type="button"
                    class="modal-close-button"
                    onclick="closeAdjustStockModal()">
                ×
            </button>
        </div>

        <form asp-controller="StockItems"
              asp-action="AdjustStock"
              asp-route-id="@Model.Id"
              method="post">

            <div class="form-group">
                <label>Yeni Stok Miktarı</label>
                <input name="NewQuantity"
                       type="number"
                       step="0.01"
                       min="0"
                       class="form-control-custom"
                       value="@Model.Quantity" />
            </div>

            <div class="form-group">
                <label>Açıklama</label>
                <textarea name="Description"
                          class="form-control-custom"
                          rows="3"
                          placeholder="Örn: Depo sayım düzeltmesi"></textarea>
            </div>

            <div class="modal-actions-custom">
                <button type="button"
                        class="stock-secondary-btn"
                        onclick="closeAdjustStockModal()">
                    Vazgeç
                </button>

                <button type="submit"
                        class="stock-primary-btn">
                    Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .stock-detail-page {
        padding-top: 28px;
        padding-bottom: 32px;
    }

    .stock-detail-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 26px;
    }

    .breadcrumb-lite {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #94a3b8;
        font-size: 13px;
        margin-bottom: 10px;
    }

        .breadcrumb-lite a {
            color: #64748b;
            text-decoration: none;
            font-weight: 700;
        }

            .breadcrumb-lite a:hover {
                color: #4f46e5;
            }

    .stock-detail-header h1 {
        margin: 0;
        font-size: 30px;
        font-weight: 900;
        color: #0f172a;
    }

    .stock-detail-header p {
        margin: 8px 0 0;
        color: #64748b;
        font-size: 14px;
    }

    .stock-header-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
        flex-wrap: wrap;
    }

    .stock-primary-btn,
    .stock-secondary-btn,
    .stock-warning-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 11px 17px;
        border-radius: 12px;
        font-weight: 800;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: .18s ease;
        white-space: nowrap;
    }

    .stock-primary-btn {
        background: #4f46e5;
        color: #fff;
        box-shadow: 0 10px 24px rgba(79, 70, 229, .22);
    }

        .stock-primary-btn:hover {
            background: #4338ca;
            color: #fff;
            transform: translateY(-1px);
        }

    .stock-secondary-btn {
        background: #f8fafc;
        color: #334155;
        border: 1px solid #cfd8e6;
    }

        .stock-secondary-btn:hover {
            background: #eef2ff;
            border-color: #c7d2fe;
            color: #4f46e5;
        }

    .stock-warning-btn {
        background: #fef3c7;
        color: #92400e;
        border: 1px solid #fde68a;
    }

        .stock-warning-btn:hover {
            background: #fde68a;
            color: #78350f;
        }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
        margin-bottom: 22px;
    }

    .summary-card {
        background: #fff;
        border: 1px solid #dbe3ef;
        border-radius: 18px;
        padding: 20px;
        box-shadow: 0 8px 22px rgba(15, 23, 42, .06);
    }

        .summary-card span {
            display: block;
            color: #64748b;
            font-size: 13px;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .summary-card strong {
            display: block;
            color: #0f172a;
            font-size: 24px;
            font-weight: 900;
            margin-bottom: 6px;
        }

        .summary-card p {
            margin: 0;
            color: #94a3b8;
            font-size: 13px;
        }

    .detail-grid {
        display: grid;
        grid-template-columns: minmax(0, 2fr) minmax(320px, 1fr);
        gap: 20px;
        margin-bottom: 22px;
    }

    .detail-card,
    .movements-card {
        background: #fff;
        border: 1px solid #dbe3ef;
        border-radius: 18px;
        padding: 24px;
        box-shadow: 0 8px 22px rgba(15, 23, 42, .06);
    }

    .card-title-row {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 22px;
    }

        .card-title-row h2,
        .detail-card h2 {
            margin: 0;
            font-size: 19px;
            font-weight: 900;
            color: #0f172a;
        }

        .card-title-row p,
        .detail-card p {
            margin: 6px 0 0;
            color: #64748b;
            font-size: 14px;
        }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
    }

    .info-item {
        padding: 15px;
        border: 1px solid #edf2f7;
        border-radius: 14px;
        background: #fbfdff;
    }

        .info-item span {
            display: block;
            color: #64748b;
            font-size: 12px;
            font-weight: 800;
            margin-bottom: 7px;
        }

        .info-item strong {
            color: #0f172a;
            font-weight: 900;
        }

    .brand-pill {
        display: inline-flex;
        align-items: center;
        padding: 5px 10px;
        border-radius: 8px;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        color: #475569;
        font-size: 12px;
        font-weight: 800;
    }

    .status-badge,
    .movement-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 900;
        white-space: nowrap;
    }

        .status-badge.success,
        .movement-badge.success {
            background: #dcfce7;
            color: #166534;
        }

        .status-badge.danger,
        .movement-badge.danger {
            background: #ffe4e6;
            color: #be123c;
        }

        .movement-badge.warning {
            background: #fef3c7;
            color: #92400e;
        }

        .movement-badge.primary {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .movement-badge.secondary {
            background: #f1f5f9;
            color: #475569;
        }

        .movement-badge.dark {
            background: #e2e8f0;
            color: #0f172a;
        }

    .success-text {
        color: #166534 !important;
    }

    .danger-text {
        color: #e11d48 !important;
    }

    .muted-text {
        color: #94a3b8 !important;
        font-weight: 700 !important;
    }

    .danger-zone-card {
        align-self: start;
    }

    .action-list {
        display: grid;
        gap: 12px;
        margin-top: 20px;
    }

        .action-list form {
            margin: 0;
        }

    .action-button {
        width: 100%;
        min-height: 44px;
        border-radius: 12px;
        border: none;
        text-decoration: none;
        font-weight: 900;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: .18s ease;
    }

        .action-button.primary {
            background: #4f46e5;
            color: #fff;
        }

        .action-button.warning {
            background: #fef3c7;
            color: #92400e;
            border: 1px solid #fde68a;
        }

        .action-button.danger {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

        .action-button:hover {
            transform: translateY(-1px);
        }

    .table-responsive {
        width: 100%;
        overflow-x: auto;
    }

    .movement-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 820px;
    }

        .movement-table th {
            padding: 15px 16px;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: .04em;
            color: #64748b;
            font-weight: 900;
            text-align: left;
            background: #f8fafc;
            border-bottom: 1px solid #dbe3ef;
        }

        .movement-table td {
            padding: 17px 16px;
            border-bottom: 1px solid #edf2f7;
            vertical-align: middle;
            color: #0f172a;
            font-size: 14px;
        }

        .movement-table tr:last-child td {
            border-bottom: none;
        }

    .empty-cell {
        padding: 34px !important;
        text-align: center;
        color: #64748b !important;
    }

    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        display: none;
        align-items: center;
        justify-content: center;
        background: rgba(15, 23, 42, .55);
        backdrop-filter: blur(8px);
        z-index: 9999;
        padding: 20px;
    }

        .modal-backdrop-custom.show {
            display: flex;
        }

    .modal-card-custom {
        width: min(520px, 100%);
        background: white;
        border-radius: 22px;
        padding: 24px;
        box-shadow: 0 30px 80px rgba(15, 23, 42, .28);
    }

    .modal-header-custom {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 20px;
    }

        .modal-header-custom h3 {
            margin: 0;
            font-size: 24px;
            font-weight: 900;
            color: #0f172a;
        }

        .modal-header-custom p {
            margin: 6px 0 0;
            color: #64748b;
            font-size: 14px;
        }

    .modal-close-button {
        width: 38px;
        height: 38px;
        border: none;
        border-radius: 12px;
        background: #f1f5f9;
        color: #0f172a;
        font-size: 24px;
        cursor: pointer;
    }

    .form-group {
        margin-bottom: 16px;
    }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 900;
            font-size: 14px;
            color: #0f172a;
        }

    .form-control-custom {
        width: 100%;
        border: 1px solid #cfd8e6;
        border-radius: 12px;
        padding: 12px 13px;
        font-size: 14px;
        outline: none;
    }

        .form-control-custom:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 3px rgba(79, 70, 229, .12);
        }

    .modal-actions-custom {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 22px;
    }

    @@media (max-width: 1100px) {
        .summary-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .detail-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .stock-detail-header {
            flex-direction: column;
        }

        .stock-header-actions {
            width: 100%;
            justify-content: flex-start;
        }

        .summary-grid {
            grid-template-columns: 1fr;
        }

        .info-grid {
            grid-template-columns: 1fr;
        }

        .stock-primary-btn,
        .stock-secondary-btn,
        .stock-warning-btn {
            width: 100%;
        }

        .modal-actions-custom {
            flex-direction: column;
        }
    }
</style>

<script>
    function openAdjustStockModal() {
        document.getElementById("adjustStockModal")?.classList.add("show");
    }

    function closeAdjustStockModal() {
        document.getElementById("adjustStockModal")?.classList.remove("show");
    }

    document.addEventListener("DOMContentLoaded", function () {
        const modal = document.getElementById("adjustStockModal");

        modal?.addEventListener("click", function (event) {
            if (event.target === modal) {
                closeAdjustStockModal();
            }
        });

        document.addEventListener("keydown", function (event) {
            if (event.key === "Escape") {
                closeAdjustStockModal();
            }
        });
    });
</script>