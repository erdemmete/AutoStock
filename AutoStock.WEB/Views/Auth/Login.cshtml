@model AutoStock.WEB.Models.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sente360 | Giriş</title>

    <style>
            * {
                box-sizing: border-box;
            }

            html, body {
                margin: 0;
                min-height: 100%;
                font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
                color: #0f172a;
            }

            body {
                min-height: 100vh;
                background: radial-gradient(circle at top left, rgba(37, 99, 235, .35), transparent 34%), radial-gradient(circle at bottom right, rgba(22, 163, 74, .22), transparent 30%), linear-gradient(135deg, #020617, #0f172a 45%, #1e3a8a);
            }

            .login-page {
                min-height: 100vh;
                display: grid;
                place-items: center;
                padding: 28px;
            }

            .login-shell {
                width: min(1080px, 100%);
                display: grid;
                grid-template-columns: 1.05fr .95fr;
                background: rgba(255,255,255,.08);
                border: 1px solid rgba(255,255,255,.14);
                border-radius: 34px;
                overflow: hidden;
                box-shadow: 0 40px 90px rgba(0,0,0,.35);
                backdrop-filter: blur(18px);
            }

            .brand-panel {
                padding: 56px;
                color: white;
                position: relative;
                overflow: hidden;
            }

            .brand-badge {
                width: 64px;
                height: 64px;
                border-radius: 22px;
                display: grid;
                place-items: center;
                font-weight: 900;
                font-size: 22px;
                background: linear-gradient(135deg, #2563eb, #16a34a);
                box-shadow: 0 20px 45px rgba(37,99,235,.35);
                margin-bottom: 28px;
            }

            .brand-panel h1 {
                font-size: clamp(38px, 5vw, 62px);
                line-height: .95;
                letter-spacing: -2px;
                margin: 0 0 18px;
            }

            .brand-panel p {
                max-width: 460px;
                color: #cbd5e1;
                font-size: 16px;
                line-height: 1.7;
                margin: 0;
            }

            .mini-stats {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 14px;
                margin-top: 44px;
            }

            .stat {
                padding: 16px;
                border-radius: 20px;
                background: rgba(255,255,255,.08);
                border: 1px solid rgba(255,255,255,.12);
            }

                .stat strong {
                    display: block;
                    font-size: 22px;
                }

                .stat span {
                    color: #cbd5e1;
                    font-size: 12px;
                }

            .form-panel {
                padding: 48px;
                background: rgba(255,255,255,.96);
                display: flex;
                align-items: center;
            }

            .login-card {
                width: 100%;
            }

                .login-card h2 {
                    margin: 0;
                    font-size: 30px;
                    letter-spacing: -.8px;
                }

            .subtitle {
                margin: 10px 0 30px;
                color: #64748b;
                line-height: 1.5;
            }

            .field {
                margin-bottom: 18px;
            }

                .field label {
                    display: block;
                    font-size: 13px;
                    font-weight: 800;
                    color: #334155;
                    margin-bottom: 8px;
                }

                .field input {
                    width: 100%;
                    height: 54px;
                    border: 1px solid #dbe3ef;
                    border-radius: 16px;
                    padding: 0 16px;
                    font-size: 15px;
                    background: #f8fafc;
                    outline: none;
                    transition: .18s ease;
                }

                    .field input:focus {
                        border-color: #2563eb;
                        background: white;
                        box-shadow: 0 0 0 4px rgba(37,99,235,.12);
                    }

            .login-button {
                width: 100%;
                height: 56px;
                border: none;
                border-radius: 16px;
                margin-top: 8px;
                background: linear-gradient(135deg, #0f172a, #2563eb);
                color: white;
                font-size: 16px;
                font-weight: 900;
                cursor: pointer;
                box-shadow: 0 18px 35px rgba(37,99,235,.25);
                transition: .18s ease;
            }

                .login-button:hover {
                    transform: translateY(-1px);
                    box-shadow: 0 22px 45px rgba(37,99,235,.32);
                }

            .error {
                margin-top: 16px;
                padding: 12px 14px;
                border-radius: 14px;
                background: #fee2e2;
                color: #991b1b;
                font-size: 14px;
                font-weight: 700;
            }

            .footer-note {
                margin-top: 24px;
                font-size: 12px;
                color: #94a3b8;
                text-align: center;
            }

            @@media (max-width: 860px) {
                .login-shell {
                    grid-template-columns: 1fr;
                }

                .brand-panel {
                    padding: 34px;
                }

                .mini-stats {
                    display: none;
                }

                .form-panel {
                    padding: 30px;
                }
            }
    </style>
</head>

<body>
    <main class="login-page">
        <section class="login-shell">
            <div class="brand-panel">
                <div class="brand-badge">S360</div>

                <h1>Sente360</h1>
                <p>
                    Araç servis operasyonlarını tek ekrandan yönetmek için geliştirilen modern servis takip platformu.
                </p>

                <div class="mini-stats">
                    <div class="stat">
                        <strong>PDF</strong>
                        <span>Servis formu</span>
                    </div>
                    <div class="stat">
                        <strong>QR</strong>
                        <span>Müşteri erişimi</span>
                    </div>
                    <div class="stat">
                        <strong>V2</strong>
                        <span>Giriş sistemi</span>
                    </div>
                </div>
            </div>

            <div class="form-panel">
                <div class="login-card">
                    <h2>Hoş Geldin</h2>
                    <p class="subtitle">
                        Devam etmek için giriş yap.
                    </p>

                    <form asp-action="Login" method="post">
                        <div class="field">
                            <label asp-for="LoginName">Kullanıcı adı veya e-posta</label>
                            <input asp-for="LoginName" type="text" placeholder="Kullanıcı adı veya e-posta" autocomplete="username" />
                        </div>

                        <div class="field">
                            <label asp-for="Password">Şifre</label>
                            <input asp-for="Password" type="password" placeholder="Şifreni gir" autocomplete="current-password" />
                        </div>

                        <button class="login-button" type="submit">
                            Giriş Yap
                        </button>
                    </form>

                    @if (ViewBag.Error != null)
                    {
                        <div class="error">@ViewBag.Error</div>
                    }

                    <div class="footer-note">
                        © 2026 Sente360
                    </div>
                </div>
            </div>
        </section>
    </main>
</body>
</html>