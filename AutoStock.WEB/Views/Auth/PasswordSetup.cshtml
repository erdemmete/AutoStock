@model AutoStock.WEB.Models.Auth.PasswordSetupViewModel

@{
    ViewData["Title"] = "Şifre Oluştur";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Şifrenizi Oluşturun</h1>
            <p>Sente360 hesabınız için güvenli bir şifre belirleyin.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert-error">
                @Model.ErrorMessage
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.FullName))
        {
            <div class="user-summary">
                <div>
                    <span>Ad Soyad</span>
                    <strong>@Model.FullName</strong>
                </div>

                <div>
                    <span>Kullanıcı Adı</span>
                    <strong>@Model.UserName</strong>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.WorkshopName))
                {
                    <div>
                        <span>Servis</span>
                        <strong>@Model.WorkshopName</strong>
                    </div>
                }
            </div>
        }

        @if (string.IsNullOrWhiteSpace(Model.ErrorMessage) || !string.IsNullOrWhiteSpace(Model.Token))
        {
            <form asp-action="PasswordSetup"
                  asp-controller="Auth"
                  method="post"
                  data-password-policy-form>
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Token" />
                <input type="hidden" asp-for="FullName" />
                <input type="hidden" asp-for="UserName" />
                <input type="hidden" asp-for="WorkshopName" />

                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <div class="form-group">
                    <label asp-for="NewPassword">Yeni Şifre</label>
                    <input asp-for="NewPassword"
                           type="password"
                           class="form-control-custom"
                           data-password-input
                           autocomplete="new-password"
                           placeholder="Yeni şifrenizi girin" />
                    <span asp-validation-for="NewPassword" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmNewPassword">Yeni Şifre Tekrar</label>
                    <input asp-for="ConfirmNewPassword"
                           type="password"
                           class="form-control-custom"
                           data-password-confirm
                           autocomplete="new-password"
                           placeholder="Yeni şifrenizi tekrar girin" />
                    <span asp-validation-for="ConfirmNewPassword" class="validation-message"></span>
                </div>

                <partial name="_PasswordRequirements" />

                <div class="password-note">
                    Şifreniz sistem yöneticisi tarafından görülmez. Şifre oluşturulduktan sonra bu bağlantı tekrar kullanılamaz.
                </div>

                <button type="submit" class="btn-primary-custom">
                    Şifremi Oluştur
                </button>
            </form>
        }

        <div class="auth-footer">
            <a href="/Auth/Login">Giriş ekranına dön</a>
        </div>
    </div>
</div>

<style>
    .auth-page {
        min-height: calc(100vh - 80px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 16px;
        background: #f8fafc;
    }

    .auth-card {
        width: 100%;
        max-width: 480px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        box-shadow: 0 14px 38px rgba(15, 23, 42, 0.08);
        padding: 28px;
    }

    .auth-header {
        margin-bottom: 22px;
    }

        .auth-header h1 {
            margin: 0;
            font-size: 26px;
            font-weight: 800;
            color: #111827;
        }

        .auth-header p {
            margin: 8px 0 0;
            color: #6b7280;
            line-height: 1.5;
        }

    .user-summary {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        border-radius: 14px;
        padding: 14px;
        margin-bottom: 20px;
        display: grid;
        gap: 10px;
    }

        .user-summary div {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            border-bottom: 1px solid #dbeafe;
            padding-bottom: 8px;
        }

            .user-summary div:last-child {
                border-bottom: none;
                padding-bottom: 0;
            }

        .user-summary span {
            color: #1e40af;
            font-size: 13px;
        }

        .user-summary strong {
            color: #111827;
            text-align: right;
        }

    .form-group {
        margin-bottom: 16px;
    }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 700;
            font-size: 14px;
            color: #111827;
        }

    .form-control-custom {
        width: 100%;
        border: 1px solid #d1d5db;
        border-radius: 10px;
        padding: 12px;
        font-size: 14px;
        outline: none;
    }

        .form-control-custom:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
        }

    .btn-primary-custom {
        width: 100%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 18px;
        border-radius: 10px;
        background: #2563eb;
        color: #fff;
        text-decoration: none;
        font-weight: 800;
        border: none;
        cursor: pointer;
        margin-top: 8px;
    }

        .btn-primary-custom:hover {
            background: #1d4ed8;
            color: #fff;
        }

    .alert-error {
        background: #fee2e2;
        color: #991b1b;
        padding: 12px 14px;
        border-radius: 12px;
        margin-bottom: 16px;
        border: 1px solid #fecaca;
        font-weight: 600;
    }

    .validation-message,
    .validation-summary {
        color: #991b1b;
        font-size: 13px;
        margin-top: 6px;
    }

    .password-note {
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        color: #475569;
        border-radius: 12px;
        padding: 12px;
        font-size: 13px;
        line-height: 1.5;
        margin-bottom: 12px;
    }

    .auth-footer {
        margin-top: 18px;
        text-align: center;
    }

        .auth-footer a {
            color: #2563eb;
            font-weight: 700;
            text-decoration: none;
        }

            .auth-footer a:hover {
                text-decoration: underline;
            }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/password-policy.js" asp-append-version="true"></script>
}
