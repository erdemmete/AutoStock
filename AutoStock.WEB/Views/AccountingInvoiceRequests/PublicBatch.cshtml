@model AutoStock.WEB.Models.Accounting.AccountingInvoiceBatchPublicViewModel

@{
    Layout = null;
    ViewData["Title"] = "Fatura Yükleme";

    string UploadUrl(int requestId) =>
        Url.Action("PublicBatchUploadItem", "AccountingInvoiceRequests", new { batchToken = Model.BatchToken, requestId }) ?? "#";

    string CompleteUrl() =>
        Url.Action("PublicBatchComplete", "AccountingInvoiceRequests", new { batchToken = Model.BatchToken }) ?? "#";

    string DisplayDocumentNo(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "-";

        var trimmed = value.Trim();
        return trimmed.StartsWith("MAT-", StringComparison.OrdinalIgnoreCase) ||
               trimmed.StartsWith("FAT-", StringComparison.OrdinalIgnoreCase)
            ? $"SHO-{trimmed[4..]}"
            : trimmed;
    }
}

<!doctype html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Fatura Yükleme - Sente360</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body{margin:0;min-height:100dvh;background:#f4f8ff;color:#0f172a;font-family:Arial,sans-serif}
        .page{width:min(1080px,calc(100% - 28px));margin:0 auto;padding:22px 0 44px}
        .hero,.item,.complete-card{background:#fff;border:1px solid #dbe3ef;border-radius:22px;box-shadow:0 16px 44px rgba(15,23,42,.075)}
        .hero{padding:20px;margin-bottom:14px;display:grid;grid-template-columns:1fr auto;gap:14px;align-items:end}
        .eyebrow{color:#2563eb;font-size:12px;font-weight:950;letter-spacing:.2px}
        h1{margin:3px 0 6px;font-size:clamp(26px,4vw,38px);font-weight:950;letter-spacing:-.6px}
        .muted{margin:0;color:#64748b;font-weight:750;line-height:1.42}
        .stats{display:grid;grid-template-columns:repeat(3,92px);gap:8px}
        .stat{padding:12px;border-radius:16px;background:#f8fafc;border:1px solid #e2e8f0}
        .stat span{display:block;color:#64748b;font-size:11px;font-weight:950}.stat strong{display:block;margin-top:3px;font-size:22px;font-weight:950}
        .batch-fields{margin-bottom:14px;padding:14px;border-radius:20px;background:#fff;border:1px solid #dbe3ef;display:grid;grid-template-columns:minmax(240px,360px) 1fr;gap:12px;align-items:end}
        .field label{display:block;margin-bottom:5px;color:#64748b;font-size:12px;font-weight:950}
        .field input,.field textarea{width:100%;min-height:40px;border:1px solid #dbe3ef;border-radius:13px;padding:0 12px;color:#0f172a;font-weight:800;outline:none;background:#fff}
        .field textarea{padding-top:10px;min-height:66px;resize:vertical}
        .notice{padding:13px 15px;border-radius:16px;margin-bottom:12px;font-weight:850}.notice.success{color:#047857;background:#ecfdf5;border:1px solid #a7f3d0}.notice.error{color:#b91c1c;background:#fef2f2;border:1px solid #fecaca}.notice.info{color:#1d4ed8;background:#eff6ff;border:1px solid #bfdbfe}
        .items{display:grid;gap:12px}.item{padding:16px;display:grid;grid-template-columns:1fr minmax(300px,390px);gap:16px;align-items:start}
        .item-head{display:grid;gap:9px}.item-title{display:flex;align-items:center;gap:9px;flex-wrap:wrap}.item-title strong{font-size:17px;font-weight:950}
        .badge-soft{display:inline-flex;align-items:center;min-height:26px;padding:0 9px;border-radius:999px;background:#eff6ff;color:#2563eb;font-size:11px;font-weight:950}.badge-soft.done{background:#dcfce7;color:#15803d}
        .item-meta{display:flex;gap:9px;flex-wrap:wrap;color:#64748b;font-size:12px;font-weight:850}.item-meta span{padding-right:9px;border-right:1px solid #e2e8f0}.item-meta span:last-child{border-right:0}
        .upload-form{display:grid;gap:9px}.form-row{display:grid;grid-template-columns:1fr 1fr;gap:9px}
        .file-picker{display:grid;grid-template-columns:auto 1fr;gap:9px;align-items:center}.file-picker input{position:absolute;opacity:0;pointer-events:none}.file-name{min-height:40px;padding:0 12px;border:1px dashed #cbd5e1;border-radius:13px;display:flex;align-items:center;color:#64748b;font-size:12px;font-weight:850;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
        .actions{display:flex;gap:8px;align-items:center;justify-content:flex-end;flex-wrap:wrap}.btn-main,.btn-soft{min-height:40px;border:0;border-radius:13px;padding:0 14px;font-size:13px;font-weight:950;text-decoration:none;display:inline-flex;align-items:center;justify-content:center}.btn-main{background:#2563eb;color:#fff}.btn-soft{background:#f1f5f9;color:#334155;border:1px solid #dbe3ef}.btn-main:disabled,.btn-soft:disabled{opacity:.5}
        .card-message{display:none;padding:10px 12px;border-radius:13px;font-size:12px;font-weight:850}.card-message.error{display:block;background:#fef2f2;color:#b91c1c;border:1px solid #fecaca}.card-message.success{display:block;background:#ecfdf5;color:#047857;border:1px solid #a7f3d0}
        .complete-card{position:sticky;bottom:12px;z-index:10;margin-top:16px;padding:14px;display:flex;justify-content:space-between;align-items:center;gap:12px}.complete-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end}
        @@media(max-width:820px){.page{width:min(100% - 20px,1080px);padding-top:12px}.hero{grid-template-columns:1fr}.stats{grid-template-columns:repeat(3,1fr)}.batch-fields,.item{grid-template-columns:1fr}.complete-card{align-items:stretch;flex-direction:column}.complete-actions,.btn-main,.btn-soft{width:100%}.form-row{grid-template-columns:1fr}.actions{justify-content:stretch}.item{padding:13px}.item-title strong{font-size:15px}.item-meta{gap:6px}.item-meta span{font-size:11px}}
    </style>
</head>
<body>
    <main class="page">
        <section class="hero">
            <div>
                <div class="eyebrow">SENTE360</div>
                <h1>Fatura Yükleme</h1>
                <p class="muted">@Model.WorkshopName tarafından gönderilen servis hesap özetleri için fatura PDF'lerini yükleyin.</p>
            </div>
            <div class="stats">
                <div class="stat"><span>Toplam</span><strong data-total-count>@Model.TotalCount</strong></div>
                <div class="stat"><span>Yüklendi</span><strong data-uploaded-count>@Model.UploadedCount</strong></div>
                <div class="stat"><span>Bekleyen</span><strong data-pending-count>@Model.PendingCount</strong></div>
            </div>
        </section>

        <section class="batch-fields">
            <div class="field">
                <label>Yükleyen e-posta</label>
                <input type="email" id="batchUploaderEmail" value="@Model.RecipientEmail" required />
            </div>
            <p class="muted">Bu e-posta tüm yüklemelerde kullanılacak. Gerekirse değiştirebilirsiniz.</p>
        </section>

        <div class="notice info" data-page-message>
            @Model.UploadedCount / @Model.TotalCount fatura yüklendi. Eksik kayıt varsa aynı bağlantıdan devam edebilirsiniz.
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.UploadError))
        {
            <div class="notice error">@Model.UploadError</div>
        }

        <section class="items">
            @foreach (var item in Model.Items)
            {
                var hasDocument = item.OfficialInvoiceDocument is not null;
                var displayNo = DisplayDocumentNo(item.InvoiceNumber);
                var uploadDate = item.OfficialInvoiceDocument?.OfficialInvoiceDate.ToString("yyyy-MM-dd") ?? DateTime.Today.ToString("yyyy-MM-dd");
                <article class="item" data-upload-card data-request-id="@item.RequestId" data-has-document="@(hasDocument ? "true" : "false")">
                    <div class="item-head">
                        <div class="item-title">
                            <strong>@displayNo</strong>
                            <span class="badge-soft @(hasDocument ? "done" : string.Empty)" data-status-badge>@(hasDocument ? "Fatura yüklendi" : "Fatura bekliyor")</span>
                        </div>
                        <div class="item-meta">
                            <span>@item.InvoiceDate.ToString("dd.MM.yyyy")</span>
                            <span>@item.CustomerTitle</span>
                            <span>@(string.IsNullOrWhiteSpace(item.Plate) ? "Plaka yok" : item.Plate)</span>
                            <span>@SenteMoney.Format(item.GrandTotal)</span>
                        </div>
                    </div>

                    <form class="upload-form" method="post" action="@UploadUrl(item.RequestId)" enctype="multipart/form-data" data-upload-form>
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="UploadedByEmail" value="@Model.RecipientEmail" data-uploaded-email />
                        <div class="form-row">
                            <div class="field">
                                <label>Fatura No</label>
                                <input name="OfficialInvoiceNumber" value="@item.OfficialInvoiceDocument?.OfficialInvoiceNumber" required maxlength="100" />
                            </div>
                            <div class="field">
                                <label>Fatura Tarihi</label>
                                <input type="date" name="OfficialInvoiceDate" value="@uploadDate" required />
                            </div>
                        </div>
                        <div class="field">
                            <label>Not</label>
                            <textarea name="Note" rows="2">@item.OfficialInvoiceDocument?.Note</textarea>
                        </div>
                        <label class="file-picker">
                            <input type="file" name="File" accept="application/pdf,.pdf" data-file-input @(hasDocument ? null : "required") />
                            <span class="btn-soft">PDF Seç</span>
                            <span class="file-name" data-file-name>@(hasDocument ? "Yeni PDF seçilmedi" : "PDF seçilmedi")</span>
                        </label>
                        <div class="card-message" data-card-message></div>
                        <div class="actions">
                            <span data-view-slot>
                                @if (hasDocument)
                                {
                                    <a class="btn-soft" href="@Url.Action("PublicInvoiceFile", "AccountingInvoiceRequests", new { shareToken = item.OfficialInvoiceDocument!.ShareToken })" target="_blank">Görüntüle</a>
                                }
                            </span>
                            <button class="btn-main" type="submit" @(item.CanUpload ? null : "disabled") data-upload-button>
                                @(hasDocument ? "Değiştir" : "Yükle")
                            </button>
                        </div>
                    </form>
                </article>
            }
        </section>

        <form class="complete-card" method="post" action="@CompleteUrl()" data-complete-form>
            @Html.AntiForgeryToken()
            <div>
                <strong data-complete-summary>@Model.UploadedCount / @Model.TotalCount fatura yüklendi.</strong>
                <p class="muted mb-0" data-selected-summary>Seçilmiş dosya yok.</p>
            </div>
            <div class="complete-actions">
                <button class="btn-soft" type="button" data-bulk-upload disabled>Seçilen Dosyaları Yükle</button>
                <button class="btn-main" type="submit">Yüklemeleri Tamamla</button>
            </div>
        </form>
    </main>

    <script>
        (() => {
            const maxFileSize = 10 * 1024 * 1024;
            const cards = Array.from(document.querySelectorAll("[data-upload-card]"));
            const uploaderEmail = document.getElementById("batchUploaderEmail");
            const pageMessage = document.querySelector("[data-page-message]");
            const uploadedCountEl = document.querySelector("[data-uploaded-count]");
            const pendingCountEl = document.querySelector("[data-pending-count]");
            const totalCountEl = document.querySelector("[data-total-count]");
            const completeSummary = document.querySelector("[data-complete-summary]");
            const selectedSummary = document.querySelector("[data-selected-summary]");
            const bulkButton = document.querySelector("[data-bulk-upload]");
            const completeForm = document.querySelector("[data-complete-form]");

            function showPageMessage(message, type = "info") {
                if (!pageMessage) return;
                pageMessage.className = `notice ${type}`;
                pageMessage.textContent = message;
            }

            function setCardMessage(card, message, type) {
                const target = card.querySelector("[data-card-message]");
                if (!target) return;
                target.className = message ? `card-message ${type}` : "card-message";
                target.textContent = message || "";
            }

            function getSelectedFileForms() {
                return cards
                    .map(card => ({ card, input: card.querySelector("[data-file-input]"), form: card.querySelector("[data-upload-form]") }))
                    .filter(x => x.input?.files?.length);
            }

            function updateCounts() {
                const total = cards.length;
                const uploaded = cards.filter(card => card.dataset.hasDocument === "true").length;
                const pending = Math.max(0, total - uploaded);
                const selected = getSelectedFileForms().length;

                if (totalCountEl) totalCountEl.textContent = String(total);
                if (uploadedCountEl) uploadedCountEl.textContent = String(uploaded);
                if (pendingCountEl) pendingCountEl.textContent = String(pending);
                if (completeSummary) completeSummary.textContent = `${uploaded} / ${total} fatura yüklendi.`;
                if (selectedSummary) selectedSummary.textContent = selected ? `${selected} dosya seçildi, henüz yüklenmedi.` : "Seçilmiş dosya yok.";
                if (bulkButton) {
                    bulkButton.disabled = selected === 0;
                    bulkButton.textContent = selected ? `Seçilen Dosyaları Yükle (${selected})` : "Seçilen Dosyaları Yükle";
                }
            }

            function validateFile(file) {
                if (!file) return "PDF dosyası seçiniz.";
                const isPdf = file.type === "application/pdf" || file.name.toLowerCase().endsWith(".pdf");
                if (!isPdf) return "Yalnızca PDF dosyası yükleyebilirsiniz.";
                if (file.size > maxFileSize) return "PDF dosyası en fazla 10 MB olabilir.";
                return null;
            }

            async function readResponse(response) {
                const text = await response.text();
                if (!text) return { isSuccess: response.ok };
                try { return JSON.parse(text); }
                catch { return { isSuccess: false, errorMessage: text }; }
            }

            async function uploadForm(card) {
                const form = card.querySelector("[data-upload-form]");
                const input = card.querySelector("[data-file-input]");
                const button = card.querySelector("[data-upload-button]");
                const hiddenEmail = card.querySelector("[data-uploaded-email]");
                const file = input?.files?.[0];
                const fileError = validateFile(file);

                if (fileError) {
                    setCardMessage(card, fileError, "error");
                    return false;
                }

                if (!uploaderEmail?.value?.trim()) {
                    setCardMessage(card, "Yükleyen e-posta adresi zorunludur.", "error");
                    uploaderEmail?.focus();
                    return false;
                }

                if (hiddenEmail) hiddenEmail.value = uploaderEmail.value.trim();
                setCardMessage(card, "", "");
                if (button) {
                    button.disabled = true;
                    button.textContent = "Yükleniyor...";
                }

                try {
                    const response = await fetch(form.action, {
                        method: "POST",
                        body: new FormData(form),
                        headers: { "X-Requested-With": "XMLHttpRequest", "Accept": "application/json" }
                    });
                    const result = await readResponse(response);

                    if (!response.ok || result.isSuccess === false) {
                        const message = result.errorMessage || result.ErrorMessage || "Fatura PDF'i yüklenemedi.";
                        setCardMessage(card, message, "error");
                        return false;
                    }

                    const data = result.data || result.Data || {};
                    card.dataset.hasDocument = "true";
                    const badge = card.querySelector("[data-status-badge]");
                    if (badge) {
                        badge.textContent = "Fatura yüklendi";
                        badge.classList.add("done");
                    }

                    const viewSlot = card.querySelector("[data-view-slot]");
                    const shareToken = data.shareToken || data.ShareToken;
                    if (viewSlot && shareToken) {
                        viewSlot.innerHTML = `<a class="btn-soft" href="/Accounting/InvoiceFile/${encodeURIComponent(shareToken)}" target="_blank">Görüntüle</a>`;
                    }

                    if (input) input.value = "";
                    const fileName = card.querySelector("[data-file-name]");
                    if (fileName) fileName.textContent = "Yeni PDF seçilmedi";
                    if (input) input.required = false;
                    setCardMessage(card, "Fatura PDF'i yüklendi.", "success");
                    updateCounts();
                    return true;
                } catch {
                    setCardMessage(card, "Bağlantı sırasında hata oluştu. Lütfen tekrar deneyin.", "error");
                    return false;
                } finally {
                    if (button) {
                        button.disabled = false;
                        button.textContent = card.dataset.hasDocument === "true" ? "Değiştir" : "Yükle";
                    }
                }
            }

            cards.forEach(card => {
                const input = card.querySelector("[data-file-input]");
                const fileName = card.querySelector("[data-file-name]");
                const form = card.querySelector("[data-upload-form]");

                input?.addEventListener("change", () => {
                    const file = input.files?.[0];
                    if (fileName) fileName.textContent = file ? file.name : "PDF seçilmedi";
                    const fileError = file ? validateFile(file) : null;
                    setCardMessage(card, fileError, fileError ? "error" : "");
                    updateCounts();
                });

                form?.addEventListener("submit", async event => {
                    event.preventDefault();
                    await uploadForm(card);
                });
            });

            bulkButton?.addEventListener("click", async () => {
                const selected = getSelectedFileForms();
                if (!selected.length) return;

                bulkButton.disabled = true;
                let success = 0;
                let failed = 0;

                for (const item of selected) {
                    const ok = await uploadForm(item.card);
                    if (ok) success++;
                    else failed++;
                }

                showPageMessage(`${selected.length} dosyadan ${success}'i yüklendi.${failed ? ` ${failed} dosya yüklenemedi.` : ""}`, failed ? "info" : "success");
                updateCounts();
            });

            completeForm?.addEventListener("submit", async event => {
                event.preventDefault();
                const selected = getSelectedFileForms();

                if (selected.length) {
                    showPageMessage(`${selected.length} dosya seçildi ancak henüz yüklenmedi. Önce seçilen dosyaları yükleyin.`, "error");
                    return;
                }

                const button = completeForm.querySelector("button[type='submit']");
                if (button) {
                    button.disabled = true;
                    button.textContent = "Tamamlanıyor...";
                }

                try {
                    const response = await fetch(completeForm.action, {
                        method: "POST",
                        body: new FormData(completeForm),
                        headers: { "X-Requested-With": "XMLHttpRequest", "Accept": "application/json" }
                    });
                    const result = await readResponse(response);

                    if (!response.ok || result.isSuccess === false) {
                        showPageMessage(result.errorMessage || result.ErrorMessage || "Yükleme durumu tamamlanamadı.", "error");
                        return;
                    }

                    const data = result.data || result.Data || {};
                    const message = data.message || data.Message || "Yükleme durumu kaydedildi.";
                    showPageMessage(message, "success");
                    if (typeof data.uploadedCount === "number" && uploadedCountEl) uploadedCountEl.textContent = String(data.uploadedCount);
                    if (typeof data.pendingCount === "number" && pendingCountEl) pendingCountEl.textContent = String(data.pendingCount);
                    if (typeof data.totalCount === "number" && totalCountEl) totalCountEl.textContent = String(data.totalCount);
                    if (completeSummary && typeof data.uploadedCount === "number" && typeof data.totalCount === "number") {
                        completeSummary.textContent = `${data.uploadedCount} / ${data.totalCount} fatura yüklendi.`;
                    }
                } catch {
                    showPageMessage("Bağlantı sırasında hata oluştu. Lütfen tekrar deneyin.", "error");
                } finally {
                    if (button) {
                        button.disabled = false;
                        button.textContent = "Yüklemeleri Tamamla";
                    }
                }
            });

            updateCounts();
        })();
    </script>
</body>
</html>
