@model AutoStock.WEB.Models.Accounting.AccountingInvoiceBatchPublicViewModel

@{
    Layout = null;
    ViewData["Title"] = "Fatura Yükleme";

    string UploadUrl(int requestId) =>
        $"{Model.ApiBaseUrl}/api/accounting-invoice-requests/public/batches/{Uri.EscapeDataString(Model.BatchToken)}/items/{requestId}/upload";

    string CompleteUrl() =>
        $"{Model.ApiBaseUrl}/api/accounting-invoice-requests/public/batches/{Uri.EscapeDataString(Model.BatchToken)}/complete";
}

<!doctype html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Fatura Yükleme - Sente360</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            margin: 0;
            min-height: 100dvh;
            background: #f4f8ff;
            color: #0f172a;
            font-family: Arial, sans-serif;
        }

        .page {
            width: min(1120px, calc(100% - 28px));
            margin: 0 auto;
            padding: 28px 0 48px;
        }

        .hero,
        .item,
        .complete-card {
            background: #fff;
            border: 1px solid #dbe3ef;
            border-radius: 24px;
            box-shadow: 0 18px 48px rgba(15,23,42,.08);
        }

        .hero {
            padding: 24px;
            margin-bottom: 18px;
            display: grid;
            gap: 14px;
        }

        .eyebrow {
            color: #2563eb;
            font-size: 12px;
            font-weight: 900;
            letter-spacing: .2px;
        }

        h1 {
            margin: 0;
            font-size: clamp(28px, 5vw, 42px);
            font-weight: 950;
            letter-spacing: -.8px;
        }

        .muted {
            margin: 0;
            color: #64748b;
            font-weight: 700;
            line-height: 1.45;
        }

        .stats {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 10px;
        }

        .stat {
            padding: 14px;
            border-radius: 18px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
        }

        .stat span {
            display: block;
            color: #64748b;
            font-size: 12px;
            font-weight: 900;
        }

        .stat strong {
            display: block;
            margin-top: 4px;
            font-size: 24px;
            font-weight: 950;
        }

        .notice {
            padding: 14px 16px;
            border-radius: 18px;
            margin-bottom: 14px;
            font-weight: 850;
        }

        .notice.success {
            color: #047857;
            background: #ecfdf5;
            border: 1px solid #a7f3d0;
        }

        .notice.error {
            color: #b91c1c;
            background: #fef2f2;
            border: 1px solid #fecaca;
        }

        .items {
            display: grid;
            gap: 14px;
        }

        .item {
            padding: 18px;
            display: grid;
            grid-template-columns: 1fr minmax(320px, 420px);
            gap: 18px;
            align-items: start;
        }

        .item-title {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .item-title strong {
            font-size: 18px;
            font-weight: 950;
        }

        .badge-soft {
            display: inline-flex;
            align-items: center;
            min-height: 28px;
            padding: 0 10px;
            border-radius: 999px;
            background: #eff6ff;
            color: #2563eb;
            font-size: 12px;
            font-weight: 950;
        }

        .item-meta {
            margin-top: 10px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            color: #64748b;
            font-size: 13px;
            font-weight: 850;
        }

        .upload-form {
            display: grid;
            gap: 10px;
        }

        .field label {
            display: block;
            margin-bottom: 5px;
            color: #64748b;
            font-size: 12px;
            font-weight: 950;
        }

        .field input,
        .field textarea {
            width: 100%;
            min-height: 42px;
            border: 1px solid #dbe3ef;
            border-radius: 14px;
            padding: 0 12px;
            color: #0f172a;
            font-weight: 800;
            outline: none;
        }

        .field textarea {
            padding-top: 10px;
            min-height: 72px;
        }

        .actions {
            display: flex;
            gap: 10px;
            align-items: center;
            justify-content: flex-end;
            flex-wrap: wrap;
        }

        .btn-main,
        .btn-soft {
            min-height: 42px;
            border: 0;
            border-radius: 14px;
            padding: 0 15px;
            font-size: 13px;
            font-weight: 950;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-main {
            background: #2563eb;
            color: #fff;
        }

        .btn-soft {
            background: #f1f5f9;
            color: #334155;
            border: 1px solid #dbe3ef;
        }

        .complete-card {
            margin-top: 18px;
            padding: 18px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 14px;
        }

        @@media (max-width: 820px) {
            .stats,
            .item {
                grid-template-columns: 1fr;
            }

            .complete-card {
                align-items: stretch;
                flex-direction: column;
            }

            .actions,
            .btn-main,
            .btn-soft {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <main class="page">
        <section class="hero">
            <div>
                <div class="eyebrow">SENTE360</div>
                <h1>Fatura Yükleme</h1>
                <p class="muted">@Model.WorkshopName tarafından gönderilen servis hesap özetleri için fatura PDF'lerini yükleyin.</p>
            </div>
            <div class="stats">
                <div class="stat"><span>Toplam</span><strong>@Model.TotalCount</strong></div>
                <div class="stat"><span>Yüklendi</span><strong>@Model.UploadedCount</strong></div>
                <div class="stat"><span>Bekleyen</span><strong>@Model.PendingCount</strong></div>
            </div>
        </section>

        @if (Model.Uploaded)
        {
            <div class="notice success">Fatura PDF'i kaydedildi.</div>
        }

        @if (Model.Completed)
        {
            <div class="notice success">Yükleme durumu Sente360 ekibine iletildi.</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.UploadError))
        {
            <div class="notice error">@Model.UploadError</div>
        }

        <section class="items">
            @foreach (var item in Model.Items)
            {
                <article class="item">
                    <div>
                        <div class="item-title">
                            <strong>@item.InvoiceNumber</strong>
                            <span class="badge-soft">@item.StatusText</span>
                        </div>
                        <div class="item-meta">
                            <span>@item.InvoiceDate.ToString("dd.MM.yyyy")</span>
                            <span>@item.CustomerTitle</span>
                            <span>@(string.IsNullOrWhiteSpace(item.Plate) ? "Plaka yok" : item.Plate)</span>
                            <span>@SenteMoney.Format(item.GrandTotal)</span>
                        </div>
                    </div>

                    <form class="upload-form" method="post" action="@UploadUrl(item.RequestId)" enctype="multipart/form-data">
                        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                        <div class="field">
                            <label>Fatura No</label>
                            <input name="officialInvoiceNumber" value="@item.OfficialInvoiceDocument?.OfficialInvoiceNumber" required />
                        </div>
                        <div class="field">
                            <label>Fatura Tarihi</label>
                            <input type="date" name="officialInvoiceDate" value="@(item.OfficialInvoiceDocument?.OfficialInvoiceDate.ToString("yyyy-MM-dd") ?? DateTime.Today.ToString("yyyy-MM-dd"))" required />
                        </div>
                        <div class="field">
                            <label>Yükleyen E-posta</label>
                            <input type="email" name="uploadedByEmail" value="@Model.RecipientEmail" required />
                        </div>
                        <div class="field">
                            <label>PDF</label>
                            <input type="file" name="file" accept="application/pdf,.pdf" required />
                        </div>
                        <div class="actions">
                            @if (item.OfficialInvoiceDocument is not null)
                            {
                                <a class="btn-soft" href="@Url.Action("PublicInvoiceFile", "AccountingInvoiceRequests", new { shareToken = item.OfficialInvoiceDocument.ShareToken })" target="_blank">
                                    Görüntüle
                                </a>
                            }
                            <button class="btn-main" type="submit" @(item.CanUpload ? null : "disabled")>
                                @(item.OfficialInvoiceDocument is null ? "Fatura Yükle" : "Değiştir")
                            </button>
                        </div>
                    </form>
                </article>
            }
        </section>

        <form class="complete-card" method="post" action="@CompleteUrl()">
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <div>
                <strong>@Model.UploadedCount / @Model.TotalCount fatura yüklendi.</strong>
                <p class="muted mb-0">Eksik kayıt varsa daha sonra aynı bağlantıdan devam edebilirsiniz.</p>
            </div>
            <button class="btn-main" type="submit">Yüklemeleri Tamamla</button>
        </form>
    </main>
</body>
</html>
