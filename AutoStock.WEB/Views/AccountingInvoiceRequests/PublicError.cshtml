@model string
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Bağlantı Bulunamadı</title>
    <style>
        body { margin:0; min-height:100vh; display:grid; place-items:center; background:#eef2f7; font-family:Arial, sans-serif; color:#0f172a; }
        .box { width:min(560px, calc(100% - 28px)); padding:28px; border-radius:24px; background:white; border:1px solid #dbe3ef; box-shadow:0 20px 50px rgba(15,23,42,.10); text-align:center; }
        h1 { margin:0 0 10px; font-size:28px; }
        p { margin:0; color:#64748b; font-weight:750; line-height:1.5; }
    </style>
</head>
<body>
    <main class="box">
        <h1>Bağlantı kullanılamıyor</h1>
        <p>@Model</p>
    </main>
</body>
</html>
