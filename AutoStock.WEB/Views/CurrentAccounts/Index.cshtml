@model AutoStock.WEB.Models.CurrentAccounts.CurrentAccountIndexViewModel
@using AutoStock.WEB.Models.CurrentAccounts

@{
    ViewData["Title"] = "Hesap Özeti";

    var summary = Model.Summary;
    var balances = summary.CustomerBalances.Items ?? new List<CustomerBalanceSummaryViewModel>();

    var pageNumber = summary.CustomerBalances.PageNumber > 0
        ? summary.CustomerBalances.PageNumber
        : Model.Query.PageNumber;

    var pageSize = summary.CustomerBalances.PageSize > 0
        ? summary.CustomerBalances.PageSize
        : Model.Query.PageSize;

    var totalCount = summary.CustomerBalances.TotalCount;
    var totalPages = pageSize > 0
        ? Math.Max(1, (int)Math.Ceiling(totalCount / (double)pageSize))
        : 1;

    string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length == 1)
            return parts[0].Substring(0, 1).ToUpper();

        return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
    }

    string GetBalanceText(decimal balance)
    {
        if (balance > 0) return "Alacaklıyız";
        if (balance < 0) return "Borçluyuz";
        return "Bakiye yok";
    }

    string GetBalanceClass(decimal balance)
    {
        if (balance > 0) return "is-positive";
        if (balance < 0) return "is-negative";
        return "is-zero";
    }
}

<div class="cur-page">
    <section class="cur-hero">
        <div class="cur-hero-left">
            <a asp-controller="Dashboard"
               asp-action="Index"
               class="cur-home-btn"
               title="Ana sayfa">
                ⌂
            </a>

            <div>
                <span class="cur-eyebrow">SENTE360</span>
                <h1>Hesap Özeti</h1>
                <p>Müşteri bakiyelerini, tahsilatları ve açık alacakları hızlıca takip edin.</p>
            </div>
        </div>
    </section>

    <section class="cur-stats">
        <article class="cur-stat-card">
            <div class="cur-stat-icon icon-blue">₺</div>
            <div>
                <span>Bu Ay Net Fatura</span>
                <strong>@summary.ThisMonthInvoiceTotal.ToString("N2") TL</strong>
                <small>kesilen - iptal</small>
            </div>
        </article>

        <article class="cur-stat-card">
            <div class="cur-stat-icon icon-purple">✓</div>
            <div>
                <span>Bu Ay Tahsilat</span>
                <strong>@summary.ThisMonthPaymentTotal.ToString("N2") TL</strong>
                <small>gelen ödeme</small>
            </div>
        </article>

        <article class="cur-stat-card highlight">
            <div class="cur-stat-icon icon-green">↗</div>
            <div>
                <span>Toplam Açık Alacak</span>
                <strong>@summary.TotalReceivableBalance.ToString("N2") TL</strong>
                <small>tahsil edilecek</small>
            </div>
        </article>
    </section>

    <section class="cur-filter-shell">
        <form method="get"
              asp-controller="CurrentAccounts"
              asp-action="Index"
              class="cur-filter-form">

            <input type="hidden" name="PageNumber" value="1" />

            <div class="cur-search-row">
                <div class="cur-search-box">
                    <span class="cur-search-icon">⌕</span>
                    <input name="Search"
                           value="@Model.Query.Search"
                           type="text"
                           placeholder="Müşteri adı, firma veya telefon ile ara..." />
                </div>

                <button type="submit" class="cur-search-submit">
                    Ara
                </button>

                <button type="button"
                        class="cur-filter-toggle @(pageSize != 10 ? "is-open" : "")"
                        data-filter-toggle
                        aria-expanded="@(pageSize != 10 ? "true" : "false")">
                    <span>☷</span>
                    <strong>Filtreler</strong>
                    <em>⌄</em>
                </button>
            </div>

            <div class="cur-advanced-filters @(pageSize != 10 ? "is-open" : "")" data-filter-panel>
                <div class="cur-filter-section">
                    <label>Sayfa Boyutu</label>

                    <select name="PageSize">
                        <option value="10" selected="@(pageSize == 10 ? "selected" : null)">10 kayıt</option>
                        <option value="25" selected="@(pageSize == 25 ? "selected" : null)">25 kayıt</option>
                        <option value="50" selected="@(pageSize == 50 ? "selected" : null)">50 kayıt</option>
                    </select>
                </div>

                <div class="cur-filter-actions">
                    <button type="submit" class="cur-apply-btn">Filtrele</button>

                    <a asp-controller="CurrentAccounts"
                       asp-action="Index"
                       class="cur-clear-btn">
                        Temizle
                    </a>
                </div>
            </div>
        </form>
    </section>

    <section class="cur-list-shell">
        <div class="cur-list-toolbar">
            <div class="cur-list-summary">
                @if (totalCount > 0)
                {
                    <span>
                        <strong>@totalCount</strong> müşteri hesabı —
                        <strong>Sayfa @pageNumber / @totalPages</strong>
                    </span>
                }
                else
                {
                    <span>Müşteri hesabı bulunamadı.</span>
                }
            </div>

            @if (totalPages > 1)
            {
                <div class="cur-top-pager">
                    <a class="cur-top-nav @(pageNumber > 1 ? "" : "disabled")"
                       href="@(pageNumber > 1
                                                      ? Url.Action("Index", "CurrentAccounts", new
                                                      {
                                                          Search = Model.Query.Search,
                                                          PageNumber = pageNumber - 1,
                                                          PageSize = pageSize
                                                      })
                                                      : "#")">
                        ‹
                    </a>

                    <div class="cur-top-page-list">
                        @for (var number = 1; number <= totalPages; number++)
                        {
                            if (number == 1 ||
                                number == totalPages ||
                                Math.Abs(number - pageNumber) <= 1)
                            {
                                <a class="cur-top-page @(number == pageNumber ? "active" : "")"
                                   href="@Url.Action("Index", "CurrentAccounts", new
                                   {
                                       Search = Model.Query.Search,
                                       PageNumber = number,
                                       PageSize = pageSize
                                   })">
                                    @number
                                </a>
                            }
                        }
                    </div>

                    <a class="cur-top-nav @(pageNumber < totalPages ? "" : "disabled")"
                       href="@(pageNumber<totalPages
                                                      ? Url.Action("Index", "CurrentAccounts", new
                                                      {
                                                          Search = Model.Query.Search,
                                                          PageNumber = pageNumber + 1,
                                                          PageSize = pageSize
                                                      })
                              : "#")">
                        ›
                    </a>
                </div>
            }
        </div>

        <div class="cur-list">
            @if (!balances.Any())
            {
                <div class="cur-empty">
                    <div class="cur-empty-icon">⌕</div>
                    <strong>Kayıt bulunamadı</strong>
                    <span>Arama kriterini değiştirerek tekrar deneyebilirsin.</span>
                </div>
            }
            else
            {
                foreach (var item in balances)
                {
                    var balanceClass = GetBalanceClass(item.Balance);
                    var balanceText = GetBalanceText(item.Balance);
                    var initials = GetInitials(item.CustomerName);

                    <article class="cur-card">
                        <a class="cur-customer-main"
                           href="/CurrentAccounts/Customer/@item.CustomerId">
                            <div class="cur-avatar">@initials</div>

                            <div class="cur-customer-text">
                                <strong>@item.CustomerName</strong>
                                <span>Müşteri hesabı</span>
                            </div>
                        </a>

                        <div class="cur-balance-box">
                            <span>Güncel Bakiye</span>
                            <strong class="@balanceClass">@item.Balance.ToString("N2") TL</strong>
                            <small>@balanceText</small>
                        </div>

                        <div class="cur-card-actions">
                            <button type="button"
                                    class="cur-action-btn success js-payment-button"
                                    data-customer-id="@item.CustomerId"
                                    data-customer-name="@item.CustomerName">
                                Tahsilat
                            </button>

                            <a class="cur-action-btn"
                               href="/CurrentAccounts/Customer/@item.CustomerId">
                                Ekstre
                            </a>
                        </div>
                    </article>
                }
            }
        </div>

        @if (totalPages > 1)
        {
            <div class="cur-pagination">
                <a class="cur-page-btn @(pageNumber > 1 ? "" : "disabled")"
                   href="@(pageNumber > 1
                                              ? Url.Action("Index", "CurrentAccounts", new
                                              {
                                                  Search = Model.Query.Search,
                                                  PageNumber = pageNumber - 1,
                                                  PageSize = pageSize
                                              })
                                              : "#")">
                    Önceki
                </a>

                <div class="cur-page-numbers">
                    @for (var number = 1; number <= totalPages; number++)
                    {
                        if (number == 1 ||
                            number == totalPages ||
                            Math.Abs(number - pageNumber) <= 2)
                        {
                            <a class="cur-page-number @(number == pageNumber ? "active" : "")"
                               href="@Url.Action("Index", "CurrentAccounts", new
                               {
                                   Search = Model.Query.Search,
                                   PageNumber = number,
                                   PageSize = pageSize
                               })">
                                @number
                            </a>
                        }
                    }
                </div>

                <a class="cur-page-btn @(pageNumber < totalPages ? "" : "disabled")"
                   href="@(pageNumber<totalPages
                                              ? Url.Action("Index", "CurrentAccounts", new
                                              {
                                                  Search = Model.Query.Search,
                                                  PageNumber = pageNumber + 1,
                                                  PageSize = pageSize
                                              })
                          : "#")">
                    Sonraki
                </a>
            </div>
        }
    </section>
</div>

<div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content cur-modal-content">

            <div class="modal-header cur-modal-header">
                <div>
                    <span class="cur-modal-eyebrow">Tahsilat</span>
                    <h5 class="modal-title">Tahsilat Ekle</h5>
                </div>

                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body cur-modal-body">
                <input type="hidden" id="paymentCustomerId" />
                <input type="hidden" id="paymentInvoiceId" />

                <div class="cur-modal-error" id="paymentModalError" hidden></div>

                <div class="cur-modal-field">
                    <label>Müşteri</label>
                    <input type="text" id="paymentCustomerName" disabled />
                </div>

                <div class="cur-modal-field">
                    <label>Tutar</label>
                    <input type="number" id="paymentAmount" step="0.01" min="0.01" placeholder="0,00" />
                </div>

                <div class="cur-modal-field cur-modal-field-two">
                    <div>
                        <label>Tarih</label>
                        <input type="datetime-local" id="paymentDate" />
                    </div>

                    <div>
                        <label>Ödeme Yöntemi</label>
                        <select id="paymentMethod">
                            <option value="Nakit">Nakit</option>
                            <option value="Kredi Kartı">Kredi Kartı</option>
                            <option value="Havale/EFT">Havale/EFT</option>
                            <option value="Diğer">Diğer</option>
                        </select>
                    </div>
                </div>

                <div class="cur-modal-field">
                    <label>Açıklama</label>
                    <textarea id="paymentDescription" rows="3" maxlength="500" placeholder="Örn: Nakit tahsilat"></textarea>
                </div>
            </div>

            <div class="modal-footer cur-modal-footer">
                <button type="button" class="cur-modal-btn soft" data-bs-dismiss="modal">
                    Vazgeç
                </button>

                <button type="button" class="cur-modal-btn success" onclick="submitPayment()">
                    Tahsilat Kaydet
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    function showCurrentAccountToast(message, type = "error") {
        if (typeof window.showToast === "function") {
            window.showToast(message, type);
            return;
        }

        console.error(message);
    }

    function clearPaymentFieldError(input) {
        if (!input) return;

        input.classList.remove("is-invalid");
        input.removeAttribute("aria-invalid");

        const field = input.closest(".cur-modal-field") || input.parentElement;
        field?.querySelectorAll(".cur-field-error").forEach(error => error.remove());
    }

    function clearPaymentErrors() {
        const errorBox = document.getElementById("paymentModalError");

        if (errorBox) {
            errorBox.textContent = "";
            errorBox.hidden = true;
        }

        document.querySelectorAll("#paymentModal .is-invalid").forEach(input => {
            clearPaymentFieldError(input);
        });
    }

    function showPaymentError(message, input) {
        const errorBox = document.getElementById("paymentModalError");

        if (errorBox) {
            errorBox.textContent = message;
            errorBox.hidden = false;
        }

        if (!input) return;

        clearPaymentFieldError(input);
        input.classList.add("is-invalid");
        input.setAttribute("aria-invalid", "true");

        const field = input.closest(".cur-modal-field") || input.parentElement;

        if (field) {
            const error = document.createElement("small");
            error.className = "cur-field-error";
            error.textContent = message;
            field.appendChild(error);
        }

        input.focus();
    }

    function hidePaymentErrorIfClean() {
        if (document.querySelector("#paymentModal .is-invalid")) {
            return;
        }

        const errorBox = document.getElementById("paymentModalError");

        if (errorBox) {
            errorBox.textContent = "";
            errorBox.hidden = true;
        }
    }

    document.addEventListener("DOMContentLoaded", function () {
        const toggleButton = document.querySelector("[data-filter-toggle]");
        const filterPanel = document.querySelector("[data-filter-panel]");

        toggleButton?.addEventListener("click", function () {
            const isOpen = filterPanel?.classList.toggle("is-open");

            toggleButton.classList.toggle("is-open", !!isOpen);
            toggleButton.setAttribute("aria-expanded", isOpen ? "true" : "false");
        });

        document.querySelectorAll(".js-payment-button").forEach(function (button) {
            button.addEventListener("click", function () {
                const customerId = parseInt(this.dataset.customerId);
                const customerName = this.dataset.customerName || "";

                openPaymentModal(customerId, customerName);
            });
        });

        document.querySelectorAll("#paymentModal input, #paymentModal select, #paymentModal textarea")
            .forEach(function (input) {
                input.addEventListener("input", function () {
                    clearPaymentFieldError(input);
                    hidePaymentErrorIfClean();
                });

                input.addEventListener("change", function () {
                    clearPaymentFieldError(input);
                    hidePaymentErrorIfClean();
                });
            });
    });

    function openPaymentModal(customerId, customerName, invoiceId, amount, description) {
        clearPaymentErrors();

        document.getElementById("paymentCustomerId").value = customerId;
        document.getElementById("paymentInvoiceId").value = invoiceId || "";
        document.getElementById("paymentCustomerName").value = customerName;
        document.getElementById("paymentAmount").value = amount || "";
        document.getElementById("paymentDate").value = "";
        document.getElementById("paymentMethod").value = "Nakit";
        document.getElementById("paymentDescription").value = description || "Tahsilat";

        const modalElement = document.getElementById("paymentModal");

        if (typeof bootstrap === "undefined") {
            showCurrentAccountToast("Tahsilat penceresi açılamadı. Lütfen sayfayı yenileyin.");
            return;
        }

        const modal = bootstrap.Modal.getOrCreateInstance(modalElement);
        modal.show();
    }

    async function submitPayment() {
        const customerId = parseInt(document.getElementById("paymentCustomerId").value);
        const invoiceIdValue = document.getElementById("paymentInvoiceId").value;
        const amount = parseFloat(document.getElementById("paymentAmount").value);
        const paymentDate = document.getElementById("paymentDate").value;
        const paymentMethod = document.getElementById("paymentMethod").value;
        const description = document.getElementById("paymentDescription").value;

        if (!amount || amount <= 0) {
            showPaymentError(
                "Geçerli bir tahsilat tutarı giriniz.",
                document.getElementById("paymentAmount")
            );
            return;
        }

        const response = await fetch("/CurrentAccounts/CreatePayment", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                customerId: customerId,
                invoiceId: invoiceIdValue ? parseInt(invoiceIdValue) : null,
                amount: amount,
                paymentDate: paymentDate || null,
                paymentMethod: paymentMethod || null,
                description: description || null
            })
        });

        if (!response.ok) {
            showPaymentError("Tahsilat kaydedilemedi. Lütfen tekrar deneyin.");
            return;
        }

        const result = await response.json();

        if (result.isFailure || result.isSuccess === false) {
            const message = result.errorMessage
                || (Array.isArray(result.errorMessages) ? result.errorMessages.join("\n") : null)
                || "Tahsilat kaydedilemedi.";

            showPaymentError(message);
            return;
        }

        location.reload();
    }
</script>

