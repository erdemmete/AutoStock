    }

    .ca-btn-outline {
        color: #18365d;
        border-color: #cbd8ea;
        box-shadow: 0 2px 4px rgba(15, 23, 42, .08);
    }

    .ca-btn-success {
        background: #059669;
        color: #fff;
        margin-right: 8px;
    }

    .empty-state {
        padding: 26px;
        text-align: center;
        color: #536b8a;
        font-weight: 700;
    }

    .text-end {
        text-align: right !important;
    }

    @@media (max-width: 900px) {
        .ca-header {
            align-items: flex-start;
            gap: 16px;
            flex-direction: column;
        }

        .ca-stats {
            grid-template-columns: 1fr;
