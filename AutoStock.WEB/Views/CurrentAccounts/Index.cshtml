            font-weight: 800;
            margin-right: 8px;
        }

        .ca-card small {
            color: #51698b;
            font-weight: 600;
        }

    .ca-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        font-weight: 700;
    }

    .ca-icon-green {
        background: #e7fbf1;
        color: #0ca66f;
    }

    .ca-icon-blue {
        background: #eef3ff;
        color: #335cff;
    }

    .ca-icon-purple {
        background: #f1ecff;
        color: #4f35e8;
    }

    .ca-table-card {
        background: #fff;
        border: 1px solid #dbe4f0;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 2px 6px rgba(15, 23, 42, .06);
    }

    .ca-toolbar {
        padding: 24px;
        display: flex;
        justify-content: space-between;
        gap: 16px;
        border-bottom: 1px solid #e5edf7;
        flex-wrap: wrap;
    }

    .ca-search {
        width: 520px;
