@model AutoStock.WEB.Models.CurrentAccounts.CurrentAccountIndexViewModel
@using AutoStock.WEB.Models.Common
@using AutoStock.WEB.Models.CurrentAccounts

@{
    ViewData["Title"] = "Cari Yönetimi";

    var summary = Model.Summary;
    var balances = summary.CustomerBalances.Items ?? new List<CustomerBalanceSummaryViewModel>();

    var pageNumber = summary.CustomerBalances.PageNumber > 0
        ? summary.CustomerBalances.PageNumber
        : Model.Query.PageNumber;

    var pageSize = summary.CustomerBalances.PageSize > 0
        ? summary.CustomerBalances.PageSize
        : Model.Query.PageSize;

    var totalCount = summary.CustomerBalances.TotalCount;

    var paginationModel = new PaginationViewModel
    {
        Controller = "CurrentAccounts",
        Action = "Index",
        PageNumber = pageNumber,
        PageSize = pageSize,
        TotalCount = totalCount,
        RouteValues = new Dictionary<string, string?>
        {
            ["search"] = Model.Query.Search
        }
    };
}

<div class="ca-page">
    <div class="ca-header">
        <div>
            <h1>Cari Yönetimi</h1>
            <p>Müşteri hesaplarını görüntüleyin, yönetin ve takip edin.</p>
        </div>

        @await Html.PartialAsync("_PageActions", new PageActionViewModel
        {
            BackController = "Dashboard",
            BackAction = "Index",
            HomeController = "Dashboard",
            HomeAction = "Index"
        })
    </div>

    <div class="ca-stats">
        <div class="ca-card">
            <div class="ca-icon ca-icon-blue">₺</div>
            <div>
                <span>Bu Ay Net Fatura</span>
                <strong>@summary.ThisMonthInvoiceTotal.ToString("N2") TL</strong>
                <small>kesilen - iptal</small>
            </div>
        </div>

        <div class="ca-card">
            <div class="ca-icon ca-icon-purple">✓</div>
            <div>
                <span>Bu Ay Tahsilat</span>
                <strong>@summary.ThisMonthPaymentTotal.ToString("N2") TL</strong>
                <small>gelen ödeme</small>
            </div>
        </div>

        <div class="ca-card">
            <div class="ca-icon ca-icon-green">↗</div>
            <div>
                <span>Toplam Açık Alacak</span>
                <strong>@summary.TotalReceivableBalance.ToString("N2") TL</strong>
                <small>tahsil edilecek</small>
            </div>
        </div>
    </div>

    <div class="ca-table-card">
        <form method="get"
              asp-controller="CurrentAccounts"
              asp-action="Index"
              class="ca-toolbar">

            <div class="ca-search">
                <span>⌕</span>
                <input name="Search"
                       value="@Model.Query.Search"
                       type="text"
                       placeholder="Müşteri adı, firma veya telefon ile ara..." />
            </div>

            <select name="PageSize" class="ca-page-size">
                <option value="10" selected="@(pageSize == 10 ? "selected" : null)">10 kayıt</option>
                <option value="25" selected="@(pageSize == 25 ? "selected" : null)">25 kayıt</option>
                <option value="50" selected="@(pageSize == 50 ? "selected" : null)">50 kayıt</option>
            </select>

            <input type="hidden" name="PageNumber" value="1" />

            <button class="ca-btn ca-btn-outline" type="submit">
                Filtrele
            </button>

            <a asp-controller="CurrentAccounts"
               asp-action="Index"
               class="ca-btn ca-btn-outline">
                Temizle
            </a>
        </form>

        @await Html.PartialAsync("_Pagination", paginationModel)

        <table class="ca-table">
            <thead>
                <tr>
                    <th>Müşteri</th>
                    <th>Güncel Bakiye</th>
                    <th class="text-end">İşlem</th>
                </tr>
            </thead>
            <tbody>
                @if (!balances.Any())
                {
                    <tr>
                        <td colspan="3">
                            <div class="empty-state">
                                Kayıt bulunamadı. Arama kriterini değiştirerek tekrar deneyin.
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in balances)
                    {
                        var balanceClass = item.Balance > 0 ? "positive" : "negative";
                        var balanceText = item.Balance > 0 ? "Alacaklıyız" : "Borçluyuz";

                        <tr>
                            <td>
                                <div class="ca-customer">
                                    <div class="ca-avatar">
                                        @(string.IsNullOrWhiteSpace(item.CustomerName) ? "?" : item.CustomerName.Substring(0, 1).ToUpper())
                                    </div>
                                    <div>
                                        <strong>@item.CustomerName</strong>
                                        <small>Müşteri hesabı</small>
                                    </div>
                                </div>
                            </td>

                            <td>
                                <div class="ca-balance @balanceClass">
                                    @item.Balance.ToString("N2") TL
                                </div>
                                <small>@balanceText</small>
                            </td>

                            <td class="text-end">
                                <button type="button"
                                        class="ca-btn ca-btn-success js-payment-button"
                                        data-customer-id="@item.CustomerId"
                                        data-customer-name="@item.CustomerName">
                                    Tahsilat
                                </button>

                                <a class="ca-btn ca-btn-outline"
                                   href="/CurrentAccounts/Customer/@item.CustomerId">
                                    Ekstre
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        @await Html.PartialAsync("_Pagination", paginationModel)
    </div>
</div>

<div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Tahsilat Ekle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="paymentCustomerId" />

                <div class="mb-3">
                    <label class="form-label">Müşteri</label>
                    <input type="text" id="paymentCustomerName" class="form-control" disabled />
                </div>

                <div class="mb-3">
                    <label class="form-label">Tutar</label>
                    <input type="number" id="paymentAmount" class="form-control" step="0.01" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Açıklama</label>
                    <textarea id="paymentDescription" class="form-control"></textarea>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Vazgeç
                </button>

                <button type="button" class="btn btn-success" onclick="submitPayment()">
                    Tahsilat Kaydet
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".js-payment-button").forEach(function (button) {
            button.addEventListener("click", function () {
                const customerId = parseInt(this.dataset.customerId);
                const customerName = this.dataset.customerName || "";

                openPaymentModal(customerId, customerName);
            });
        });
    });

    function openPaymentModal(customerId, customerName) {
        document.getElementById("paymentCustomerId").value = customerId;
        document.getElementById("paymentCustomerName").value = customerName;
        document.getElementById("paymentAmount").value = "";
        document.getElementById("paymentDescription").value = "";

        const modalElement = document.getElementById("paymentModal");

        if (typeof bootstrap === "undefined") {
            alert("Bootstrap JS yüklenmemiş. _Layout.cshtml dosyasını kontrol et.");
            return;
        }

        const modal = bootstrap.Modal.getOrCreateInstance(modalElement);
        modal.show();
    }

    async function submitPayment() {
        const customerId = parseInt(document.getElementById("paymentCustomerId").value);
        const amount = parseFloat(document.getElementById("paymentAmount").value);
        const description = document.getElementById("paymentDescription").value;

        if (!amount || amount <= 0) {
            alert("Geçerli bir tahsilat tutarı giriniz.");
            return;
        }

        const response = await fetch("/CurrentAccounts/CreatePayment", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                customerId: customerId,
                amount: amount,
                description: description
            })
        });

        if (!response.ok) {
            alert("Tahsilat isteği başarısız oldu. HTTP " + response.status);
            return;
        }

        const result = await response.json();

        if (!result.isSuccess) {
            alert(result.errorMessage || "Tahsilat kaydedilemedi.");
            return;
        }

        location.reload();
    }
</script>
<style>
