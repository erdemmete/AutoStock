            font-size: 30px;
            font-weight: 800;
            margin: 0;
        }

        .ca-header p {
            margin: 8px 0 0;
            color: #536b8a;
            font-size: 16px;
        }

    .ca-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 38px;
    }

    .ca-card {
        background: #fff;
