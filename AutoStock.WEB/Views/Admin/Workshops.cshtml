@model List<AutoStock.WEB.Models.Admin.Workshops.AdminWorkshopListItemViewModel>

@{
    ViewData["Title"] = "Servisler";
}

<div class="page-header">
    <div>
        <h1>Servisler</h1>
        <p>Sente360 sistemindeki servis hesapları ve üyelik durumları</p>
    </div>

    <a href="/Admin/Workshops/Create" class="btn-primary-custom">
        Yeni Servis Oluştur
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="admin-card">
    @if (!Model.Any())
    {
        <div class="empty-state">
            Henüz servis kaydı oluşturulmamış.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Servis</th>
                        <th>Durum</th>
                        <th>Üyelik</th>
                        <th>Bitiş Tarihi</th>
                        <th>Kullanıcı</th>
                        <th>Oluşturulma</th>
                        <th>İşlem</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.Name</strong>
                                <div class="text-muted">#@item.Id</div>
                            </td>

                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="status-badge success">Aktif</span>
                                }
                                else
                                {
                                    <span class="status-badge danger">Pasif</span>
                                }
                            </td>

                            <td>
                                @if (item.IsExpired)
                                {
                                    <span class="status-badge danger">Süresi Doldu</span>
                                }
                                else if (item.SubscriptionStatusText == "Trial")
                                {
                                    <span class="status-badge warning">Trial</span>
                                }
                                else if (item.SubscriptionStatusText == "Active")
                                {
                                    <span class="status-badge success">Active</span>
                                }
                                else
                                {
                                    <span class="status-badge secondary">@item.SubscriptionStatusText</span>
                                }
                            </td>

                            <td>
                                @if (item.SubscriptionEndDate.HasValue)
                                {
                                    @item.SubscriptionEndDate.Value.ToString("dd.MM.yyyy")
                                }
                                else
                                {
                                    <span class="text-muted">Süresiz</span>
                                }
                            </td>

                            <td>@item.UserCount</td>

                            <td>@item.CreatedAt.ToString("dd.MM.yyyy")</td>

                            <td>
                                <a href="/Admin/Workshops/Details/@item.Id" class="btn-detail">
                                    Detay
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 24px;
    }

        .page-header h1 {
            margin: 0;
            font-size: 28px;
            font-weight: 700;
        }

        .page-header p {
            margin: 6px 0 0;
            color: #6b7280;
        }

    .admin-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
        overflow: hidden;
    }

    .table-responsive {
        width: 100%;
        overflow-x: auto;
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
    }

        .admin-table th {
            text-align: left;
            padding: 14px 16px;
            font-size: 13px;
            color: #6b7280;
            background: #f9fafb;
            border-bottom: 1px solid #e5e7eb;
        }

        .admin-table td {
            padding: 16px;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

        .admin-table tr:last-child td {
            border-bottom: none;
        }

    .text-muted {
        color: #6b7280;
        font-size: 13px;
        margin-top: 4px;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }

        .status-badge.success {
            background: #dcfce7;
            color: #166534;
        }

        .status-badge.warning {
            background: #fef3c7;
            color: #92400e;
        }

        .status-badge.danger {
            background: #fee2e2;
            color: #991b1b;
        }

        .status-badge.secondary {
            background: #f3f4f6;
            color: #374151;
        }

    .btn-primary-custom {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 16px;
        border-radius: 10px;
        background: #2563eb;
        color: #fff;
        text-decoration: none;
        font-weight: 700;
        border: none;
    }

        .btn-primary-custom:hover {
            background: #1d4ed8;
            color: #fff;
        }

    .btn-detail {
        display: inline-flex;
        padding: 8px 12px;
        border-radius: 8px;
        border: 1px solid #d1d5db;
        color: #374151;
        text-decoration: none;
        font-weight: 600;
        font-size: 13px;
    }

        .btn-detail:hover {
            background: #f9fafb;
            color: #111827;
        }

    .empty-state {
        padding: 32px;
        color: #6b7280;
        text-align: center;
    }

    .alert-success {
        background: #dcfce7;
        color: #166534;
        padding: 14px 16px;
        border-radius: 12px;
        margin-bottom: 18px;
        border: 1px solid #bbf7d0;
        font-weight: 600;
    }
</style>