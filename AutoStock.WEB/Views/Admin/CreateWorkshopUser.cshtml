@model AutoStock.WEB.Models.Admin.Workshops.CreateAdminWorkshopUserViewModel

@{
    ViewData["Title"] = "Kullanıcı Oluştur";
    var workshopName = ViewBag.WorkshopName as string ?? "Servis";
}

<div class="page-header">
    <div>
        <h1>Kullanıcı Oluştur</h1>
        <p>@workshopName için Owner veya Staff kullanıcısı oluştur.</p>
    </div>

    <a href="/Admin/Workshops/Details/@Model.WorkshopId" class="btn-secondary-custom">
        Geri Dön
    </a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert-error">
        @Html.Raw(ViewBag.Error)
    </div>
}

<form asp-action="CreateWorkshopUser"
      asp-controller="Admin"
      asp-route-workshopId="@Model.WorkshopId"
      method="post">

    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="WorkshopId" />

    <div class="admin-card">
        <h2>Kullanıcı Bilgileri</h2>

        <div class="form-grid">
            <div class="form-group">
                <label>Ad Soyad</label>
                <input asp-for="FullName" class="form-control-custom" placeholder="Örn: Ahmet Yılmaz" />
                <span asp-validation-for="FullName" class="validation-message"></span>
            </div>

            <div class="form-group">
                <label>Kullanıcı Adı</label>
                <div class="input-with-button">
                    <input asp-for="UserName"
                           id="UserName"
                           class="form-control-custom"
                           placeholder="Örn: testoto.ahmet.yilmaz" />

                    <button type="button" id="generateCredentialsBtn" class="btn-secondary-small">
                        Oluştur
                    </button>
                </div>
                <span asp-validation-for="UserName" class="validation-message"></span>
            </div>

            <div class="form-group">
                <label>E-posta</label>
                <input asp-for="Email" class="form-control-custom" placeholder="ornek@mail.com" />
                <span asp-validation-for="Email" class="validation-message"></span>
            </div>

            <div class="form-group">
                <label>Şifre</label>
                <input asp-for="Password"
                       id="Password"
                       type="text"
                       class="form-control-custom"
                       placeholder="Oluştur butonuyla otomatik üretilebilir" />
                <span asp-validation-for="Password" class="validation-message"></span>
            </div>

            <div class="form-group">
                <label>Rol</label>
                <select asp-for="Role" class="form-control-custom">
                    <option value="Staff">Staff</option>
                    <option value="Owner">Owner</option>
                </select>
                <small>Admin kullanıcı bu ekrandan oluşturulmaz.</small>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary-custom">
                Kullanıcı Oluştur
            </button>
        </div>
    </div>
</form>

<style>
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 24px;
    }

        .page-header h1 {
            margin: 0;
            font-size: 28px;
            font-weight: 700;
        }

        .page-header p {
            margin: 6px 0 0;
            color: #6b7280;
        }

    .admin-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
        padding: 24px;
    }

        .admin-card h2 {
            font-size: 18px;
            margin: 0 0 20px;
            font-weight: 700;
        }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px;
    }

    .form-group label {
        display: block;
        margin-bottom: 8px;
        font-weight: 700;
        font-size: 14px;
    }

    .form-group small {
        display: block;
        margin-top: 6px;
        color: #6b7280;
        font-size: 12px;
    }

    .form-control-custom {
        width: 100%;
        border: 1px solid #d1d5db;
        border-radius: 10px;
        padding: 11px 12px;
        font-size: 14px;
        outline: none;
    }

        .form-control-custom:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
        }

    .validation-message {
        color: #dc2626;
        font-size: 13px;
        margin-top: 6px;
        display: block;
    }

    .form-actions {
        display: flex;
        justify-content: flex-end;
        margin-top: 20px;
    }

    .btn-primary-custom,
    .btn-secondary-custom {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 11px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 700;
        border: none;
        cursor: pointer;
    }

    .btn-primary-custom {
        background: #2563eb;
        color: #fff;
    }

        .btn-primary-custom:hover {
            background: #1d4ed8;
            color: #fff;
        }

    .btn-secondary-custom {
        background: #f3f4f6;
        color: #374151;
        border: 1px solid #d1d5db;
    }

        .btn-secondary-custom:hover {
            background: #e5e7eb;
            color: #111827;
        }

    .alert-error {
        background: #fee2e2;
        color: #991b1b;
        padding: 14px 16px;
        border-radius: 12px;
        margin-bottom: 18px;
        border: 1px solid #fecaca;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }

        .page-header {
            align-items: flex-start;
            flex-direction: column;
        }
    }

    .input-with-button {
        display: flex;
        gap: 8px;
    }

        .input-with-button .form-control-custom {
            flex: 1;
        }

    .btn-secondary-small {
        padding: 0 14px;
        border-radius: 10px;
        border: 1px solid #d1d5db;
        background: #f3f4f6;
        color: #374151;
        font-weight: 700;
        cursor: pointer;
        white-space: nowrap;
    }

        .btn-secondary-small:hover {
            background: #e5e7eb;
        }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const generateButton = document.getElementById("generateCredentialsBtn");
        const fullNameInput = document.getElementById("FullName");
        const userNameInput = document.getElementById("UserName");
        const passwordInput = document.getElementById("Password");

        if (!generateButton || !fullNameInput || !userNameInput || !passwordInput) {
            return;
        }

        generateButton.addEventListener("click", async function () {
            const fullName = fullNameInput.value.trim();

            if (!fullName) {
                alert("Önce ad soyad gir.");
                fullNameInput.focus();
                return;
            }

            generateButton.disabled = true;
            generateButton.textContent = "Oluşturuluyor...";

            try {
                const response = await fetch(`/Admin/Workshops/@Model.WorkshopId/Users/SuggestCredentials?fullName=${encodeURIComponent(fullName)}`);

                const result = await response.json();

                if (!result.isSuccess) {
                    alert(result.errorMessage || "Kullanıcı adı ve şifre oluşturulamadı.");
                    return;
                }

                userNameInput.value = result.userName;
                passwordInput.value = result.password;
            }
            catch {
                alert("Kullanıcı adı ve şifre oluşturulurken hata oluştu.");
            }
            finally {
                generateButton.disabled = false;
                generateButton.textContent = "Oluştur";
            }
        });
    });
</script>