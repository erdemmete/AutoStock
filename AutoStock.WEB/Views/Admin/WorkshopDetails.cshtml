<div class="admin-card partners-card">
    <div class="card-header-row">
        <div>
            <h2>İşletme Sahipleri / Ortaklar</h2>
            <p>Bu kişiler sisteme giriş kullanıcısı olmak zorunda değildir.</p>
        </div>
    </div>

    <form asp-action="AddWorkshopPartner" asp-controller="Admin" method="post" class="partner-form">
        @Html.AntiForgeryToken()

        <input type="hidden" name="WorkshopId" value="@Model.Id" />

        <div class="form-grid">
            <div class="form-group">
                <label>Ad Soyad</label>
                <input name="FullName"
                       class="form-control-custom"
                       placeholder="Örn: Savaş Karaoğlunoğlu" />
            </div>

            <div class="form-group">
                <label>Unvan / Görev</label>
                <input name="Title"
                       class="form-control-custom"
                       placeholder="Örn: Şirket Ortağı / Yetkili" />
            </div>

            <div class="form-group">
                <label>Telefon</label>
                <input name="PhoneNumber"
                       class="form-control-custom mobile-phone-input"
                       value="05"
                       maxlength="14"
                       inputmode="numeric"
                       autocomplete="tel"
                       placeholder="0534 888 77 99" />
            </div>

            <div class="form-group">
                <label>E-posta</label>
                <input name="Email"
                       class="form-control-custom"
                       placeholder="Örn: ortak@servis.com" />
            </div>

            <div class="form-group full">
                <label>Not</label>
                <textarea name="Note"
                          class="form-control-custom"
                          rows="2"
                          placeholder="Örn: Birincil yetkili, imza yetkisi var."></textarea>
            </div>

            <div class="form-group full checkbox-row">
                <label>
                    <input type="checkbox" name="IsPrimary" value="true" />
                    Birincil yetkili olarak işaretle
                </label>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary-custom">
                Yetkili / Ortak Ekle
            </button>
        </div>
    </form>

    @if (!Model.Partners.Any())
    {
        <div class="empty-state">
            Henüz işletme sahibi veya ortak eklenmemiş.
        </div>
    }
    else
    {
        <div class="table-responsive partners-table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Ad Soyad</th>
                        <th>Unvan</th>
                        <th>Telefon</th>
                        <th>E-posta</th>
                        <th>Durum</th>
                        <th>Not</th>
                        <th>İşlem</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var partner in Model.Partners)
                    {
                        <tr>
                            <td>
                                <strong>@partner.FullName</strong>
                            </td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(partner.Title))
                                {
                                    @partner.Title
                                }
                                else
                                {
                                    <span class="text-muted">Yok</span>
                                }
                            </td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(partner.PhoneNumber))
                                {
                                    @partner.PhoneNumber
                                }
                                else
                                {
                                    <span class="text-muted">Yok</span>
                                }
                            </td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(partner.Email))
                                {
                                    @partner.Email
                                }
                                else
                                {
                                    <span class="text-muted">Yok</span>
                                }
                            </td>

                            <td>
                                @if (partner.IsPrimary)
                                {
                                    <span class="status-badge success">Birincil</span>
                                }
                                else
                                {
                                    <span class="status-badge secondary">Standart</span>
                                }
                            </td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(partner.Note))
                                {
                                    @partner.Note
                                }
                                else
                                {
                                    <span class="text-muted">Yok</span>
                                }
                            </td>

                            <td>
                                <form asp-action="DeleteWorkshopPartner"
                                      asp-controller="Admin"
                                      method="post"
                                      onsubmit="return confirm('Bu yetkili/ortak kaydını silmek istiyor musun?');">
                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="workshopId" value="@Model.Id" />
                                    <input type="hidden" name="partnerId" value="@partner.Id" />

                                    <button type="submit" class="btn-danger-custom">
                                        Sil
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
