<script>
      document.addEventListener("DOMContentLoaded", function () {
        makeAdminCardsCollapsible();
        initializeMobilePhoneInputs();
        initializeCredentialActions();
        initializeUserRows();
    });

    function initializeUserRows() {
        document.querySelectorAll(".clickable-user-row").forEach(row => {
            row.addEventListener("click", function (event) {
                if (event.target.closest("a, button, input, select, textarea, label, form")) {
                    return;
                }

                const href = row.dataset.href;

                if (href) {
                    window.location.href = href;
                }
            });
        });
    }

    function makeAdminCardsCollapsible() {
        const cards = document.querySelectorAll(".admin-card");

        cards.forEach((card, index) => {
            const header = card.querySelector(":scope > .card-header-row") || card.querySelector(":scope > h2");

            if (!header) {
                return;
            }

            card.classList.add("collapsible-card");

            header.classList.add("collapsible-header");

            const body = document.createElement("div");
            body.classList.add("collapsible-body");

            const nodesToMove = [];

            let current = header.nextSibling;

            while (current) {
                nodesToMove.push(current);
                current = current.nextSibling;
            }

            nodesToMove.forEach(node => body.appendChild(node));

            card.appendChild(body);

            // İlk kart açık kalsın, diğerleri kapalı gelsin.
            if (index !== 0) {
                card.classList.add("is-collapsed");
            }

            header.addEventListener("click", function (event) {
                const clickedInteractiveElement = event.target.closest("a, button, input, select, textarea, label, form");

                if (clickedInteractiveElement) {
                    return;
                }

                card.classList.toggle("is-collapsed");
            });
        });
    }

    function initializeMobilePhoneInputs() {
        const inputs = document.querySelectorAll(".mobile-phone-input");

        inputs.forEach(input => {
            if (!input.value || input.value.trim() === "") {
                input.value = "05";
            }

            input.value = formatMobilePhone(input.value);

            input.addEventListener("focus", function () {
                if (!input.value || input.value.trim() === "") {
                    input.value = "05";
                }

                setCursorToEnd(input);
            });

            input.addEventListener("input", function () {
                input.value = formatMobilePhone(input.value);
                setCursorToEnd(input);
            });

            input.addEventListener("blur", function () {
                if (!input.value || input.value.replace(/\D/g, "").length <= 2) {
                    input.value = "05";
                }
            });
        });
    }

    function formatMobilePhone(value) {
        let digits = value.replace(/\D/g, "");

        if (digits.startsWith("90")) {
            digits = "0" + digits.substring(2);
        }

        if (digits.startsWith("5")) {
            digits = "0" + digits;
        }

        if (!digits.startsWith("05")) {
            digits = "05" + digits.replace(/^0+/, "");
        }

        digits = digits.substring(0, 11);

        if (digits.length <= 2) {
            return digits;
        }

        if (digits.length <= 4) {
            return digits;
        }

        if (digits.length <= 7) {
            return digits.substring(0, 4) + " " + digits.substring(4);
        }

        if (digits.length <= 9) {
            return digits.substring(0, 4) + " " +
                digits.substring(4, 7) + " " +
                digits.substring(7);
        }

        return digits.substring(0, 4) + " " +
            digits.substring(4, 7) + " " +
            digits.substring(7, 9) + " " +
            digits.substring(9, 11);
    }

    function setCursorToEnd(input) {
        setTimeout(() => {
            input.selectionStart = input.value.length;
            input.selectionEnd = input.value.length;
        }, 0);
    }

            function initializeCredentialActions() {
        const copyButtons = document.querySelectorAll(".copy-message-btn");

        copyButtons.forEach(copyButton => {
            copyButton.addEventListener("click", async function () {
                const explicitText = copyButton.dataset.copyText;
                let message = explicitText || "";

                if (!message) {
                    const targetId = copyButton.dataset.copyTarget;
                    const target = targetId ? document.getElementById(targetId) : null;

                    if (!target) {
                        return;
                    }

                    message = target.textContent || "";
                }

                if (!message.trim()) {
                    return;
                }

                try {
                    await navigator.clipboard.writeText(message);

                    const originalText = copyButton.textContent;
                    copyButton.textContent = "Kopyalandı";

                    setTimeout(() => {
                        copyButton.textContent = originalText;
                    }, 1500);
                }
                catch {
                    alert("Kopyalama başarısız oldu. Bilgileri manuel seçip kopyalayabilirsin.");
                }
            });
        });
    }

    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".iban-input").forEach(input => {
            input.addEventListener("input", function () {
                this.value = this.value
                    .toUpperCase()
                    .replace(/[^A-Z0-9]/g, "")
                    .slice(0, 34);
            });
        });
    });
</script>
