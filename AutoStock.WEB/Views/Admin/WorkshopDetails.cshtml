@model AutoStock.WEB.Models.Admin.Workshops.AdminWorkshopDetailViewModel

@{
    ViewData["Title"] = "Servis Detayı";

    var profile = Model.Profile ?? new AutoStock.WEB.Models.Admin.Workshops.AdminWorkshopProfileViewModel
    {
        WorkshopId = Model.Id,
        DisplayName = Model.Name,
        Country = "Türkiye"
    };

    var bankAccounts = Model.BankAccounts ?? new List<AutoStock.WEB.Models.Admin.Workshops.AdminWorkshopBankAccountViewModel>();

    var subscriptionStatusOptions = new List<(int Value, string Text)>
    {
        (1, "Deneme"),
        (2, "Aktif"),
        (3, "Askıya Alındı"),
        (4, "Süresi Doldu"),
        (5, "İptal Edildi")
    };

    string SubscriptionStatusLabel(string? status) => status switch
    {
        "Trial" => "Deneme",
        "Active" => "Aktif",
        "Suspended" => "Askıya Alındı",
        "Expired" => "Süresi Doldu",
        "Cancelled" => "İptal Edildi",
        _ => status ?? "-"
    };

    var createdUserFullName = TempData["CreatedUserFullName"] as string;
    var createdUserName = TempData["CreatedUserName"] as string;
    var createdUserPhone = TempData["CreatedUserPhone"] as string;
    var createdUserPasswordSetupToken = TempData["CreatedUserPasswordSetupToken"] as string;
    var createdUserPasswordSetupCode = TempData["CreatedUserPasswordSetupCode"] as string;

    var resetUserFullName = TempData["ResetUserFullName"] as string;
    var resetUserName = TempData["ResetUserName"] as string;
    var resetUserPhone = TempData["ResetUserPhone"] as string;
    var resetPasswordToken = TempData["ResetPasswordToken"] as string;
    var resetPasswordExpiresAt = TempData["ResetPasswordExpiresAt"] as string;

    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.PathBase}".TrimEnd('/');
    var loginUrl = $"{baseUrl}/";

    var passwordSetupUrl = !string.IsNullOrWhiteSpace(createdUserPasswordSetupToken)
        ? $"{baseUrl}/Auth/PasswordSetup?token={Uri.EscapeDataString(createdUserPasswordSetupToken)}"
        : null;

    var passwordResetUrl = !string.IsNullOrWhiteSpace(resetPasswordToken)
        ? $"{baseUrl}/Auth/PasswordReset?token={Uri.EscapeDataString(resetPasswordToken)}"
        : null;

    string? createdUserMessage = null;
    string? createdUserCodeMessage = null;
    string? whatsappUrl = null;
    string? codeWhatsappUrl = null;

    string? resetPasswordMessage = null;
    string? resetWhatsappUrl = null;

    if (!string.IsNullOrWhiteSpace(createdUserName) &&
        !string.IsNullOrWhiteSpace(passwordSetupUrl))
    {
        createdUserMessage =
$@"Merhaba {createdUserFullName},

Sente360 servis yönetim hesabınız oluşturuldu.

Güvenliğiniz için şifrenizi siz belirleyeceksiniz.

Kurulum bağlantısı:
{passwordSetupUrl}

Kullanıcı adınız:
{createdUserName}";

        if (!string.IsNullOrWhiteSpace(createdUserPasswordSetupCode))
        {
            createdUserCodeMessage =
$@"Merhaba {createdUserFullName},

Linke tıklamak istemezseniz tarayıcınızdan {loginUrl} adresine girip ""Davet Kodum Var"" seçeneğini kullanabilirsiniz.

Kullanıcı adınız:
{createdUserName}

Davet kodunuz:
{createdUserPasswordSetupCode}";
        }

        var phoneDigits = new string((createdUserPhone ?? "")
            .Where(char.IsDigit)
            .ToArray());

        if (phoneDigits.StartsWith("0"))
        {
            phoneDigits = "90" + phoneDigits.Substring(1);
        }
        else if (phoneDigits.StartsWith("5"))
        {
            phoneDigits = "90" + phoneDigits;
        }

        if (!string.IsNullOrWhiteSpace(phoneDigits) && phoneDigits.Length >= 12)
        {
            whatsappUrl = $"https://wa.me/{phoneDigits}?text={Uri.EscapeDataString(createdUserMessage)}";

            if (!string.IsNullOrWhiteSpace(createdUserCodeMessage))
            {
                codeWhatsappUrl = $"https://wa.me/{phoneDigits}?text={Uri.EscapeDataString(createdUserCodeMessage)}";
            }
        }
    }

    if (!string.IsNullOrWhiteSpace(resetUserName) &&
        !string.IsNullOrWhiteSpace(passwordResetUrl))
    {
        resetPasswordMessage =
$@"Merhaba {resetUserFullName},

Sente360 hesabınız için şifre sıfırlama bağlantısı oluşturuldu.

Güvenliğiniz için yeni şifrenizi siz belirleyeceksiniz.

Şifre sıfırlama bağlantısı:
{passwordResetUrl}

Kullanıcı adınız:
{resetUserName}

Bu bağlantı tek kullanımlıktır.";

        var resetPhoneDigits = new string((resetUserPhone ?? "")
            .Where(char.IsDigit)
            .ToArray());

        if (resetPhoneDigits.StartsWith("0"))
        {
            resetPhoneDigits = "90" + resetPhoneDigits.Substring(1);
        }
        else if (resetPhoneDigits.StartsWith("5"))
        {
            resetPhoneDigits = "90" + resetPhoneDigits;
        }

        if (!string.IsNullOrWhiteSpace(resetPhoneDigits) && resetPhoneDigits.Length >= 12)
        {
            resetWhatsappUrl = $"https://wa.me/{resetPhoneDigits}?text={Uri.EscapeDataString(resetPasswordMessage)}";
        }
    }
}

<div class="page-header">
    <div>
        <h1>@Model.Name</h1>
        <p>Servis hesabı, üyelik bilgileri, işletme profili ve kullanıcılar</p>
    </div>

    <a href="/Admin/Workshops" class="btn-secondary-custom">
        Geri Dön
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-error">
        @Html.Raw(TempData["ErrorMessage"])
    </div>
}
    @if (!string.IsNullOrWhiteSpace(createdUserMessage))
    {
        <div class="credential-card">
            <div>
                <h2>Yeni Kullanıcı Davet Bağlantısı</h2>
                <p>
                    Bu bağlantı sadece oluşturma sonrası gösterilir.
                    Ana akış olarak kullanıcıya kurulum bağlantısını gönder.
                </p>
            </div>

            <pre id="createdCredentialsText">@createdUserMessage</pre>

            <div class="credential-actions">
                <button type="button"
                        class="btn-secondary-custom copy-message-btn"
                        data-copy-target="createdCredentialsText">
                    Bilgileri Kopyala
                </button>

                @if (!string.IsNullOrWhiteSpace(whatsappUrl))
                {
                    <a href="@whatsappUrl"
                       target="_blank"
                       rel="noopener"
                       class="btn-whatsapp-custom">
                        WhatsApp ile Gönder
                    </a>
                }
                else
                {
                    <span class="text-muted">
                        WhatsApp için geçerli cep telefonu girilmemiş.
                    </span>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(createdUserCodeMessage))
            {
                <details class="invite-code-fallback">
                    <summary>Linke tıklamak istemeyen kullanıcı için davet kodu seçeneği</summary>

                    <p>
                        Bu alanı sadece kullanıcı linke tıklamak istemezse kullan.
                        Normal akışta davet kodunu ayrıca göndermeye gerek yok.
                    </p>

                    <pre id="createdInviteCodeText">@createdUserCodeMessage</pre>

                    <div class="credential-actions">
                    <button type="button"
                            class="btn-secondary-custom copy-message-btn"
                            data-copy-text="@createdUserPasswordSetupCode">
                        Davet Kodunu Kopyala
                    </button>

                        @if (!string.IsNullOrWhiteSpace(codeWhatsappUrl))
                        {
                            <a href="@codeWhatsappUrl"
                               target="_blank"
                               rel="noopener"
                               class="btn-whatsapp-custom">
                                Davet Kodunu WhatsApp ile Gönder
                            </a>
                        }
                    </div>
                </details>
            }
        </div>
    }

@if (!string.IsNullOrWhiteSpace(resetPasswordMessage))
{
    <div class="credential-card password-reset-card">
        <div>
            <h2>Şifre Sıfırlama Bağlantısı</h2>
            <p>
                Bu bağlantı sadece oluşturma sonrası gösterilir.
                Kullanıcı yeni şifresini kendisi belirler.
            </p>
        </div>

        <pre id="resetPasswordText">@resetPasswordMessage</pre>

        <div class="credential-actions">
            <button type="button"
                    class="btn-secondary-custom copy-message-btn"
                    data-copy-target="resetPasswordText">
                Reset Linkini Kopyala
            </button>

            @if (!string.IsNullOrWhiteSpace(resetWhatsappUrl))
            {
                <a href="@resetWhatsappUrl"
                   target="_blank"
                   rel="noopener"
                   class="btn-whatsapp-custom">
                    WhatsApp ile Gönder
                </a>
            }
            else
            {
                <span class="text-muted">
                    WhatsApp için geçerli cep telefonu girilmemiş.
                </span>
            }
        </div>
    </div>
}

<div class="detail-grid">
    <div class="admin-card">
        <h2>Servis Bilgileri</h2>

        <div class="info-list">
            <div>
                <span>Servis ID</span>
                <strong>#@Model.Id</strong>
            </div>

            <div>
                <span>Servis Adı</span>
                <strong>@Model.Name</strong>
            </div>

            <div>
                <span>Oluşturulma</span>
                <strong>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</strong>
            </div>

            <div>
                <span>Üyelik Başlangıcı</span>
                <strong>@Model.SubscriptionStartDate.ToString("dd.MM.yyyy HH:mm")</strong>
            </div>

            <div>
                <span>Mevcut Durum</span>
                @if (Model.IsActive)
                {
                    <strong class="status-text success">Aktif</strong>
                }
                else
                {
                    <strong class="status-text danger">Pasif</strong>
                }
            </div>

            <div>
                <span>Üyelik</span>
                <strong>@SubscriptionStatusLabel(Model.SubscriptionStatusText)</strong>
            </div>

            <div>
                <span>Üyelik Bitişi</span>
                @if (Model.SubscriptionEndDate.HasValue)
                {
                    <strong>@Model.SubscriptionEndDate.Value.ToString("dd.MM.yyyy HH:mm")</strong>
                }
                else
                {
                    <strong class="text-muted">Süresiz</strong>
                }
            </div>

            <div>
                <span>Kullanıcı Sayısı</span>
                <strong>@Model.Users.Count</strong>
            </div>
        </div>
    </div>

    <div class="admin-card">
        <h2>Üyelik Güncelle</h2>

        <form asp-action="UpdateWorkshopSubscription" asp-controller="Admin" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" name="WorkshopId" value="@Model.Id" />

            <div class="form-group">
                <label>Aktif mi?</label>
                <select name="IsActive" class="form-control-custom">
                    @if (Model.IsActive)
                    {
                        <option value="true" selected>Aktif</option>
                        <option value="false">Pasif</option>
                    }
                    else
                    {
                        <option value="true">Aktif</option>
                        <option value="false" selected>Pasif</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label>Üyelik Durumu</label>
                <select name="SubscriptionStatus" class="form-control-custom">
                    @foreach (var option in subscriptionStatusOptions)
                    {
                        if (Model.SubscriptionStatus == option.Value)
                        {
                            <option value="@option.Value" selected>@option.Text</option>
                        }
                        else
                        {
                            <option value="@option.Value">@option.Text</option>
                        }
                    }
                </select>
            </div>

            <div class="form-group">
                <label>Üyelik Bitiş Tarihi</label>
                <input name="SubscriptionEndDate"
                       type="datetime-local"
                       class="form-control-custom"
                       value="@(Model.SubscriptionEndDate.HasValue ? Model.SubscriptionEndDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                <small>Boş bırakırsan süresiz gibi davranır.</small>
            </div>

            <div class="form-group">
                <label>Üyelik Notu</label>
                <textarea name="SubscriptionNote"
                          class="form-control-custom"
                          rows="4"
                          placeholder="Örn: 15 günlük deneme hesabı">@Model.SubscriptionNote</textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary-custom">
                    Üyelik Bilgilerini Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

<div class="admin-card profile-card">
    <h2>Resmi İşletme Bilgileri</h2>
    <p class="section-description">
        Bu bilgiler teklif, servis formu, fatura çıktısı ve resmi dokümanlarda kullanılacaktır.
    </p>

    <form asp-action="UpdateWorkshopProfile" asp-controller="Admin" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" name="WorkshopId" value="@Model.Id" />

        <div class="form-grid">
            <div class="form-group">
                <label>Görünen Ad</label>
                <input name="DisplayName"
                       value="@profile.DisplayName"
                       class="form-control-custom"
                       placeholder="Örn: Mete Oto Servis" />
            </div>

            <div class="form-group">
                <label>Ticari Ünvan</label>
                <input name="LegalTitle"
                       value="@profile.LegalTitle"
                       class="form-control-custom"
                       placeholder="Örn: Mete Otomotiv San. ve Tic. Ltd. Şti." />
            </div>

            <div class="form-group">
                <label>Vergi Dairesi</label>
                <input name="TaxOffice"
                       value="@profile.TaxOffice"
                       class="form-control-custom"
                       placeholder="Örn: Tuzla" />
            </div>

            <div class="form-group">
                <label>VKN / TCKN</label>
                <input name="TaxNumber"
                       value="@profile.TaxNumber"
                       class="form-control-custom"
                       placeholder="Örn: 1234567890" />
            </div>

            <div class="form-group">
                <label>Ticaret Sicil No</label>
                <input name="TradeRegistryNumber"
                       value="@profile.TradeRegistryNumber"
                       class="form-control-custom"
                       placeholder="Örn: 223164-5" />
            </div>

            <div class="form-group">
                <label>MERSİS No</label>
                <input name="MersisNumber"
                       value="@profile.MersisNumber"
                       class="form-control-custom"
                       placeholder="Örn: 0753-1061-9250-0001" />
            </div>

            <div class="form-group">
                <label>E-posta</label>
                <input name="Email"
                       value="@profile.Email"
                       class="form-control-custom"
                       placeholder="Örn: info@servis.com" />
            </div>

            <div class="form-group">
                <label>Web Sitesi</label>
                <input name="Website"
                       value="@profile.Website"
                       class="form-control-custom"
                       placeholder="Örn: https://servis.com" />
            </div>

            <div class="form-group">
                <label>Sabit Telefon</label>
                <input name="PhoneNumber"
                       value="@profile.PhoneNumber"
                       class="form-control-custom"
                       placeholder="Örn: 02164900001" />
            </div>

            <div class="form-group">
                <label>Fax</label>
                <input name="FaxNumber"
                       value="@profile.FaxNumber"
                       class="form-control-custom"
                       placeholder="Örn: 02164940626" />
            </div>

            <div class="form-group full">
                <label>Adres</label>
                <textarea name="AddressLine"
                          class="form-control-custom"
                          rows="3"
                          placeholder="Örn: Aydıntepe Mah. Aydınlı Yolu Cad. No:25/A">@profile.AddressLine</textarea>
            </div>

            <div class="form-group">
                <label>İl</label>
                <input name="City"
                       value="@profile.City"
                       class="form-control-custom"
                       placeholder="Örn: İstanbul" />
            </div>

            <div class="form-group">
                <label>İlçe</label>
                <input name="District"
                       value="@profile.District"
                       class="form-control-custom"
                       placeholder="Örn: Tuzla" />
            </div>

            <div class="form-group">
                <label>Posta Kodu</label>
                <input name="PostalCode"
                       value="@profile.PostalCode"
                       class="form-control-custom"
                       placeholder="Örn: 34947" />
            </div>

            <div class="form-group">
                <label>Ülke</label>
                <input name="Country"
                       value="@(string.IsNullOrWhiteSpace(profile.Country) ? "Türkiye" : profile.Country)"
                       class="form-control-custom" />
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary-custom">
                İşletme Bilgilerini Kaydet
            </button>
        </div>
    </form>
</div>


<div class="admin-card bank-accounts-card">
    <div class="card-header-row">
        <div>
            <h2>Banka Hesapları / IBAN</h2>
            <p>Fatura ve servis formlarında gösterilecek ödeme hesapları.</p>
        </div>
    </div>

    <form asp-action="AddWorkshopBankAccount" asp-controller="Admin" method="post" class="bank-account-form">
        @Html.AntiForgeryToken()

        <input type="hidden" name="WorkshopId" value="@Model.Id" />

        <div class="form-grid">
            <div class="form-group">
                <label>Banka Adı</label>
                <input name="BankName"
                       class="form-control-custom"
                       placeholder="Örn: Garanti Bankası" />
            </div>

            <div class="form-group">
                <label>Alıcı Ünvanı</label>
                <input name="AccountHolder"
                       class="form-control-custom"
                       value="@(profile.LegalTitle ?? profile.DisplayName ?? Model.Name)"
                       placeholder="Örn: Mete Otomotiv Ltd. Şti." />
            </div>

            <div class="form-group full">
                <label>IBAN</label>
                <input name="Iban"
                       class="form-control-custom iban-input"
                       maxlength="34"
                       placeholder="TR00 0000 0000 0000 0000 0000 00" />
            </div>

            <div class="form-group">
                <label>Para Birimi</label>
                <select name="CurrencyCode" class="form-control-custom">
                    <option value="TRY" selected>TRY</option>
                    <option value="USD">USD</option>
                    <option value="EUR">EUR</option>
                </select>
            </div>

            <div class="form-group">
                <label>Sıra</label>
                <input name="SortOrder"
                       type="number"
                       value="@((bankAccounts.Count + 1))"
                       class="form-control-custom"
                       min="0" />
            </div>

            <div class="form-group">
                <label>Şube</label>
                <input name="BranchName"
                       class="form-control-custom"
                       placeholder="Opsiyonel" />
            </div>

            <div class="form-group">
                <label>Hesap No</label>
                <input name="AccountNumber"
                       class="form-control-custom"
                       placeholder="Opsiyonel" />
            </div>

            <div class="form-group full">
                <label>Açıklama</label>
                <input name="Description"
                       class="form-control-custom"
                       placeholder="Örn: Servis ödeme hesabı" />
            </div>

            <div class="form-group full bank-checkbox-grid">
                <label>
                    <input type="checkbox" name="IsDefault" value="true" />
                    Varsayılan hesap
                </label>

                <label>
                    <input type="checkbox" name="ShowOnInvoices" value="true" checked />
                    Faturalarda göster
                </label>

                <label>
                    <input type="checkbox" name="ShowOnServiceForms" value="true" />
                    Servis formlarında göster
                </label>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary-custom">
                IBAN Ekle
            </button>
        </div>
    </form>

    @if (!bankAccounts.Any())
    {
        <div class="empty-state">
            Henüz banka hesabı eklenmemiş.
        </div>
    }
    else
    {
        <div class="bank-account-list">
            @foreach (var bankAccount in bankAccounts)
            {
                <div class="bank-account-item">
                    <div class="bank-account-main">
                        <div>
                            <strong>@bankAccount.BankName</strong>

                            @if (bankAccount.IsDefault)
                            {
                                <span class="status-badge success">Varsayılan</span>
                            }

                            @if (bankAccount.ShowOnInvoices)
                            {
                                <span class="status-badge secondary">Faturada görünür</span>
                            }

                            @if (bankAccount.ShowOnServiceForms)
                            {
                                <span class="status-badge secondary">Servis Kayıt Formu (SKF)</span>
                            }
                        </div>

                        <div class="bank-iban">@bankAccount.Iban</div>

                        <div class="text-muted">
                            @bankAccount.AccountHolder
                            @if (!string.IsNullOrWhiteSpace(bankAccount.CurrencyCode))
                            {
                                <span> • @bankAccount.CurrencyCode</span>
                            }

                            @if (!string.IsNullOrWhiteSpace(bankAccount.Description))
                            {
                                <span> • @bankAccount.Description</span>
                            }
                        </div>
                    </div>

                    <div class="bank-account-actions">
                        <details>
                            <summary class="btn-secondary-custom btn-small-custom">
                                Düzenle
                            </summary>

                            <form asp-action="UpdateWorkshopBankAccount"
                                  asp-controller="Admin"
                                  method="post"
                                  class="bank-account-edit-form">
                                @Html.AntiForgeryToken()

                                <input type="hidden" name="WorkshopId" value="@Model.Id" />
                                <input type="hidden" name="BankAccountId" value="@bankAccount.Id" />
                                <input type="hidden" name="IsActive" value="true" />

                                <div class="form-grid">
                                    <div class="form-group">
                                        <label>Banka Adı</label>
                                        <input name="BankName"
                                               value="@bankAccount.BankName"
                                               class="form-control-custom" />
                                    </div>

                                    <div class="form-group">
                                        <label>Alıcı Ünvanı</label>
                                        <input name="AccountHolder"
                                               value="@bankAccount.AccountHolder"
                                               class="form-control-custom" />
                                    </div>

                                    <div class="form-group full">
                                        <label>IBAN</label>
                                        <input name="Iban"
                                               value="@bankAccount.Iban"
                                               class="form-control-custom iban-input"
                                               maxlength="34" />
                                    </div>

                                    <div class="form-group">
                                        <label>Para Birimi</label>
                                        <select name="CurrencyCode" class="form-control-custom">
                                            @foreach (var currency in new[] { "TRY", "USD", "EUR" })
                                            {
                                                if (bankAccount.CurrencyCode == currency)
                                                {
                                                    <option value="@currency" selected>@currency</option>
                                                }
                                                else
                                                {
                                                    <option value="@currency">@currency</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div class="form-group">
                                        <label>Sıra</label>
                                        <input name="SortOrder"
                                               type="number"
                                               value="@bankAccount.SortOrder"
                                               class="form-control-custom"
                                               min="0" />
                                    </div>

                                    <div class="form-group">
                                        <label>Şube</label>
                                        <input name="BranchName"
                                               value="@bankAccount.BranchName"
                                               class="form-control-custom" />
                                    </div>

                                    <div class="form-group">
                                        <label>Hesap No</label>
                                        <input name="AccountNumber"
                                               value="@bankAccount.AccountNumber"
                                               class="form-control-custom" />
                                    </div>

                                    <div class="form-group full">
                                        <label>Açıklama</label>
                                        <input name="Description"
                                               value="@bankAccount.Description"
                                               class="form-control-custom" />
                                    </div>

                                    <div class="form-group full bank-checkbox-grid">
                                        <label>
                                            <input type="checkbox" name="IsDefault" value="true" checked="@bankAccount.IsDefault" />
                                            Varsayılan hesap
                                        </label>

                                        <label>
                                            <input type="checkbox" name="ShowOnInvoices" value="true" checked="@bankAccount.ShowOnInvoices" />
                                            Faturalarda göster
                                        </label>

                                        <label>
                                            <input type="checkbox" name="ShowOnServiceForms" value="true" checked="@bankAccount.ShowOnServiceForms" />
                                            Servis formlarında göster
                                        </label>
                                    </div>
                                </div>

                                <div class="form-actions">
