@model AutoStock.WEB.Models.SupportRequests.CreateUserSupportRequestViewModel
@using AutoStock.Repositories.Enums
@using AutoStock.WEB.Models.Common

@{
    ViewData["Title"] = "Kullanıcı Ekleme Talebi";
}

<div class="support-page">
    <div class="support-header">
        <div class="support-title-area">
            <div class="support-icon">
                <span>+</span>
            </div>

            <div>
                <h1>Kullanıcı Ekleme Talebi</h1>
                <p>Servisinize yeni kullanıcı eklenmesi için admin tarafına talep oluşturabilirsiniz.</p>
            </div>
        </div>

        @await Html.PartialAsync("_PageActions", new PageActionViewModel
        {
            BackController = "SupportRequests",
            BackAction = "Index",
            HomeController = "Dashboard",
            HomeAction = "Index"
        })
    </div>

    <div class="support-form-card">
        <form asp-controller="SupportRequests"
              asp-action="CreateUserRequest"
              method="post">

            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="RequestedUserFullName">Ad Soyad</label>
                <input asp-for="RequestedUserFullName"
                       class="form-control-custom"
                       placeholder="Örn: Ahmet Yılmaz" />
                <span asp-validation-for="RequestedUserFullName" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="RequestedUserPhone">Telefon</label>
                <input asp-for="RequestedUserPhone"
                       class="form-control-custom"
                       placeholder="Örn: 05xx xxx xx xx" />
                <span asp-validation-for="RequestedUserPhone" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="RequestedUserEmail">E-posta</label>
                <input asp-for="RequestedUserEmail"
                       class="form-control-custom"
                       placeholder="Örn: kullanici@mail.com" />
                <span asp-validation-for="RequestedUserEmail" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="RequestedUserRole">Rol Talebi</label>
                <select asp-for="RequestedUserRole" class="form-control-custom">
                    <option value="@SupportRequestedUserRole.Staff">Personel</option>
                    <option value="@SupportRequestedUserRole.Owner">Servis Sahibi</option>
                </select>
                <span asp-validation-for="RequestedUserRole" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Priority">Öncelik</label>
                <select asp-for="Priority" class="form-control-custom">
                    <option value="@SupportRequestPriority.Low">Düşük</option>
                    <option value="@SupportRequestPriority.Normal">Normal</option>
                    <option value="@SupportRequestPriority.High">Yüksek</option>
                    <option value="@SupportRequestPriority.Critical">Kritik</option>
                </select>
                <span asp-validation-for="Priority" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Note">Not</label>
                <textarea asp-for="Note"
                          class="form-control-custom textarea"
                          rows="5"
                          placeholder="Eklemek istediğiniz açıklama varsa yazabilirsiniz."></textarea>
                <span asp-validation-for="Note" class="validation-text"></span>
            </div>

            <div class="support-info-box">
                <strong>Not:</strong>
                Bu talep kullanıcıyı otomatik oluşturmaz. Admin talebi inceleyip kullanıcıyı manuel oluşturacaktır.
            </div>

            <div class="form-actions">
                <a asp-controller="SupportRequests"
                   asp-action="Index"
                   class="secondary-btn">
                    Vazgeç
                </a>

                <button type="submit" class="primary-btn">
                    Talep Oluştur
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .support-page {
        padding-top: 28px;
        padding-bottom: 32px;
    }

    .support-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 32px;
    }

    .support-title-area {
        display: flex;
        align-items: flex-start;
        gap: 14px;
    }

    .support-icon {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        background: #eef2ff;
        color: #4f46e5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        font-weight: 800;
    }

    .support-header h1 {
        margin: 0;
        font-size: 28px;
        font-weight: 800;
        color: #0f172a;
    }

    .support-header p {
        margin: 8px 0 0;
        color: #64748b;
        font-size: 14px;
    }

    .support-form-card {
        max-width: 820px;
        background: #fff;
        border: 1px solid #dbe3ef;
        border-radius: 18px;
        padding: 24px;
        box-shadow: 0 8px 22px rgba(15, 23, 42, .06);
    }

    .form-group {
        margin-bottom: 18px;
    }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-size: 13px;
            font-weight: 800;
            color: #334155;
        }

    .form-control-custom {
        width: 100%;
        min-height: 48px;
        border: 1px solid #cfd8e6;
        border-radius: 13px;
        padding: 0 14px;
        color: #0f172a;
        font-size: 14px;
        outline: none;
    }

        .form-control-custom:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 3px rgba(79, 70, 229, .12);
        }

        .form-control-custom.textarea {
            padding-top: 14px;
            resize: vertical;
        }

    .validation-text {
        display: block;
        margin-top: 6px;
        font-size: 12px;
        color: #e11d48;
        font-weight: 700;
    }

    .support-info-box {
        margin-top: 8px;
        padding: 14px 16px;
        border-radius: 14px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        color: #475569;
        font-size: 13px;
    }

    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 24px;
    }

    .primary-btn,
    .secondary-btn {
        height: 44px;
        border-radius: 12px;
        padding: 0 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 14px;
        text-decoration: none;
        border: 1px solid transparent;
        cursor: pointer;
    }

    .primary-btn {
        background: #4f46e5;
        color: #fff;
    }

        .primary-btn:hover {
            background: #4338ca;
            color: #fff;
        }

    .secondary-btn {
        background: #fff;
        color: #334155;
        border-color: #cfd8e6;
    }

        .secondary-btn:hover {
            background: #f8fafc;
            color: #0f172a;
        }

    @@media (max-width: 900px) {
        .support-header {
            align-items: flex-start;
            flex-direction: column;
        }

        .support-form-card {
            padding: 18px;
        }

        .form-actions {
            flex-direction: column-reverse;
        }

        .primary-btn,
        .secondary-btn {
            width: 100%;
        }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}