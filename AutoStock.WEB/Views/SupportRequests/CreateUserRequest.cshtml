@model AutoStock.WEB.Models.SupportRequests.CreateUserSupportRequestViewModel
@using AutoStock.Repositories.Enums

@{
    ViewData["Title"] = "Kullanıcı Ekleme Talebi";
}

<div class="sup-compose-page">
    <section class="sup-compose-hero">
        <a asp-controller="SupportRequests"
           asp-action="Index"
           class="sup-back-mark"
           title="Destek listesine dön">
            ←
        </a>

        <div>
            <span class="sup-eyebrow">Destek Merkezi</span>
            <h1>Kullanıcı Ekleme Talebi</h1>
            <p>Yeni kullanıcı için bilgileri gönderin.</p>
        </div>
    </section>

    <form asp-controller="SupportRequests"
          asp-action="CreateUserRequest"
          method="post"
          class="sup-compose-card">

        @Html.AntiForgeryToken()

        <input type="hidden" name="Priority" value="@SupportRequestPriority.Normal" />

        <div class="sup-form-grid">
            <div class="sup-form-section full">
                <label asp-for="RequestedUserFullName">Ad Soyad</label>

                <input asp-for="RequestedUserFullName"
                       class="sup-input"
                       placeholder="Örn: Ahmet Yılmaz" />

                <span asp-validation-for="RequestedUserFullName" class="sup-validation"></span>
            </div>

            <div class="sup-form-section">
                <label asp-for="RequestedUserPhone">Telefon</label>

                <input asp-for="RequestedUserPhone"
                       class="sup-input"
                       placeholder="05xx xxx xx xx" />

                <span asp-validation-for="RequestedUserPhone" class="sup-validation"></span>
            </div>

            <div class="sup-form-section">
                <label asp-for="RequestedUserEmail">E-posta</label>

                <input asp-for="RequestedUserEmail"
                       class="sup-input"
                       placeholder="kullanici@mail.com" />

                <span asp-validation-for="RequestedUserEmail" class="sup-validation"></span>
            </div>

            <div class="sup-form-section full">
                <label asp-for="RequestedUserRole">Rol</label>

                <select asp-for="RequestedUserRole" class="sup-input">
                    <option value="@SupportRequestedUserRole.Staff">Personel</option>
                    <option value="@SupportRequestedUserRole.Owner">Servis Sahibi</option>
                </select>

                <span asp-validation-for="RequestedUserRole" class="sup-validation"></span>
            </div>

            <div class="sup-form-section full">
                <label asp-for="Note">Not</label>

                <textarea asp-for="Note"
                          class="sup-input sup-textarea"
                          rows="5"
                          placeholder="Gerekli gördüğünüz ek bilgi varsa yazın."></textarea>

                <span asp-validation-for="Note" class="sup-validation"></span>
            </div>
        </div>

        <div class="sup-compose-actions">
            <a asp-controller="SupportRequests"
               asp-action="Index"
               class="sup-secondary-btn">
                Vazgeç
            </a>

            <button type="submit" class="sup-primary-btn">
                Talep Oluştur
            </button>
        </div>
    </form>
</div>

<style>
    .sup-compose-page {
        width: min(860px, calc(100% - 56px));
        margin: 0 auto;
        padding: 30px 0 64px;
        color: #071a36;
    }

    .sup-compose-hero {
        margin-bottom: 18px;
        padding: 24px;
        border-radius: 30px;
        background:
            radial-gradient(circle at 20% 0%, rgba(8, 145, 178, .14), transparent 30%),
            linear-gradient(135deg, #ffffff 0%, #f8fbff 100%);
        border: 1px solid #dbe3ef;
        box-shadow: 0 18px 46px rgba(15, 23, 42, .08);
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .sup-back-mark {
        width: 54px;
        height: 54px;
        flex: 0 0 54px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background: #111827;
        color: white;
        text-decoration: none;
        font-size: 26px;
        font-weight: 950;
    }

    .sup-eyebrow {
        display: inline-flex;
        margin-bottom: 7px;
        padding: 6px 11px;
        border-radius: 999px;
        background: #ecfeff;
        color: #0891b2;
        font-size: 12px;
        font-weight: 950;
    }

    .sup-compose-hero h1 {
        margin: 0;
        color: #061936;
        font-size: clamp(30px, 4vw, 42px);
        letter-spacing: -1.4px;
        line-height: 1;
    }

    .sup-compose-hero p {
        margin: 9px 0 0;
        color: #64748b;
        font-size: 15px;
        font-weight: 800;
    }

    .sup-compose-card {
        padding: 24px;
        border-radius: 28px;
        background: white;
        border: 1px solid #dbe3ef;
        box-shadow: 0 14px 36px rgba(15, 23, 42, .06);
        display: grid;
        gap: 18px;
    }

    .sup-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
    }

    .sup-form-section {
        display: grid;
        gap: 8px;
    }

    .sup-form-section.full {
        grid-column: span 2;
    }

    .sup-form-section label {
        color: #0f172a;
        font-size: 14px;
        font-weight: 950;
    }

    .sup-input {
        width: 100%;
        min-height: 56px;
        border-radius: 18px;
        border: 1px solid #d4deeb;
        background: #f8fafc;
        color: #0f172a;
        padding: 0 16px;
        font-size: 15px;
        font-weight: 750;
        outline: none;
        box-sizing: border-box;
    }

    .sup-input:focus {
        background: white;
        border-color: #0891b2;
        box-shadow: 0 0 0 4px rgba(8, 145, 178, .10);
    }

    .sup-textarea {
        min-height: 132px;
        padding: 15px 16px;
        resize: vertical;
        line-height: 1.55;
    }

    .sup-validation {
        min-height: 16px;
        color: #e11d48;
        font-size: 12px;
        font-weight: 850;
    }

    .sup-compose-actions {
        padding-top: 14px;
        border-top: 1px solid #edf2f7;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }

    .sup-primary-btn,
    .sup-secondary-btn {
        min-height: 52px;
        padding: 0 22px;
        border-radius: 17px;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-size: 15px;
        font-weight: 950;
        cursor: pointer;
        white-space: nowrap;
    }

    .sup-primary-btn {
        background: #0891b2;
        color: white;
        box-shadow: 0 16px 30px rgba(8, 145, 178, .22);
    }

    .sup-secondary-btn {
        background: #f8fafc;
        color: #334155;
        border: 1px solid #d4deeb;
    }

    @@media (max-width: 720px) {
        .sup-compose-page {
            width: min(100% - 20px, 860px);
            padding: 16px 0 44px;
        }

        .sup-compose-hero {
            padding: 18px;
            border-radius: 24px;
            align-items: flex-start;
        }

        .sup-back-mark {
            width: 46px;
            height: 46px;
            flex-basis: 46px;
            border-radius: 16px;
            font-size: 22px;
        }

        .sup-compose-hero h1 {
            font-size: 29px;
            letter-spacing: -1px;
        }

        .sup-compose-card {
            padding: 18px;
            border-radius: 24px;
        }

        .sup-form-grid {
            grid-template-columns: 1fr;
        }

        .sup-form-section.full {
            grid-column: auto;
        }

        .sup-compose-actions {
            display: grid;
            grid-template-columns: 1fr;
        }

        .sup-primary-btn {
            order: -1;
        }

        .sup-primary-btn,
        .sup-secondary-btn {
            width: 100%;
        }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
