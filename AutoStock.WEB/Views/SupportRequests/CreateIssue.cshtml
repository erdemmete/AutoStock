@model AutoStock.WEB.Models.SupportRequests.CreateIssueSupportRequestViewModel
@using AutoStock.Repositories.Enums

@{
    ViewData["Title"] = "Yeni Sorun Bildir";
}

<div class="sup-compose-page">
    <section class="sup-compose-hero">
        <a asp-controller="SupportRequests"
           asp-action="Index"
           class="sup-back-mark"
           title="Destek listesine dön">
            ←
        </a>

        <div>
            <span class="sup-eyebrow">Destek Merkezi</span>
            <h1>Yeni Sorun Bildir</h1>
            <p>Yaşadığınız problemi bize iletin.</p>
        </div>
    </section>

    <form asp-controller="SupportRequests"
          asp-action="CreateIssue"
          method="post"
          class="sup-compose-card">

        @Html.AntiForgeryToken()

        <input type="hidden" name="Priority" value="@SupportRequestPriority.Normal" />

        <div class="sup-form-section">
            <label asp-for="Subject">Konu</label>

            <input asp-for="Subject"
                   class="sup-input"
                   placeholder="Örn: Fatura taslağı oluşturulamıyor" />

            <span asp-validation-for="Subject" class="sup-validation"></span>
        </div>

        <div class="sup-form-section">
            <label asp-for="Description">Açıklama</label>

            <textarea asp-for="Description"
                      class="sup-input sup-textarea"
                      rows="8"
                      placeholder="Ekranı, yaptığınız işlemi ve gördüğünüz hatayı yazın."></textarea>

            <span asp-validation-for="Description" class="sup-validation"></span>
        </div>

        <div class="sup-compose-actions">
            <a asp-controller="SupportRequests"
               asp-action="Index"
               class="sup-secondary-btn">
                Vazgeç
            </a>

            <button type="submit" class="sup-primary-btn">
                Talep Oluştur
            </button>
        </div>
    </form>
</div>

<style>
    .sup-compose-page {
        width: min(820px, calc(100% - 56px));
        margin: 0 auto;
        padding: 30px 0 64px;
        color: #071a36;
    }

    .sup-compose-hero {
        margin-bottom: 18px;
        padding: 24px;
        border-radius: 30px;
        background:
            radial-gradient(circle at 20% 0%, rgba(79, 70, 229, .16), transparent 30%),
            linear-gradient(135deg, #ffffff 0%, #f8fbff 100%);
        border: 1px solid #dbe3ef;
        box-shadow: 0 18px 46px rgba(15, 23, 42, .08);
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .sup-back-mark {
        width: 54px;
        height: 54px;
        flex: 0 0 54px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background: #111827;
        color: white;
        text-decoration: none;
        font-size: 26px;
        font-weight: 950;
    }

    .sup-eyebrow {
        display: inline-flex;
        margin-bottom: 7px;
        padding: 6px 11px;
        border-radius: 999px;
        background: #eef2ff;
        color: #4f46e5;
        font-size: 12px;
        font-weight: 950;
    }

    .sup-compose-hero h1 {
        margin: 0;
        color: #061936;
        font-size: clamp(30px, 4vw, 42px);
        letter-spacing: -1.4px;
        line-height: 1;
    }

    .sup-compose-hero p {
        margin: 9px 0 0;
        color: #64748b;
        font-size: 15px;
        font-weight: 800;
    }

    .sup-compose-card {
        padding: 24px;
        border-radius: 28px;
        background: white;
        border: 1px solid #dbe3ef;
        box-shadow: 0 14px 36px rgba(15, 23, 42, .06);
        display: grid;
        gap: 18px;
    }

    .sup-form-section {
        display: grid;
        gap: 8px;
    }

    .sup-form-section label {
        color: #0f172a;
        font-size: 14px;
        font-weight: 950;
    }

    .sup-input {
        width: 100%;
        min-height: 56px;
        border-radius: 18px;
        border: 1px solid #d4deeb;
        background: #f8fafc;
        color: #0f172a;
        padding: 0 16px;
        font-size: 15px;
        font-weight: 750;
        outline: none;
        box-sizing: border-box;
    }

    .sup-input:focus {
        background: white;
        border-color: #4f46e5;
        box-shadow: 0 0 0 4px rgba(79, 70, 229, .10);
    }

    .sup-textarea {
        min-height: 190px;
        padding: 15px 16px;
        resize: vertical;
        line-height: 1.55;
    }

    .sup-validation {
        min-height: 16px;
        color: #e11d48;
        font-size: 12px;
        font-weight: 850;
    }

    .sup-compose-actions {
        padding-top: 14px;
        border-top: 1px solid #edf2f7;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }

    .sup-primary-btn,
    .sup-secondary-btn {
        min-height: 52px;
        padding: 0 22px;
        border-radius: 17px;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-size: 15px;
        font-weight: 950;
        cursor: pointer;
        white-space: nowrap;
    }

    .sup-primary-btn {
        background: #4f46e5;
        color: white;
        box-shadow: 0 16px 30px rgba(79, 70, 229, .24);
    }

    .sup-secondary-btn {
        background: #f8fafc;
        color: #334155;
        border: 1px solid #d4deeb;
    }

    @@media (max-width: 720px) {
        .sup-compose-page {
            width: min(100% - 20px, 820px);
            padding: 16px 0 44px;
        }

        .sup-compose-hero {
            padding: 18px;
            border-radius: 24px;
            align-items: flex-start;
        }

        .sup-back-mark {
            width: 46px;
            height: 46px;
            flex-basis: 46px;
            border-radius: 16px;
            font-size: 22px;
        }

        .sup-compose-hero h1 {
            font-size: 29px;
            letter-spacing: -1px;
        }

        .sup-compose-card {
            padding: 18px;
            border-radius: 24px;
        }

        .sup-compose-actions {
            display: grid;
            grid-template-columns: 1fr;
        }

        .sup-primary-btn {
            order: -1;
        }

        .sup-primary-btn,
        .sup-secondary-btn {
            width: 100%;
        }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
