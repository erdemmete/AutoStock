@model AutoStock.WEB.Models.SupportRequests.SupportRequestDetailViewModel
@using AutoStock.Repositories.Enums
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Destek Talebi Detayı";

    var currentUserId = Context.Session.GetInt32("UserId");

    var canCancel =
        currentUserId.HasValue &&
        currentUserId.Value == Model.CreatedByUserId &&
        Model.Status != SupportRequestStatus.Closed &&
        Model.Status != SupportRequestStatus.Cancelled;

    string GetStatusClass(string? statusText)
    {
        if (string.IsNullOrWhiteSpace(statusText))
            return "status-default";

        if (statusText.Contains("Açık", StringComparison.OrdinalIgnoreCase))
            return "status-open";

        if (statusText.Contains("İşlem", StringComparison.OrdinalIgnoreCase))
            return "status-progress";

        if (statusText.Contains("Yanıt", StringComparison.OrdinalIgnoreCase) ||
            statusText.Contains("Cevap", StringComparison.OrdinalIgnoreCase))
            return "status-answered";

        if (statusText.Contains("Kapan", StringComparison.OrdinalIgnoreCase))
            return "status-closed";

        if (statusText.Contains("İptal", StringComparison.OrdinalIgnoreCase))
            return "status-cancelled";

        return "status-default";
    }
}

<div class="sup-detail-page">
    <section class="sup-detail-hero">
        <div class="sup-detail-hero-main">
            <a asp-controller="SupportRequests"
               asp-action="Index"
               class="sup-back-mark"
               title="Listeye dön">
                ←
            </a>

            <div>
                <span class="sup-eyebrow">Destek Talebi</span>
                <h1>@Model.Subject</h1>
                <p>@Model.RequestTypeText</p>
            </div>
        </div>

        <div class="sup-detail-actions">
            <a asp-controller="SupportRequests"
               asp-action="Index"
               class="sup-ghost-btn">
                Listeye Dön
            </a>

            <a asp-controller="Dashboard"
               asp-action="Index"
               class="sup-ghost-btn">
                Ana Sayfa
            </a>
        </div>
    </section>

    <section class="sup-detail-layout">
        <main class="sup-ticket-detail-card">
            <div class="sup-ticket-detail-head">
                <div>
                    <span class="sup-small-label">Konu</span>
                    <h2>@Model.Subject</h2>
                </div>

                <span class="sup-status-pill @GetStatusClass(Model.StatusText)">
                    @Model.StatusText
                </span>
            </div>

            <div class="sup-meta-grid">
                <div class="sup-meta-box">
                    <span>Talep Tipi</span>
                    <strong>@Model.RequestTypeText</strong>
                </div>

                <div class="sup-meta-box">
                    <span>Oluşturan</span>
                    <strong>@Model.CreatedByUserName</strong>
                </div>

                <div class="sup-meta-box">
                    <span>Oluşturma Tarihi</span>
                    <strong>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</strong>
                </div>
            </div>

            <div class="sup-content-section">
                <span class="sup-small-label">Açıklama</span>
                <div class="sup-description-box">
                    @Model.Description
                </div>
            </div>

            @if (Model.RequestType == SupportRequestType.UserCreateRequest)
            {
                <div class="sup-content-section">
                    <span class="sup-small-label">Talep Edilen Kullanıcı</span>

                    <div class="sup-user-request-grid">
                        <div>
                            <span>Ad Soyad</span>
                            <strong>@Model.RequestedUserFullName</strong>
                        </div>

                        <div>
                            <span>Telefon</span>
                            <strong>@(string.IsNullOrWhiteSpace(Model.RequestedUserPhone) ? "-" : Model.RequestedUserPhone)</strong>
                        </div>

                        <div>
                            <span>E-posta</span>
                            <strong>@(string.IsNullOrWhiteSpace(Model.RequestedUserEmail) ? "-" : Model.RequestedUserEmail)</strong>
                        </div>

                        <div>
                            <span>Rol</span>
                            <strong>@(string.IsNullOrWhiteSpace(Model.RequestedUserRoleText) ? "-" : Model.RequestedUserRoleText)</strong>
                        </div>
                    </div>
                </div>
            }

            <div class="sup-content-section">
                <span class="sup-small-label">Cevap</span>

                @if (!string.IsNullOrWhiteSpace(Model.AdminResponse))
                {
                    <div class="sup-response-box">
                        <div class="sup-response-icon">✓</div>

                        <div>
                            <div class="sup-response-text">
                                @Model.AdminResponse
                            </div>

                            <div class="sup-response-meta">
                                @if (!string.IsNullOrWhiteSpace(Model.RespondedByUserName))
                                {
                                    <span>@Model.RespondedByUserName</span>
                                }

                                @if (Model.RespondedAt.HasValue)
                                {
                                    <span>@Model.RespondedAt.Value.ToString("dd.MM.yyyy HH:mm")</span>
                                }
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="sup-waiting-box">
                        Talebiniz yanıtlandığında cevap burada görünecek.
                    </div>
                }
            </div>

            <div class="sup-detail-footer">
                <a asp-controller="SupportRequests"
                   asp-action="Index"
                   class="sup-secondary-btn">
                    Listeye Dön
                </a>

                @if (canCancel)
                {
                    <form asp-controller="SupportRequests"
                          asp-action="Cancel"
                          asp-route-id="@Model.Id"
                          method="post"
                          onsubmit="return confirm('Bu destek talebini iptal etmek istediğinize emin misiniz?');">

                        @Html.AntiForgeryToken()

                        <button type="submit" class="sup-danger-btn">
                            Talebi İptal Et
                        </button>
                    </form>
                }
            </div>
        </main>

        <aside class="sup-side-panel">
            <div class="sup-side-card">
                <h3>Durum Akışı</h3>

                <div class="sup-timeline">
                    <div class="sup-timeline-item active">
                        <span></span>
                        <div>
                            <strong>Talep oluşturuldu</strong>
                            <small>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                        </div>
                    </div>

                    @if (Model.RespondedAt.HasValue)
                    {
                        <div class="sup-timeline-item active">
                            <span></span>
                            <div>
                                <strong>Yanıt verildi</strong>
                                <small>@Model.RespondedAt.Value.ToString("dd.MM.yyyy HH:mm")</small>
                            </div>
                        </div>
                    }

                    @if (Model.ClosedAt.HasValue)
                    {
                        <div class="sup-timeline-item active">
                            <span></span>
                            <div>
                                <strong>Talep kapandı</strong>
                                <small>@Model.ClosedAt.Value.ToString("dd.MM.yyyy HH:mm")</small>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="sup-side-status">
                <span>Güncel Durum</span>
                <strong>@Model.StatusText</strong>
            </div>
        </aside>
    </section>
</div>

<style>
    .sup-detail-page {
        width: min(1180px, calc(100% - 56px));
        margin: 0 auto;
        padding: 30px 0 64px;
        color: #071a36;
    }

    .sup-detail-hero {
        margin-bottom: 18px;
        display: flex;
        align-items: stretch;
        justify-content: space-between;
        gap: 16px;
    }

    .sup-detail-hero-main {
        flex: 1;
        min-width: 0;
        padding: 24px;
        border-radius: 30px;
        background:
            radial-gradient(circle at 20% 0%, rgba(79, 70, 229, .16), transparent 30%),
            linear-gradient(135deg, #ffffff 0%, #f8fbff 100%);
        border: 1px solid #dbe3ef;
        box-shadow: 0 18px 46px rgba(15, 23, 42, .08);
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .sup-back-mark {
        width: 54px;
        height: 54px;
        flex: 0 0 54px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background: #111827;
        color: white;
        text-decoration: none;
        font-size: 26px;
        font-weight: 950;
    }

    .sup-eyebrow {
        display: inline-flex;
        margin-bottom: 7px;
        padding: 6px 11px;
        border-radius: 999px;
        background: #eef2ff;
        color: #4f46e5;
        font-size: 12px;
        font-weight: 950;
    }

    .sup-detail-hero h1 {
        margin: 0;
        color: #061936;
        font-size: clamp(28px, 4vw, 40px);
        letter-spacing: -1.4px;
        line-height: 1.05;
    }

    .sup-detail-hero p {
        margin: 8px 0 0;
        color: #64748b;
        font-weight: 850;
    }

    .sup-detail-actions {
        display: grid;
        gap: 10px;
        min-width: 150px;
    }

    .sup-ghost-btn {
        min-height: 54px;
        padding: 0 18px;
        border-radius: 18px;
        background: white;
        border: 1px solid #dbe3ef;
        color: #0f172a;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 950;
        box-shadow: 0 14px 32px rgba(15, 23, 42, .05);
    }

    .sup-detail-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 320px;
        gap: 18px;
        align-items: start;
    }

    .sup-ticket-detail-card,
    .sup-side-card,
    .sup-side-status {
        border-radius: 28px;
        background: white;
        border: 1px solid #dbe3ef;
        box-shadow: 0 14px 36px rgba(15, 23, 42, .06);
    }

    .sup-ticket-detail-card {
        padding: 24px;
    }

    .sup-ticket-detail-head {
        margin-bottom: 18px;
        padding-bottom: 18px;
        border-bottom: 1px solid #edf2f7;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
    }

    .sup-small-label {
        display: block;
        margin-bottom: 7px;
        color: #64748b;
        font-size: 12px;
        font-weight: 950;
        letter-spacing: .5px;
        text-transform: uppercase;
    }

    .sup-ticket-detail-head h2 {
        margin: 0;
        color: #0f172a;
        font-size: 26px;
        font-weight: 950;
        letter-spacing: -.7px;
    }

    .sup-status-pill {
        min-height: 34px;
        padding: 0 13px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        font-size: 12px;
        font-weight: 950;
        white-space: nowrap;
    }

    .status-open {
        background: #fef3c7;
        color: #b45309;
    }

    .status-progress {
        background: #eef2ff;
        color: #4f46e5;
    }

    .status-answered {
        background: #dcfce7;
        color: #15803d;
    }

    .status-closed {
        background: #e2e8f0;
        color: #334155;
    }

    .status-cancelled {
        background: #fee2e2;
        color: #b91c1c;
    }

    .status-default {
        background: #f1f5f9;
        color: #475569;
    }

    .sup-meta-grid {
        margin-bottom: 18px;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
    }

    .sup-meta-box,
    .sup-user-request-grid > div {
        min-width: 0;
        padding: 14px;
        border-radius: 18px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
    }

    .sup-meta-box span,
    .sup-user-request-grid span {
        display: block;
        margin-bottom: 5px;
        color: #8aa0bd;
        font-size: 12px;
        font-weight: 950;
    }

    .sup-meta-box strong,
    .sup-user-request-grid strong {
        display: block;
        color: #0f172a;
        font-size: 14px;
        font-weight: 950;
        word-break: break-word;
    }

    .sup-content-section {
        margin-top: 20px;
    }

    .sup-description-box {
        padding: 18px;
        min-height: 120px;
        border-radius: 20px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        color: #334155;
        font-size: 15px;
        line-height: 1.65;
        font-weight: 650;
        white-space: pre-wrap;
    }

    .sup-user-request-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .sup-response-box {
        padding: 18px;
        border-radius: 22px;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        display: flex;
        gap: 14px;
    }

    .sup-response-icon {
        width: 38px;
        height: 38px;
        flex: 0 0 38px;
        border-radius: 14px;
        background: white;
        color: #16a34a;
        display: grid;
        place-items: center;
        font-weight: 950;
    }

    .sup-response-text {
        color: #14532d;
        font-size: 15px;
        line-height: 1.6;
        font-weight: 750;
        white-space: pre-wrap;
    }

    .sup-response-meta {
        margin-top: 10px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        color: #64748b;
        font-size: 12px;
        font-weight: 850;
    }

    .sup-waiting-box {
        padding: 18px;
        border-radius: 20px;
        background: #fffbeb;
        border: 1px solid #fde68a;
        color: #92400e;
        font-size: 14px;
        font-weight: 850;
    }

    .sup-detail-footer {
        margin-top: 24px;
        padding-top: 18px;
        border-top: 1px solid #edf2f7;
        display: flex;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .sup-secondary-btn,
    .sup-danger-btn {
        min-height: 46px;
        padding: 0 18px;
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 950;
        cursor: pointer;
    }

    .sup-secondary-btn {
        background: #f8fafc;
        color: #334155;
        border: 1px solid #d4deeb;
    }

    .sup-danger-btn {
        background: #fff1f2;
        color: #b91c1c;
        border: 1px solid #fecaca;
    }

    .sup-side-panel {
        display: grid;
        gap: 14px;
    }

    .sup-side-card {
        padding: 20px;
    }

    .sup-side-card h3 {
        margin: 0 0 18px;
        color: #0f172a;
        font-size: 20px;
        font-weight: 950;
    }

    .sup-timeline {
        display: grid;
        gap: 16px;
    }

    .sup-timeline-item {
        display: flex;
        gap: 12px;
    }

    .sup-timeline-item > span {
        width: 13px;
        height: 13px;
        margin-top: 3px;
        flex: 0 0 13px;
        border-radius: 999px;
        background: #cbd5e1;
    }

    .sup-timeline-item.active > span {
        background: #4f46e5;
        box-shadow: 0 0 0 5px rgba(79,70,229,.12);
    }

    .sup-timeline-item strong {
        display: block;
        color: #0f172a;
        font-size: 14px;
        font-weight: 950;
    }

    .sup-timeline-item small {
        display: block;
        margin-top: 3px;
        color: #64748b;
        font-size: 12px;
        font-weight: 800;
    }

    .sup-side-status {
        padding: 18px;
        background: #111827;
        color: white;
    }

    .sup-side-status span {
        display: block;
        margin-bottom: 6px;
        color: rgba(255,255,255,.72);
        font-size: 12px;
        font-weight: 950;
    }

    .sup-side-status strong {
        font-size: 20px;
        font-weight: 950;
    }

    @@media (max-width: 1000px) {
        .sup-detail-layout {
            grid-template-columns: 1fr;
        }

        .sup-detail-hero {
            flex-direction: column;
        }

        .sup-detail-actions {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 720px) {
        .sup-detail-page {
            width: min(100% - 20px, 1180px);
            padding: 16px 0 44px;
        }

        .sup-detail-hero-main {
            padding: 18px;
            border-radius: 24px;
            align-items: flex-start;
        }

        .sup-back-mark {
            width: 46px;
            height: 46px;
            flex-basis: 46px;
            border-radius: 16px;
            font-size: 22px;
        }

        .sup-detail-hero h1 {
            font-size: 28px;
            letter-spacing: -1px;
        }

        .sup-ticket-detail-card,
        .sup-side-card,
        .sup-side-status {
            border-radius: 24px;
        }

        .sup-ticket-detail-card {
            padding: 18px;
        }

        .sup-ticket-detail-head {
            flex-direction: column;
        }

        .sup-meta-grid,
        .sup-user-request-grid {
            grid-template-columns: 1fr;
        }

        .sup-response-box {
            flex-direction: column;
        }

        .sup-detail-footer,
        .sup-detail-actions {
            display: grid;
            grid-template-columns: 1fr;
        }

        .sup-secondary-btn,
        .sup-danger-btn {
            width: 100%;
        }
    }
</style>
