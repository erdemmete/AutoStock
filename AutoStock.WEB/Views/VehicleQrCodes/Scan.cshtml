@{
    Layout = null;

    var role = (ViewBag.Role as string ?? "").Trim();
    var isOwner = string.Equals(role, "Owner", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Sente360 | QR Tara</title>

    <style>
            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                min-height: 100vh;
                font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
                background: #f6f8fc;
                color: #0f172a;
            }

            .qr-page {
                width: min(760px, calc(100% - 32px));
                margin: 0 auto;
                padding: 32px 0 48px;
            }

            .qr-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                gap: 16px;
                margin-bottom: 22px;
            }

                .qr-header h1 {
                    margin: 0;
                    font-size: 28px;
                    font-weight: 950;
                    letter-spacing: -.8px;
                }

                .qr-header p {
                    margin: 7px 0 0;
                    color: #64748b;
                    font-weight: 700;
                }

            .back-link {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                min-height: 42px;
                padding: 0 15px;
                border-radius: 13px;
                border: 1px solid #e2e8f0;
                background: #fff;
                color: #334155;
                text-decoration: none;
                font-weight: 900;
            }

            .panel {
                background: #fff;
                border: 1px solid #e2e8f0;
                border-radius: 22px;
                padding: 24px;
                box-shadow: 0 14px 34px rgba(15, 23, 42, .07);
            }

            #qr-reader {
                overflow: hidden;
                border-radius: 18px;
                background: #0f172a;
                min-height: 320px;
            }

                #qr-reader video {
                    width: 100% !important;
                    height: auto !important;
                }

            .actions {
                display: flex;
                gap: 12px;
                margin-top: 18px;
                flex-wrap: wrap;
            }

            .btn {
                min-height: 46px;
                padding: 0 18px;
                border-radius: 14px;
                border: none;
                cursor: pointer;
                font-weight: 950;
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                justify-content: center;
            }

            .btn-primary {
                background: #635bff;
                color: #fff;
                box-shadow: 0 12px 26px rgba(99, 91, 255, .22);
            }

            .btn-secondary {
                background: #f8fafc;
                color: #334155;
                border: 1px solid #e2e8f0;
            }

            .status-box {
                margin-top: 16px;
                border-radius: 16px;
                padding: 14px 16px;
                background: #eff6ff;
                border: 1px solid #bfdbfe;
                color: #1e40af;
                font-weight: 800;
                line-height: 1.45;
            }

                .status-box.error {
                    background: #fff1f2;
                    border-color: #fecdd3;
                    color: #be123c;
                }

            .result-card {
                display: none;
                margin-top: 22px;
                background: #fff;
                border: 1px solid #e2e8f0;
                border-radius: 22px;
                padding: 22px;
                box-shadow: 0 14px 34px rgba(15, 23, 42, .07);
            }

                .result-card.active {
                    display: block;
                }

            .vehicle-title {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 14px;
                margin-bottom: 14px;
            }

                .vehicle-title h2 {
                    margin: 0;
                    font-size: 24px;
                    font-weight: 950;
                    letter-spacing: -.6px;
                }

            .plate-badge {
                display: inline-flex;
                align-items: center;
                min-height: 36px;
                padding: 0 13px;
                border-radius: 10px;
                background: #eef2ff;
                color: #3730a3;
                font-weight: 950;
                letter-spacing: .3px;
                white-space: nowrap;
            }

            .vehicle-info {
                display: grid;
                gap: 10px;
                margin-bottom: 18px;
            }

                .vehicle-info div {
                    display: flex;
                    justify-content: space-between;
                    gap: 16px;
                    border-bottom: 1px solid #f1f5f9;
                    padding-bottom: 10px;
                }

                    .vehicle-info div:last-child {
                        border-bottom: none;
                        padding-bottom: 0;
                    }

                .vehicle-info span {
                    color: #64748b;
                    font-weight: 750;
                }

                .vehicle-info strong {
                    font-weight: 950;
                    text-align: right;
                }

            .action-grid {
                display: grid;
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: 12px;
            }

            .action-card {
                min-height: 84px;
                border: 1px solid #e2e8f0;
                border-radius: 17px;
                padding: 16px;
                text-decoration: none;
                color: #0f172a;
                background: #fff;
                display: flex;
                align-items: center;
                gap: 13px;
                transition: .16s ease;
            }

                .action-card:hover {
                    transform: translateY(-2px);
                    border-color: #c7d2fe;
                    box-shadow: 0 14px 28px rgba(15, 23, 42, .08);
                }

            .action-icon {
                width: 44px;
                height: 44px;
                border-radius: 14px;
                display: grid;
                place-items: center;
                background: #eef2ff;
                flex: 0 0 auto;
                font-size: 20px;
            }

            .action-card strong {
                display: block;
                font-weight: 950;
                margin-bottom: 3px;
            }

            .action-card span {
                display: block;
                color: #64748b;
                font-size: 12px;
                font-weight: 700;
                line-height: 1.35;
            }

            @@media (max-width: 620px) {
                .qr-header {
                    flex-direction: column;
                    align-items: flex-start;
                }

                .back-link {
                    width: 100%;
                }

                .action-grid {
                    grid-template-columns: 1fr;
                }

                .vehicle-title {
                    align-items: flex-start;
                    flex-direction: column;
                }
            }
    </style>
</head>

<body>
    <main class="qr-page">
        <header class="qr-header">
            <div>
                <h1>QR Tara</h1>
                <p>Araç QR kodunu tarayın.</p>
            </div>

            <a href="/Dashboard/Index" class="back-link">
                Ana ekrana dön
            </a>
        </header>

        <section class="panel">
            <div id="qr-reader"></div>

            <div class="actions">
                <button type="button" id="startButton" class="btn btn-primary">
                    QR Tara
                </button>

                <button type="button" id="stopButton" class="btn btn-secondary" disabled>
                    Kapat
                </button>
            </div>

            <div id="statusBox" class="status-box">
                QR taramayı başlatın.
            </div>
        </section>

        <section id="resultCard" class="result-card">
            <div class="vehicle-title">
                <h2>Araç bulundu</h2>
                <span id="plateBadge" class="plate-badge"></span>
            </div>

            <div class="vehicle-info">
                <div>
                    <span>Müşteri</span>
                    <strong id="customerName"></strong>
                </div>

                <div>
                    <span>Araç</span>
                    <strong id="vehicleName"></strong>
                </div>

                <div id="openRecordRow">
                    <span>Açık kayıt</span>
                    <strong id="openRecordText"></strong>
                </div>
            </div>

            <div id="actionGrid" class="action-grid"></div>
        </section>
    </main>

    <script src="https://unpkg.com/html5-qrcode"></script>

    <script>
        let scanner = null;
        let locked = false;

        const startButton = document.getElementById("startButton");
        const stopButton = document.getElementById("stopButton");
        const statusBox = document.getElementById("statusBox");
        const resultCard = document.getElementById("resultCard");

        startButton.addEventListener("click", startScanner);
        stopButton.addEventListener("click", stopScanner);

        function setStatus(message, isError = false) {
        statusBox.textContent = message;
        statusBox.classList.toggle("error", isError);
        }

        async function startScanner() {
        if (scanner) {
        return;
        }

        locked = false;
        resultCard.classList.remove("active");
        setStatus("Kamera açılıyor...");

        try {
        scanner = new Html5Qrcode("qr-reader");

        await scanner.start(
        { facingMode: "environment" },
        {
        fps: 10,
        qrbox: {
        width: 240,
        height: 240
        }
        },
        async decodedText => {
        if (locked) {
        return;
        }

        locked = true;

        setStatus("QR okundu. Araç bilgisi getiriliyor...");

        await stopScanner(false);

        await resolveQr(decodedText);
        }
        );

        startButton.disabled = true;
        stopButton.disabled = false;

        setStatus("Kamera açık.");
        }
        catch (error) {
        console.error(error);
        scanner = null;
        startButton.disabled = false;
        stopButton.disabled = true;
        setStatus("Kamera açılamadı: " + (error?.message || error), true);
        }
        }

        async function stopScanner(updateStatus = true) {
        if (!scanner) {
        return;
        }

        try {
        await scanner.stop();
        }
        catch {
        }

        scanner = null;
        startButton.disabled = false;
        stopButton.disabled = true;

        if (updateStatus) {
        setStatus("Kamera kapatıldı.");
        }
        }

        async function resolveQr(decodedText) {
        try {
        const response = await fetch(
        `/VehicleQrCodes/Resolve?code=${encodeURIComponent(decodedText)}`
        );

        const payload = await response.json().catch(() => null);

        if (!response.ok) {
        const message =
        payload?.errorMessage ||
        payload?.errorMessages?.join("\n") ||
        "QR kod çözümlenemedi.";

        setStatus(message, true);
        locked = false;
        return;
        }

        renderResult(payload);
        setStatus("Araç bulundu.");
        }
        catch (error) {
        console.error(error);
        setStatus("QR çözümleme sırasında hata oluştu.", true);
        locked = false;
        }
        }

        function renderResult(data) {
        document.getElementById("plateBadge").textContent = data.plate || "";
        document.getElementById("customerName").textContent = data.customerName || "-";

        const vehicleName = [data.vehicleBrandName, data.vehicleModelName]
        .filter(Boolean)
        .join(" ");

        document.getElementById("vehicleName").textContent = vehicleName || "-";

        const openRecordRow = document.getElementById("openRecordRow");
        const openRecordText = document.getElementById("openRecordText");

        if (data.hasOpenServiceRecord && data.openServiceRecordId) {
        openRecordRow.style.display = "flex";
        openRecordText.textContent = data.openServiceRecordNumber || "Açık kayıt var";
        }
        else {
        openRecordRow.style.display = "none";
        openRecordText.textContent = "";
        }

        const actionGrid = document.getElementById("actionGrid");
        actionGrid.innerHTML = "";

        if (data.hasOpenServiceRecord && data.openServiceRecordId) {
        actionGrid.insertAdjacentHTML("beforeend", `
        <a class="action-card" href="/ServiceRecords/Detail/${data.openServiceRecordId}">
        <div class="action-icon">🔧</div>
        <div>
        <strong>Açık Kayda Git</strong>
        <span>Bu araç için devam eden servis kaydını aç.</span>
        </div>
        </a>
        `);
        }

        actionGrid.insertAdjacentHTML("beforeend", `
        <a class="action-card" href="/ServiceRecords/Create?vehicleId=${data.vehicleId}">
        <div class="action-icon">➕</div>
        <div>
        <strong>Yeni Servis Kaydı Aç</strong>
        <span>Bu araç için yeni servis kabul süreci başlat.</span>
        </div>
        </a>
        `);

        actionGrid.insertAdjacentHTML("beforeend", `
        <a class="action-card" href="/qr/${encodeURIComponent(data.code)}" target="_blank">
        <div class="action-icon">📋</div>
        <div>
        <strong>Araç Geçmişini Gör</strong>
        <span>Servis kayıt geçmişini görüntüle.</span>
        </div>
        </a>
        `);

        @if (isOwner)
        {
            <text>
                actionGrid.insertAdjacentHTML("beforeend", `
                <a class="action-card" href="/Customers/Detail/${data.customerId}">
                    <div class="action-icon">👤</div>
                    <div>
                        <strong>Müşteri Bilgileri</strong>
                        <span>Müşteri detayına git.</span>
                    </div>
                </a>
                `);
            </text>
        }

        resultCard.classList.add("active");
        }
    </script>
</body>
</html>
