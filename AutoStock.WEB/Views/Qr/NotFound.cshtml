@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Servis Geçmişi Bulunamadı</title>

    <style>
            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                min-height: 100vh;
                display: grid;
                place-items: center;
                padding: 22px;
                background: radial-gradient(circle at top left, rgba(37, 99, 235, .12), transparent 30rem), #f3f6fb;
                font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
                color: #0f172a;
            }

            .card {
                width: min(520px, 100%);
                padding: 34px;
                border-radius: 30px;
                background: white;
                border: 1px solid #e2e8f0;
                box-shadow: 0 24px 70px rgba(15, 23, 42, .10);
                text-align: center;
            }

            .icon {
                width: 64px;
                height: 64px;
                margin: 0 auto 18px;
                border-radius: 22px;
                display: grid;
                place-items: center;
                background: #eef2ff;
                color: #2563eb;
                font-size: 26px;
                font-weight: 950;
            }

            h1 {
                margin: 0;
                font-size: 28px;
                letter-spacing: -.8px;
            }

            p {
                margin: 12px 0 0;
                color: #64748b;
                line-height: 1.55;
                font-weight: 650;
            }
    </style>
</head>
<body>
    <main class="card">
        <div class="icon">?</div>
        <h1>Servis geçmişi bulunamadı</h1>
        <p>Bu QR kod geçersiz olabilir, pasifleştirilmiş olabilir veya henüz bir araca atanmış olmayabilir.</p>
    </main>
</body>
</html>
